      exact ((Hcond U HUtop HpU) HcapEq).
        + assume HyEq1: y = 1.
          (** handle the endpoint y=1 by choosing an order-basis neighborhood disjoint from ordsq_A **)
          apply FalseE.
          claim HpEq1: p = (x,1).
          { rewrite HpEq at 1.
            rewrite HyEq1 at 1.
            reflexivity. }
          apply (xm (x = 1)).
