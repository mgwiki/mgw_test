          claim HwB: w :e ordsq_B.
          { exact (andER (w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0})
                         (w :e ordsq_B)
                         Hwpack). }
          claim HwI: w :e I.
