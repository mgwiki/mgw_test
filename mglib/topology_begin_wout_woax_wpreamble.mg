                          claim HsuccIOrd: ordinal (ordsucc i).
                          { exact (ordinal_Hered omega omega_ordinal (ordsucc i) HsuccIO). }

                          claim HbprevEq: bprev = (add_SNo 1 (minus_SNo (inv_nat (ordsucc i))), eps_ 1).
                          { rewrite HmEqI.
                            reflexivity. }
                          claim HxEqJ: x = (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1).
                          { rewrite HxEq.
                            rewrite HnEq.
