    claim Ha00ltx: Rlt a00 x.
    { (** unfold a0 < p=(x,0) to get a00<x (the other disjunct contradicts unit_interval) **)
      claim Hunf: exists c1 c2 d1 d2:set,
        a0 = (c1, c2) /\ p = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
      { exact (order_rel_setprod_R_R_unfold a0 p Ha0p). }
