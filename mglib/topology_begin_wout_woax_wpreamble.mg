        { exact (andEL (Rlt y q2) (Rlt q2 1) Hq2ineq). }
        claim Hq2lt1: Rlt q2 1.
        { exact (andER (Rlt y q2) (Rlt q2 1) Hq2ineq). }

        claim Hq1R: q1 :e R.
        { exact (rational_numbers_in_R q1 Hq1Q). }
        claim Hq2R: q2 :e R.
        { exact (rational_numbers_in_R q2 Hq2Q). }
