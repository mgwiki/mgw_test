                                (fun x0:set => order_rel (setprod R R) bprev x0 /\ order_rel (setprod R R) x0 bcur)
                                x HxGap). }
                      claim Hbprevx: order_rel (setprod R R) bprev x.
                      { exact (andEL (order_rel (setprod R R) bprev x) (order_rel (setprod R R) x bcur) HxGapProp). }
                      claim Hxbcur: order_rel (setprod R R) x bcur.
                      { exact (andER (order_rel (setprod R R) bprev x) (order_rel (setprod R R) x bcur) HxGapProp). }

                      claim Hexn: exists n :e omega :\: {0},
                        x = (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
                      { exact (ReplE (omega :\: {0})
                               (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
                               x HxB). }
                      apply Hexn.
                      let n. assume Hnpack.
                      apply Hnpack.
                      assume HnIn HxEq.
                      claim HnO: n :e omega.
                      { exact (setminusE1 omega {0} n HnIn). }
                      claim HnNat: nat_p n.
                      { exact (omega_nat_p n HnO). }
                      claim HnCase: n = 0 \/ exists j:set, nat_p j /\ n = ordsucc j.
                      { exact (nat_inv n HnNat). }
                      apply HnCase.
                      + assume Hn0: n = 0.
                        claim HnIn0: n :e {0}.
                        { rewrite Hn0. exact (SingI 0). }
                        claim HnNot0: n /:e {0}.
                        { exact (setminusE2 omega {0} n HnIn). }
                        exact (HnNot0 HnIn0).
                      + assume Hexj: exists j:set, nat_p j /\ n = ordsucc j.
                        apply Hexj.
                        let j. assume Hjconj.
                        claim HjNat: nat_p j.
                        { exact (andEL (nat_p j) (n = ordsucc j) Hjconj). }
                        claim HnEq: n = ordsucc j.
                        { exact (andER (nat_p j) (n = ordsucc j) Hjconj). }
                        claim HjO: j :e omega.
                        { exact (nat_p_omega j HjNat). }
                        claim HjOrd: ordinal j.
                        { exact (nat_p_ordinal j HjNat). }

                        claim HmCase: m = 0 \/ exists i:set, nat_p i /\ m = ordsucc i.
                        { exact (nat_inv m HmNat). }
                        apply HmCase.
                        * assume Hm0: m = 0.
                          exact (HmNot0 Hm0).
                        * assume Hexi: exists i:set, nat_p i /\ m = ordsucc i.
                          apply Hexi.
                          let i. assume Hiconj.
                          claim HiNat: nat_p i.
                          { exact (andEL (nat_p i) (m = ordsucc i) Hiconj). }
                          claim HmEqI: m = ordsucc i.
                          { exact (andER (nat_p i) (m = ordsucc i) Hiconj). }
                          claim HiO: i :e omega.
