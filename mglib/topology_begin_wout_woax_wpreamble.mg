		            { exact (SepI (Power ordered_square)
		                          (fun I:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
		                            I = {y :e ordered_square | order_rel RR a0 y /\ order_rel RR y b0})
		                          b3
		                          Hb3Pow
