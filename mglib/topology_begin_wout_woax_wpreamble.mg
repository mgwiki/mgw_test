            exact HwIset. }
          claim HwU: w :e U.
          { exact (HIU w HwI). }
          claim Hwcap: w :e U :/\: ordsq_B.
          { exact (binintersectI U ordsq_B w HwU HwB). }
          exact (elem_implies_nonempty (U :/\: ordsq_B) w Hwcap).
        + assume HIlow: I :e Blow.
          claim Hexb: exists b0 :e ordered_square,
            I = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}.
          { exact (SepE2 (Power ordered_square)
                    (fun J0:set => exists b0 :e ordered_square,
                      J0 = {x0 :e ordered_square | order_rel (setprod R R) x0 b0})
                    I HIlow). }
          apply Hexb.
          let b0. assume Hb0pack.
          apply Hb0pack.
          assume Hb0Sq HIeq.
          claim Hp10I': p10 :e {x0 :e ordered_square | order_rel (setprod R R) x0 b0}.
          { rewrite <- HIeq.
            exact Hp10I. }
          claim Hp10b0: order_rel (setprod R R) p10 b0.
          { exact (SepE2 ordered_square
                  (fun x0:set => order_rel (setprod R R) x0 b0)
                  p10 Hp10I'). }
          claim Hexw: exists w:set,
            w :e {x0 :e ordered_square | order_rel (setprod R R) x0 b0} /\
            w :e ordsq_B.
          { exact (ex17_18_p10_lower_basis_meets_B b0 Hb0Sq Hp10b0). }
          apply Hexw.
          let w. assume Hwpack.
          claim HwIset: w :e {x0 :e ordered_square | order_rel (setprod R R) x0 b0}.
          { exact (andEL (w :e {x0 :e ordered_square | order_rel (setprod R R) x0 b0})
                         (w :e ordsq_B)
                         Hwpack). }
          claim HwB: w :e ordsq_B.
          { exact (andER (w :e {x0 :e ordered_square | order_rel (setprod R R) x0 b0})
                         (w :e ordsq_B)
                         Hwpack). }
          claim HwI: w :e I.
          { rewrite HIeq.
            exact HwIset. }
          claim HwU: w :e U.
          { exact (HIU w HwI). }
          claim Hwcap: w :e U :/\: ordsq_B.
          { exact (binintersectI U ordsq_B w HwU HwB). }
          exact (elem_implies_nonempty (U :/\: ordsq_B) w Hwcap).
      - assume HIup: I :e Bup.
        claim Hexa: exists a0 :e ordered_square,
          I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}.
        { exact (SepE2 (Power ordered_square)
                  (fun J0:set => exists a0 :e ordered_square,
                    J0 = {x0 :e ordered_square | order_rel (setprod R R) a0 x0})
                  I HIup). }
        apply Hexa.
        let a0. assume Ha0pack.
        apply Ha0pack.
        assume Ha0Sq HIeq.
        claim Hp10I': p10 :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0}.
        { rewrite <- HIeq.
          exact Hp10I. }
        claim Ha0p10: order_rel (setprod R R) a0 p10.
        { exact (SepE2 ordered_square
                (fun x0:set => order_rel (setprod R R) a0 x0)
                p10 Hp10I'). }
        claim Hexw: exists w:set,
          w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0} /\
          w :e ordsq_B.
        { exact (ex17_18_p10_upper_basis_meets_B a0 Ha0Sq Ha0p10). }
        apply Hexw.
        let w. assume Hwpack.
        claim HwIset: w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0}.
        { exact (andEL (w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0})
                       (w :e ordsq_B)
                       Hwpack). }
        claim HwB: w :e ordsq_B.
        { exact (andER (w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0})
                       (w :e ordsq_B)
                       Hwpack). }
        claim HwI: w :e I.
        { rewrite HIeq.
          exact HwIset. }
        claim HwU: w :e U.
        { exact (HIU w HwI). }
        claim Hwcap: w :e U :/\: ordsq_B.
        { exact (binintersectI U ordsq_B w HwU HwB). }
        exact (elem_implies_nonempty (U :/\: ordsq_B) w Hwcap).
Qed.

(** helper: closure(C) in the ordered square (packaged) **)
(** LATEX VERSION: Exercise 18 asks to determine cl(C) for C={x×0|0<x<1} in the ordered square. **)
(** helper: points on the top edge x×1 with x<1 lie in cl(C) **)
Theorem ex17_18_top_edge_lt1_Sub_closure_C :
  ordsq_top_edge_lt1 c= closure_of ordered_square ordered_square_topology ordsq_C.
let p. assume HpTop: p :e ordsq_top_edge_lt1.
prove p :e closure_of ordered_square ordered_square_topology ordsq_C.
claim HpSq: p :e ordered_square.
{ exact (SepE1 ordered_square
               (fun p0:set => exists x:set, p0 = (x,1) /\ x :e unit_interval /\ Rlt x 1)
               p
               HpTop). }
claim Hexx: exists x:set, p = (x,1) /\ x :e unit_interval /\ Rlt x 1.
{ exact (SepE2 ordered_square
               (fun p0:set => exists x:set, p0 = (x,1) /\ x :e unit_interval /\ Rlt x 1)
               p
               HpTop). }
apply Hexx.
let x. assume Hxpack.
claim Hxcore: p = (x,1) /\ x :e unit_interval.
{ exact (andEL (p = (x,1) /\ x :e unit_interval) (Rlt x 1) Hxpack). }
claim Hxlt1: Rlt x 1.
{ exact (andER (p = (x,1) /\ x :e unit_interval) (Rlt x 1) Hxpack). }
claim HpEq: p = (x,1).
{ exact (andEL (p = (x,1)) (x :e unit_interval) Hxcore). }
claim HxU: x :e unit_interval.
{ exact (andER (p = (x,1)) (x :e unit_interval) Hxcore). }
claim HxR: x :e R.
{ exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) x HxU). }
claim HxS: SNo x.
{ exact (real_SNo x HxR). }
claim Hxnotlt0: ~(Rlt x 0).
{ exact (andEL (~(Rlt x 0)) (~(Rlt 1 x))
              (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) x HxU)). }
claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_C =
  {x0 :e ordered_square | forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_C <> Empty}.
{ reflexivity. }
rewrite Hdefcl.
apply (SepI ordered_square
            (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_C <> Empty)
            p
            HpSq).
let U. assume HUtop: U :e ordered_square_topology.
assume HpU: p :e U.
prove U :/\: ordsq_C <> Empty.
claim HexI: exists I :e ordered_square_order_basis, p :e I /\ I c= U.
{ exact (generated_topology_local_refine ordered_square ordered_square_order_basis U p HUtop HpU). }
apply HexI.
let I. assume HIpack.
apply HIpack.
assume HIbas HIcore.
apply HIcore.
assume HpI HIU.
set Bint := {J :e Power ordered_square | exists a :e ordered_square, exists b :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) a z /\ order_rel (setprod R R) z b}}.
set Blow := {J :e Power ordered_square | exists b :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) z b}}.
set Bup := {J :e Power ordered_square | exists a :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) a z}}.
claim HIcase: I :e ((Bint :\/: Blow) :\/: Bup).
{ claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
  { reflexivity. }
  rewrite <- Hdef.
  exact HIbas. }
apply (binunionE (Bint :\/: Blow) Bup I HIcase).
- assume HIleft: I :e (Bint :\/: Blow).
  apply (binunionE Bint Blow I HIleft).
  + assume HIint: I :e Bint.
    claim Hexab: exists a :e ordered_square, exists b :e ordered_square,
      I = {z :e ordered_square | order_rel (setprod R R) a z /\ order_rel (setprod R R) z b}.
    { exact (SepE2 (Power ordered_square)
                   (fun J0:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
                     J0 = {z :e ordered_square | order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0})
                   I
                   HIint). }
    apply Hexab.
    let a. assume Hapack.
    apply Hapack.
    assume HaSq Hexb.
    apply Hexb.
    let b. assume Hbpack.
    apply Hbpack.
    assume HbSq HIeq.
    claim HpI': p :e {z :e ordered_square | order_rel (setprod R R) a z /\ order_rel (setprod R R) z b}.
    { rewrite <- HIeq.
      exact HpI. }
    claim Hpord: order_rel (setprod R R) a p /\ order_rel (setprod R R) p b.
    { exact (SepE2 ordered_square
                 (fun z:set => order_rel (setprod R R) a z /\ order_rel (setprod R R) z b)
                 p
                 HpI'). }
    claim Hap: order_rel (setprod R R) a p.
    { exact (andEL (order_rel (setprod R R) a p) (order_rel (setprod R R) p b) Hpord). }
    claim Hpb: order_rel (setprod R R) p b.
    { exact (andER (order_rel (setprod R R) a p) (order_rel (setprod R R) p b) Hpord). }
    claim HbEta: b = (b 0, b 1).
    { exact (setprod_eta unit_interval unit_interval b HbSq). }
    claim Hb0U: (b 0) :e unit_interval.
    { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) b HbSq). }
    claim Hb1U: (b 1) :e unit_interval.
    { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) b HbSq). }
    claim Hb0R: (b 0) :e R.
    { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 0) Hb0U). }
    claim Hb0S: SNo (b 0).
    { exact (real_SNo (b 0) Hb0R). }
    claim Hb1prop: ~(Rlt 1 (b 1)).
    { exact (andER (~(Rlt (b 1) 0)) (~(Rlt 1 (b 1)))
                  (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 1) Hb1U)). }
    claim Hxltb0: Rlt x (b 0).
    { claim Hpb_unf: exists c1 c2 d1 d2:set,
        p = (c1, c2) /\ b = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
      { exact (order_rel_setprod_R_R_unfold p b Hpb). }
      apply Hpb_unf.
      let c1. assume Hc2.
      apply Hc2.
      let c2. assume Hd1.
      apply Hd1.
      let d1. assume Hd2.
      apply Hd2.
      let d2. assume Hcore.
      claim Hpb': p = (c1, c2) /\ b = (d1, d2).
      { exact (andEL (p = (c1, c2) /\ b = (d1, d2))
                    (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                    Hcore). }
      claim HpEq': p = (c1, c2).
      { exact (andEL (p = (c1, c2)) (b = (d1, d2)) Hpb'). }
      claim HbEq': b = (d1, d2).
      { exact (andER (p = (c1, c2)) (b = (d1, d2)) Hpb'). }
      claim Hdisj: Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2).
      { exact (andER (p = (c1, c2) /\ b = (d1, d2))
                    (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                    Hcore). }
      claim Hpcoords: x = c1 /\ 1 = c2.
      { claim Hpc: (x,1) = (c1, c2).
        { rewrite <- HpEq.
          exact HpEq'. }
        exact (tuple_eq_coords x 1 c1 c2 Hpc). }
      claim Hc1eq: c1 = x.
      { symmetry.
        exact (andEL (x = c1) (1 = c2) Hpcoords). }
      claim Hbcoords: d1 = (b 0) /\ d2 = (b 1).
      { claim Hbd: (d1, d2) = (b 0, b 1).
        { rewrite <- HbEq'.
          exact HbEta. }
        exact (tuple_eq_coords d1 d2 (b 0) (b 1) Hbd). }
      claim Hd1eq: d1 = (b 0).
      { exact (andEL (d1 = (b 0)) (d2 = (b 1)) Hbcoords). }
      claim Hcase: Rlt x (b 0) \/ (x = (b 0) /\ Rlt 1 (b 1)).
      { apply Hdisj.
        - assume Hlt: Rlt c1 d1.
          apply orIL.
          rewrite <- Hc1eq at 1.
          rewrite <- Hd1eq.
          exact Hlt.
        - assume Heq: c1 = d1 /\ Rlt c2 d2.
          apply orIR.
          claim Hc1d1: c1 = d1.
          { exact (andEL (c1 = d1) (Rlt c2 d2) Heq). }
          claim Hc2d2: Rlt c2 d2.
          { exact (andER (c1 = d1) (Rlt c2 d2) Heq). }
          apply andI.
          + prove x = (b 0).
            rewrite <- Hc1eq.
            rewrite <- Hd1eq.
            exact Hc1d1.
          + prove Rlt 1 (b 1).
            claim Hc2eq: c2 = 1.
            { symmetry.
              exact (andER (x = c1) (1 = c2) Hpcoords). }
            claim Hd2eq: d2 = (b 1).
            { exact (andER (d1 = (b 0)) (d2 = (b 1)) Hbcoords). }
            rewrite <- Hc2eq at 1.
            rewrite <- Hd2eq.
            exact Hc2d2. }
      apply Hcase.
      - assume H1: Rlt x (b 0). exact H1.
      - assume H2: x = (b 0) /\ Rlt 1 (b 1).
        apply FalseE.
        exact (Hb1prop (andER (x = (b 0)) (Rlt 1 (b 1)) H2)). }
    apply (rational_dense_between_reals x (b 0) HxR Hb0R Hxltb0).
    let q. assume Hqpack.
    apply Hqpack.
    assume HqQ Hqineq.
    claim HqR: q :e R.
    { exact (rational_numbers_in_R q HqQ). }
    claim Hxltq: Rlt x q.
    { exact (andEL (Rlt x q) (Rlt q (b 0)) Hqineq). }
    claim Hqltb0: Rlt q (b 0).
    { exact (andER (Rlt x q) (Rlt q (b 0)) Hqineq). }
    claim HqU: q :e unit_interval.
    { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q HqR).
      apply andI.
      - prove ~(Rlt q 0).
        assume Hq0: Rlt q 0.
        claim Hx0: Rlt x 0.
        { exact (Rlt_tra x q 0 Hxltq Hq0). }
        exact (Hxnotlt0 Hx0).
      - prove ~(Rlt 1 q).
        assume H1q: Rlt 1 q.
        claim H1b0: Rlt 1 (b 0).
        { exact (Rlt_tra 1 q (b 0) H1q Hqltb0). }
        exact (andER (~(Rlt (b 0) 0)) (~(Rlt 1 (b 0)))
                    (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 0) Hb0U)
                    H1b0). }
    set w := (q,0).
    claim HwSq: w :e ordered_square.
    { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval q 0 HqU zero_in_unit_interval). }
    claim Hpw: order_rel (setprod R R) p w.
    { rewrite HpEq.
      apply (order_rel_setprod_R_R_intro x 1 q 0).
      apply orIL.
      exact Hxltq. }
    claim Haw: order_rel (setprod R R) a w.
    { exact (order_rel_trans (setprod R R) a p w
              simply_ordered_set_setprod_R_R
              ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) a HaSq)
              ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p HpSq)
              ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq)
              Hap Hpw). }
    claim Hwb: order_rel (setprod R R) w b.
    { rewrite HbEta.
      apply (order_rel_setprod_R_R_intro q 0 (b 0) (b 1)).
      apply orIL.
      exact Hqltb0. }
    claim HwI: w :e I.
    { rewrite HIeq.
      apply (SepI ordered_square (fun z:set => order_rel (setprod R R) a z /\ order_rel (setprod R R) z b) w HwSq).
      exact (andI (order_rel (setprod R R) a w) (order_rel (setprod R R) w b) Haw Hwb). }
    claim HwU: w :e U.
    { exact (HIU w HwI). }
    claim H0ltq: Rlt 0 q.
    { apply (SNoLt_trichotomy_or_impred x 0 HxS SNo_0 (Rlt 0 q)).
      - assume Hxlt0: x < 0.
        apply FalseE.
        exact (Hxnotlt0 (RltI x 0 HxR real_0 Hxlt0)).
      - assume Hxeq0: x = 0.
        rewrite <- Hxeq0 at 1.
        exact Hxltq.
      - assume H0ltx: 0 < x.
        exact (Rlt_tra 0 x q (RltI 0 x real_0 HxR H0ltx) Hxltq). }
    claim Hqlt1: Rlt q 1.
    { apply (SNoLt_trichotomy_or_impred (b 0) 1 Hb0S SNo_1 (Rlt q 1)).
      - assume Hb0lt1: (b 0) < 1.
        exact (Rlt_tra q (b 0) 1 Hqltb0 (RltI (b 0) 1 Hb0R real_1 Hb0lt1)).
      - assume Hb0eq1: (b 0) = 1.
        rewrite <- Hb0eq1.
        exact Hqltb0.
      - assume H1ltb0: 1 < (b 0).
        apply FalseE.
        exact (andER (~(Rlt (b 0) 0)) (~(Rlt 1 (b 0)))
                    (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 0) Hb0U)
                    (RltI 1 (b 0) real_1 Hb0R H1ltb0)). }
    claim HwC: w :e ordsq_C.
    { apply (SepI ordered_square
                (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
                w
                HwSq).
      witness q.
      prove w = (q,0) /\ Rlt 0 q /\ Rlt q 1.
      apply andI.
      - prove w = (q,0) /\ Rlt 0 q.
        apply andI.
        + reflexivity.
        + exact H0ltq.
      - exact Hqlt1. }
    claim Hwc: w :e U :/\: ordsq_C.
    { exact (binintersectI U ordsq_C w HwU HwC). }
    exact (elem_implies_nonempty (U :/\: ordsq_C) w Hwc).
  + assume HIlow: I :e Blow.
    claim Hexb: exists b :e ordered_square,
      I = {z :e ordered_square | order_rel (setprod R R) z b}.
    { exact (SepE2 (Power ordered_square)
                   (fun J0:set => exists b0 :e ordered_square,
                     J0 = {z :e ordered_square | order_rel (setprod R R) z b0})
                   I
                   HIlow). }
    apply Hexb.
    let b. assume Hbpack.
    apply Hbpack.
    assume HbSq HIeq.
    claim HpI': p :e {z :e ordered_square | order_rel (setprod R R) z b}.
    { rewrite <- HIeq.
      exact HpI. }
    claim Hpb: order_rel (setprod R R) p b.
    { exact (SepE2 ordered_square (fun z:set => order_rel (setprod R R) z b) p HpI'). }
    claim HbEta: b = (b 0, b 1).
    { exact (setprod_eta unit_interval unit_interval b HbSq). }
    claim Hb0U: (b 0) :e unit_interval.
    { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) b HbSq). }
    claim Hb0R: (b 0) :e R.
    { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 0) Hb0U). }
    claim Hb0S: SNo (b 0).
    { exact (real_SNo (b 0) Hb0R). }
    claim Hb1U: (b 1) :e unit_interval.
    { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) b HbSq). }
    claim Hb1prop: ~(Rlt 1 (b 1)).
    { exact (andER (~(Rlt (b 1) 0)) (~(Rlt 1 (b 1)))
                  (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 1) Hb1U)). }
    claim Hxltb0: Rlt x (b 0).
    { claim Hpb_unf: exists c1 c2 d1 d2:set,
        p = (c1, c2) /\ b = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
      { exact (order_rel_setprod_R_R_unfold p b Hpb). }
      apply Hpb_unf.
      let c1. assume Hc2.
      apply Hc2.
      let c2. assume Hd1.
      apply Hd1.
      let d1. assume Hd2.
      apply Hd2.
      let d2. assume Hcore.
      claim Hpb': p = (c1, c2) /\ b = (d1, d2).
      { exact (andEL (p = (c1, c2) /\ b = (d1, d2))
                    (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                    Hcore). }
      claim HpEq': p = (c1, c2).
      { exact (andEL (p = (c1, c2)) (b = (d1, d2)) Hpb'). }
      claim HbEq': b = (d1, d2).
      { exact (andER (p = (c1, c2)) (b = (d1, d2)) Hpb'). }
      claim Hdisj: Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2).
      { exact (andER (p = (c1, c2) /\ b = (d1, d2))
                    (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                    Hcore). }
      claim Hpcoords: x = c1 /\ 1 = c2.
      { claim Hpc: (x,1) = (c1, c2).
        { rewrite <- HpEq.
          exact HpEq'. }
        exact (tuple_eq_coords x 1 c1 c2 Hpc). }
      claim Hc1eq: c1 = x.
      { symmetry.
        exact (andEL (x = c1) (1 = c2) Hpcoords). }
      claim Hbcoords: d1 = (b 0) /\ d2 = (b 1).
      { claim Hbd: (d1, d2) = (b 0, b 1).
        { rewrite <- HbEq'.
          exact HbEta. }
        exact (tuple_eq_coords d1 d2 (b 0) (b 1) Hbd). }
      claim Hd1eq: d1 = (b 0).
      { exact (andEL (d1 = (b 0)) (d2 = (b 1)) Hbcoords). }
      apply Hdisj.
      - assume Hlt: Rlt c1 d1.
        rewrite <- Hc1eq at 1.
        rewrite <- Hd1eq.
        exact Hlt.
      - assume Hc1d1: c1 = d1 /\ Rlt c2 d2.
        apply FalseE.
        claim Hc2d2: Rlt c2 d2.
        { exact (andER (c1 = d1) (Rlt c2 d2) Hc1d1). }
        claim Hc2eq: c2 = 1.
        { symmetry.
          exact (andER (x = c1) (1 = c2) Hpcoords). }
        claim Hd2eq: d2 = (b 1).
        { exact (andER (d1 = (b 0)) (d2 = (b 1)) Hbcoords). }
        claim H1ltb1: Rlt 1 (b 1).
        { rewrite <- Hc2eq at 1.
          rewrite <- Hd2eq.
          exact Hc2d2. }
        exact (Hb1prop H1ltb1). }
    apply (rational_dense_between_reals x (b 0) HxR Hb0R Hxltb0).
    let q. assume Hqpack.
    apply Hqpack.
    assume HqQ Hqineq.
    claim HqR: q :e R.
    { exact (rational_numbers_in_R q HqQ). }
    claim Hxltq: Rlt x q.
    { exact (andEL (Rlt x q) (Rlt q (b 0)) Hqineq). }
    claim Hqltb0: Rlt q (b 0).
    { exact (andER (Rlt x q) (Rlt q (b 0)) Hqineq). }
    claim HqU: q :e unit_interval.
    { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q HqR).
      apply andI.
      - prove ~(Rlt q 0).
        assume Hq0: Rlt q 0.
        claim Hx0: Rlt x 0.
        { exact (Rlt_tra x q 0 Hxltq Hq0). }
        exact (Hxnotlt0 Hx0).
      - prove ~(Rlt 1 q).
        assume H1q: Rlt 1 q.
        claim H1b0: Rlt 1 (b 0).
        { exact (Rlt_tra 1 q (b 0) H1q Hqltb0). }
        exact (andER (~(Rlt (b 0) 0)) (~(Rlt 1 (b 0)))
                    (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 0) Hb0U)
                    H1b0). }
    set w := (q,0).
    claim HwSq: w :e ordered_square.
    { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval q 0 HqU zero_in_unit_interval). }
    claim Hwb: order_rel (setprod R R) w b.
    { rewrite HbEta.
      apply (order_rel_setprod_R_R_intro q 0 (b 0) (b 1)).
      apply orIL.
      exact Hqltb0. }
    claim HwI: w :e I.
    { rewrite HIeq.
      apply (SepI ordered_square (fun z:set => order_rel (setprod R R) z b) w HwSq).
      exact Hwb. }
    claim HwU: w :e U.
    { exact (HIU w HwI). }
    claim H0ltq: Rlt 0 q.
    { apply (SNoLt_trichotomy_or_impred x 0 HxS SNo_0 (Rlt 0 q)).
      - assume Hxlt0: x < 0.
        apply FalseE.
        exact (Hxnotlt0 (RltI x 0 HxR real_0 Hxlt0)).
      - assume Hxeq0: x = 0.
        rewrite <- Hxeq0 at 1.
        exact Hxltq.
      - assume H0ltx: 0 < x.
        exact (Rlt_tra 0 x q (RltI 0 x real_0 HxR H0ltx) Hxltq). }
    claim Hqlt1: Rlt q 1.
    { apply (SNoLt_trichotomy_or_impred (b 0) 1 Hb0S SNo_1 (Rlt q 1)).
      - assume Hb0lt1: (b 0) < 1.
        exact (Rlt_tra q (b 0) 1 Hqltb0 (RltI (b 0) 1 Hb0R real_1 Hb0lt1)).
      - assume Hb0eq1: (b 0) = 1.
        rewrite <- Hb0eq1.
        exact Hqltb0.
      - assume H1ltb0: 1 < (b 0).
        apply FalseE.
        exact (andER (~(Rlt (b 0) 0)) (~(Rlt 1 (b 0)))
                    (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 0) Hb0U)
                    (RltI 1 (b 0) real_1 Hb0R H1ltb0)). }
    claim HwC: w :e ordsq_C.
    { apply (SepI ordered_square
                (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
                w
                HwSq).
      witness q.
      prove w = (q,0) /\ Rlt 0 q /\ Rlt q 1.
      apply andI.
      - prove w = (q,0) /\ Rlt 0 q.
        apply andI.
        + reflexivity.
        + exact H0ltq.
      - exact Hqlt1. }
    claim Hwc: w :e U :/\: ordsq_C.
    { exact (binintersectI U ordsq_C w HwU HwC). }
    exact (elem_implies_nonempty (U :/\: ordsq_C) w Hwc).
- assume HIup: I :e Bup.
  claim Hexa: exists a :e ordered_square,
    I = {z :e ordered_square | order_rel (setprod R R) a z}.
  { exact (SepE2 (Power ordered_square)
                 (fun J0:set => exists a0 :e ordered_square,
                   J0 = {z :e ordered_square | order_rel (setprod R R) a0 z})
                 I
                 HIup). }
  apply Hexa.
  let a. assume Hapack.
  apply Hapack.
  assume HaSq HIeq.
  claim HpI': p :e {z :e ordered_square | order_rel (setprod R R) a z}.
  { rewrite <- HIeq.
    exact HpI. }
  claim Hap: order_rel (setprod R R) a p.
  { exact (SepE2 ordered_square (fun z:set => order_rel (setprod R R) a z) p HpI'). }
  apply (rational_dense_between_reals x 1 HxR real_1 Hxlt1).
  let q. assume Hqpack.
  apply Hqpack.
  assume HqQ Hqineq.
  claim HqR: q :e R.
  { exact (rational_numbers_in_R q HqQ). }
  claim Hxltq: Rlt x q.
  { exact (andEL (Rlt x q) (Rlt q 1) Hqineq). }
  claim Hqlt1: Rlt q 1.
  { exact (andER (Rlt x q) (Rlt q 1) Hqineq). }
  claim HqU: q :e unit_interval.
  { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q HqR).
    apply andI.
    - prove ~(Rlt q 0).
      assume Hq0: Rlt q 0.
      claim Hx0: Rlt x 0.
      { exact (Rlt_tra x q 0 Hxltq Hq0). }
      exact (Hxnotlt0 Hx0).
    - prove ~(Rlt 1 q).
      assume H1q: Rlt 1 q.
      exact ((not_Rlt_sym q 1 Hqlt1) H1q). }
  set w := (q,0).
  claim HwSq: w :e ordered_square.
  { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval q 0 HqU zero_in_unit_interval). }
  claim Hpw: order_rel (setprod R R) p w.
  { rewrite HpEq.
    apply (order_rel_setprod_R_R_intro x 1 q 0).
    apply orIL.
    exact Hxltq. }
  claim Haw: order_rel (setprod R R) a w.
  { exact (order_rel_trans (setprod R R) a p w
            simply_ordered_set_setprod_R_R
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) a HaSq)
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p HpSq)
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq)
            Hap Hpw). }
  claim HwI: w :e I.
  { rewrite HIeq.
    apply (SepI ordered_square (fun z:set => order_rel (setprod R R) a z) w HwSq).
    exact Haw. }
  claim HwU: w :e U.
  { exact (HIU w HwI). }
  claim H0ltq: Rlt 0 q.
  { apply (SNoLt_trichotomy_or_impred x 0 HxS SNo_0 (Rlt 0 q)).
    - assume Hxlt0: x < 0.
      apply FalseE.
      exact (Hxnotlt0 (RltI x 0 HxR real_0 Hxlt0)).
    - assume Hxeq0: x = 0.
      rewrite <- Hxeq0 at 1.
      exact Hxltq.
    - assume H0ltx: 0 < x.
      exact (Rlt_tra 0 x q (RltI 0 x real_0 HxR H0ltx) Hxltq). }
  claim HwC: w :e ordsq_C.
  { apply (SepI ordered_square
              (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
              w
              HwSq).
    witness q.
    prove w = (q,0) /\ Rlt 0 q /\ Rlt q 1.
    apply andI.
    - prove w = (q,0) /\ Rlt 0 q.
      apply andI.
      + reflexivity.
      + exact H0ltq.
    - exact Hqlt1. }
  claim Hwc: w :e U :/\: ordsq_C.
  { exact (binintersectI U ordsq_C w HwU HwC). }
  exact (elem_implies_nonempty (U :/\: ordsq_C) w Hwc).
Qed.

(** helper: (1,0) lies in cl(C) **)
(** LATEX VERSION: Exercise 18: compute the closure of C={x×0 | 0<x<1} in the ordered square. **)
Theorem ex17_18_p10_in_closure_C :
  ordsq_p10 :e closure_of ordered_square ordered_square_topology ordsq_C.
prove ordsq_p10 :e closure_of ordered_square ordered_square_topology ordsq_C.
claim Hp10Sq: ordsq_p10 :e ordered_square.
{ claim Hp10def: ordsq_p10 = (1,0).
  { reflexivity. }
  rewrite Hp10def.
  exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 1 0 one_in_unit_interval zero_in_unit_interval). }
claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_C =
  {x0 :e ordered_square | forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_C <> Empty}.
{ reflexivity. }
rewrite Hdefcl.
apply (SepI ordered_square
            (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_C <> Empty)
            ordsq_p10
            Hp10Sq).
let U. assume HUtop: U :e ordered_square_topology.
assume Hp10U: ordsq_p10 :e U.
prove U :/\: ordsq_C <> Empty.
claim HexI: exists I :e ordered_square_order_basis, ordsq_p10 :e I /\ I c= U.
{ exact (generated_topology_local_refine ordered_square ordered_square_order_basis U ordsq_p10 HUtop Hp10U). }
apply HexI.
let I. assume HIpack.
apply HIpack.
assume HIbas HIcore.
apply HIcore.
assume Hp10I HIU.
set Bint := {J :e Power ordered_square | exists a :e ordered_square, exists b :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) a z /\ order_rel (setprod R R) z b}}.
set Blow := {J :e Power ordered_square | exists b :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) z b}}.
set Bup := {J :e Power ordered_square | exists a :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) a z}}.
claim HIcase: I :e ((Bint :\/: Blow) :\/: Bup).
{ claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
  { reflexivity. }
  rewrite <- Hdef.
  exact HIbas. }
apply (binunionE (Bint :\/: Blow) Bup I HIcase).
- assume HIleft: I :e (Bint :\/: Blow).
  apply (binunionE Bint Blow I HIleft).
    + assume HIint: I :e Bint.
      claim Hexab: exists a0 :e ordered_square, exists b0 :e ordered_square,
        I = {z :e ordered_square | order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0}.
      { exact (SepE2 (Power ordered_square)
                     (fun J0:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
                       J0 = {z :e ordered_square | order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0})
                     I
                     HIint). }
      apply Hexab.
      let a0. assume Ha0pack.
      apply Ha0pack.
      assume Ha0Sq Hb0ex.
      apply Hb0ex.
      let b0. assume Hb0pack.
      apply Hb0pack.
      assume Hb0Sq HIeq.

      claim HpI': ordsq_p10 :e {z :e ordered_square | order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0}.
      { rewrite <- HIeq.
        exact Hp10I. }
      claim Hp10core: order_rel (setprod R R) a0 ordsq_p10 /\ order_rel (setprod R R) ordsq_p10 b0.
      { exact (SepE2 ordered_square
                 (fun z:set => order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0)
                 ordsq_p10
                 HpI'). }
      claim Ha0p10: order_rel (setprod R R) a0 ordsq_p10.
      { exact (andEL (order_rel (setprod R R) a0 ordsq_p10)
                    (order_rel (setprod R R) ordsq_p10 b0)
                    Hp10core). }
      claim Hp10b0: order_rel (setprod R R) ordsq_p10 b0.
      { exact (andER (order_rel (setprod R R) a0 ordsq_p10)
                    (order_rel (setprod R R) ordsq_p10 b0)
                    Hp10core). }

      set a00 := a0 0.
      set a01 := a0 1.
      set b00 := b0 0.
      set b01 := b0 1.
      claim Ha0Eta: a0 = (a00,a01).
      { exact (setprod_eta unit_interval unit_interval a0 Ha0Sq). }
      claim Hb0Eta: b0 = (b00,b01).
      { exact (setprod_eta unit_interval unit_interval b0 Hb0Sq). }
      claim Ha00U: a00 :e unit_interval.
      { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
      claim Ha01U: a01 :e unit_interval.
      { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
      claim Hb00U: b00 :e unit_interval.
      { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) b0 Hb0Sq). }
      claim Hb01U: b01 :e unit_interval.
      { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) b0 Hb0Sq). }
      claim Ha00R: a00 :e R.
      { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a00 Ha00U). }
      claim Ha01R: a01 :e R.
      { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a01 Ha01U). }
      claim Hb00R: b00 :e R.
      { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) b00 Hb00U). }
      claim Hb01R: b01 :e R.
      { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) b01 Hb01U). }
      claim Ha00notlt0: ~(Rlt a00 0).
      { exact (andEL (~(Rlt a00 0)) (~(Rlt 1 a00))
                    (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a00 Ha00U)). }
      claim Ha01notlt0: ~(Rlt a01 0).
      { exact (andEL (~(Rlt a01 0)) (~(Rlt 1 a01))
                    (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a01 Ha01U)). }

      claim Ha00S: SNo a00.
      { exact (real_SNo a00 Ha00R). }
      claim Hb00S: SNo b00.
      { exact (real_SNo b00 Hb00R). }

      claim Hunf1: exists c1 c2 d1 d2:set,
        a0 = (c1, c2) /\ ordsq_p10 = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
      { exact (order_rel_setprod_R_R_unfold a0 ordsq_p10 Ha0p10). }
      claim Ha00lt1: Rlt a00 1.
      { apply Hunf1.
        let c1. assume Hc2. apply Hc2.
        let c2. assume Hd1. apply Hd1.
        let d1. assume Hd2. apply Hd2.
        let d2. assume Hcore.
        claim Hpair: a0 = (c1, c2) /\ ordsq_p10 = (d1, d2).
        { exact (andEL (a0 = (c1, c2) /\ ordsq_p10 = (d1, d2))
                      (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                      Hcore). }
        claim Ha0Eq: a0 = (c1, c2).
        { exact (andEL (a0 = (c1, c2)) (ordsq_p10 = (d1, d2)) Hpair). }
        claim Hp10Eq: ordsq_p10 = (d1, d2).
        { exact (andER (a0 = (c1, c2)) (ordsq_p10 = (d1, d2)) Hpair). }
        claim Hdisj: Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2).
        { exact (andER (a0 = (c1, c2) /\ ordsq_p10 = (d1, d2))
                      (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                      Hcore). }
        claim Ha0coords: c1 = a00 /\ c2 = a01.
        { claim Hc: (c1,c2) = (a00,a01).
          { rewrite <- Ha0Eq.
            exact Ha0Eta. }
          exact (tuple_eq_coords c1 c2 a00 a01 Hc). }
        claim Hc1eq: c1 = a00.
        { exact (andEL (c1 = a00) (c2 = a01) Ha0coords). }
        claim Hc2eq: c2 = a01.
        { exact (andER (c1 = a00) (c2 = a01) Ha0coords). }
        claim Hp10def: ordsq_p10 = (1,0).
        { reflexivity. }
        claim Hp10coords: 1 = d1 /\ 0 = d2.
        { claim Hpc: (1,0) = (d1,d2).
          { rewrite <- Hp10def.
            exact Hp10Eq. }
          exact (tuple_eq_coords 1 0 d1 d2 Hpc). }
        claim Hd1eq: d1 = 1.
        { symmetry.
          exact (andEL (1 = d1) (0 = d2) Hp10coords). }
        claim Hd2eq: d2 = 0.
        { symmetry.
          exact (andER (1 = d1) (0 = d2) Hp10coords). }
        apply Hdisj.
        - assume Hlt: Rlt c1 d1.
          prove Rlt a00 1.
          rewrite <- Hc1eq at 1.
          rewrite <- Hd1eq.
          exact Hlt.
        - assume Heq: c1 = d1 /\ Rlt c2 d2.
          apply FalseE.
          claim Hltc2d2: Rlt c2 d2.
          { exact (andER (c1 = d1) (Rlt c2 d2) Heq). }
          claim Ha01lt0: Rlt a01 0.
          { prove Rlt a01 0.
            rewrite <- Hc2eq at 1.
            rewrite <- Hd2eq at 1.
            exact Hltc2d2. }
          exact (Ha01notlt0 Ha01lt0). }

      claim Hunf2: exists c1 c2 d1 d2:set,
        ordsq_p10 = (c1, c2) /\ b0 = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
      { exact (order_rel_setprod_R_R_unfold ordsq_p10 b0 Hp10b0). }
      claim Hb00eq1: b00 = 1.
      { apply Hunf2.
        let c1. assume Hc2. apply Hc2.
        let c2. assume Hd1. apply Hd1.
        let d1. assume Hd2. apply Hd2.
        let d2. assume Hcore.
        claim Hpair: ordsq_p10 = (c1, c2) /\ b0 = (d1, d2).
        { exact (andEL (ordsq_p10 = (c1, c2) /\ b0 = (d1, d2))
                      (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                      Hcore). }
        claim Hp10Eq: ordsq_p10 = (c1, c2).
        { exact (andEL (ordsq_p10 = (c1, c2)) (b0 = (d1, d2)) Hpair). }
        claim Hb0Eq: b0 = (d1, d2).
        { exact (andER (ordsq_p10 = (c1, c2)) (b0 = (d1, d2)) Hpair). }
        claim Hdisj: Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2).
        { exact (andER (ordsq_p10 = (c1, c2) /\ b0 = (d1, d2))
                      (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                      Hcore). }
        claim Hp10def: ordsq_p10 = (1,0).
        { reflexivity. }
        claim Hp10coords: 1 = c1 /\ 0 = c2.
        { claim Hpc: (1,0) = (c1,c2).
          { rewrite <- Hp10def.
            exact Hp10Eq. }
          exact (tuple_eq_coords 1 0 c1 c2 Hpc). }
        claim Hc1eq: c1 = 1.
        { symmetry.
          exact (andEL (1 = c1) (0 = c2) Hp10coords). }
        claim Hb0coords: d1 = b00 /\ d2 = b01.
        { claim Hd: (d1,d2) = (b00,b01).
          { rewrite <- Hb0Eq.
            exact Hb0Eta. }
          exact (tuple_eq_coords d1 d2 b00 b01 Hd). }
        claim Hd1eq: d1 = b00.
        { exact (andEL (d1 = b00) (d2 = b01) Hb0coords). }
        apply Hdisj.
        - assume Hlt: Rlt c1 d1.
          apply FalseE.
          claim H1ltb00: Rlt 1 b00.
          { rewrite <- Hc1eq at 1.
            rewrite <- Hd1eq.
            exact Hlt. }
          exact ((andER (~(Rlt b00 0)) (~(Rlt 1 b00))
                (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) b00 Hb00U)) H1ltb00).
        - assume Heq: c1 = d1 /\ Rlt c2 d2.
          claim Hc1d1: c1 = d1.
          { exact (andEL (c1 = d1) (Rlt c2 d2) Heq). }
          prove b00 = 1.
          rewrite <- Hd1eq.
          rewrite <- Hc1d1.
          rewrite Hc1eq.
          reflexivity. }

      claim Hqex: exists q :e rational_numbers, Rlt a00 q /\ Rlt q 1.
      { exact (rational_dense_between_reals a00 1 Ha00R real_1 Ha00lt1). }
      apply Hqex.
      let q. assume Hqpack.
      apply Hqpack.
      assume HqQ Hqineq.
      claim Ha00ltq: Rlt a00 q.
      { exact (andEL (Rlt a00 q) (Rlt q 1) Hqineq). }
      claim Hqlt1: Rlt q 1.
      { exact (andER (Rlt a00 q) (Rlt q 1) Hqineq). }
      claim HqR: q :e R.
      { exact (rational_numbers_in_R q HqQ). }
      claim HqS: SNo q.
      { exact (real_SNo q HqR). }
      claim Hnotq0: ~(Rlt q 0).
      { assume Hqlt0: Rlt q 0.
        claim Ha00lt0: Rlt a00 0.
        { exact (Rlt_tra a00 q 0 Ha00ltq Hqlt0). }
        exact (Ha00notlt0 Ha00lt0). }
      claim Hqneq0: ~(q = 0).
      { assume Hq0: q = 0.
        claim Ha00lt0: Rlt a00 0.
        { prove Rlt a00 0.
          rewrite <- Hq0 at 2.
          exact Ha00ltq. }
        exact (Ha00notlt0 Ha00lt0). }
      claim H0ltqS: 0 < q.
      { apply (SNoLt_trichotomy_or_impred q 0 HqS SNo_0 (0 < q)).
        - assume Hqlt0S: q < 0.
          apply FalseE.
          claim Hqlt0: Rlt q 0.
          { exact (RltI q 0 HqR real_0 Hqlt0S). }
          exact (Hnotq0 Hqlt0).
        - assume Hqeq0S: q = 0.
          apply FalseE.
          exact (Hqneq0 Hqeq0S).
        - assume H0ltqS: 0 < q.
          exact H0ltqS. }
      claim H0ltq: Rlt 0 q.
      { exact (RltI 0 q real_0 HqR H0ltqS). }
      claim Hnot1q: ~(Rlt 1 q).
      { exact (not_Rlt_sym q 1 Hqlt1). }
      claim HqU: q :e unit_interval.
      { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q HqR).
        apply andI.
        - exact Hnotq0.
        - exact Hnot1q. }

      set w := (q,0).
      claim HwSq: w :e ordered_square.
      { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval q 0 HqU zero_in_unit_interval). }
      claim Ha0w: order_rel (setprod R R) a0 w.
      { rewrite Ha0Eta.
        apply (order_rel_setprod_R_R_intro a00 a01 q 0).
        apply orIL.
        exact Ha00ltq. }
      claim Hwb0: order_rel (setprod R R) w b0.
      { rewrite Hb0Eta.
        apply (order_rel_setprod_R_R_intro q 0 b00 b01).
        apply orIL.
        rewrite Hb00eq1.
        exact Hqlt1. }
      claim HwI: w :e I.
      { rewrite HIeq.
        apply (SepI ordered_square
                (fun z:set => order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0)
                w
                HwSq).
        apply andI.
        - exact Ha0w.
        - exact Hwb0. }
      claim HwU: w :e U.
      { exact (HIU w HwI). }
      claim HwC: w :e ordsq_C.
      { apply (SepI ordered_square
                  (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
                  w
                  HwSq).
        witness q.
        prove w = (q,0) /\ Rlt 0 q /\ Rlt q 1.
        apply andI.
        - prove w = (q,0) /\ Rlt 0 q.
          apply andI.
          + reflexivity.
          + exact H0ltq.
        - exact Hqlt1. }
      claim Hwcap: w :e U :/\: ordsq_C.
      { exact (binintersectI U ordsq_C w HwU HwC). }
      exact (elem_implies_nonempty (U :/\: ordsq_C) w Hwcap).
  + assume HIlow: I :e Blow.
    claim Hexb: exists b :e ordered_square,
      I = {z :e ordered_square | order_rel (setprod R R) z b}.
    { exact (SepE2 (Power ordered_square)
                   (fun J0:set => exists b0 :e ordered_square,
                     J0 = {z :e ordered_square | order_rel (setprod R R) z b0})
                   I
                   HIlow). }
    apply Hexb.
    let b. assume Hbpack.
    apply Hbpack.
    assume HbSq HIeq.
    claim HpI': ordsq_p10 :e {z :e ordered_square | order_rel (setprod R R) z b}.
    { rewrite <- HIeq.
      exact Hp10I. }
    claim Hp10b: order_rel (setprod R R) ordsq_p10 b.
    { exact (SepE2 ordered_square (fun z:set => order_rel (setprod R R) z b) ordsq_p10 HpI'). }
    claim HbEta: b = (b 0, b 1).
    { exact (setprod_eta unit_interval unit_interval b HbSq). }
    claim Hb0U: (b 0) :e unit_interval.
    { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) b HbSq). }
    claim Hb1U: (b 1) :e unit_interval.
    { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) b HbSq). }
    claim Hb0R: (b 0) :e R.
    { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 0) Hb0U). }
    claim Hb0prop: ~(Rlt 1 (b 0)).
    { exact (andER (~(Rlt (b 0) 0)) (~(Rlt 1 (b 0)))
                  (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 0) Hb0U)). }
    claim Hb1prop: ~(Rlt 1 (b 1)).
    { exact (andER (~(Rlt (b 1) 0)) (~(Rlt 1 (b 1)))
                  (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (b 1) Hb1U)). }
    claim Hexunf: exists c1 c2 d1 d2:set,
      ordsq_p10 = (c1, c2) /\ b = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
    { exact (order_rel_setprod_R_R_unfold ordsq_p10 b Hp10b). }
    apply Hexunf.
    let c1. assume Hc2.
    apply Hc2.
    let c2. assume Hd1.
    apply Hd1.
    let d1. assume Hd2.
    apply Hd2.
    let d2. assume Hcore.
    claim Hpair: ordsq_p10 = (c1, c2) /\ b = (d1, d2).
    { exact (andEL (ordsq_p10 = (c1, c2) /\ b = (d1, d2))
                  (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                  Hcore). }
    claim Hp10Eq: ordsq_p10 = (c1, c2).
    { exact (andEL (ordsq_p10 = (c1, c2)) (b = (d1, d2)) Hpair). }
    claim HbEq: b = (d1, d2).
    { exact (andER (ordsq_p10 = (c1, c2)) (b = (d1, d2)) Hpair). }
    claim Hdisj: Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2).
    { exact (andER (ordsq_p10 = (c1, c2) /\ b = (d1, d2))
                  (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                  Hcore). }
    claim Hp10def: ordsq_p10 = (1,0).
    { reflexivity. }
    claim Hp10coords: 1 = c1 /\ 0 = c2.
    { claim Hpc: (1,0) = (c1, c2).
      { rewrite <- Hp10def.
        exact Hp10Eq. }
      exact (tuple_eq_coords 1 0 c1 c2 Hpc). }
    claim Hc1eq: c1 = 1.
    { symmetry.
      exact (andEL (1 = c1) (0 = c2) Hp10coords). }
    claim Hc2eq: c2 = 0.
    { symmetry.
      exact (andER (1 = c1) (0 = c2) Hp10coords). }
    claim Hbcoords: d1 = (b 0) /\ d2 = (b 1).
    { claim Hbd: (d1, d2) = (b 0, b 1).
      { rewrite <- HbEq.
        exact HbEta. }
      exact (tuple_eq_coords d1 d2 (b 0) (b 1) Hbd). }
    claim Hd1eq: d1 = (b 0).
    { exact (andEL (d1 = (b 0)) (d2 = (b 1)) Hbcoords). }
    claim Hd2eq: d2 = (b 1).
    { exact (andER (d1 = (b 0)) (d2 = (b 1)) Hbcoords). }
    claim Hepsltb0: Rlt (eps_ 1) (b 0).
    { apply Hdisj.
      - assume Hlt: Rlt c1 d1.
        apply FalseE.
        claim H1ltb0: Rlt 1 (b 0).
        { rewrite <- Hc1eq at 1.
          rewrite <- Hd1eq.
          exact Hlt. }
        exact (Hb0prop H1ltb0).
      - assume Heq: c1 = d1 /\ Rlt c2 d2.
        claim Hc1d1: c1 = d1.
        { exact (andEL (c1 = d1) (Rlt c2 d2) Heq). }
        rewrite <- Hd1eq.
        rewrite <- Hc1d1.
        rewrite Hc1eq.
        exact eps_1_lt1_R. }
    set w := (eps_ 1,0).
    claim HwSq: w :e ordered_square.
    { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval (eps_ 1) 0 eps_1_in_unit_interval zero_in_unit_interval). }
    claim Hwb: order_rel (setprod R R) w b.
    { rewrite HbEta.
      apply (order_rel_setprod_R_R_intro (eps_ 1) 0 (b 0) (b 1)).
      apply orIL.
      exact Hepsltb0. }
    claim HwI: w :e I.
    { rewrite HIeq.
      apply (SepI ordered_square (fun z:set => order_rel (setprod R R) z b) w HwSq).
      rewrite HbEta.
      apply (order_rel_setprod_R_R_intro (eps_ 1) 0 (b 0) (b 1)).
      apply orIL.
      exact Hepsltb0. }
    claim HwU: w :e U.
    { exact (HIU w HwI). }
    claim HwC: w :e ordsq_C.
    { apply (SepI ordered_square
                (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
                w
                HwSq).
      witness (eps_ 1).
      prove w = (eps_ 1,0) /\ Rlt 0 (eps_ 1) /\ Rlt (eps_ 1) 1.
      apply andI.
      - prove w = (eps_ 1,0) /\ Rlt 0 (eps_ 1).
        apply andI.
        + reflexivity.
        + exact eps_1_pos_R.
      - exact eps_1_lt1_R. }
    claim Hwcap: w :e U :/\: ordsq_C.
    { exact (binintersectI U ordsq_C w HwU HwC). }
    exact (elem_implies_nonempty (U :/\: ordsq_C) w Hwcap).
- assume HIup: I :e Bup.
  claim Hexa: exists a0 :e ordered_square,
    I = {z :e ordered_square | order_rel (setprod R R) a0 z}.
  { exact (SepE2 (Power ordered_square)
                 (fun J0:set => exists a1 :e ordered_square,
                   J0 = {z :e ordered_square | order_rel (setprod R R) a1 z})
                 I
                 HIup). }
  apply Hexa.
  let a0. assume Ha0pack.
  apply Ha0pack.
  assume Ha0Sq HIeq.
  claim HpI': ordsq_p10 :e {z :e ordered_square | order_rel (setprod R R) a0 z}.
  { rewrite <- HIeq.
    exact Hp10I. }
  claim Ha0p10: order_rel (setprod R R) a0 ordsq_p10.
  { exact (SepE2 ordered_square (fun z:set => order_rel (setprod R R) a0 z) ordsq_p10 HpI'). }
  set a00 := a0 0.
  set a01 := a0 1.
  claim Ha0Eta: a0 = (a00,a01).
  { exact (setprod_eta unit_interval unit_interval a0 Ha0Sq). }
  claim Ha00U: a00 :e unit_interval.
  { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
  claim Ha01U: a01 :e unit_interval.
  { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
  claim Ha00R: a00 :e R.
  { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a00 Ha00U). }
  claim Ha01R: a01 :e R.
  { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a01 Ha01U). }
  claim Ha00notlt0: ~(Rlt a00 0).
  { exact (andEL (~(Rlt a00 0)) (~(Rlt 1 a00))
                (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a00 Ha00U)). }
  claim Ha01notlt0: ~(Rlt a01 0).
  { exact (andEL (~(Rlt a01 0)) (~(Rlt 1 a01))
                (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a01 Ha01U)). }
  claim Ha00S: SNo a00.
  { exact (real_SNo a00 Ha00R). }
  claim H1S: SNo 1.
  { exact (real_SNo 1 real_1). }

  claim Hunf: exists c1 c2 d1 d2:set,
    a0 = (c1, c2) /\ ordsq_p10 = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
  { exact (order_rel_setprod_R_R_unfold a0 ordsq_p10 Ha0p10). }
  claim Ha00lt1: Rlt a00 1.
  { apply Hunf.
    let c1. assume Hc2. apply Hc2.
    let c2. assume Hd1. apply Hd1.
    let d1. assume Hd2. apply Hd2.
    let d2. assume Hcore.
    claim Hpair: a0 = (c1, c2) /\ ordsq_p10 = (d1, d2).
    { exact (andEL (a0 = (c1, c2) /\ ordsq_p10 = (d1, d2))
                  (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                  Hcore). }
    claim Ha0Eq: a0 = (c1, c2).
    { exact (andEL (a0 = (c1, c2)) (ordsq_p10 = (d1, d2)) Hpair). }
    claim Hp10Eq: ordsq_p10 = (d1, d2).
    { exact (andER (a0 = (c1, c2)) (ordsq_p10 = (d1, d2)) Hpair). }
    claim Hdisj: Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2).
    { exact (andER (a0 = (c1, c2) /\ ordsq_p10 = (d1, d2))
                  (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2))
                  Hcore). }
    claim Ha0coords: c1 = a00 /\ c2 = a01.
    { claim Hc: (c1,c2) = (a00,a01).
      { rewrite <- Ha0Eq.
        exact Ha0Eta. }
      exact (tuple_eq_coords c1 c2 a00 a01 Hc). }
    claim Hc1eq: c1 = a00.
    { exact (andEL (c1 = a00) (c2 = a01) Ha0coords). }
    claim Hc2eq: c2 = a01.
    { exact (andER (c1 = a00) (c2 = a01) Ha0coords). }
    claim Hp10def: ordsq_p10 = (1,0).
    { reflexivity. }
    claim Hp10coords: 1 = d1 /\ 0 = d2.
    { claim Hpc: (1,0) = (d1,d2).
      { rewrite <- Hp10def.
        exact Hp10Eq. }
      exact (tuple_eq_coords 1 0 d1 d2 Hpc). }
    claim Hd1eq: d1 = 1.
    { symmetry.
      exact (andEL (1 = d1) (0 = d2) Hp10coords). }
    claim Hd2eq: d2 = 0.
    { symmetry.
      exact (andER (1 = d1) (0 = d2) Hp10coords). }
    apply Hdisj.
    - assume Hlt: Rlt c1 d1.
      prove Rlt a00 1.
      rewrite <- Hc1eq at 1.
      rewrite <- Hd1eq.
      exact Hlt.
    - assume Heq: c1 = d1 /\ Rlt c2 d2.
      apply FalseE.
      claim Hltc2d2: Rlt c2 d2.
      { exact (andER (c1 = d1) (Rlt c2 d2) Heq). }
      claim Ha01lt0: Rlt a01 0.
      { prove Rlt a01 0.
        rewrite <- Hc2eq at 1.
        rewrite <- Hd2eq at 1.
        exact Hltc2d2. }
      exact (Ha01notlt0 Ha01lt0). }

  claim Hqex: exists q :e rational_numbers, Rlt a00 q /\ Rlt q 1.
  { exact (rational_dense_between_reals a00 1 Ha00R real_1 Ha00lt1). }
  apply Hqex.
  let q. assume Hqpack.
  apply Hqpack.
  assume HqQ Hqineq.
  claim Ha00ltq: Rlt a00 q.
  { exact (andEL (Rlt a00 q) (Rlt q 1) Hqineq). }
  claim Hqlt1: Rlt q 1.
  { exact (andER (Rlt a00 q) (Rlt q 1) Hqineq). }
  claim HqR: q :e R.
  { exact (rational_numbers_in_R q HqQ). }
  claim HqS: SNo q.
  { exact (real_SNo q HqR). }
  claim Hnotq0: ~(Rlt q 0).
  { assume Hqlt0: Rlt q 0.
    claim Ha00lt0: Rlt a00 0.
    { exact (Rlt_tra a00 q 0 Ha00ltq Hqlt0). }
    exact (Ha00notlt0 Ha00lt0). }
    claim Hqneq0: ~(q = 0).
    { assume Hq0: q = 0.
      claim Ha00lt0: Rlt a00 0.
      { prove Rlt a00 0.
        rewrite <- Hq0 at 2.
        exact Ha00ltq. }
      exact (Ha00notlt0 Ha00lt0). }
  claim H0ltqS: 0 < q.
  { apply (SNoLt_trichotomy_or_impred q 0 HqS SNo_0 (0 < q)).
    - assume Hqlt0S: q < 0.
      apply FalseE.
      claim Hqlt0: Rlt q 0.
      { exact (RltI q 0 HqR real_0 Hqlt0S). }
      exact (Hnotq0 Hqlt0).
    - assume Hqeq0S: q = 0.
      apply FalseE.
      exact (Hqneq0 Hqeq0S).
    - assume H0ltqS: 0 < q.
      exact H0ltqS. }
  claim H0ltq: Rlt 0 q.
  { exact (RltI 0 q real_0 HqR H0ltqS). }
  claim Hnot1q: ~(Rlt 1 q).
  { exact (not_Rlt_sym q 1 Hqlt1). }
  claim HqU: q :e unit_interval.
  { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q HqR).
    apply andI.
    - exact Hnotq0.
    - exact Hnot1q. }

  set w := (q,0).
  claim HwSq: w :e ordered_square.
  { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval q 0 HqU zero_in_unit_interval). }
  claim Ha0w: order_rel (setprod R R) a0 w.
  { rewrite Ha0Eta.
    apply (order_rel_setprod_R_R_intro a00 a01 q 0).
    apply orIL.
    exact Ha00ltq. }
  claim HwI: w :e I.
  { rewrite HIeq.
    apply (SepI ordered_square (fun z:set => order_rel (setprod R R) a0 z) w HwSq).
    exact Ha0w. }
  claim HwU: w :e U.
  { exact (HIU w HwI). }
  claim HwC: w :e ordsq_C.
  { apply (SepI ordered_square
              (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
              w
              HwSq).
    witness q.
    prove w = (q,0) /\ Rlt 0 q /\ Rlt q 1.
    apply andI.
    - prove w = (q,0) /\ Rlt 0 q.
      apply andI.
      + reflexivity.
      + exact H0ltq.
    - exact Hqlt1. }
  claim Hwcap: w :e U :/\: ordsq_C.
  { exact (binintersectI U ordsq_C w HwU HwC). }
  exact (elem_implies_nonempty (U :/\: ordsq_C) w Hwcap).
Qed.

(** LATEX VERSION: Exercise 18: determine the closure of C={x×0 | 0<x<1} in the ordered square. **)
Theorem ex17_18_closure_C_eq :
  closure_of ordered_square ordered_square_topology ordsq_C = ordsq_C_closure.
prove closure_of ordered_square ordered_square_topology ordsq_C = ordsq_C_closure.
apply set_ext.
- let p. assume Hpcl: p :e closure_of ordered_square ordered_square_topology ordsq_C.
  prove p :e ordsq_C_closure.
  claim HpSq: p :e ordered_square.
  { exact (SepE1 ordered_square
                 (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_C <> Empty)
                 p
                 Hpcl). }
  claim Hcond: forall U:set, U :e ordered_square_topology -> p :e U -> U :/\: ordsq_C <> Empty.
  { exact (SepE2 ordered_square
                 (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_C <> Empty)
                 p
                 Hpcl). }
  set a := p 0.
  set y := p 1.
  claim HaU: a :e unit_interval.
  { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) p HpSq). }
  claim HyU: y :e unit_interval.
  { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) p HpSq). }
  claim HaR: a :e R.
  { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a HaU). }
  claim HyR: y :e R.
  { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) y HyU). }
  claim HaS: SNo a.
  { exact (real_SNo a HaR). }
  claim HyS: SNo y.
  { exact (real_SNo y HyR). }
  claim HpEta: p = (a,y).
  { exact (setprod_eta unit_interval unit_interval p HpSq). }
  apply (SNoLt_trichotomy_or_impred y 0 HyS SNo_0 (p :e ordsq_C_closure)).
  + assume Hylt0: y < 0.
    apply FalseE.
    claim Hylt0R: Rlt y 0.
    { exact (RltI y 0 HyR real_0 Hylt0). }
    exact ((andEL (~(Rlt y 0)) (~(Rlt 1 y))
            (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) y HyU)) Hylt0R).
  + assume Hyeq0: y = 0.
    (** y=0: either p in C, or p=(1,0); p=(0,0) is ruled out by closure **)
    apply (SNoLt_trichotomy_or_impred a 1 HaS SNo_1 (p :e ordsq_C_closure)).
    - assume Halt1: a < 1.
      apply (SNoLt_trichotomy_or_impred a 0 HaS SNo_0 (p :e ordsq_C_closure)).
      * assume Halt0: a < 0.
        apply FalseE.
        claim Halt0R: Rlt a 0.
        { exact (RltI a 0 HaR real_0 Halt0). }
        exact ((andEL (~(Rlt a 0)) (~(Rlt 1 a))
              (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a HaU)) Halt0R).
        * assume Haeq0: a = 0.
          (** exclude p=(0,0) from the closure of C by a specific neighborhood **)
          apply FalseE.
          set b0 := (0, eps_ 1).
          set U0 := {x :e ordered_square | order_rel (setprod R R) x b0}.
          claim HU0Pow: U0 :e Power ordered_square.
          { exact (Sep_In_Power ordered_square (fun x0:set => order_rel (setprod R R) x0 b0)). }
          claim Hb0Sq: b0 :e ordered_square.
          { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 0 (eps_ 1)
                    zero_in_unit_interval eps_1_in_unit_interval). }
          claim HU0basis: U0 :e ordered_square_order_basis.
          { set Bint := {I :e Power ordered_square | exists a0 :e ordered_square, exists b :e ordered_square,
                I = {x :e ordered_square | order_rel (setprod R R) a0 x /\ order_rel (setprod R R) x b}}.
            set Blow := {I :e Power ordered_square | exists b :e ordered_square,
                I = {x :e ordered_square | order_rel (setprod R R) x b}}.
            set Bup := {I :e Power ordered_square | exists a0 :e ordered_square,
                I = {x :e ordered_square | order_rel (setprod R R) a0 x}}.
            claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
            { reflexivity. }
            rewrite Hdef.
            apply binunionI1.
            apply binunionI2.
            prove U0 :e Blow.
            apply (SepI (Power ordered_square)
                    (fun I:set => exists b :e ordered_square,
                        I = {x :e ordered_square | order_rel (setprod R R) x b})
                    U0).
            - exact HU0Pow.
            - witness b0.
              apply andI.
              + exact Hb0Sq.
              + reflexivity. }
          claim HU0top: U0 :e ordered_square_topology.
          { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
            { reflexivity. }
            rewrite HdefT.
            exact (generated_topology_contains_elem ordered_square ordered_square_order_basis U0 HU0Pow HU0basis). }
          claim HpOrd: order_rel (setprod R R) p b0.
          { rewrite HpEta.
            rewrite Haeq0.
            rewrite Hyeq0.
            apply (order_rel_setprod_R_R_intro 0 0 0 (eps_ 1)).
            apply orIR.
            claim Hcore: 0 = 0 /\ Rlt 0 (eps_ 1).
            { apply andI.
              - reflexivity.
              - exact eps_1_pos_R. }
            exact Hcore. }
          claim HpU0: p :e U0.
          { apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) x0 b0) p HpSq).
            exact HpOrd. }
          claim HcapSub: U0 :/\: ordsq_C c= Empty.
          { let z. assume Hz: z :e U0 :/\: ordsq_C.
            prove z :e Empty.
            apply FalseE.
            claim HzU: z :e U0.
            { exact (binintersectE1 U0 ordsq_C z Hz). }
            claim HzC: z :e ordsq_C.
            { exact (binintersectE2 U0 ordsq_C z Hz). }
            claim HzOrd: order_rel (setprod R R) z b0.
            { exact (SepE2 ordered_square (fun x0:set => order_rel (setprod R R) x0 b0) z HzU). }
            claim HzEx: exists x0:set, z = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1.
            { exact (SepE2 ordered_square
                       (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
                       z
                       HzC). }
            apply HzEx.
            let x0. assume Hx0pack.
            apply Hx0pack.
            assume Hcore Hx0lt1.
            apply Hcore.
            assume HzEq H0ltx0.
            claim Hnotx00: ~(Rlt x0 0).
            { exact (not_Rlt_sym 0 x0 H0ltx0). }
            claim Hx0R: x0 :e R.
            { exact (RltE_right 0 x0 H0ltx0). }
            claim HUnf: exists a1 a2 b1 b2:set,
              z = (a1, a2) /\ b0 = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
            { exact (order_rel_setprod_R_R_unfold z b0 HzOrd). }
            apply HUnf.
            let a1. assume Ha2. apply Ha2.
            let a2. assume Hb1. apply Hb1.
            let b1. assume Hb2. apply Hb2.
            let b2. assume Hcore2. apply Hcore2.
            assume Hpair Hdisj.
            apply Hpair.
            assume HzEq2 Hb0Eq2.
            claim Hzpair: (x0,0) = (a1,a2).
            { prove (x0,0) = (a1,a2).
              rewrite <- HzEq at 1.
              exact HzEq2. }
            claim HzCoords: x0 = a1 /\ 0 = a2.
            { exact (tuple_eq_coords x0 0 a1 a2 Hzpair). }
            claim Hx0eq: x0 = a1.
            { exact (andEL (x0 = a1) (0 = a2) HzCoords). }
            claim H0eq: 0 = a2.
            { exact (andER (x0 = a1) (0 = a2) HzCoords). }
            claim Hb0pair: (0, eps_ 1) = (b1,b2).
            { prove (0, eps_ 1) = (b1,b2).
              rewrite <- Hb0Eq2 at 1.
              reflexivity. }
            claim Hb0Coords: 0 = b1 /\ (eps_ 1) = b2.
            { exact (tuple_eq_coords 0 (eps_ 1) b1 b2 Hb0pair). }
            claim Hb1eq: 0 = b1.
            { exact (andEL (0 = b1) ((eps_ 1) = b2) Hb0Coords). }
            apply Hdisj.
            - assume Hlt: Rlt a1 b1.
              apply FalseE.
                claim Hx0lt0: Rlt x0 0.
                { prove Rlt x0 0.
                  rewrite Hx0eq.
                  rewrite Hb1eq.
                  exact Hlt. }
              exact (Hnotx00 Hx0lt0).
            - assume Heq: a1 = b1 /\ Rlt a2 b2.
              apply FalseE.
              claim Ha1eq: a1 = b1.
              { exact (andEL (a1 = b1) (Rlt a2 b2) Heq). }
              claim Hx0eq0: x0 = 0.
              { prove x0 = 0.
                rewrite Hx0eq.
                rewrite Ha1eq.
                rewrite <- Hb1eq.
                reflexivity. }
              claim Hbad: Rlt 0 0.
              { prove Rlt 0 0.
                rewrite <- Hx0eq0 at 2.
                exact H0ltx0. }
              exact ((not_Rlt_refl 0 real_0) Hbad). }
          claim HcapEq: U0 :/\: ordsq_C = Empty.
          { exact (Empty_Subq_eq (U0 :/\: ordsq_C) HcapSub). }
          exact ((Hcond U0 HU0top HpU0) HcapEq).
          * assume H0lta: 0 < a.
            claim HpEq0: p = (a,0).
            { rewrite HpEta at 1.
              rewrite Hyeq0.
              reflexivity. }
            claim HpC: p :e ordsq_C.
            { apply (SepI ordered_square
                        (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
                        p
                    HpSq).
          witness a.
          prove p = (a,0) /\ Rlt 0 a /\ Rlt a 1.
