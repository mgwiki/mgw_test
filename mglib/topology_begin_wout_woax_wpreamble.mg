			              * apply Subq_ref. }
		        { (** a2 < a1: shrink to (a1,b2x) **)
		          assume Ha2lt: order_rel RR a2 a1.
		          set b3 := {y :e ordered_square | order_rel RR a1 y /\ order_rel RR y b2x}.
		          witness b3.
		          apply andI.
		          - (** b3 is an interval basis element **)
		            claim Hb3Pow: b3 :e Power ordered_square.
		            { apply PowerI.
		              let y. assume Hy: y :e b3.
		              exact (SepE1 ordered_square (fun y0:set => order_rel RR a1 y0 /\ order_rel RR y0 b2x) y Hy). }
		            claim Hexab: exists a0 :e ordered_square, exists b0 :e ordered_square,
		              b3 = {y :e ordered_square | order_rel RR a0 y /\ order_rel RR y b0}.
