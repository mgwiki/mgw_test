            claim Hexbc: exists j2 n2 k p:set,
              j2 :e 2 /\ n2 :e omega /\ k :e 2 /\ p :e omega /\
              b = (j2, n2) /\ c = (k, p) /\ (j2 :e k \/ (j2 = k /\ n2 :e p)).
            { apply (Hbc2 (exists j2 n2 k p:set,
                             (j2 :e 2 /\ n2 :e omega /\ k :e 2 /\ p :e omega /\
