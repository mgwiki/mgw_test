          exact ((Hcond U0 HU0top HpU0) HcapEq).
      * assume H1lta: 1 < a.
        apply FalseE.
        claim H1ltaR: Rlt 1 a.
        { exact (RltI 1 a real_1 HaR H1lta). }
        exact ((andER (~(Rlt a 0)) (~(Rlt 1 a))
