            { exact (andEL (i :e 2) (m :e omega) Hab0). }
            claim HmO: m :e omega.
            { exact (andER (i :e 2) (m :e omega) Hab0). }
            claim Hbc3: HbcT3.
            { exact (andEL HbcT3 (c = (k, p)) HbcCoords). }
            claim Hbc2: HbcT2.
            { exact (andEL HbcT2 (b = (j2, n2)) Hbc3). }
            claim Hbc1: HbcT1.
            { exact (andEL HbcT1 (p :e omega) Hbc2). }
            claim Hbc0: HbcT0.
            { exact (andEL HbcT0 (k :e 2) Hbc1). }
