        let a2. assume Ha2. apply Ha2.
        let b1. assume Hb1. apply Hb1.
        let b2. assume Hpack2.
        claim Hpair2: (inv_nat n,0) = (a1, a2) /\ (x,y2) = (b1, b2).
        { exact (andEL ((inv_nat n,0) = (a1, a2) /\ (x,y2) = (b1, b2))
                       (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2))
                       Hpack2). }
        claim Hdisj2: Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2).
        { exact (andER ((inv_nat n,0) = (a1, a2) /\ (x,y2) = (b1, b2))
                       (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2))
                       Hpack2). }
        claim HaPair2: (inv_nat n,0) = (a1, a2).
