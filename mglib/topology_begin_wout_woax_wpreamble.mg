        (** exclude 0<y<1 by a small interval neighborhood in the fiber {a}×I **)
        apply FalseE.
        claim H0y: Rlt 0 y.
        { exact (RltI 0 y real_0 HyR H0lty). }
        claim Hy1: Rlt y 1.
        { exact (RltI y 1 HyR real_1 Hylt1). }
        claim Hq1ex: exists q1 :e rational_numbers, Rlt 0 q1 /\ Rlt q1 y.
        { exact (rational_dense_between_reals 0 y real_0 HyR H0y). }
        apply Hq1ex.
        let q1. assume Hq1pack.
        apply Hq1pack.
        assume Hq1Q Hq1ineq.
        claim H0ltq1: Rlt 0 q1.
        { exact (andEL (Rlt 0 q1) (Rlt q1 y) Hq1ineq). }
        claim Hq1lty: Rlt q1 y.
        { exact (andER (Rlt 0 q1) (Rlt q1 y) Hq1ineq). }
        claim Hq2ex: exists q2 :e rational_numbers, Rlt y q2 /\ Rlt q2 1.
