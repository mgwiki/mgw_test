              claim Hb3ABC: b3 :e ((Bint :\/: Blow) :\/: Bup).
              { exact (binunionI1 (Bint :\/: Blow) Bup b3 Hb3AB). }
              claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
              { reflexivity. }
              rewrite Hdef.
              exact Hb3ABC.
            - apply andI.
              + exact (SepI ordered_square (fun y:set => order_rel RR a1 y /\ order_rel RR y b2x) x HxSq
                         (andI (order_rel RR a1 x) (order_rel RR x b2x) Ha1x Hxb2)).
              + apply (binintersect_Subq_max b1 b2 b3).
                * let y. assume Hy: y :e b3.
                  prove y :e b1.
                  claim HySq: y :e ordered_square.
