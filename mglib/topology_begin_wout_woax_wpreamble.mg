            (** TODO: use a basic upper-ray neighborhood U = {z|a0<z} with a0=(1,q) and q<1 to avoid ordsq_A **)
            set U1 := {z :e ordered_square | order_rel (setprod R R) (1,0) z}.
            claim HU1Pow: U1 :e Power ordered_square.
            { exact (Sep_In_Power ordered_square (fun z0:set => order_rel (setprod R R) (1,0) z0)). }
            set Bint := {J :e Power ordered_square | exists a0 :e ordered_square, exists b0 :e ordered_square,
              J = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}}.
            set Blow := {J :e Power ordered_square | exists b0 :e ordered_square,
              J = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}}.
            set Bup := {J :e Power ordered_square | exists a0 :e ordered_square,
              J = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}}.
            claim HU1basis: U1 :e ordered_square_order_basis.
            { claim HdefB: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
              { reflexivity. }
              rewrite HdefB.
              apply binunionI2.
              apply (SepI (Power ordered_square)
                (fun J0:set => exists a0 :e ordered_square, J0 = {x0 :e ordered_square | order_rel (setprod R R) a0 x0})
                U1
                HU1Pow).
              witness (1,0).
              prove (1,0) :e ordered_square /\ U1 = {x0 :e ordered_square | order_rel (setprod R R) (1,0) x0}.
              apply andI.
              - exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 1 0 one_in_unit_interval zero_in_unit_interval).
              - reflexivity. }
            claim HU1top: U1 :e ordered_square_topology.
            { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
              { reflexivity. }
              rewrite HdefT.
              exact (generated_topology_contains_elem ordered_square ordered_square_order_basis U1 HU1Pow HU1basis). }
            claim HpU1: p :e U1.
            { apply (SepI ordered_square (fun z0:set => order_rel (setprod R R) (1,0) z0) p HpSq).
              claim Hap: order_rel (setprod R R) (1,0) p.
              { rewrite HpEq1 at 1.
                rewrite Hx1 at 1.
                exact (order_rel_setprod_R_R_same_first 1 0 1 Rlt_0_1). }
