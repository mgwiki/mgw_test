                       (fun J0:set => exists a0 :e ordered_square,
                         J0 = {x :e ordered_square | order_rel (setprod R R) a0 x})
                       I
                       HIup). }
        apply HIup_ex.
        let a0. assume Ha0pack.
        apply Ha0pack.
        assume Ha0Sq HeqI.
        claim Hp1I2: p1 :e {x :e ordered_square | order_rel (setprod R R) a0 x}.
        { rewrite <- HeqI.
          exact Hp1I. }
        claim Ha0p1: order_rel (setprod R R) a0 p1.
        { exact (SepE2 ordered_square (fun x0:set => order_rel (setprod R R) a0 x0) p1 Hp1I2). }
        (** choose w :e E with a0 < w < p1 **)
        claim Hcase: exists c1 c2 d1 d2:set,
            a0 = (c1, c2) /\ p1 = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
        { exact (order_rel_setprod_R_R_unfold a0 p1 Ha0p1). }
        apply Hcase.
        let c1. assume Hc2.
        apply Hc2.
        let c2. assume Hd1.
        apply Hd1.
        let d1. assume Hd2.
        apply Hd2.
        let d2. assume Hcore.
        apply Hcore.
        assume Hab Hdisj.
        apply Hab.
        assume Ha0Eq Hp1Eq.
        claim Hp1def: p1 = (eps_ 1,1).
        { reflexivity. }
        claim HdPair: (d1,d2) = (eps_ 1,1).
        { rewrite <- Hp1def at 1.
          rewrite Hp1Eq at 1.
          reflexivity. }
        claim Hd1eq: d1 = (eps_ 1).
        { prove d1 = (eps_ 1).
          rewrite <- (tuple_2_0_eq d1 d2) at 1.
          rewrite HdPair at 1.
          exact (tuple_2_0_eq (eps_ 1) 1). }
        claim Hd2eq: d2 = 1.
        { prove d2 = 1.
          rewrite <- (tuple_2_1_eq d1 d2) at 1.
          rewrite HdPair at 1.
          exact (tuple_2_1_eq (eps_ 1) 1). }
        apply Hdisj.
        - assume Hlt: Rlt c1 d1.
          set w := (eps_ 1, eps_ 1).
          claim HwE: w :e ordsq_E.
          { claim Hweq: w = (eps_ 1, eps_ 1).
            { reflexivity. }
            rewrite Hweq.
            exact ordsq_eps1_eps1_in_E. }
          claim HwSq: w :e ordered_square.
          { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval (eps_ 1) (eps_ 1)
                  eps_1_in_unit_interval eps_1_in_unit_interval). }
          claim Ha0w: order_rel (setprod R R) a0 w.
          { rewrite Ha0Eq at 1.
            apply (order_rel_setprod_R_R_intro c1 c2 (eps_ 1) (eps_ 1)).
            apply orIL.
            claim Hc1lt: Rlt c1 (eps_ 1).
            { rewrite <- Hd1eq.
              exact Hlt. }
            exact Hc1lt. }
          claim Hwp1: order_rel (setprod R R) w p1.
          { apply (order_rel_setprod_R_R_intro (eps_ 1) (eps_ 1) (eps_ 1) 1).
            apply orIR.
            apply andI.
            - reflexivity.
            - exact eps_1_lt1_R. }
          claim HwI: w :e I.
          { rewrite HeqI.
            apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) a0 x0) w HwSq).
            exact Ha0w. }
          claim HwU: w :e U.
          { exact (HIU w HwI). }
          claim HwUcap: w :e U :/\: ordsq_E.
          { exact (binintersectI U ordsq_E w HwU HwE). }
          exact (elem_implies_nonempty (U :/\: ordsq_E) w HwUcap).
        - assume Heq: c1 = d1 /\ Rlt c2 d2.
          claim Hc2lt1: Rlt c2 1.
          { rewrite <- Hd2eq.
            exact (andER (c1 = d1) (Rlt c2 d2) Heq). }
          claim Ha0proj1: proj1 a0 :e unit_interval.
          { exact (proj1_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
          claim Ha0_1U: a0 1 :e unit_interval.
          { rewrite <- (proj1_ap_1 a0) at 1.
            exact Ha0proj1. }
          claim Hc2eq: c2 = (a0 1).
          { prove c2 = (a0 1).
            rewrite <- (tuple_2_1_eq c1 c2) at 1.
            rewrite <- Ha0Eq at 1.
            reflexivity. }
          claim Hc2U: c2 :e unit_interval.
          { rewrite Hc2eq at 1.
            exact Ha0_1U. }
          claim Hc2R: c2 :e R.
          { exact (unit_interval_sub_R c2 Hc2U). }
          apply (rational_dense_between_reals c2 1 Hc2R real_1 Hc2lt1).
          let q. assume Hqpack.
          apply Hqpack.
          assume HqQ Hqconj.
          apply Hqconj.
          assume Hc2ltq Hqlt1.
          claim HqR: q :e R.
          { exact (rational_numbers_in_R q HqQ). }
          claim Hc2prop: ~(Rlt c2 0) /\ ~(Rlt 1 c2).
          { exact (SepE2 R (fun z : set => ~(Rlt z 0) /\ ~(Rlt 1 z)) c2 Hc2U). }
          claim Hnotc2lt0: ~(Rlt c2 0).
          { exact (andEL (~(Rlt c2 0)) (~(Rlt 1 c2)) Hc2prop). }
          claim H0lec2: Rle 0 c2.
          { exact (RleI 0 c2 real_0 Hc2R Hnotc2lt0). }
          claim H0ltq: Rlt 0 q.
          { exact (Rle_Rlt_tra_Euclid 0 c2 q H0lec2 Hc2ltq). }
          claim HqU: q :e unit_interval.
          { apply (SepI R (fun z : set => ~(Rlt z 0) /\ ~(Rlt 1 z)) q HqR).
            apply andI.
            - exact (not_Rlt_sym 0 q H0ltq).
            - exact (not_Rlt_sym q 1 Hqlt1). }
          set w := (eps_ 1, q).
          claim HwSq: w :e ordered_square.
          { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval (eps_ 1) q
                  eps_1_in_unit_interval HqU). }
          claim HwE: w :e ordsq_E.
          { apply (SepI ordered_square
                       (fun p0:set => exists y0:set, p0 = (eps_ 1,y0) /\ Rlt 0 y0 /\ Rlt y0 1)
                       w
                       HwSq).
            witness q.
            prove w = (eps_ 1,q) /\ Rlt 0 q /\ Rlt q 1.
            apply andI.
            - apply andI.
              + reflexivity.
              + exact H0ltq.
            - exact Hqlt1. }
          claim Ha0w: order_rel (setprod R R) a0 w.
          { rewrite Ha0Eq at 1.
            apply (order_rel_setprod_R_R_intro c1 c2 (eps_ 1) q).
            apply orIR.
            apply andI.
            - rewrite <- Hd1eq.
              exact (andEL (c1 = d1) (Rlt c2 d2) Heq).
            - exact Hc2ltq. }
          claim HwI: w :e I.
          { rewrite HeqI.
            apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) a0 x0) w HwSq).
            exact Ha0w. }
          claim HwU: w :e U.
          { exact (HIU w HwI). }
          claim HwUcap: w :e U :/\: ordsq_E.
          { exact (binintersectI U ordsq_E w HwU HwE). }
          exact (elem_implies_nonempty (U :/\: ordsq_E) w HwUcap).
Qed.

(** helper: reciprocal of a natural is <= 1 (local copy to avoid forward references) **)
(** LATEX VERSION: For n∈ω\\{0}, 1/n ≤ 1. **)
Theorem inv_nat_Rle_1_local : forall n:set, n :e omega :\: {0} -> Rle (inv_nat n) 1.
let n.
assume HnIn: n :e omega :\: {0}.
claim HnO: n :e omega.
{ exact (setminusE1 omega {0} n HnIn). }
claim Hnnot0: n /:e {0}.
{ exact (setminusE2 omega {0} n HnIn). }
claim Hnneq0: n <> 0.
{ assume Hn0: n = 0.
  claim Hnin0: n :e {0}.
  { rewrite Hn0. exact (SingI 0). }
  exact (Hnnot0 Hnin0). }
claim HinvR: inv_nat n :e R.
{ exact (inv_nat_real n HnO). }
apply (RleI (inv_nat n) 1 HinvR real_1).
prove ~(Rlt 1 (inv_nat n)).
assume Hlt: Rlt 1 (inv_nat n).
claim HltS: 1 < inv_nat n.
{ exact (RltE_lt 1 (inv_nat n) Hlt). }
claim HnS: SNo n.
{ exact (omega_SNo n HnO). }
claim HinvS: SNo (inv_nat n).
{ exact (SNo_recip_SNo n HnS). }
claim HnNat: nat_p n.
{ exact (omega_nat_p n HnO). }
claim HnOrd: ordinal n.
{ exact (nat_p_ordinal n HnNat). }
claim H1Ord: ordinal 1.
{ exact (nat_p_ordinal 1 nat_1). }
claim HnCase: n = 0 \/ exists k:set, nat_p k /\ n = ordsucc k.
{ exact (nat_inv n HnNat). }
claim Hexk: exists k:set, nat_p k /\ n = ordsucc k.
{ apply (HnCase (exists k:set, nat_p k /\ n = ordsucc k)).
  - assume Hn0: n = 0.
    apply FalseE.
    exact (Hnneq0 Hn0).
  - assume H. exact H. }
apply Hexk.
let k.
assume Hkconj.
claim HkNat: nat_p k.
{ exact (andEL (nat_p k) (n = ordsucc k) Hkconj). }
claim Hneq: n = ordsucc k.
{ exact (andER (nat_p k) (n = ordsucc k) Hkconj). }
claim HkOrd: ordinal k.
{ exact (nat_p_ordinal k HkNat). }
claim H0ltn: 0 < n.
{ rewrite Hneq.
  exact (ordinal_ordsucc_pos k HkOrd). }
claim HmulLt: mul_SNo n 1 < mul_SNo n (inv_nat n).
{ exact (pos_mul_SNo_Lt n 1 (inv_nat n) HnS H0ltn SNo_1 HinvS HltS). }
claim Hmul1: mul_SNo n 1 = n.
{ exact (mul_SNo_oneR n HnS). }
claim HmulInv: mul_SNo n (inv_nat n) = 1.
{ exact (recip_SNo_invR n HnS Hnneq0). }
claim Hnlt1: n < 1.
{ rewrite <- Hmul1.
  rewrite <- HmulInv at 2.
  exact HmulLt. }
claim HnIn1: n :e 1.
{ exact (ordinal_SNoLt_In n 1 HnOrd H1Ord Hnlt1). }
claim Hcase1: n :e 0 \/ n = 0.
{ exact (ordsuccE 0 n HnIn1). }
claim Hn0: n = 0.
{ apply (Hcase1 (n = 0)).
  - assume HnIn0: n :e 0.
    exact (EmptyE n HnIn0 (n = 0)).
  - assume H. exact H. }
exact (Hnneq0 Hn0).
Qed.

(** helper: inv_nat n lies in the unit interval for n in omega setminus {0} **)
(** LATEX VERSION: For n∈ω\\{0}, 1/n ∈ [0,1]. **)
Theorem inv_nat_in_unit_interval : forall n:set,
  n :e omega :\: {0} ->
  inv_nat n :e unit_interval.
let n. assume HnIn: n :e omega :\: {0}.
claim HnO: n :e omega.
{ exact (setminusE1 omega {0} n HnIn). }
claim HinvR: inv_nat n :e R.
{ exact (inv_nat_real n HnO). }
claim Hinvpos: Rlt 0 (inv_nat n).
{ exact (inv_nat_pos n HnIn). }
claim Hnlt0: ~(Rlt (inv_nat n) 0).
{ exact (not_Rlt_sym 0 (inv_nat n) Hinvpos). }
claim Hinvle1: Rle (inv_nat n) 1.
{ exact (inv_nat_Rle_1_local n HnIn). }
claim Hnlt1: ~(Rlt 1 (inv_nat n)).
{ exact (RleE_nlt (inv_nat n) 1 Hinvle1). }
apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (inv_nat n) HinvR).
exact (andI (~(Rlt (inv_nat n) 0)) (~(Rlt 1 (inv_nat n))) Hnlt0 Hnlt1).
Qed.

(** helper: ordsq_B is a subset of the ordered square **)
(** LATEX VERSION: Every point (1 - 1/n, eps(1)) lies in [0,1]×[0,1]. **)
Theorem ordsq_B_sub_ordered_square : ordsq_B c= ordered_square.
let p. assume HpB: p :e ordsq_B.
prove p :e ordered_square.
claim Hexn: exists n :e omega :\: {0}, p = (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
{ exact (ReplE (omega :\: {0}) (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)),eps_  1)) p HpB). }
apply Hexn.
let n. assume Hnpack.
apply Hnpack.
assume HnIn Hpeq.
rewrite Hpeq.
claim HinvU: inv_nat n :e unit_interval.
{ exact (inv_nat_in_unit_interval n HnIn). }
claim HflipI: apply_fun flip_unit_interval (inv_nat n) :e unit_interval.
{ exact (flip_unit_interval_function_on (inv_nat n) HinvU). }
claim HflipEq: apply_fun flip_unit_interval (inv_nat n) = add_SNo 1 (minus_SNo (inv_nat n)).
{ exact (flip_unit_interval_apply (inv_nat n) HinvU). }
claim HfirstU: add_SNo 1 (minus_SNo (inv_nat n)) :e unit_interval.
{ rewrite <- HflipEq.
  exact HflipI. }
exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval
        (add_SNo 1 (minus_SNo (inv_nat n))) (eps_ 1)
        HfirstU eps_1_in_unit_interval).
Qed.

(** helper: division by n equals inv_nat n when numerator is 1 (local copy) **)
(** LATEX VERSION: For n≠0, 1/n = inv_nat n. **)
Theorem div_SNo_1_eq_inv_nat_local : forall n:set,
  SNo n -> div_SNo 1 n = inv_nat n.
let n.
assume HnS: SNo n.
prove div_SNo 1 n = inv_nat n.
claim Hdivdef: div_SNo 1 n = mul_SNo 1 (recip_SNo n).
{ reflexivity. }
rewrite Hdivdef.
rewrite (mul_SNo_oneL (recip_SNo n) (SNo_recip_SNo n HnS)).
claim Hinvdef: inv_nat n = recip_SNo n.
{ reflexivity. }
rewrite Hinvdef.
reflexivity.
Qed.

(** helper: given r>0, some inv_nat (n+1) is below r (local copy to avoid forward references) **)
(** LATEX VERSION: For every real r>0, there exists N with inv_nat(N+1) < r. **)
Theorem exists_inv_nat_ordsucc_lt_local : forall r:set,
  r :e R -> Rlt 0 r ->
  exists N:set, N :e omega /\ Rlt (inv_nat (ordsucc N)) r.
let r.
assume HrR: r :e R.
assume HrposR: Rlt 0 r.
set rinv := recip_SNo r.
claim HrS: SNo r.
{ exact (real_SNo r HrR). }
claim Hrpos: 0 < r.
{ exact (RltE_lt 0 r HrposR). }
claim HrinvR: rinv :e R.
{ exact (real_recip_SNo r HrR). }
claim HrinvS: SNo rinv.
{ exact (real_SNo rinv HrinvR). }
claim HrinvPos: 0 < rinv.
{ exact (recip_SNo_of_pos_is_pos r HrS Hrpos). }
claim HrinvNN: 0 <= rinv.
{ exact (SNoLtLe 0 rinv HrinvPos). }
claim Hexn: exists n :e omega, n <= rinv /\ rinv < ordsucc n.
{ exact (nonneg_real_nat_interval rinv HrinvR HrinvNN). }
apply Hexn.
let n. assume Hnconj.
claim HnO: n :e omega.
{ exact (andEL (n :e omega) (n <= rinv /\ rinv < ordsucc n) Hnconj). }
claim Hnrest: n <= rinv /\ rinv < ordsucc n.
{ exact (andER (n :e omega) (n <= rinv /\ rinv < ordsucc n) Hnconj). }
claim HrinvLt: rinv < ordsucc n.
{ exact (andER (n <= rinv) (rinv < ordsucc n) Hnrest). }
claim HnOrd: ordinal n.
{ exact (ordinal_Hered omega omega_ordinal n HnO). }
claim HNpos: 0 < ordsucc n.
{ exact (ordinal_ordsucc_pos n HnOrd). }
claim HNinO: ordsucc n :e omega.
{ exact (omega_ordsucc n HnO). }
claim HNS: SNo (ordsucc n).
{ exact (omega_SNo (ordsucc n) HNinO). }
claim HmulLt: mul_SNo r rinv < mul_SNo r (ordsucc n).
{ exact (pos_mul_SNo_Lt r rinv (ordsucc n) HrS Hrpos HrinvS HNS HrinvLt). }
claim Hrne0: r <> 0.
{ assume Hr0: r = 0.
  claim H00: 0 < 0.
  { rewrite <- Hr0 at 2.
    exact Hrpos. }
  exact ((SNoLt_irref 0) H00). }
claim HmulEq: mul_SNo r rinv = 1.
{ prove mul_SNo r rinv = 1.
  claim Hrinvdef: rinv = recip_SNo r.
  { reflexivity. }
  rewrite Hrinvdef.
  exact (recip_SNo_invR r HrS Hrne0). }
claim HoneLt: 1 < mul_SNo r (ordsucc n).
{ rewrite <- HmulEq at 1.
  exact HmulLt. }
claim HdivLt: div_SNo 1 (ordsucc n) < r.
{ exact (div_SNo_pos_LtL 1 (ordsucc n) r SNo_1 HNS HrS HNpos HoneLt). }
claim HdivEq: div_SNo 1 (ordsucc n) = inv_nat (ordsucc n).
{ exact (div_SNo_1_eq_inv_nat_local (ordsucc n) HNS). }
claim HinvLtS: inv_nat (ordsucc n) < r.
{ rewrite <- HdivEq.
  exact HdivLt. }
claim HinvR: inv_nat (ordsucc n) :e R.
{ exact (inv_nat_real (ordsucc n) HNinO). }
witness n.
apply andI.
- exact HnO.
- exact (RltI (inv_nat (ordsucc n)) r HinvR HrR HinvLtS).
Qed.

(** helper: for i<j in omega, inv_nat (i+1) is larger than inv_nat (j+1) (local copy to avoid forward references) **)
(** LATEX VERSION: For i<j in omega, 1/(j+1) < 1/(i+1). **)
Theorem inv_nat_ordsucc_antitone_local2 : forall i j:set,
  i :e omega -> j :e omega -> i :e j ->
  Rlt (inv_nat (ordsucc j)) (inv_nat (ordsucc i)).
let i j.
assume HiO: i :e omega.
assume HjO: j :e omega.
assume Hij: i :e j.
set mi := ordsucc i.
set mj := ordsucc j.
claim HiOrd: ordinal i.
{ exact (ordinal_Hered omega omega_ordinal i HiO). }
claim HjOrd: ordinal j.
{ exact (ordinal_Hered omega omega_ordinal j HjO). }
claim Hijlt: i < j.
{ exact (ordinal_In_SNoLt j HjOrd i Hij). }
claim HiS: SNo i.
{ exact (omega_SNo i HiO). }
claim HjS: SNo j.
{ exact (omega_SNo j HjO). }
claim HmiS: SNo mi.
{ exact (omega_SNo mi (omega_ordsucc i HiO)). }
claim HmjS: SNo mj.
{ exact (omega_SNo mj (omega_ordsucc j HjO)). }
claim Hsucclt: mi < mj.
{ prove mi < mj.
  rewrite <- (add_SNo_1_ordsucc i HiO).
  rewrite <- (add_SNo_1_ordsucc j HjO).
  exact (add_SNo_Lt1 i 1 j HiS SNo_1 HjS Hijlt). }
claim HmiNot0: mi <> 0.
{ exact (neq_ordsucc_0 i). }
claim HmjNot0: mj <> 0.
{ exact (neq_ordsucc_0 j). }
claim HinvmiR: inv_nat mi :e R.
{ exact (inv_nat_real mi (omega_ordsucc i HiO)). }
claim HinvmiS: SNo (inv_nat mi).
{ exact (real_SNo (inv_nat mi) HinvmiR). }
claim HmiNotIn0: mi /:e {0}.
{ assume Hmi0: mi :e {0}.
  claim Heq0: mi = 0.
  { exact (SingE 0 mi Hmi0). }
  exact (HmiNot0 Heq0). }
claim HmiIn: mi :e omega :\: {0}.
{ exact (setminusI omega {0} mi (omega_ordsucc i HiO) HmiNotIn0). }
claim HinvmiPosR: Rlt 0 (inv_nat mi).
{ exact (inv_nat_pos mi HmiIn). }
claim HinvmiPos: 0 < inv_nat mi.
{ exact (RltE_lt 0 (inv_nat mi) HinvmiPosR). }
claim HmulLt: mul_SNo (inv_nat mi) mi < mul_SNo (inv_nat mi) mj.
{ exact (pos_mul_SNo_Lt (inv_nat mi) mi mj HinvmiS HinvmiPos HmiS HmjS Hsucclt). }
claim HmulEq: mul_SNo (inv_nat mi) mi = 1.
{ prove mul_SNo (inv_nat mi) mi = 1.
  rewrite (mul_SNo_com (inv_nat mi) mi HinvmiS HmiS).
  claim Hinvdef: inv_nat mi = recip_SNo mi.
  { reflexivity. }
  rewrite Hinvdef.
  exact (recip_SNo_invR mi HmiS HmiNot0). }
claim HoneLt: 1 < mul_SNo (inv_nat mi) mj.
{ rewrite <- HmulEq at 1.
  exact HmulLt. }
claim Hmjpos: 0 < mj.
{ exact (ordinal_ordsucc_pos j HjOrd). }
claim HdivLt: div_SNo 1 mj < inv_nat mi.
{ exact (div_SNo_pos_LtL 1 mj (inv_nat mi) SNo_1 HmjS HinvmiS Hmjpos HoneLt). }
claim HdivEq: div_SNo 1 mj = inv_nat mj.
{ exact (div_SNo_1_eq_inv_nat_local mj HmjS). }
claim HinvLtS: inv_nat mj < inv_nat mi.
{ rewrite <- HdivEq.
  exact HdivLt. }
claim HinvMiInR: inv_nat mi :e R.
{ exact HinvmiR. }
claim HinvMjR: inv_nat mj :e R.
{ exact (inv_nat_real mj (omega_ordsucc j HjO)). }
exact (RltI (inv_nat mj) (inv_nat mi) HinvMjR HinvMiInR HinvLtS).
Qed.

(** helper: one inclusion for closure of A in the ordered square **)
(** LATEX VERSION: A ∪ {(0,1)} ⊆ cl(A). **)
Theorem ex17_18_closure_A_Supq :
  ordsq_A :\/: {ordsq_p01} c= closure_of ordered_square ordered_square_topology ordsq_A.
let p. assume Hp: p :e ordsq_A :\/: {ordsq_p01}.
prove p :e closure_of ordered_square ordered_square_topology ordsq_A.
apply (binunionE ordsq_A {ordsq_p01} p Hp).
- assume HpA: p :e ordsq_A.
  claim Hexn: exists n :e omega :\: {0}, p = (inv_nat n,0).
  { exact (ReplE (omega :\: {0}) (fun n0:set => (inv_nat n0,0)) p HpA). }
  apply Hexn.
  let n. assume Hnpack.
  apply Hnpack.
  assume HnIn HpEq.
  rewrite HpEq.
  set p0 := (inv_nat n,0).
  claim Hp0A: p0 :e ordsq_A.
  { rewrite <- HpEq.
    exact HpA. }
  claim HnO: n :e omega.
  { exact (setminusE1 omega {0} n HnIn). }
  claim HinvR: inv_nat n :e R.
  { exact (inv_nat_real n HnO). }
  claim Hinvpos: Rlt 0 (inv_nat n).
  { exact (inv_nat_pos n HnIn). }
  claim Hnlt0: ~(Rlt (inv_nat n) 0).
  { exact (not_Rlt_sym 0 (inv_nat n) Hinvpos). }
  claim Hinvle1: Rle (inv_nat n) 1.
  { exact (inv_nat_Rle_1_local n HnIn). }
  claim Hnlt1: ~(Rlt 1 (inv_nat n)).
  { exact (RleE_nlt (inv_nat n) 1 Hinvle1). }
  claim HinvU: (inv_nat n) :e unit_interval.
  { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (inv_nat n) HinvR).
    apply andI.
    - exact Hnlt0.
    - exact Hnlt1. }
  claim Hp0Sq: p0 :e ordered_square.
  { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval (inv_nat n) 0
            HinvU zero_in_unit_interval). }
  claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_A =
    {x :e ordered_square | forall U:set, U :e ordered_square_topology -> x :e U -> U :/\: ordsq_A <> Empty}.
  { reflexivity. }
