            claim HcapEq: U1 :/\: ordsq_A = Empty.
            { claim Hsub: U1 :/\: ordsq_A c= Empty.
              { let z. assume Hz: z :e U1 :/\: ordsq_A.
                prove z :e Empty.
                apply FalseE.
                claim HzU1: z :e U1.
                { exact (binintersectE1 U1 ordsq_A z Hz). }
                claim HzA: z :e ordsq_A.
                { exact (binintersectE2 U1 ordsq_A z Hz). }
                claim Hrel: order_rel (setprod R R) (1,0) z.
                { exact (SepE2 ordered_square (fun z0:set => order_rel (setprod R R) (1,0) z0) z HzU1). }
                apply (ReplE_impred (omega :\: {0}) (fun n:set => (inv_nat n,0)) z HzA False).
                let n. assume HnIn: n :e omega :\: {0}. assume HzEq: z = (inv_nat n,0).
                claim Hrel': order_rel (setprod R R) (1,0) (inv_nat n,0).
                { rewrite <- HzEq at 1.
                  exact Hrel. }
                claim Hdisj: Rlt 1 (inv_nat n) \/ (1 = inv_nat n /\ Rlt 0 0).
                { exact (order_rel_setprod_R_R_disj 1 0 (inv_nat n) 0 Hrel'). }
                apply Hdisj.
                - assume H1ltinv: Rlt 1 (inv_nat n).
                  apply FalseE.
                  claim Hinvle1: Rle (inv_nat n) 1.
                  { exact (inv_nat_Rle_1_local n HnIn). }
                  claim Hnot: ~(Rlt 1 (inv_nat n)).
                  { exact (RleE_nlt (inv_nat n) 1 Hinvle1). }
                  exact (Hnot H1ltinv).
                - assume HeqAnd.
                  apply FalseE.
                  claim Hlt: Rlt 0 0.
                  { exact (andER (1 = inv_nat n) (Rlt 0 0) HeqAnd). }
                  exact (not_Rlt_refl 0 real_0 Hlt). }
              exact (Empty_Subq_eq (U1 :/\: ordsq_A) Hsub). }
            exact ((Hcond U1 HU1top HpU1) HcapEq).
            - assume Hxneq1: ~(x = 1).
              (** use the finite set of K_set points above x to pick a minimal m, then take an interval neighborhood disjoint from ordsq_A **)
              set F := K_set :/\: {t :e R|Rlt x t}.
              claim HFfin: finite F.
              { exact (K_set_above_positive_bound_finite x HxR Hxpos). }
              claim HallS: forall t :e F, SNo t.
              { let t. assume HtF.
                claim HtK: t :e K_set.
                { exact (binintersectE1 K_set {t0 :e R|Rlt x t0} t HtF). }
                claim HtR: t :e R.
                { exact (K_set_Subq_R t HtK). }
                exact (real_SNo t HtR). }
              claim HxS: SNo x.
              { exact (real_SNo x HxR). }
              claim HxPropUI: ~(Rlt x 0) /\ ~(Rlt 1 x).
              { exact (SepE2 R (fun t0:set => ~(Rlt t0 0) /\ ~(Rlt 1 t0)) x HxI). }
              claim Hnot1x: ~(Rlt 1 x).
              { exact (andER (~(Rlt x 0)) (~(Rlt 1 x)) HxPropUI). }
              claim Hxlt1: Rlt x 1.
              { apply (SNoLt_trichotomy_or_impred 1 x SNo_1 HxS (Rlt x 1)).
                - assume H1ltx: 1 < x.
                  apply FalseE.
                  claim H1ltxR: Rlt 1 x.
                  { exact (RltI 1 x real_1 HxR H1ltx). }
                  exact (Hnot1x H1ltxR).
                - assume H1eqx: 1 = x.
                  apply FalseE.
                  claim Hxeq1: x = 1.
                  { rewrite <- H1eqx at 1.
                    reflexivity. }
                  exact (Hxneq1 Hxeq1).
                - assume Hxlt1': x < 1.
                  exact (RltI x 1 HxR real_1 Hxlt1'). }
              claim H1Above: 1 :e {t :e R|Rlt x t}.
              { apply (SepI R (fun t0:set => Rlt x t0) 1 real_1).
                exact Hxlt1. }
              claim H1F: 1 :e F.
              { exact (binintersectI K_set {t :e R|Rlt x t} 1 one_in_K_set H1Above). }
              claim HFne0: F <> 0.
              { assume HF0: F = 0.
                claim H1in0: 1 :e 0.
                { rewrite <- HF0 at 2.
                  exact H1F. }
                exact (EmptyE 1 H1in0). }
              claim Hexm: exists m:set, SNo_min_of F m.
              { exact (finite_min_exists F HallS HFfin HFne0). }
              apply Hexm.
              let m. assume HmMin.
              claim HmPair: m :e F /\ SNo m.
              { exact (andEL (m :e F /\ SNo m) (forall y :e F, SNo y -> m <= y) HmMin). }
              claim HmInF: m :e F.
              { exact (andEL (m :e F) (SNo m) HmPair). }
              claim HmS: SNo m.
              { exact (andER (m :e F) (SNo m) HmPair). }
              claim HmProp: forall y :e F, SNo y -> m <= y.
              { exact (andER (m :e F /\ SNo m) (forall y :e F, SNo y -> m <= y) HmMin). }
              claim HmAbove: m :e {t :e R|Rlt x t}.
              { exact (binintersectE2 K_set {t :e R|Rlt x t} m HmInF). }
              claim HmR: m :e R.
              { exact (SepE1 R (fun t0:set => Rlt x t0) m HmAbove). }
              claim Hxltm: Rlt x m.
              { exact (SepE2 R (fun t0:set => Rlt x t0) m HmAbove). }
              claim HmK: m :e K_set.
              { exact (binintersectE1 K_set {t :e R|Rlt x t} m HmInF). }
              claim HexnM: exists n :e omega :\: {0}, m = inv_nat n.
              { exact (ReplE (omega :\: {0}) (fun n0:set => inv_nat n0) m HmK). }
              claim HmU: m :e unit_interval.
              { apply HexnM.
                let n. assume Hnpack.
                apply Hnpack.
                assume HnIn Hmeq.
                rewrite Hmeq.
                exact (inv_nat_in_unit_interval n HnIn). }
              claim HmUprop: ~(Rlt m 0) /\ ~(Rlt 1 m).
              { exact (SepE2 R (fun t0:set => ~(Rlt t0 0) /\ ~(Rlt 1 t0)) m HmU). }
              claim Hnot1m: ~(Rlt 1 m).
              { exact (andER (~(Rlt m 0)) (~(Rlt 1 m)) HmUprop). }
              claim Hexq: exists q:set, q :e rational_numbers /\ (Rlt x q /\ Rlt q m).
              { exact (rational_dense_between_reals x m HxR HmR Hxltm). }
              apply Hexq.
              let q. assume Hqpack.
              claim HqQ: q :e rational_numbers.
              { exact (andEL (q :e rational_numbers) (Rlt x q /\ Rlt q m) Hqpack). }
              claim Hqprop: Rlt x q /\ Rlt q m.
              { exact (andER (q :e rational_numbers) (Rlt x q /\ Rlt q m) Hqpack). }
              claim Hxltq: Rlt x q.
              { exact (andEL (Rlt x q) (Rlt q m) Hqprop). }
              claim Hqltm: Rlt q m.
              { exact (andER (Rlt x q) (Rlt q m) Hqprop). }
              claim HqR: q :e R.
              { exact (rational_numbers_in_R q HqQ). }
              claim H0ltq: Rlt 0 q.
              { exact (Rlt_tra 0 x q Hxpos Hxltq). }
              claim Hnltq0: ~(Rlt q 0).
              { exact (not_Rlt_sym 0 q H0ltq). }
              claim Hnlt1q: ~(Rlt 1 q).
              { assume H1ltq: Rlt 1 q.
                claim H1ltm: Rlt 1 m.
                { exact (Rlt_tra 1 q m H1ltq Hqltm). }
                exact (Hnot1m H1ltm). }
              claim HqU: q :e unit_interval.
              { apply (SepI R (fun t0:set => ~(Rlt t0 0) /\ ~(Rlt 1 t0)) q HqR).
                apply andI.
                - exact Hnltq0.
                - exact Hnlt1q. }
              set x2 := q.
              claim Hx2R: x2 :e R.
              { exact HqR. }
              claim Hx2U: x2 :e unit_interval.
              { exact HqU. }
              claim Hxltx2: Rlt x x2.
              { exact Hxltq. }
              claim Hx2ltm: Rlt x2 m.
              { exact Hqltm. }

              set U := {z :e ordered_square | order_rel (setprod R R) (x, eps_ 1) z /\ order_rel (setprod R R) z (x2,0)}.
              claim HUpow: U :e Power ordered_square.
              { exact (Sep_In_Power ordered_square (fun z0:set => order_rel (setprod R R) (x, eps_ 1) z0 /\ order_rel (setprod R R) z0 (x2,0))). }
              claim Ha0Sq: (x, eps_ 1) :e ordered_square.
              { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval x (eps_ 1) HxI eps_1_in_unit_interval). }
              claim Hb0Sq: (x2,0) :e ordered_square.
              { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval x2 0 Hx2U zero_in_unit_interval). }
              claim HUbas: U :e ordered_square_order_basis.
              { set Bint := {I :e Power ordered_square | exists a0 :e ordered_square, exists b0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}}.
                set Blow := {I :e Power ordered_square | exists b0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}}.
                set Bup := {I :e Power ordered_square | exists a0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}}.
                claim HdefB: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
                { reflexivity. }
                rewrite HdefB.
                apply binunionI1.
                apply binunionI1.
                apply (SepI (Power ordered_square)
                  (fun I:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0})
                  U HUpow).
                witness (x, eps_ 1).
                apply andI.
                - exact Ha0Sq.
                - witness (x2,0).
                  apply andI.
                  + exact Hb0Sq.
                  + reflexivity. }
              claim HUtop: U :e ordered_square_topology.
              { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
                { reflexivity. }
                rewrite HdefT.
                exact (generated_topology_contains_elem ordered_square ordered_square_order_basis U HUpow HUbas). }
              claim HpU: p :e U.
              { apply (SepI ordered_square
                     (fun z0:set => order_rel (setprod R R) (x, eps_ 1) z0 /\ order_rel (setprod R R) z0 (x2,0))
                     p
                     HpSq).
                  claim Hleft: order_rel (setprod R R) (x, eps_ 1) p.
                  { rewrite HpEq1 at 2.
                    apply (order_rel_setprod_R_R_intro x (eps_ 1) x 1).
                    apply orIR.
                    apply andI.
                    - reflexivity.
                    - exact eps_1_lt1_R. }
                  claim Hright: order_rel (setprod R R) p (x2,0).
                  { rewrite HpEq1 at 1.
                    apply (order_rel_setprod_R_R_intro x 1 x2 0).
                    apply orIL.
                    exact Hxltx2. }
                exact (andI (order_rel (setprod R R) (x, eps_ 1) p)
                            (order_rel (setprod R R) p (x2,0))
                            Hleft Hright). }
              claim HcapEq: U :/\: ordsq_A = Empty.
              { claim Hsub: U :/\: ordsq_A c= Empty.
                { let w. assume Hw: w :e U :/\: ordsq_A.
                  prove w :e Empty.
                  apply FalseE.
                  claim HwU: w :e U.
                  { exact (binintersectE1 U ordsq_A w Hw). }
                  claim HwA: w :e ordsq_A.
                  { exact (binintersectE2 U ordsq_A w Hw). }
                  claim HexnA: exists n :e omega :\: {0}, w = (inv_nat n,0).
                  { exact (ReplE (omega :\: {0}) (fun m0:set => (inv_nat m0,0)) w HwA). }
                  apply HexnA.
                  let n. assume Hnpack.
                  apply Hnpack.
                  assume HnIn Hweq.
                  claim HnO: n :e omega.
                  { exact (setminusE1 omega {0} n HnIn). }
                  claim HinvR: inv_nat n :e R.
                  { exact (inv_nat_real n HnO). }
                  claim HinvS: SNo (inv_nat n).
                  { exact (real_SNo (inv_nat n) HinvR). }
                  claim HinvK: inv_nat n :e K_set.
                  { exact (ReplI (omega :\: {0}) (fun n0:set => inv_nat n0) n HnIn). }
                  claim HordPack: order_rel (setprod R R) (x, eps_ 1) w /\ order_rel (setprod R R) w (x2,0).
                  { exact (SepE2 ordered_square
                          (fun z0:set => order_rel (setprod R R) (x, eps_ 1) z0 /\ order_rel (setprod R R) z0 (x2,0))
                          w HwU). }
                  claim Hord1: order_rel (setprod R R) (x, eps_ 1) w.
                  { exact (andEL (order_rel (setprod R R) (x, eps_ 1) w)
                                 (order_rel (setprod R R) w (x2,0))
                                 HordPack). }
                  claim Hord2: order_rel (setprod R R) w (x2,0).
                  { exact (andER (order_rel (setprod R R) (x, eps_ 1) w)
                                 (order_rel (setprod R R) w (x2,0))
                                 HordPack). }
                  claim Hord1': order_rel (setprod R R) (x, eps_ 1) (inv_nat n,0).
                  { rewrite <- Hweq at 1.
                    exact Hord1. }
                  claim Hord2': order_rel (setprod R R) (inv_nat n,0) (x2,0).
                  { rewrite <- Hweq at 1.
                    exact Hord2. }
                  claim Hdisj1: Rlt x (inv_nat n) \/ (x = inv_nat n /\ Rlt (eps_ 1) 0).
                  { exact (order_rel_setprod_R_R_disj x (eps_ 1) (inv_nat n) 0 Hord1'). }
                  claim HxltInv: Rlt x (inv_nat n).
                  { apply Hdisj1.
                    - assume Hlt. exact Hlt.
                    - assume Hbad.
                      apply FalseE.
                      claim Heps0: Rlt (eps_ 1) 0.
                      { exact (andER (x = inv_nat n) (Rlt (eps_ 1) 0) Hbad). }
                      exact ((not_Rlt_sym 0 (eps_ 1) eps_1_pos_R) Heps0). }
                  claim Hdisj2: Rlt (inv_nat n) x2 \/ (inv_nat n = x2 /\ Rlt 0 0).
                  { exact (order_rel_setprod_R_R_disj (inv_nat n) 0 x2 0 Hord2'). }
                  claim HinvLtx2: Rlt (inv_nat n) x2.
                  { apply Hdisj2.
                    - assume Hlt. exact Hlt.
                    - assume Hbad.
                      apply FalseE.
                      claim H00: Rlt 0 0.
                      { exact (andER (inv_nat n = x2) (Rlt 0 0) Hbad). }
                      exact (not_Rlt_refl 0 real_0 H00). }
                  claim HinvInAbove: (inv_nat n) :e {t :e R|Rlt x t}.
                  { apply (SepI R (fun t0:set => Rlt x t0) (inv_nat n) HinvR).
                    exact HxltInv. }
                  claim HinvInF: (inv_nat n) :e F.
                  { exact (binintersectI K_set {t :e R|Rlt x t} (inv_nat n) HinvK HinvInAbove). }
                  claim HmLeInv: m <= (inv_nat n).
                  { exact (HmProp (inv_nat n) HinvInF HinvS). }
                  claim HinvLtS: inv_nat n < x2.
                  { exact (RltE_lt (inv_nat n) x2 HinvLtx2). }
                  claim Hx2LtS: x2 < m.
                  { exact (RltE_lt x2 m Hx2ltm). }
                  claim HinvLtM: inv_nat n < m.
                  { exact (SNoLt_tra (inv_nat n) x2 m HinvS (real_SNo x2 Hx2R) HmS HinvLtS Hx2LtS). }
                  claim Hmm: m < m.
                  { exact (SNoLeLt_tra m (inv_nat n) m HmS HinvS HmS HmLeInv HinvLtM). }
                  exact ((SNoLt_irref m) Hmm). }
                exact (Empty_Subq_eq (U :/\: ordsq_A) Hsub). }
              exact ((Hcond U HUtop HpU) HcapEq).
        + assume H1lty: 1 < y.
          apply FalseE.
        claim H1ltyR: Rlt 1 y.
        { exact (RltI 1 y real_1 HyR H1lty). }
      exact (Hnot1y H1ltyR).
- assume Heq: p01 = p.
  apply binunionI2.
  rewrite <- Heq.
  exact (SingI p01).
- assume Hpp01: order_rel (setprod R R) p p01.
  apply FalseE.
  (** take the basic neighborhood U = {z :e ordered_square | z < p01} **)
  set U := {z :e ordered_square | order_rel (setprod R R) z p01}.
  claim HUpow: U :e Power ordered_square.
  { apply (PowerI ordered_square U).
    let z. assume Hz: z :e U.
    exact (SepE1 ordered_square (fun z0:set => order_rel (setprod R R) z0 p01) z Hz). }
  claim HUbas: U :e ordered_square_order_basis.
  { set Bint := {J :e Power ordered_square | exists a0 :e ordered_square, exists b0 :e ordered_square,
        J = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}}.
    set Blow := {J :e Power ordered_square | exists b0 :e ordered_square,
        J = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}}.
    set Bup := {J :e Power ordered_square | exists a0 :e ordered_square,
        J = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}}.
    claim HUinBlow: U :e Blow.
    { apply (SepI (Power ordered_square)
             (fun J0:set => exists b0 :e ordered_square,
               J0 = {x0 :e ordered_square | order_rel (setprod R R) x0 b0})
             U HUpow).
      witness p01.
      apply andI.
      - exact Hp01Sq.
      - reflexivity. }
    claim HdefB: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
    { reflexivity. }
    rewrite HdefB.
    apply binunionI1.
    apply binunionI2.
    exact HUinBlow. }
  claim HUtop: U :e ordered_square_topology.
  { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
    { reflexivity. }
    rewrite HdefT.
    exact (generated_topology_contains_elem ordered_square ordered_square_order_basis U HUpow HUbas). }
  claim HpU: p :e U.
  { apply (SepI ordered_square (fun z0:set => order_rel (setprod R R) z0 p01) p HpSq).
    exact Hpp01. }
  claim HcapSub: U :/\: ordsq_A c= Empty.
  { let w. assume Hw: w :e U :/\: ordsq_A.
    prove w :e Empty.
    apply FalseE.
    claim HwA: w :e ordsq_A.
    { exact (binintersectE2 U ordsq_A w Hw). }
    claim HwU: w :e U.
    { exact (binintersectE1 U ordsq_A w Hw). }
    claim Hexm: exists m :e omega :\: {0}, w = (inv_nat m,0).
    { exact (ReplE (omega :\: {0}) (fun m0:set => (inv_nat m0,0)) w HwA). }
    apply Hexm.
    let m. assume Hmpack.
    apply Hmpack.
    assume HmIn Hweq.
    claim Hinvpos: Rlt 0 (inv_nat m).
    { exact (inv_nat_pos m HmIn). }
    claim Hrelwp01: order_rel (setprod R R) (inv_nat m,0) (0,1).
    { claim Hrel: order_rel (setprod R R) (inv_nat m,0) p01.
      { rewrite <- Hweq.
        exact (SepE2 ordered_square (fun z0:set => order_rel (setprod R R) z0 p01) w HwU). }
      rewrite <- Hp01def.
      exact Hrel. }
    claim Hex: exists c1 c2 d1 d2:set,
      (inv_nat m,0) = (c1,c2) /\ (0,1) = (d1,d2) /\
      (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
    { exact (order_rel_setprod_R_R_unfold (inv_nat m,0) (0,1) Hrelwp01). }
    apply Hex.
    let c1. assume Hc1.
    apply Hc1.
    let c2. assume Hd1.
    apply Hd1.
    let d1. assume Hd2.
    apply Hd2.
    let d2. assume Hcore.
    apply Hcore.
    assume Hpair Hdisj.
    apply Hdisj.
    - assume Hlt: Rlt c1 d1.
      claim Heq1: (inv_nat m,0) = (c1,c2).
      { exact (andEL ((inv_nat m,0) = (c1,c2)) ((0,1) = (d1,d2)) Hpair). }
      claim Heq2: (0,1) = (d1,d2).
      { exact (andER ((inv_nat m,0) = (c1,c2)) ((0,1) = (d1,d2)) Hpair). }
      claim Hc1eq: c1 = inv_nat m.
      { claim H0eq: (inv_nat m,0) 0 = (c1,c2) 0.
        { rewrite Heq1. reflexivity. }
        claim Htmp: inv_nat m = c1.
        { rewrite <- (tuple_2_0_eq (inv_nat m) 0).
          rewrite <- (tuple_2_0_eq c1 c2).
          exact H0eq. }
        rewrite <- Htmp.
        reflexivity. }
      claim Hd1eq: d1 = 0.
      { claim H0eq: (0,1) 0 = (d1,d2) 0.
        { rewrite Heq2. reflexivity. }
        claim Htmp: 0 = d1.
        { rewrite <- (tuple_2_0_eq 0 1).
          rewrite <- (tuple_2_0_eq d1 d2).
          exact H0eq. }
        rewrite <- Htmp.
        reflexivity. }
      claim Hbad: Rlt (inv_nat m) 0.
      { rewrite <- Hc1eq.
        rewrite <- Hd1eq.
        exact Hlt. }
      exact ((not_Rlt_sym 0 (inv_nat m) Hinvpos) Hbad).
    - assume Heq2: c1 = d1 /\ Rlt c2 d2.
      claim Heq1': (inv_nat m,0) = (c1,c2).
      { exact (andEL ((inv_nat m,0) = (c1,c2)) ((0,1) = (d1,d2)) Hpair). }
      claim Heq2': (0,1) = (d1,d2).
      { exact (andER ((inv_nat m,0) = (c1,c2)) ((0,1) = (d1,d2)) Hpair). }
      claim Hc1eq: c1 = inv_nat m.
      { claim H0eq: (inv_nat m,0) 0 = (c1,c2) 0.
        { rewrite Heq1'. reflexivity. }
        claim Htmp: inv_nat m = c1.
        { rewrite <- (tuple_2_0_eq (inv_nat m) 0).
          rewrite <- (tuple_2_0_eq c1 c2).
          exact H0eq. }
        rewrite <- Htmp.
        reflexivity. }
      claim Hd1eq: d1 = 0.
      { claim H0eq: (0,1) 0 = (d1,d2) 0.
        { rewrite Heq2'. reflexivity. }
        claim Htmp: 0 = d1.
        { rewrite <- (tuple_2_0_eq 0 1).
          rewrite <- (tuple_2_0_eq d1 d2).
          exact H0eq. }
        rewrite <- Htmp.
        reflexivity. }
      claim Hc1eqd1: inv_nat m = 0.
      { claim Hc1d1: c1 = d1.
        { exact (andEL (c1 = d1) (Rlt c2 d2) Heq2). }
        rewrite <- Hc1eq.
        rewrite Hc1d1.
        exact Hd1eq. }
      claim Hbad: Rlt 0 0.
      { rewrite <- Hc1eqd1 at 2.
        exact Hinvpos. }
      exact ((not_Rlt_refl 0 real_0) Hbad). }
  claim HcapEq: U :/\: ordsq_A = Empty.
  { exact (Empty_Subq_eq (U :/\: ordsq_A) HcapSub). }
  exact ((Hcond U HUtop HpU) HcapEq).
Qed.

(** helper: basis neighborhoods of p10 meet B in the ordered square **)
(** LATEX VERSION: Near (1,0), the points (1 - 1/n, eps(1)) accumulate in the dictionary order topology. **)
Theorem ex17_18_p10_interval_basis_meets_B : forall a0 b0:set,
  a0 :e ordered_square ->
  b0 :e ordered_square ->
  order_rel (setprod R R) a0 ordsq_p10 ->
  order_rel (setprod R R) ordsq_p10 b0 ->
  exists w:set,
    w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0} /\
    w :e ordsq_B.
let a0 b0.
assume Ha0Sq: a0 :e ordered_square.
assume Hb0Sq: b0 :e ordered_square.
assume Ha0p10: order_rel (setprod R R) a0 ordsq_p10.
assume Hp10b0: order_rel (setprod R R) ordsq_p10 b0.

set p10 := ordsq_p10.
claim Hp10def: p10 = (1,0).
{ reflexivity. }

claim Ha0xU: a0 0 :e unit_interval.
{ exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
claim Ha0yU: a0 1 :e unit_interval.
{ exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
claim Ha0yprop: ~(Rlt (a0 1) 0) /\ ~(Rlt 1 (a0 1)).
{ exact (SepE2 R (fun x:set => ~(Rlt x 0) /\ ~(Rlt 1 x)) (a0 1) Ha0yU). }
claim Ha0ynlt0: ~(Rlt (a0 1) 0).
{ exact (andEL (~(Rlt (a0 1) 0)) (~(Rlt 1 (a0 1))) Ha0yprop). }

claim Hunf: exists a1 a2 b1 b2:set,
  a0 = (a1, a2) /\ p10 = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
{ exact (order_rel_setprod_R_R_unfold a0 p10 Ha0p10). }
apply Hunf.
let a1. assume H1.
apply H1.
let a2. assume H2.
apply H2.
let b1. assume H3.
apply H3.
let b2. assume Hconj.
apply Hconj.
assume Hcore Hdisj.
apply Hcore.
assume Ha0eq Hp10eq.

claim Ha0_0_eq: a0 0 = a1.
{ rewrite Ha0eq.
  exact (tuple_2_0_eq a1 a2). }
claim Ha0_1_eq: a0 1 = a2.
{ rewrite Ha0eq.
  exact (tuple_2_1_eq a1 a2). }

claim Heqp: (1,0) = (b1,b2).
{ rewrite <- Hp10def at 1.
  rewrite Hp10eq.
  reflexivity. }
claim Hb1eq: b1 = 1.
{ claim H0eq: (1,0) 0 = (b1,b2) 0.
  { rewrite Heqp.
    reflexivity. }
  claim Htmp: 1 = b1.
  { rewrite <- (tuple_2_0_eq 1 0).
    rewrite <- (tuple_2_0_eq b1 b2).
    exact H0eq. }
  rewrite <- Htmp.
  reflexivity. }
claim Hb2eq: b2 = 0.
{ claim H1eq: (1,0) 1 = (b1,b2) 1.
  { rewrite Heqp.
    reflexivity. }
  claim Htmp: 0 = b2.
  { rewrite <- (tuple_2_1_eq 1 0).
    rewrite <- (tuple_2_1_eq b1 b2).
    exact H1eq. }
  rewrite <- Htmp.
  reflexivity. }

claim Ha1U: a1 :e unit_interval.
{ rewrite <- Ha0_0_eq at 1.
  exact Ha0xU. }
claim Ha1R: a1 :e R.
{ exact (SepE1 R (fun x:set => ~(Rlt x 0) /\ ~(Rlt 1 x)) a1 Ha1U). }
claim Ha1S: SNo a1.
{ exact (real_SNo a1 Ha1R). }

claim Ha1lt1: Rlt a1 1.
{ prove Rlt a1 1.
  apply Hdisj.
  - assume Hlt: Rlt a1 b1.
    rewrite <- Hb1eq at 1.
    exact Hlt.
  - assume Heqand: a1 = b1 /\ Rlt a2 b2.
    apply FalseE.
    claim Ha2lt: Rlt a2 b2.
    { exact (andER (a1 = b1) (Rlt a2 b2) Heqand). }
    claim Ha2lt0: Rlt a2 0.
    { rewrite <- Hb2eq at 1.
      exact Ha2lt. }
    claim Ha0ylt0: Rlt (a0 1) 0.
    { rewrite Ha0_1_eq at 1.
      exact Ha2lt0. }
    exact (Ha0ynlt0 Ha0ylt0). }

set diff := add_SNo 1 (minus_SNo a1).
claim HdiffR: diff :e R.
{ exact (real_add_SNo 1 real_1 (minus_SNo a1) (real_minus_SNo a1 Ha1R)). }
claim Hdiffpos: Rlt 0 diff.
{ exact (Rlt_0_diff_of_lt a1 1 Ha1lt1). }
claim HexN: exists N:set, N :e omega /\ Rlt (inv_nat (ordsucc N)) diff.
{ exact (exists_inv_nat_ordsucc_lt_local diff HdiffR Hdiffpos). }
apply HexN.
let N. assume HNpack.
apply HNpack.
assume HNO HinvLtR.

set n := ordsucc N.
claim Hndef: n = ordsucc N.
{ reflexivity. }
claim HnO: n :e omega.
{ exact (omega_ordsucc N HNO). }
claim Hnnot0: n /:e {0}.
{ assume Hn0: n :e {0}.
  claim Heq0: n = 0.
  { exact (SingE 0 n Hn0). }
  claim Heq1: ordsucc N = 0.
  { rewrite <- Hndef at 1.
    exact Heq0. }
  exact ((neq_ordsucc_0 N) Heq1). }
claim HnIn: n :e omega :\: {0}.
{ exact (setminusI omega {0} n HnO Hnnot0). }

set w := (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
claim HwB: w :e ordsq_B.
{ exact (ReplI (omega :\: {0})
         (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
         n HnIn). }
claim HwSq: w :e ordered_square.
{ exact (ordsq_B_sub_ordered_square w HwB). }

claim HinvLtS: inv_nat n < diff.
{ exact (RltE_lt (inv_nat n) diff HinvLtR). }
claim HinvR: inv_nat n :e R.
{ exact (inv_nat_real n HnO). }
claim HinvS: SNo (inv_nat n).
{ exact (real_SNo (inv_nat n) HinvR). }
claim HsumLt: add_SNo (inv_nat n) a1 < 1.
{ exact (add_SNo_minus_Lt2 1 a1 (inv_nat n) SNo_1 Ha1S HinvS HinvLtS). }
claim Hcom: add_SNo (inv_nat n) a1 = add_SNo a1 (inv_nat n).
{ exact (add_SNo_com (inv_nat n) a1 HinvS Ha1S). }
claim HsumLt2: add_SNo a1 (inv_nat n) < 1.
{ rewrite <- Hcom at 1.
  exact HsumLt. }
claim Ha1ltwx: a1 < add_SNo 1 (minus_SNo (inv_nat n)).
{ exact (add_SNo_minus_Lt2b 1 (inv_nat n) a1 SNo_1 HinvS Ha1S HsumLt2). }
claim HwxR: add_SNo 1 (minus_SNo (inv_nat n)) :e R.
{ exact (real_add_SNo 1 real_1 (minus_SNo (inv_nat n)) (real_minus_SNo (inv_nat n) HinvR)). }
claim Ha1ltwxR: Rlt a1 (add_SNo 1 (minus_SNo (inv_nat n))).
{ exact (RltI a1 (add_SNo 1 (minus_SNo (inv_nat n))) Ha1R HwxR Ha1ltwx). }

claim Ha0w: order_rel (setprod R R) a0 w.
{ rewrite Ha0eq.
  apply (order_rel_setprod_R_R_intro a1 a2 (add_SNo 1 (minus_SNo (inv_nat n))) (eps_ 1)).
  apply orIL.
  exact Ha1ltwxR. }

claim Hp10Sq: p10 :e ordered_square.
{ rewrite Hp10def.
  exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 1 0 one_in_unit_interval zero_in_unit_interval). }
claim HwRR: w :e setprod R R.
{ exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq). }
claim Hp10RR: p10 :e setprod R R.
{ exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p10 Hp10Sq). }
claim Hb0RR: b0 :e setprod R R.
{ exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) b0 Hb0Sq). }

claim Hwp10: order_rel (setprod R R) w p10.
{ claim Hexn: exists n :e omega :\: {0},
    w = (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
  { exact (ReplE (omega :\: {0})
           (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
           w HwB). }
  apply Hexn.
  let n. assume Hnpack.
  apply Hnpack.
  assume HnIn HwEq.
  rewrite HwEq.
  claim HnO: n :e omega.
  { exact (setminusE1 omega {0} n HnIn). }
  set inv := inv_nat n.
  claim HinvR: inv :e R.
  { exact (inv_nat_real n HnO). }
  claim HinvS: SNo inv.
  { exact (real_SNo inv HinvR). }
  claim HinvPosR: Rlt 0 inv.
  { exact (inv_nat_pos n HnIn). }
  claim HinvPos: 0 < inv.
  { exact (RltE_lt 0 inv HinvPosR). }
  claim H10eq: add_SNo 1 0 = 1.
  { exact (add_SNo_0R 1 SNo_1). }
    claim H1lt: 1 < add_SNo 1 inv.
    { claim Htmp: add_SNo 1 0 < add_SNo 1 inv.
      { exact (add_SNo_Lt2 1 0 inv SNo_1 SNo_0 HinvS HinvPos). }
      rewrite <- H10eq at 1.
      exact Htmp. }
  claim Hxlt: add_SNo 1 (minus_SNo inv) < 1.
  { exact (add_SNo_minus_Lt1b 1 inv 1 SNo_1 HinvS SNo_1 H1lt). }
  claim HxR: add_SNo 1 (minus_SNo inv) :e R.
  { exact (real_add_SNo 1 real_1 (minus_SNo inv) (real_minus_SNo inv HinvR)). }
  claim HxltR: Rlt (add_SNo 1 (minus_SNo inv)) 1.
  { exact (RltI (add_SNo 1 (minus_SNo inv)) 1 HxR real_1 Hxlt). }
  rewrite Hp10def.
  apply (order_rel_setprod_R_R_intro (add_SNo 1 (minus_SNo inv)) (eps_ 1) 1 0).
  apply orIL.
  exact HxltR. }
claim Hwb0: order_rel (setprod R R) w b0.
{ exact (order_rel_trans (setprod R R) w p10 b0
          simply_ordered_set_setprod_R_R
          HwRR Hp10RR Hb0RR
          Hwp10 Hp10b0). }

witness w.
apply andI.
- apply (SepI ordered_square
            (fun x0:set => order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0)
            w
            HwSq).
  apply andI.
  + exact Ha0w.
  + exact Hwb0.
- exact HwB.
Qed.

(** LATEX VERSION: Any lower ray neighborhood of (1,0) intersects B. **)
Theorem ex17_18_p10_lower_basis_meets_B : forall b0:set,
  b0 :e ordered_square ->
  order_rel (setprod R R) ordsq_p10 b0 ->
  exists w:set,
    w :e {x0 :e ordered_square | order_rel (setprod R R) x0 b0} /\
    w :e ordsq_B.
let b0.
assume Hb0Sq: b0 :e ordered_square.
assume Hp10b0: order_rel (setprod R R) ordsq_p10 b0.
set p10 := ordsq_p10.
set w := (add_SNo 1 (minus_SNo (inv_nat 1)), eps_ 1).

(** w is in B by choosing n=1 **)
claim H1omega: 1 :e omega.
{ exact (nat_p_omega 1 nat_1). }
claim H1not0: 1 /:e {0}.
{ assume H10: 1 :e {0}.
  claim Heq: 1 = 0.
  { exact (SingE 0 1 H10). }
  exact (neq_1_0 Heq). }
claim H1In: 1 :e omega :\: {0}.
{ exact (setminusI omega {0} 1 H1omega H1not0). }
claim HwB: w :e ordsq_B.
{ exact (ReplI (omega :\: {0}) (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)),eps_ 1)) 1 H1In). }
claim HwSq: w :e ordered_square.
{ exact (ordsq_B_sub_ordered_square w HwB). }

(** w < p10 and p10 < b0 imply w < b0 **)
claim Hp10def: p10 = (1,0).
{ reflexivity. }
claim Hp10Sq: p10 :e ordered_square.
{ rewrite Hp10def.
  exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 1 0 one_in_unit_interval zero_in_unit_interval). }
claim HwRR: w :e setprod R R.
{ exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq). }
claim Hp10RR: p10 :e setprod R R.
{ exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p10 Hp10Sq). }
claim Hb0RR: b0 :e setprod R R.
{ exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) b0 Hb0Sq). }

claim Hw0: add_SNo 1 (minus_SNo (inv_nat 1)) = 0.
{ claim Hinv1eq: inv_nat 1 = 1.
  { prove inv_nat 1 = 1.
    claim H1neq0': 1 <> 0.
    { exact neq_1_0. }
    claim Hmul: mul_SNo 1 (inv_nat 1) = 1.
    { exact (recip_SNo_invR 1 SNo_1 H1neq0'). }
    rewrite <- (mul_SNo_oneL (inv_nat 1) (SNo_recip_SNo 1 SNo_1)) at 1.
    exact Hmul. }
  rewrite Hinv1eq.
  exact (add_SNo_minus_SNo_rinv 1 SNo_1). }
claim Hweq: w = (0, eps_ 1).
{ rewrite Hw0.
  reflexivity. }
claim Hwp10: order_rel (setprod R R) w p10.
{ rewrite Hweq.
  rewrite Hp10def.
  apply (order_rel_setprod_R_R_intro 0 (eps_ 1) 1 0).
  apply orIL.
  exact Rlt_0_1. }
claim Hwb0: order_rel (setprod R R) w b0.
{ exact (order_rel_trans (setprod R R) w p10 b0
          simply_ordered_set_setprod_R_R
          HwRR Hp10RR Hb0RR
          Hwp10 Hp10b0). }

witness w.
apply andI.
- apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) x0 b0) w HwSq).
  exact Hwb0.
- exact HwB.
Qed.

(** LATEX VERSION: Any upper ray neighborhood of (1,0) intersects B. **)
Theorem ex17_18_p10_upper_basis_meets_B : forall a0:set,
  a0 :e ordered_square ->
  order_rel (setprod R R) a0 ordsq_p10 ->
  exists w:set,
    w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0} /\
    w :e ordsq_B.
let a0.
assume Ha0Sq: a0 :e ordered_square.
assume Ha0p10: order_rel (setprod R R) a0 ordsq_p10.
set p10 := ordsq_p10.
claim Hp10def: p10 = (1,0).
{ reflexivity. }

claim Ha0xU: a0 0 :e unit_interval.
{ exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
claim Ha0yU: a0 1 :e unit_interval.
{ exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
claim Ha0yprop: ~(Rlt (a0 1) 0) /\ ~(Rlt 1 (a0 1)).
{ exact (SepE2 R (fun x:set => ~(Rlt x 0) /\ ~(Rlt 1 x)) (a0 1) Ha0yU). }
claim Ha0ynlt0: ~(Rlt (a0 1) 0).
{ exact (andEL (~(Rlt (a0 1) 0)) (~(Rlt 1 (a0 1))) Ha0yprop). }

claim Hunf: exists a1 a2 b1 b2:set,
  a0 = (a1, a2) /\ p10 = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
{ exact (order_rel_setprod_R_R_unfold a0 p10 Ha0p10). }
apply Hunf.
let a1. assume H1.
apply H1.
let a2. assume H2.
apply H2.
let b1. assume H3.
apply H3.
let b2. assume Hconj.
apply Hconj.
assume Hcore Hdisj.
apply Hcore.
assume Ha0eq Hp10eq.

claim Ha0_0_eq: a0 0 = a1.
{ rewrite Ha0eq.
  exact (tuple_2_0_eq a1 a2). }
claim Ha0_1_eq: a0 1 = a2.
{ rewrite Ha0eq.
  exact (tuple_2_1_eq a1 a2). }

claim Heqp: (1,0) = (b1,b2).
{ rewrite <- Hp10def at 1.
  rewrite Hp10eq.
  reflexivity. }
claim Hb1eq: b1 = 1.
{ claim H0eq: (1,0) 0 = (b1,b2) 0.
  { rewrite Heqp.
    reflexivity. }
  claim Htmp: 1 = b1.
  { rewrite <- (tuple_2_0_eq 1 0).
    rewrite <- (tuple_2_0_eq b1 b2).
    exact H0eq. }
  rewrite <- Htmp.
  reflexivity. }
claim Hb2eq: b2 = 0.
{ claim H1eq: (1,0) 1 = (b1,b2) 1.
  { rewrite Heqp.
    reflexivity. }
  claim Htmp: 0 = b2.
  { rewrite <- (tuple_2_1_eq 1 0).
    rewrite <- (tuple_2_1_eq b1 b2).
    exact H1eq. }
  rewrite <- Htmp.
  reflexivity. }

claim Ha1U: a1 :e unit_interval.
{ rewrite <- Ha0_0_eq at 1.
  exact Ha0xU. }
claim Ha1R: a1 :e R.
{ exact (SepE1 R (fun x:set => ~(Rlt x 0) /\ ~(Rlt 1 x)) a1 Ha1U). }
claim Ha1S: SNo a1.
{ exact (real_SNo a1 Ha1R). }

claim Ha1lt1: Rlt a1 1.
{ prove Rlt a1 1.
  apply Hdisj.
  - assume Hlt: Rlt a1 b1.
    rewrite <- Hb1eq at 1.
    exact Hlt.
  - assume Heqand: a1 = b1 /\ Rlt a2 b2.
    apply FalseE.
    claim Ha2lt: Rlt a2 b2.
    { exact (andER (a1 = b1) (Rlt a2 b2) Heqand). }
    claim Ha2lt0: Rlt a2 0.
    { rewrite <- Hb2eq at 1.
      exact Ha2lt. }
    claim Ha0ylt0: Rlt (a0 1) 0.
    { rewrite Ha0_1_eq at 1.
      exact Ha2lt0. }
    exact (Ha0ynlt0 Ha0ylt0). }

set diff := add_SNo 1 (minus_SNo a1).
claim HdiffR: diff :e R.
{ exact (real_add_SNo 1 real_1 (minus_SNo a1) (real_minus_SNo a1 Ha1R)). }
claim Hdiffpos: Rlt 0 diff.
{ exact (Rlt_0_diff_of_lt a1 1 Ha1lt1). }
claim HexN: exists N:set, N :e omega /\ Rlt (inv_nat (ordsucc N)) diff.
{ exact (exists_inv_nat_ordsucc_lt_local diff HdiffR Hdiffpos). }
apply HexN.
let N. assume HNpack.
apply HNpack.
assume HNO HinvLtR.

set n := ordsucc N.
claim Hndef: n = ordsucc N.
{ reflexivity. }
claim HnO: n :e omega.
{ exact (omega_ordsucc N HNO). }
claim Hnnot0: n /:e {0}.
{ assume Hn0: n :e {0}.
  claim Heq0: n = 0.
  { exact (SingE 0 n Hn0). }
  claim Heq1: ordsucc N = 0.
  { rewrite <- Hndef at 1.
    exact Heq0. }
  exact ((neq_ordsucc_0 N) Heq1). }
claim HnIn: n :e omega :\: {0}.
{ exact (setminusI omega {0} n HnO Hnnot0). }

set w := (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
claim HwB: w :e ordsq_B.
{ exact (ReplI (omega :\: {0})
         (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
         n HnIn). }
claim HwSq: w :e ordered_square.
{ exact (ordsq_B_sub_ordered_square w HwB). }

claim HinvLtS: inv_nat n < diff.
{ exact (RltE_lt (inv_nat n) diff HinvLtR). }
claim HinvR: inv_nat n :e R.
{ exact (inv_nat_real n HnO). }
claim HinvS: SNo (inv_nat n).
{ exact (real_SNo (inv_nat n) HinvR). }
claim HdiffS: SNo diff.
{ exact (real_SNo diff HdiffR). }
claim HsumLt: add_SNo (inv_nat n) a1 < 1.
{ exact (add_SNo_minus_Lt2 1 a1 (inv_nat n) SNo_1 Ha1S HinvS HinvLtS). }
claim Hcom: add_SNo (inv_nat n) a1 = add_SNo a1 (inv_nat n).
{ exact (add_SNo_com (inv_nat n) a1 HinvS Ha1S). }
claim HsumLt2: add_SNo a1 (inv_nat n) < 1.
{ rewrite <- Hcom at 1.
  exact HsumLt. }
claim Ha1ltwx: a1 < add_SNo 1 (minus_SNo (inv_nat n)).
{ exact (add_SNo_minus_Lt2b 1 (inv_nat n) a1 SNo_1 HinvS Ha1S HsumLt2). }
claim HwxR: add_SNo 1 (minus_SNo (inv_nat n)) :e R.
{ exact (real_add_SNo 1 real_1 (minus_SNo (inv_nat n)) (real_minus_SNo (inv_nat n) HinvR)). }
claim Ha1ltwxR: Rlt a1 (add_SNo 1 (minus_SNo (inv_nat n))).
{ exact (RltI a1 (add_SNo 1 (minus_SNo (inv_nat n))) Ha1R HwxR Ha1ltwx). }

claim Ha0w: order_rel (setprod R R) a0 w.
{ rewrite Ha0eq.
  apply (order_rel_setprod_R_R_intro a1 a2 (add_SNo 1 (minus_SNo (inv_nat n))) (eps_ 1)).
  apply orIL.
  exact Ha1ltwxR. }

witness w.
apply andI.
- apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) a0 x0) w HwSq).
  exact Ha0w.
- exact HwB.
Qed.

(** helper: every point of B is strictly below p10 in the dictionary order **)
(** LATEX VERSION: For every n, (1 - 1/n, eps(1)) < (1,0). **)
Theorem ordsq_B_lt_p10 : forall w:set,
  w :e ordsq_B ->
  order_rel (setprod R R) w ordsq_p10.
let w. assume HwB: w :e ordsq_B.
claim Hexn: exists n :e omega :\: {0},
  w = (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
{ exact (ReplE (omega :\: {0})
         (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
         w HwB). }
apply Hexn.
let n. assume Hnpack.
apply Hnpack.
assume HnIn HwEq.
rewrite HwEq.
set inv := inv_nat n.
claim HnO: n :e omega.
{ exact (setminusE1 omega {0} n HnIn). }
claim HinvR: inv :e R.
{ exact (inv_nat_real n HnO). }
claim HinvS: SNo inv.
{ exact (real_SNo inv HinvR). }
claim HinvPosR: Rlt 0 inv.
{ exact (inv_nat_pos n HnIn). }
claim HinvPos: 0 < inv.
{ exact (RltE_lt 0 inv HinvPosR). }
claim H10eq: add_SNo 1 0 = 1.
{ exact (add_SNo_0R 1 SNo_1). }
claim H1lt: 1 < add_SNo 1 inv.
{ claim Htmp: add_SNo 1 0 < add_SNo 1 inv.
  { exact (add_SNo_Lt2 1 0 inv SNo_1 SNo_0 HinvS HinvPos). }
  rewrite <- H10eq at 1.
  exact Htmp. }
claim Hxlt: add_SNo 1 (minus_SNo inv) < 1.
{ exact (add_SNo_minus_Lt1b 1 inv 1 SNo_1 HinvS SNo_1 H1lt). }
claim HxR: add_SNo 1 (minus_SNo inv) :e R.
{ exact (real_add_SNo 1 real_1 (minus_SNo inv) (real_minus_SNo inv HinvR)). }
claim HxltR: Rlt (add_SNo 1 (minus_SNo inv)) 1.
{ exact (RltI (add_SNo 1 (minus_SNo inv)) 1 HxR real_1 Hxlt). }
claim Hp10def: ordsq_p10 = (1,0).
{ reflexivity. }
rewrite Hp10def.
apply (order_rel_setprod_R_R_intro (add_SNo 1 (minus_SNo inv)) (eps_ 1) 1 0).
apply orIL.
exact HxltR.
Qed.

(** helper: the B-sequence is increasing when indexed by omega via ordsucc **)
(** LATEX VERSION: If i<j then (1-1/(i+1),eps(1)) < (1-1/(j+1),eps(1)). **)
Theorem ordsq_B_ordsucc_index_increasing : forall i j:set,
  i :e omega -> j :e omega -> i :e j ->
  order_rel (setprod R R)
    (add_SNo 1 (minus_SNo (inv_nat (ordsucc i))), eps_ 1)
    (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1).
let i j.
assume HiO: i :e omega.
assume HjO: j :e omega.
assume Hij: i :e j.
set mi := ordsucc i.
set mj := ordsucc j.
claim HmiO: mi :e omega.
{ exact (omega_ordsucc i HiO). }
claim HmjO: mj :e omega.
{ exact (omega_ordsucc j HjO). }
claim HinvMiR: inv_nat mi :e R.
{ exact (inv_nat_real mi HmiO). }
claim HinvMjR: inv_nat mj :e R.
{ exact (inv_nat_real mj HmjO). }
claim HinvMiS: SNo (inv_nat mi).
{ exact (real_SNo (inv_nat mi) HinvMiR). }
claim HinvMjS: SNo (inv_nat mj).
{ exact (real_SNo (inv_nat mj) HinvMjR). }
claim HinvLt: Rlt (inv_nat mj) (inv_nat mi).
{ exact (inv_nat_ordsucc_antitone_local2 i j HiO HjO Hij). }
claim HinvLtS: inv_nat mj < inv_nat mi.
{ exact (RltE_lt (inv_nat mj) (inv_nat mi) HinvLt). }
claim HnegLtS: minus_SNo (inv_nat mi) < minus_SNo (inv_nat mj).
{ exact (minus_SNo_Lt_contra (inv_nat mj) (inv_nat mi) HinvMjS HinvMiS HinvLtS). }
claim HxLtS: add_SNo 1 (minus_SNo (inv_nat mi)) < add_SNo 1 (minus_SNo (inv_nat mj)).
{ exact (add_SNo_Lt2 1 (minus_SNo (inv_nat mi)) (minus_SNo (inv_nat mj))
          SNo_1 (SNo_minus_SNo (inv_nat mi) HinvMiS) (SNo_minus_SNo (inv_nat mj) HinvMjS) HnegLtS). }
claim HxR: add_SNo 1 (minus_SNo (inv_nat mi)) :e R.
{ exact (real_add_SNo 1 real_1 (minus_SNo (inv_nat mi)) (real_minus_SNo (inv_nat mi) HinvMiR)). }
claim HyR: add_SNo 1 (minus_SNo (inv_nat mj)) :e R.
{ exact (real_add_SNo 1 real_1 (minus_SNo (inv_nat mj)) (real_minus_SNo (inv_nat mj) HinvMjR)). }
claim HxLtR: Rlt (add_SNo 1 (minus_SNo (inv_nat mi))) (add_SNo 1 (minus_SNo (inv_nat mj))).
{ exact (RltI (add_SNo 1 (minus_SNo (inv_nat mi))) (add_SNo 1 (minus_SNo (inv_nat mj))) HxR HyR HxLtS). }
apply (order_rel_setprod_R_R_intro
        (add_SNo 1 (minus_SNo (inv_nat mi))) (eps_ 1)
        (add_SNo 1 (minus_SNo (inv_nat mj))) (eps_ 1)).
apply orIL.
exact HxLtR.
Qed.

(** helper: closure(B) in the ordered square (packaged) **)
(** LATEX VERSION: cl(B) = B ∪ {(1,0)}. **)
Theorem ex17_18_closure_B_eq :
  closure_of ordered_square ordered_square_topology ordsq_B = ordsq_B :\/: {ordsq_p10}.
prove closure_of ordered_square ordered_square_topology ordsq_B = ordsq_B :\/: {ordsq_p10}.
apply set_ext.
- let p. assume Hpcl: p :e closure_of ordered_square ordered_square_topology ordsq_B.
  prove p :e ordsq_B :\/: {ordsq_p10}.
  claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_B =
    {x :e ordered_square | forall U:set, U :e ordered_square_topology -> x :e U -> U :/\: ordsq_B <> Empty}.
  { reflexivity. }
  claim Hpcl': p :e {x :e ordered_square | forall U:set, U :e ordered_square_topology -> x :e U -> U :/\: ordsq_B <> Empty}.
  { rewrite <- Hdefcl.
    exact Hpcl. }
  claim HpSq: p :e ordered_square.
  { exact (SepE1 ordered_square
                (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_B <> Empty)
                p Hpcl'). }
  claim Hcond: forall U:set, U :e ordered_square_topology -> p :e U -> U :/\: ordsq_B <> Empty.
  { exact (SepE2 ordered_square
                (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_B <> Empty)
                p Hpcl'). }

  apply (xm (p :e ordsq_B)).
  + assume HpB: p :e ordsq_B.
    exact (binunionI1 ordsq_B {ordsq_p10} p HpB).
  + assume HpNotB: ~(p :e ordsq_B).
    apply binunionI2.
    set p10 := ordsq_p10.
    claim Hp10def: p10 = (1,0).
    { reflexivity. }
    claim Hp10Sq: p10 :e ordered_square.
    { rewrite Hp10def.
      exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 1 0 one_in_unit_interval zero_in_unit_interval). }
    claim HpRR: p :e setprod R R.
    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p HpSq). }
    claim Hp10RR: p10 :e setprod R R.
    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p10 Hp10Sq). }

    set U0 := {x0 :e ordered_square | order_rel (setprod R R) p10 x0}.
    claim HU0Pow: U0 :e Power ordered_square.
    { exact (Sep_In_Power ordered_square (fun x0:set => order_rel (setprod R R) p10 x0)). }
    claim HU0basis: U0 :e ordered_square_order_basis.
    { set Bint := {I :e Power ordered_square | exists a0 :e ordered_square, exists b0 :e ordered_square,
          I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}}.
      set Blow := {I :e Power ordered_square | exists b0 :e ordered_square,
          I = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}}.
      set Bup := {I :e Power ordered_square | exists a0 :e ordered_square,
          I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}}.
      claim HdefB: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
      { reflexivity. }
      rewrite HdefB.
      apply binunionI2.
      prove U0 :e Bup.
      apply (SepI (Power ordered_square)
                  (fun I:set => exists a0 :e ordered_square,
                      I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0})
                  U0).
      - exact HU0Pow.
      - witness p10.
        apply andI.
        + exact Hp10Sq.
        + reflexivity. }
    claim HU0top: U0 :e ordered_square_topology.
    { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
      { reflexivity. }
      rewrite HdefT.
      exact (generated_topology_contains_elem ordered_square ordered_square_order_basis U0 HU0Pow HU0basis). }

      apply (order_rel_trichotomy_or_impred (setprod R R) p p10
              simply_ordered_set_setprod_R_R
              HpRR Hp10RR
              (p :e {ordsq_p10})).
      * assume Hpp10: order_rel (setprod R R) p p10.
        apply FalseE.
        (** Start isolating p from ordsq_B using the least B-point above p **)
        claim Hexw: exists w:set,
          w :e {x0 :e ordered_square | order_rel (setprod R R) p x0} /\ w :e ordsq_B.
        { exact (ex17_18_p10_upper_basis_meets_B p HpSq Hpp10). }
        apply Hexw.
        let w. assume Hwpack.
        claim HwSep: w :e {x0 :e ordered_square | order_rel (setprod R R) p x0}.
        { exact (andEL (w :e {x0 :e ordered_square | order_rel (setprod R R) p x0}) (w :e ordsq_B) Hwpack). }
        claim HwB: w :e ordsq_B.
        { exact (andER (w :e {x0 :e ordered_square | order_rel (setprod R R) p x0}) (w :e ordsq_B) Hwpack). }
        claim Hpw: order_rel (setprod R R) p w.
        { exact (SepE2 ordered_square (fun x0:set => order_rel (setprod R R) p x0) w HwSep). }
        claim Hexn: exists n :e omega :\: {0},
          w = (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
        { exact (ReplE (omega :\: {0})
                 (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
                 w HwB). }
        apply Hexn.
        let n. assume Hnpack.
          apply Hnpack.
          assume HnIn HwEq.
          claim Hpn: order_rel (setprod R R) p (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
          { rewrite <- HwEq. exact Hpw. }
          (** Choose the least index nmin in omega :\\: {0} with p < b(nmin) **)
          set Pn := (fun n0:set => n0 :e omega :\: {0} /\ order_rel (setprod R R) p
                       (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1)).
        claim HexOrd: exists alpha:set, ordinal alpha /\ Pn alpha.
        { witness n.
          prove ordinal n /\ Pn n.
          apply andI.
          - exact (ordinal_Hered omega omega_ordinal n (setminusE1 omega {0} n HnIn)).
            - prove n :e omega :\: {0} /\ order_rel (setprod R R) p
                     (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
              apply andI.
              + exact HnIn.
              + exact Hpn. }
          apply (least_ordinal_ex Pn HexOrd).
          let nmin. assume HminPack.
          (** Use minimality of nmin to isolate p from ordsq_B **)
          claim Hmin12: (ordinal nmin /\ Pn nmin).
          { exact (andEL (ordinal nmin /\ Pn nmin) (forall beta :e nmin, ~Pn beta) HminPack). }
          claim HminPn: Pn nmin.
          { exact (andER (ordinal nmin) (Pn nmin) Hmin12). }
          claim HminMin: forall beta :e nmin, ~Pn beta.
          { exact (andER (ordinal nmin /\ Pn nmin) (forall beta :e nmin, ~Pn beta) HminPack). }
          apply HminPn.
          assume HnminIn Hppmin.

          (** Split nmin into successor form; m=0 gives nmin=1, handled explicitly. **)
          claim HnminO: nmin :e omega.
          { exact (setminusE1 omega {0} nmin HnminIn). }
          claim HnminNat: nat_p nmin.
          { exact (omega_nat_p nmin HnminO). }
          claim HnminCase: nmin = 0 \/ exists m:set, nat_p m /\ nmin = ordsucc m.
          { exact (nat_inv nmin HnminNat). }
          apply HnminCase.
          - assume Hnmin0: nmin = 0.
            claim HnminIn0: nmin :e {0}.
            { rewrite Hnmin0. exact (SingI 0). }
            claim HnminNot0: nmin /:e {0}.
            { exact (setminusE2 omega {0} nmin HnminIn). }
            exact (HnminNot0 HnminIn0).
          - assume Hexm: exists m:set, nat_p m /\ nmin = ordsucc m.
            apply Hexm.
            let m. assume Hmconj.
            claim HmNat: nat_p m.
            { exact (andEL (nat_p m) (nmin = ordsucc m) Hmconj). }
            claim HmEq: nmin = ordsucc m.
            { exact (andER (nat_p m) (nmin = ordsucc m) Hmconj). }
            apply (xm (m = 0)).
            + assume Hm0: m = 0.
              (** Neighborhood below b(nmin)=b(1) is disjoint from B. **)
              set bmin := (add_SNo 1 (minus_SNo (inv_nat nmin)), eps_ 1).
              set Ubad := {x0 :e ordered_square | order_rel (setprod R R) x0 bmin}.
              claim HUbadPow: Ubad :e Power ordered_square.
              { exact (Sep_In_Power ordered_square (fun x0:set => order_rel (setprod R R) x0 bmin)). }
              claim HbminSq: bmin :e ordered_square.
              { rewrite HmEq.
                rewrite Hm0.
                exact (ordsq_B_sub_ordered_square (add_SNo 1 (minus_SNo (inv_nat 1)), eps_ 1)
                          (ReplI (omega :\: {0})
                                 (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)),eps_ 1))
                                 1
                                 (setminusI omega {0} 1 (nat_p_omega 1 nat_1)
                                      (fun H10: 1 :e {0} => neq_1_0 (SingE 0 1 H10))))). }
              claim HUbadBasis: Ubad :e ordered_square_order_basis.
              { set Bint := {I :e Power ordered_square | exists a0 :e ordered_square, exists b0 :e ordered_square,
                  I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}}.
                set Blow := {I :e Power ordered_square | exists b0 :e ordered_square,
                  I = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}}.
                set Bup := {I :e Power ordered_square | exists a0 :e ordered_square,
                  I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}}.
                claim HdefB: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
                { reflexivity. }
                rewrite HdefB.
                apply binunionI1.
                apply binunionI2.
                apply (SepI (Power ordered_square)
                            (fun I:set => exists b0 :e ordered_square, I = {x0 :e ordered_square | order_rel (setprod R R) x0 b0})
                            Ubad).
                - exact HUbadPow.
                - witness bmin.
                  apply andI.
                  + exact HbminSq.
                  + reflexivity. }
              claim HUbadTop: Ubad :e ordered_square_topology.
              { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
                { reflexivity. }
                rewrite HdefT.
                exact (generated_topology_contains_elem ordered_square ordered_square_order_basis Ubad HUbadPow HUbadBasis). }
              claim HpUbad: p :e Ubad.
              { apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) x0 bmin) p HpSq).
                exact Hppmin. }
                claim HcapNe: Ubad :/\: ordsq_B <> Empty.
                { exact (Hcond Ubad HUbadTop HpUbad). }
                claim HcapEmp: Ubad :/\: ordsq_B = Empty.
                { apply set_ext.
                  - let x. assume Hx: x :e Ubad :/\: ordsq_B.
                    prove x :e Empty.
                    apply binintersectE Ubad ordsq_B x Hx.
                    assume HxUbad HxB.
                    apply FalseE.
                    claim Hxbmin: order_rel (setprod R R) x bmin.
                    { exact (SepE2 ordered_square (fun x0:set => order_rel (setprod R R) x0 bmin) x HxUbad). }
                    claim Hexn: exists n :e omega :\: {0},
                      x = (add_SNo 1 (minus_SNo (inv_nat n)), eps_ 1).
                    { exact (ReplE (omega :\: {0})
                             (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
                             x HxB). }
                    apply Hexn.
                    let n. assume Hnpack.
                    apply Hnpack.
                    assume HnInx HxEq.
                    claim HxSq: x :e ordered_square.
                    { exact (ordsq_B_sub_ordered_square x HxB). }
                    claim HxRR: x :e setprod R R.
                    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) x HxSq). }
                    claim HbminRR: bmin :e setprod R R.
                    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) bmin HbminSq). }

                    claim HnO: n :e omega.
                    { exact (setminusE1 omega {0} n HnInx). }
                    claim HnNat: nat_p n.
                    { exact (omega_nat_p n HnO). }
                    claim HnCase: n = 0 \/ exists k:set, nat_p k /\ n = ordsucc k.
                    { exact (nat_inv n HnNat). }
                    apply HnCase.
                    + assume Hn0: n = 0.
                      claim HnIn0: n :e {0}.
                      { rewrite Hn0. exact (SingI 0). }
                      claim HnNot0: n /:e {0}.
                      { exact (setminusE2 omega {0} n HnInx). }
                      exact (HnNot0 HnIn0).
                    + assume Hexk: exists k:set, nat_p k /\ n = ordsucc k.
                      apply Hexk.
                      let k. assume Hkconj.
                      claim HkNat: nat_p k.
                      { exact (andEL (nat_p k) (n = ordsucc k) Hkconj). }
                      claim HnEq: n = ordsucc k.
                      { exact (andER (nat_p k) (n = ordsucc k) Hkconj). }
                        apply (xm (k = 0)).
                        * assume Hk0: k = 0.
                          claim HnEq1: n = nmin.
                          { claim HnEq0: n = ordsucc 0.
                            { prove n = ordsucc 0.
                              rewrite <- Hk0.
                              exact HnEq. }
                            claim HnminEq0: nmin = ordsucc 0.
                            { rewrite HmEq.
                              rewrite Hm0.
                              reflexivity. }
                            rewrite HnminEq0.
                            exact HnEq0. }
                        claim HxEqbmin: x = bmin.
                        { rewrite HxEq.
                          rewrite HnEq1.
                          reflexivity. }
                          claim Hbb: order_rel (setprod R R) bmin bmin.
                          { rewrite <- HxEqbmin at 1.
                            exact Hxbmin. }
                        exact ((order_rel_irref (setprod R R) bmin) Hbb).
                      * assume HkNot0: ~(k = 0).
                        claim HkO: k :e omega.
                        { exact (nat_p_omega k HkNat). }
                        claim HkCase: k = 0 \/ exists t:set, nat_p t /\ k = ordsucc t.
                        { exact (nat_inv k HkNat). }
                          apply HkCase.
                          - assume Hk0: k = 0.
                            exact (HkNot0 Hk0).
                          - assume Hext: exists t:set, nat_p t /\ k = ordsucc t.
                            apply Hext.
                            let t. assume Htconj.
                           claim HtNat: nat_p t.
                           { exact (andEL (nat_p t) (k = ordsucc t) Htconj). }
                           claim HkEqS: k = ordsucc t.
                           { exact (andER (nat_p t) (k = ordsucc t) Htconj). }
                           claim H0ink: 0 :e k.
                           { rewrite HkEqS.
                             exact (nat_0_in_ordsucc t HtNat). }
                           claim H0omega: 0 :e omega.
                           { exact (nat_p_omega 0 nat_0). }
                           claim Hbminltx: order_rel (setprod R R) bmin x.
                           { claim Htmp: order_rel (setprod R R)
                               (add_SNo 1 (minus_SNo (inv_nat (ordsucc 0))), eps_ 1)
                               (add_SNo 1 (minus_SNo (inv_nat (ordsucc k))), eps_ 1).
                             { exact (ordsq_B_ordsucc_index_increasing 0 k H0omega HkO H0ink). }
                             claim HbminEq: bmin = (add_SNo 1 (minus_SNo (inv_nat (ordsucc 0))), eps_ 1).
                             { rewrite HmEq.
                               rewrite Hm0.
                               reflexivity. }
                             claim HxEqk: x = (add_SNo 1 (minus_SNo (inv_nat (ordsucc k))), eps_ 1).
                             { rewrite HxEq.
                               rewrite HnEq.
                               reflexivity. }
                               rewrite HbminEq at 1.
                               rewrite HxEqk.
                               exact Htmp. }
                           claim Hxx: order_rel (setprod R R) x x.
                           { exact (order_rel_trans (setprod R R) x bmin x
                                     simply_ordered_set_setprod_R_R
                                     HxRR HbminRR HxRR
                                     Hxbmin Hbminltx). }
                           exact ((order_rel_irref (setprod R R) x) Hxx).
                  - let x. assume Hx: x :e Empty.
                    prove x :e Ubad :/\: ordsq_B.
                    apply FalseE.
                    exact (EmptyE x Hx). }
                apply HcapNe.
                exact HcapEmp.
              + assume HmNot0: ~(m = 0).
                (** Remaining case m<>0: use an interval neighborhood between b(m) and b(nmin) **)
                apply FalseE.
                set bprev := (add_SNo 1 (minus_SNo (inv_nat m)), eps_ 1).
                set bcur := (add_SNo 1 (minus_SNo (inv_nat nmin)), eps_ 1).

                claim HmO: m :e omega.
                { exact (nat_p_omega m HmNat). }
                claim HmNotIn0: m /:e {0}.
                { assume HmIn0: m :e {0}.
                  claim Hm0: m = 0.
                  { exact (SingE 0 m HmIn0). }
                  exact (HmNot0 Hm0). }
                claim HmIn: m :e omega :\: {0}.
                { exact (setminusI omega {0} m HmO HmNotIn0). }

                claim HbprevB: bprev :e ordsq_B.
                { exact (ReplI (omega :\: {0})
                               (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
                               m HmIn). }
                claim HbprevSq: bprev :e ordered_square.
                { exact (ordsq_B_sub_ordered_square bprev HbprevB). }
                claim HbprevRR: bprev :e setprod R R.
                { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) bprev HbprevSq). }

                claim HbcurSq: bcur :e ordered_square.
                { exact (ordsq_B_sub_ordered_square bcur (ReplI (omega :\: {0})
                               (fun n0:set => (add_SNo 1 (minus_SNo (inv_nat n0)), eps_ 1))
                               nmin HnminIn)). }
                claim HbcurRR: bcur :e setprod R R.
                { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) bcur HbcurSq). }

                claim HmInNmin: m :e nmin.
                { rewrite HmEq.
                  exact (ordsuccI2 m). }
                claim HnotPnm: ~Pn m.
                { exact (HminMin m HmInNmin). }
                  claim HnotPpm: ~(order_rel (setprod R R) p bprev).
                  { assume Hpprev: order_rel (setprod R R) p bprev.
                    claim HPn: Pn m.
                    { prove m :e omega :\: {0} /\ order_rel (setprod R R) p bprev.
                      apply andI.
                      - exact HmIn.
                      - exact Hpprev. }
                    exact (HnotPnm HPn). }

                (** Deduce bprev < p using trichotomy and HpNotB **)
                claim Hbprevp: order_rel (setprod R R) bprev p.
                { apply (order_rel_trichotomy_or_impred (setprod R R) p bprev
                        simply_ordered_set_setprod_R_R
                        HpRR HbprevRR
                        (order_rel (setprod R R) bprev p)).
                  - assume Hpprev: order_rel (setprod R R) p bprev.
                    apply FalseE.
                    exact (HnotPpm Hpprev).
                  - assume HpEq: p = bprev.
                    apply FalseE.
                    claim HpB: p :e ordsq_B.
                    { rewrite HpEq.
                      exact HbprevB. }
                    exact (HpNotB HpB).
                  - assume Hbprevp0: order_rel (setprod R R) bprev p.
                    exact Hbprevp0. }

                (** Open interval neighborhood around p **)
                set Ugap := {x0 :e ordered_square | order_rel (setprod R R) bprev x0 /\ order_rel (setprod R R) x0 bcur}.
                claim HUgapPow: Ugap :e Power ordered_square.
                { exact (Sep_In_Power ordered_square
                          (fun x0:set => order_rel (setprod R R) bprev x0 /\ order_rel (setprod R R) x0 bcur)). }
                claim HUgapBasis: Ugap :e ordered_square_order_basis.
                { set Bint := {I :e Power ordered_square | exists a0 :e ordered_square, exists b0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}}.
                  set Blow := {I :e Power ordered_square | exists b0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}}.
                  set Bup := {I :e Power ordered_square | exists a0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}}.
                  claim HdefB: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
                  { reflexivity. }
                  rewrite HdefB.
                  apply binunionI1.
                  apply binunionI1.
                  apply (SepI (Power ordered_square)
                              (fun I:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
                                 I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0})
                              Ugap).
                  - exact HUgapPow.
                  - witness bprev.
                    apply andI.
                    + exact HbprevSq.
                    + witness bcur.
                      apply andI.
                      * exact HbcurSq.
                      * reflexivity. }
                claim HUgapTop: Ugap :e ordered_square_topology.
                { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
                  { reflexivity. }
                  rewrite HdefT.
                  exact (generated_topology_contains_elem ordered_square ordered_square_order_basis Ugap HUgapPow HUgapBasis). }
                claim HpUgap: p :e Ugap.
                { apply (SepI ordered_square
                          (fun x0:set => order_rel (setprod R R) bprev x0 /\ order_rel (setprod R R) x0 bcur)
                          p
                          HpSq).
                  apply andI.
                  - exact Hbprevp.
                  - exact Hppmin. }
                claim HcapNe2: Ugap :/\: ordsq_B <> Empty.
                { exact (Hcond Ugap HUgapTop HpUgap). }
                  claim HcapEmp2: Ugap :/\: ordsq_B = Empty.
                  { apply set_ext.
                    - let x. assume Hx: x :e Ugap :/\: ordsq_B.
