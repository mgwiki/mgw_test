                           HabCore). }
            claim HbcCoords: b = (b1x, b2x) /\ c = (c1, c2).
            { exact (andEL (b = (b1x, b2x) /\ c = (c1, c2))
                           (Rlt b1x c1 \/ (b1x = c1 /\ Rlt b2x c2))
                           HbcCore). }
            claim HbcCmp: Rlt b1x c1 \/ (b1x = c1 /\ Rlt b2x c2).
            { exact (andER (b = (b1x, b2x) /\ c = (c1, c2))
                           (Rlt b1x c1 \/ (b1x = c1 /\ Rlt b2x c2))
                           HbcCore). }
            claim HbEqTuples: (b1, b2) = (b1x, b2x).
            { claim HbEq1: b = (b1, b2).
              { exact (andER (a = (a1, a2)) (b = (b1, b2)) HabCoords). }
              claim HbEq2: b = (b1x, b2x).
              { exact (andEL (b = (b1x, b2x)) (c = (c1, c2)) HbcCoords). }
              rewrite <- HbEq1 at 1.
              exact HbEq2. }
            claim Hbcoords: b1 = b1x /\ b2 = b2x.
            { exact (tuple_eq_coords b1 b2 b1x b2x HbEqTuples). }
            claim Hb1eq: b1 = b1x.
            { exact (andEL (b1 = b1x) (b2 = b2x) Hbcoords). }
            claim Hb2eq: b2 = b2x.
            { exact (andER (b1 = b1x) (b2 = b2x) Hbcoords). }
            claim HbcCmp2: Rlt b1 c1 \/ (b1 = c1 /\ Rlt b2 c2).
            { apply (HbcCmp (Rlt b1 c1 \/ (b1 = c1 /\ Rlt b2 c2))).
              - assume Hb1xc1: Rlt b1x c1.
                apply orIL.
                rewrite Hb1eq at 1.
                exact Hb1xc1.
              - assume Hb1xeq: b1x = c1 /\ Rlt b2x c2.
                claim Hb1xeq2: b1x = c1.
                { exact (andEL (b1x = c1) (Rlt b2x c2) Hb1xeq). }
                claim Hb2xlt: Rlt b2x c2.
                { exact (andER (b1x = c1) (Rlt b2x c2) Hb1xeq). }
                apply orIR.
                apply andI.
                + rewrite Hb1eq at 1.
                  exact Hb1xeq2.
                + rewrite Hb2eq at 1.
                  exact Hb2xlt. }
            claim HacCmp: Rlt a1 c1 \/ (a1 = c1 /\ Rlt a2 c2).
            { apply (HabCmp (Rlt a1 c1 \/ (a1 = c1 /\ Rlt a2 c2))).
              - assume Ha1b1: Rlt a1 b1.
                apply (HbcCmp2 (Rlt a1 c1 \/ (a1 = c1 /\ Rlt a2 c2))).
                + assume Hb1c1: Rlt b1 c1.
                  apply orIL.
                  exact (Rlt_tra a1 b1 c1 Ha1b1 Hb1c1).
                + assume Hb1eqc1: b1 = c1 /\ Rlt b2 c2.
                  apply orIL.
                  claim Hb1eq2: b1 = c1.
                  { exact (andEL (b1 = c1) (Rlt b2 c2) Hb1eqc1). }
                  rewrite <- Hb1eq2.
                  exact Ha1b1.
              - assume Ha1eqb1: a1 = b1 /\ Rlt a2 b2.
                claim Ha1eq: a1 = b1.
                { exact (andEL (a1 = b1) (Rlt a2 b2) Ha1eqb1). }
                claim Ha2lt: Rlt a2 b2.
                { exact (andER (a1 = b1) (Rlt a2 b2) Ha1eqb1). }
                apply (HbcCmp2 (Rlt a1 c1 \/ (a1 = c1 /\ Rlt a2 c2))).
                + assume Hb1c1: Rlt b1 c1.
                  apply orIL.
                  rewrite Ha1eq.
                  exact Hb1c1.
                + assume Hb1eqc1: b1 = c1 /\ Rlt b2 c2.
                  claim Hb1eq2: b1 = c1.
                  { exact (andEL (b1 = c1) (Rlt b2 c2) Hb1eqc1). }
                  claim Hb2lt: Rlt b2 c2.
                  { exact (andER (b1 = c1) (Rlt b2 c2) Hb1eqc1). }
                  apply orIR.
                  apply andI.
                  * rewrite Ha1eq.
                    exact Hb1eq2.
                  * exact (Rlt_tra a2 b2 c2 Ha2lt Hb2lt). }
            claim HaEq: a = (a1, a2).
            { exact (andEL (a = (a1, a2)) (b = (b1, b2)) HabCoords). }
            claim HcEq: c = (c1, c2).
            { exact (andER (b = (b1x, b2x)) (c = (c1, c2)) HbcCoords). }
            rewrite HaEq.
            rewrite HcEq.
            prove order_rel (setprod R R) (a1,a2) (c1,c2).
            prove (setprod R R = R /\ Rlt (a1,a2) (c1,c2))
              \/
              (setprod R R = rational_numbers /\ Rlt (a1,a2) (c1,c2))
              \/
              (setprod R R = omega /\ (a1,a2) :e (c1,c2))
              \/
              (setprod R R = omega :\: {0} /\ (a1,a2) :e (c1,c2))
              \/
              (setprod R R = setprod 2 omega /\
               exists i m j n:set,
                 (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
                  (a1,a2) = (i, m) /\ (c1,c2) = (j, n) /\ (i :e j \/ (i = j /\ m :e n))))
              \/
              (setprod R R = setprod R R /\
               exists x1 x2 y1 y2:set,
                 (a1,a2) = (x1, x2) /\ (c1,c2) = (y1, y2) /\
                 (Rlt x1 y1 \/ (x1 = y1 /\ Rlt x2 y2)))
              \/
              (ordinal (setprod R R) /\ setprod R R <> R /\ setprod R R <> rational_numbers /\
               setprod R R <> setprod 2 omega /\ setprod R R <> setprod R R /\ (a1,a2) :e (c1,c2)).
            apply orIL.
            apply orIR.
            prove setprod R R = setprod R R /\
              exists x1 x2 y1 y2:set,
                (a1,a2) = (x1, x2) /\ (c1,c2) = (y1, y2) /\
                (Rlt x1 y1 \/ (x1 = y1 /\ Rlt x2 y2)).
            apply andI.
            - reflexivity.
            - witness a1.
              witness a2.
              witness c1.
              witness c2.
              apply andI.
              + apply andI.
                * reflexivity.
                * reflexivity.
              + exact HacCmp.
          - assume HneqRR: ~(X = setprod R R).
            (** ordinal case for all other carriers **)
            claim HordX: ordinal X.
            { apply Hso.
              - assume Hleft6.
                apply Hleft6.
                - assume Hleft5.
                  apply Hleft5.
                  + assume Hleft4.
                    apply Hleft4.
                    * assume Hleft3.
                      apply Hleft3.
                      - assume Hleft2.
                        apply Hleft2.
                        - assume HXeq: X = R.
                          apply FalseE.
                          exact (HneqR HXeq).
                        - assume HXeq: X = rational_numbers.
                          apply FalseE.
                          exact (HneqQ HXeq).
                      - assume HXeq: X = omega.
                        apply FalseE.
                        exact (HneqO HXeq).
                    * assume HXeq: X = omega :\: {0}.
                      apply FalseE.
                      exact (HneqNz HXeq).
                  + assume HXeq: X = setprod 2 omega.
                    apply FalseE.
                    exact (Hneq2 HXeq).
                - assume HXeq: X = setprod R R.
                  apply FalseE.
                  exact (HneqRR HXeq).
              - assume Hord.
                exact Hord. }
            claim Habmem: a :e b.
            { apply (Hab (a :e b)).
              - assume Hleft6.
                apply (Hleft6 (a :e b)).
                - assume Hleft5.
                  apply (Hleft5 (a :e b)).
                  + assume Hleft4.
                    apply (Hleft4 (a :e b)).
                    * assume Hleft3.
                      apply (Hleft3 (a :e b)).
                      - assume Hleft2.
                        apply (Hleft2 (a :e b)).
                        - assume Hc1: X = R /\ Rlt a b.
                          apply FalseE.
                          claim Heq: X = R.
                          { exact (andEL (X = R) (Rlt a b) Hc1). }
                          exact (HneqR Heq).
                        - assume Hc2: X = rational_numbers /\ Rlt a b.
                          apply FalseE.
                          claim Heq: X = rational_numbers.
                          { exact (andEL (X = rational_numbers) (Rlt a b) Hc2). }
                          exact (HneqQ Heq).
                      - assume Hc3: X = omega /\ a :e b.
                        apply FalseE.
                        claim Heq: X = omega.
                        { exact (andEL (X = omega) (a :e b) Hc3). }
                        exact (HneqO Heq).
                    * assume Hc4: X = omega :\: {0} /\ a :e b.
                      apply FalseE.
                      claim Heq: X = omega :\: {0}.
                      { exact (andEL (X = omega :\: {0}) (a :e b) Hc4). }
                      exact (HneqNz Heq).
                  + assume Hc5: X = setprod 2 omega /\
                      exists i m j n:set,
                        i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
                        a = (i, m) /\ b = (j, n) /\ (i :e j \/ (i = j /\ m :e n)).
                    apply FalseE.
                    claim Heq: X = setprod 2 omega.
                    { exact (andEL (X = setprod 2 omega)
                                  (exists i m j n:set,
                                    i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
                                    a = (i, m) /\ b = (j, n) /\ (i :e j \/ (i = j /\ m :e n)))
                                  Hc5). }
                    exact (Hneq2 Heq).
                - assume Hc6: X = setprod R R /\
                    exists a1 a2 b1 b2:set,
                      a = (a1, a2) /\ b = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
                  apply FalseE.
                  claim Heq: X = setprod R R.
                  { exact (andEL (X = setprod R R)
                                 (exists a1 a2 b1 b2:set,
                                   a = (a1, a2) /\ b = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)))
                                 Hc6). }
                  exact (HneqRR Heq).
              - assume Hord:
                  ordinal X /\ X <> R /\ X <> rational_numbers /\ X <> setprod 2 omega /\ X <> setprod R R /\ a :e b.
                set T := ((((ordinal X /\ X <> R) /\ X <> rational_numbers) /\ X <> setprod 2 omega) /\ X <> setprod R R).
                exact (andER T (a :e b) Hord). }
            claim Hbcmem: b :e c.
            { apply (Hbc (b :e c)).
              - assume Hleft6.
                apply (Hleft6 (b :e c)).
                - assume Hleft5.
                  apply (Hleft5 (b :e c)).
                  + assume Hleft4.
                    apply (Hleft4 (b :e c)).
                    * assume Hleft3.
                      apply (Hleft3 (b :e c)).
                      - assume Hleft2.
                        apply (Hleft2 (b :e c)).
                        - assume Hc1: X = R /\ Rlt b c.
                          apply FalseE.
                          claim Heq: X = R.
                          { exact (andEL (X = R) (Rlt b c) Hc1). }
                          exact (HneqR Heq).
                        - assume Hc2: X = rational_numbers /\ Rlt b c.
                          apply FalseE.
                          claim Heq: X = rational_numbers.
                          { exact (andEL (X = rational_numbers) (Rlt b c) Hc2). }
                          exact (HneqQ Heq).
                      - assume Hc3: X = omega /\ b :e c.
                        apply FalseE.
                        claim Heq: X = omega.
                        { exact (andEL (X = omega) (b :e c) Hc3). }
                        exact (HneqO Heq).
                    * assume Hc4: X = omega :\: {0} /\ b :e c.
                      apply FalseE.
                      claim Heq: X = omega :\: {0}.
                      { exact (andEL (X = omega :\: {0}) (b :e c) Hc4). }
                      exact (HneqNz Heq).
                  + assume Hc5: X = setprod 2 omega /\
                      exists i m j n:set,
                        i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
                        b = (i, m) /\ c = (j, n) /\ (i :e j \/ (i = j /\ m :e n)).
                    apply FalseE.
                    claim Heq: X = setprod 2 omega.
                    { exact (andEL (X = setprod 2 omega)
                                  (exists i m j n:set,
                                    i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
                                    b = (i, m) /\ c = (j, n) /\ (i :e j \/ (i = j /\ m :e n)))
                                  Hc5). }
                    exact (Hneq2 Heq).
                - assume Hc6: X = setprod R R /\
                    exists a1 a2 b1 b2:set,
                      b = (a1, a2) /\ c = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
                  apply FalseE.
                  claim Heq: X = setprod R R.
                  { exact (andEL (X = setprod R R)
                                 (exists a1 a2 b1 b2:set,
                                   b = (a1, a2) /\ c = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)))
                                 Hc6). }
                  exact (HneqRR Heq).
              - assume Hord:
                  ordinal X /\ X <> R /\ X <> rational_numbers /\ X <> setprod 2 omega /\ X <> setprod R R /\ b :e c.
                set T := ((((ordinal X /\ X <> R) /\ X <> rational_numbers) /\ X <> setprod 2 omega) /\ X <> setprod R R).
                exact (andER T (b :e c) Hord). }
            claim HcOrd: ordinal c.
            { exact (ordinal_Hered X HordX c HcX). }
            claim HcTr: TransSet c.
            { exact (ordinal_TransSet c HcOrd). }
            claim HbSubc: b c= c.
            { exact (HcTr b Hbcmem). }
            claim Hacmem: a :e c.
            { exact (HbSubc a Habmem). }
            prove (X = R /\ Rlt a c)
              \/
              (X = rational_numbers /\ Rlt a c)
              \/
              (X = omega /\ a :e c)
              \/
              (X = omega :\: {0} /\ a :e c)
              \/
              (X = setprod 2 omega /\
               exists i m j n:set,
                 i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
                 a = (i, m) /\ c = (j, n) /\ (i :e j \/ (i = j /\ m :e n)))
              \/
              (X = setprod R R /\
               exists a1 a2 b1 b2:set,
                 a = (a1, a2) /\ c = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)))
              \/
              (ordinal X /\ X <> R /\ X <> rational_numbers /\ X <> setprod 2 omega /\ X <> setprod R R /\ a :e c).
            apply orIR.
            apply and6I.
            - exact HordX.
            - exact HneqR.
            - exact HneqQ.
            - exact Hneq2.
            - exact HneqRR.
            - exact Hacmem.
Qed.

(** helper: order_rel is irreflexive (by case analysis on its definition) **)
(** LATEX VERSION: A strict order is irreflexive, so x<x never holds. **)
Theorem order_rel_irref : forall X x:set, ~(order_rel X x x).
let X x.
assume Hxx: order_rel X x x.
apply (Hxx False).
- assume H6.
  apply (H6 False).
  - assume H5.
    apply (H5 False).
    + assume H4.
      apply (H4 False).
      * assume H3.
        apply (H3 False).
        - assume H2.
          apply (H2 False).
          + assume HXR.
            claim Hlt: Rlt x x.
            { exact (andER (X = R) (Rlt x x) HXR). }
            claim HxR: x :e R.
            { exact (RltE_left x x Hlt). }
            exact ((not_Rlt_refl x HxR) Hlt).
          + assume HXQ.
            claim Hlt: Rlt x x.
            { exact (andER (X = rational_numbers) (Rlt x x) HXQ). }
            claim HxR: x :e R.
            { exact (RltE_left x x Hlt). }
            exact ((not_Rlt_refl x HxR) Hlt).
        - assume HXo.
          claim Hmem: x :e x.
          { exact (andER (X = omega) (x :e x) HXo). }
          exact (In_irref x Hmem).
      * assume HXo0.
        claim Hmem: x :e x.
        { exact (andER (X = omega :\: {0}) (x :e x) HXo0). }
        exact (In_irref x Hmem).
    + assume HX2o.
      claim Hex: exists i m j n:set,
        (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
         x = (i, m) /\ x = (j, n) /\ (i :e j \/ (i = j /\ m :e n))).
      { exact (andER (X = setprod 2 omega)
                     (exists i m j n:set,
                       (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
                        x = (i, m) /\ x = (j, n) /\ (i :e j \/ (i = j /\ m :e n))))
                     HX2o). }
      apply Hex.
      let i. assume Hmjn.
      apply Hmjn.
      let m. assume Hjnn.
      apply Hjnn.
      let j. assume Hnn.
      apply Hnn.
      let n. assume Hpack.
      claim Hcoords5:
        (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\
         x = (i, m) /\ x = (j, n)).
      { exact (andEL (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\ x = (i, m) /\ x = (j, n))
                     (i :e j \/ (i = j /\ m :e n))
                     Hpack). }
      claim Hcmp: i :e j \/ (i = j /\ m :e n).
      { exact (andER (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\ x = (i, m) /\ x = (j, n))
                     (i :e j \/ (i = j /\ m :e n))
                     Hpack). }
      claim Hcoords4:
        (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\ x = (i, m)).
      { exact (andEL (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\ x = (i, m))
                     (x = (j, n))
                     Hcoords5). }
      claim Hxjn: x = (j, n).
      { exact (andER (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega /\ x = (i, m))
                     (x = (j, n))
                     Hcoords5). }
      claim Hxim: x = (i, m).
      { exact (andER (i :e 2 /\ m :e omega /\ j :e 2 /\ n :e omega)
                     (x = (i, m))
                     Hcoords4). }
      claim HeqPair: (i,m) = (j,n).
      { rewrite <- Hxim at 1.
        exact Hxjn. }
      claim Hij: i = j.
      { rewrite <- (tuple_2_0_eq i m).
        rewrite <- (tuple_2_0_eq j n).
        rewrite <- HeqPair.
        reflexivity. }
      claim Hmn: m = n.
      { rewrite <- (tuple_2_1_eq i m).
        rewrite <- (tuple_2_1_eq j n).
        rewrite <- HeqPair.
        reflexivity. }
      apply (Hcmp False).
      * assume Hilj: i :e j.
        claim Hii: i :e i.
        { prove i :e i.
          rewrite Hij at 2.
          exact Hilj. }
        exact (In_irref i Hii).
      * assume Hind: i = j /\ m :e n.
        claim Hmnin: m :e n.
        { exact (andER (i = j) (m :e n) Hind). }
        claim Hmm: m :e m.
        { prove m :e m.
          rewrite Hmn at 2.
          exact Hmnin. }
        exact (In_irref m Hmm).
  - assume HXRR.
    claim Hex: exists a1 a2 b1 b2:set,
      x = (a1, a2) /\ x = (b1, b2) /\
      (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
    { exact (andER (X = setprod R R)
                   (exists a1 a2 b1 b2:set,
                     x = (a1, a2) /\ x = (b1, b2) /\
                     (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)))
                   HXRR). }
    apply Hex.
    let a1. assume Ha2b1b2.
    apply Ha2b1b2.
    let a2. assume Hb1b2.
    apply Hb1b2.
    let b1. assume Hb2.
      apply Hb2.
      let b2. assume Hpack.
      claim Hxyxz: x = (a1,a2) /\ x = (b1,b2).
      { exact (andEL (x = (a1, a2) /\ x = (b1, b2))
                     (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2))
                     Hpack). }
      claim Hcmp: Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2).
      { exact (andER (x = (a1, a2) /\ x = (b1, b2))
                     (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2))
                     Hpack). }
      claim Hxy: x = (a1,a2).
      { exact (andEL (x = (a1, a2))
                     (x = (b1, b2))
                     Hxyxz). }
      claim Hxz: x = (b1,b2).
      { exact (andER (x = (a1, a2))
                     (x = (b1, b2))
                     Hxyxz). }
      claim HeqPair: (a1,a2) = (b1,b2).
      { prove (a1,a2) = (b1,b2).
        rewrite <- Hxy at 1.
        exact Hxz. }
      claim Hab1: a1 = b1.
      { rewrite <- (tuple_2_0_eq a1 a2).
        rewrite <- (tuple_2_0_eq b1 b2).
        rewrite <- HeqPair.
        reflexivity. }
      claim Hab2: a2 = b2.
      { rewrite <- (tuple_2_1_eq a1 a2).
        rewrite <- (tuple_2_1_eq b1 b2).
        rewrite <- HeqPair.
        reflexivity. }
      apply (Hcmp False).
      + assume Hlt: Rlt a1 b1.
        claim Hltself: Rlt a1 a1.
        { prove Rlt a1 a1.
          rewrite Hab1 at 2.
          exact Hlt. }
        exact ((not_Rlt_refl a1 (RltE_left a1 a1 Hltself)) Hltself).
      + assume Hlt2: a1 = b1 /\ Rlt a2 b2.
        claim Hlt: Rlt a2 b2.
        { exact (andER (a1 = b1) (Rlt a2 b2) Hlt2). }
        claim Hltself: Rlt a2 a2.
        { prove Rlt a2 a2.
          rewrite Hab2 at 2.
          exact Hlt. }
        exact ((not_Rlt_refl a2 (RltE_left a2 a2 Hltself)) Hltself).
- assume Hord.
  claim Hmem: x :e x.
  { exact (andER ((((ordinal X /\ X <> R) /\ X <> rational_numbers) /\ X <> setprod 2 omega) /\ X <> setprod R R)
                 (x :e x)
                 Hord). }
  exact (In_irref x Hmem).
Qed.

(** from §16 Definition: order topology basis **)
(** LATEX VERSION: The order topology is generated by basic open intervals (a,b) together with open rays (a0,b) and (a,b0) at endpoints. **)
Definition order_topology_basis : set -> set := fun X =>
  (({I :e Power X | exists a :e X, exists b :e X,
          I = {x :e X | order_rel X a x /\ order_rel X x b}}
    :\/:
    {I :e Power X | exists b :e X, I = {x :e X | order_rel X x b}}
    :\/:
    {I :e Power X | exists a :e X, I = {x :e X | order_rel X a x}})
   :\/:
   {X}).
(** NOTE: This `order_topology_basis` includes both open intervals and open rays for all X; the TeX-definition basis is given separately as `order_topology_basis_tex`. **)

(** helper: cases for membership in the order topology basis **)
(** LATEX VERSION: Basis elements are open intervals, open rays, or the whole space. **)
Theorem order_topology_basis_cases : forall X I:set,
  I :e order_topology_basis X ->
  (exists a :e X, exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b})
  \/
  (exists b :e X, I = {x :e X | order_rel X x b})
  \/
  (exists a :e X, I = {x :e X | order_rel X a x})
  \/
  I = X.
let X I.
assume HI: I :e order_topology_basis X.
set S1 := {I0 :e Power X | exists a :e X, exists b :e X,
                 I0 = {x :e X | order_rel X a x /\ order_rel X x b}}.
set S2 := {I0 :e Power X | exists b :e X, I0 = {x :e X | order_rel X x b}}.
set S3 := {I0 :e Power X | exists a :e X, I0 = {x :e X | order_rel X a x}}.
set S12 := S1 :\/: S2.
set S123 := S12 :\/: S3.
set SX := {X}.
claim Hdef: order_topology_basis X = (S123 :\/: SX).
{ reflexivity. }
claim HI': I :e (S123 :\/: SX).
{ rewrite <- Hdef.
  exact HI. }
apply (binunionE' S123 SX I ((((
  (exists a :e X, exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b})
  \/
  (exists b :e X, I = {x :e X | order_rel X x b}))
  \/
  (exists a :e X, I = {x :e X | order_rel X a x}))
  \/
  I = X))).
- assume HIS123: I :e S123.
  apply (binunionE' S12 S3 I ((((
    (exists a :e X, exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b})
    \/
    (exists b :e X, I = {x :e X | order_rel X x b}))
    \/
    (exists a :e X, I = {x :e X | order_rel X a x}))
    \/
    I = X))).
  + assume HIS12: I :e S12.
    apply (binunionE' S1 S2 I ((((
      (exists a :e X, exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b})
      \/
      (exists b :e X, I = {x :e X | order_rel X x b}))
      \/
      (exists a :e X, I = {x :e X | order_rel X a x}))
      \/
      I = X))).
      * assume HIS1: I :e S1.
        apply orIL.
        apply orIL.
        apply orIL.
        exact (SepE2 (Power X)
               (fun I0:set => exists a :e X, exists b :e X,
                   I0 = {x :e X | order_rel X a x /\ order_rel X x b})
               I HIS1).
      * assume HIS2: I :e S2.
        apply orIL.
        apply orIL.
        apply orIR.
        exact (SepE2 (Power X)
               (fun I0:set => exists b :e X, I0 = {x :e X | order_rel X x b})
               I HIS2).
    * exact HIS12.
    + assume HIS3: I :e S3.
      apply orIL.
      apply orIR.
      exact (SepE2 (Power X)
             (fun I0:set => exists a :e X, I0 = {x :e X | order_rel X a x})
             I HIS3).
  + exact HIS123.
- assume HISX: I :e SX.
  apply orIR.
  exact (SingE X I HISX).
- exact HI'.
Qed.

(** helper: basis elements are convex under betweenness **)
(** LATEX VERSION: Any basic open interval or ray is convex: if y1<z<y2 and y1,y2 lie in the basis element, then so does z. **)
Theorem order_topology_basis_between : forall X I y1 y2 z:set,
  simply_ordered_set X ->
  I :e order_topology_basis X ->
  y1 :e I ->
  y2 :e I ->
  z :e X ->
  order_rel X y1 z ->
  order_rel X z y2 ->
  z :e I.
let X I y1 y2 z.
assume Hso HI Hy1 Hy2 HzX Hy1z Hzy2.
claim Hcases:
  (exists a :e X, exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b})
  \/
  (exists b :e X, I = {x :e X | order_rel X x b})
  \/
  (exists a :e X, I = {x :e X | order_rel X a x})
  \/
  I = X.
{ exact (order_topology_basis_cases X I HI). }
apply (Hcases (z :e I)).
- assume H123:
    ((exists a :e X, exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b})
      \/ (exists b :e X, I = {x :e X | order_rel X x b}))
      \/ (exists a :e X, I = {x :e X | order_rel X a x}).
  apply (H123 (z :e I)).
  + assume H12:
      (exists a :e X, exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b})
        \/ (exists b :e X, I = {x :e X | order_rel X x b}).
    apply (H12 (z :e I)).
    * assume HInt: exists a :e X, exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b}.
      apply HInt.
      let a. assume HaCore.
      claim HaX: a :e X.
      { exact (andEL (a :e X) (exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b}) HaCore). }
      claim Hexb: exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b}.
      { exact (andER (a :e X) (exists b :e X, I = {x :e X | order_rel X a x /\ order_rel X x b}) HaCore). }
      apply Hexb.
      let b. assume HbCore.
      claim HbX: b :e X.
      { exact (andEL (b :e X) (I = {x :e X | order_rel X a x /\ order_rel X x b}) HbCore). }
      claim HIeq: I = {x :e X | order_rel X a x /\ order_rel X x b}.
      { exact (andER (b :e X) (I = {x :e X | order_rel X a x /\ order_rel X x b}) HbCore). }
      rewrite HIeq.
      apply (SepI X (fun t:set => order_rel X a t /\ order_rel X t b) z HzX).
      claim Hy1': y1 :e {x :e X | order_rel X a x /\ order_rel X x b}.
      { rewrite <- HIeq.
        exact Hy1. }
      claim Hy2': y2 :e {x :e X | order_rel X a x /\ order_rel X x b}.
      { rewrite <- HIeq.
        exact Hy2. }
      claim Hy1Conj: order_rel X a y1 /\ order_rel X y1 b.
      { exact (SepE2 X (fun t:set => order_rel X a t /\ order_rel X t b) y1 Hy1'). }
      claim Hy2Conj: order_rel X a y2 /\ order_rel X y2 b.
      { exact (SepE2 X (fun t:set => order_rel X a t /\ order_rel X t b) y2 Hy2'). }
      claim Hay1: order_rel X a y1.
      { exact (andEL (order_rel X a y1) (order_rel X y1 b) Hy1Conj). }
      claim Hy2b: order_rel X y2 b.
      { exact (andER (order_rel X a y2) (order_rel X y2 b) Hy2Conj). }
      apply andI.
      { exact (order_rel_trans X a y1 z Hso
                HaX
                (SepE1 X (fun t:set => order_rel X a t /\ order_rel X t b) y1 Hy1')
                HzX
                Hay1 Hy1z). }
      { exact (order_rel_trans X z y2 b Hso
                HzX
                (SepE1 X (fun t:set => order_rel X a t /\ order_rel X t b) y2 Hy2')
                HbX
                Hzy2 Hy2b). }
    * assume HRayL: exists b :e X, I = {x :e X | order_rel X x b}.
      apply HRayL.
      let b. assume HbCore.
      claim HbX: b :e X.
      { exact (andEL (b :e X) (I = {x :e X | order_rel X x b}) HbCore). }
      claim HIeq: I = {x :e X | order_rel X x b}.
      { exact (andER (b :e X) (I = {x :e X | order_rel X x b}) HbCore). }
      rewrite HIeq.
      apply (SepI X (fun t:set => order_rel X t b) z HzX).
      claim Hy2': y2 :e {x :e X | order_rel X x b}.
      { rewrite <- HIeq.
        exact Hy2. }
      claim Hy2b: order_rel X y2 b.
      { exact (SepE2 X (fun t:set => order_rel X t b) y2 Hy2'). }
      exact (order_rel_trans X z y2 b Hso
                HzX
                (SepE1 X (fun t:set => order_rel X t b) y2 Hy2')
                HbX
                Hzy2 Hy2b).
  + assume HRayR: exists a :e X, I = {x :e X | order_rel X a x}.
    apply HRayR.
    let a. assume HaCore.
    claim HaX: a :e X.
    { exact (andEL (a :e X) (I = {x :e X | order_rel X a x}) HaCore). }
    claim HIeq: I = {x :e X | order_rel X a x}.
    { exact (andER (a :e X) (I = {x :e X | order_rel X a x}) HaCore). }
    rewrite HIeq.
    apply (SepI X (fun t:set => order_rel X a t) z HzX).
    claim Hy1': y1 :e {x :e X | order_rel X a x}.
    { rewrite <- HIeq.
      exact Hy1. }
    claim Hay1: order_rel X a y1.
    { exact (SepE2 X (fun t:set => order_rel X a t) y1 Hy1'). }
    exact (order_rel_trans X a y1 z Hso
              HaX
              (SepE1 X (fun t:set => order_rel X a t) y1 Hy1')
              HzX
              Hay1 Hy1z).
- assume HX: I = X.
  rewrite HX.
  exact HzX.
Qed.

(** helper: intersection of two open intervals refines to an open interval basis element **)
(** LATEX VERSION: The intersection of two basic open intervals contains a basic open interval around any common point. **)
Theorem order_topology_interval_refine : forall X a1 b1x a2 b2x b1 b2 x:set,
  simply_ordered_set X ->
  a1 :e X ->
  b1x :e X ->
  a2 :e X ->
  b2x :e X ->
  b1 = {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x} ->
  b2 = {x0 :e X | order_rel X a2 x0 /\ order_rel X x0 b2x} ->
  x :e b1 ->
  x :e b2 ->
  exists b3 :e (order_topology_basis X), x :e b3 /\ b3 c= b1 :/\: b2.
let X a1 b1x a2 b2x b1 b2 x.
assume Hso Ha1X Hb1xX Ha2X Hb2xX Hb1def Hb2def Hxb1 Hxb2.
set I1 := {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
set I2 := {x0 :e X | order_rel X a2 x0 /\ order_rel X x0 b2x}.
claim HxI1: x :e I1.
{ rewrite <- Hb1def.
  exact Hxb1. }
claim HxI2: x :e I2.
{ rewrite <- Hb2def.
  exact Hxb2. }
claim HxX: x :e X.
{ exact (SepE1 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) x HxI1). }
claim HxI1prop: order_rel X a1 x /\ order_rel X x b1x.
{ exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) x HxI1). }
claim Ha1x: order_rel X a1 x.
{ exact (andEL (order_rel X a1 x) (order_rel X x b1x) HxI1prop). }
claim Hxb1x: order_rel X x b1x.
{ exact (andER (order_rel X a1 x) (order_rel X x b1x) HxI1prop). }
claim HxI2prop: order_rel X a2 x /\ order_rel X x b2x.
{ exact (SepE2 X (fun x0:set => order_rel X a2 x0 /\ order_rel X x0 b2x) x HxI2). }
claim Ha2x: order_rel X a2 x.
{ exact (andEL (order_rel X a2 x) (order_rel X x b2x) HxI2prop). }
claim Hxb2x: order_rel X x b2x.
{ exact (andER (order_rel X a2 x) (order_rel X x b2x) HxI2prop). }

(** choose a left endpoint among a1,a2 that is below x **)
claim Hexa: exists a3 :e X,
  (a3 = a1 \/ a3 = a2) /\
  (order_rel X a3 x /\
   ((a1 = a3 \/ order_rel X a1 a3) /\ (a2 = a3 \/ order_rel X a2 a3))).
{ apply (order_rel_trichotomy_or_impred X a1 a2 Hso Ha1X Ha2X
        (exists a3 :e X,
           (a3 = a1 \/ a3 = a2) /\
           (order_rel X a3 x /\
            ((a1 = a3 \/ order_rel X a1 a3) /\ (a2 = a3 \/ order_rel X a2 a3))))).
  - assume Ha12: order_rel X a1 a2.
    witness a2.
    apply andI.
    + exact Ha2X.
    + apply andI.
      * prove a2 = a1 \/ a2 = a2.
        apply orIR.
        reflexivity.
      * apply andI.
        - exact Ha2x.
        - apply andI.
          + prove a1 = a2 \/ order_rel X a1 a2.
            apply orIR.
            exact Ha12.
          + prove a2 = a2 \/ order_rel X a2 a2.
            apply orIL.
            reflexivity.
  - assume Haeq: a1 = a2.
    witness a1.
    apply andI.
    + exact Ha1X.
    + apply andI.
      * prove a1 = a1 \/ a1 = a2.
        apply orIL.
        reflexivity.
      * apply andI.
        - exact Ha1x.
        - apply andI.
          + prove a1 = a1 \/ order_rel X a1 a1.
            apply orIL.
            reflexivity.
          + prove a2 = a1 \/ order_rel X a2 a1.
            apply orIL.
            rewrite <- Haeq.
            reflexivity.
  - assume Ha21: order_rel X a2 a1.
    witness a1.
    apply andI.
    + exact Ha1X.
    + apply andI.
      * prove a1 = a1 \/ a1 = a2.
        apply orIL.
        reflexivity.
      * apply andI.
        - exact Ha1x.
        - apply andI.
          + prove a1 = a1 \/ order_rel X a1 a1.
            apply orIL.
            reflexivity.
          + prove a2 = a1 \/ order_rel X a2 a1.
            apply orIR.
            exact Ha21. }
apply Hexa.
let a3.
assume Ha3pack.
apply Ha3pack.
assume Ha3X Ha3core.
claim Ha3x_and_max: order_rel X a3 x /\
  ((a1 = a3 \/ order_rel X a1 a3) /\ (a2 = a3 \/ order_rel X a2 a3)).
{ exact (andER (a3 = a1 \/ a3 = a2)
               (order_rel X a3 x /\
                ((a1 = a3 \/ order_rel X a1 a3) /\ (a2 = a3 \/ order_rel X a2 a3)))
               Ha3core). }
claim Ha3x: order_rel X a3 x.
{ exact (andEL (order_rel X a3 x)
               ((a1 = a3 \/ order_rel X a1 a3) /\ (a2 = a3 \/ order_rel X a2 a3))
               Ha3x_and_max). }
claim Ha_max: (a1 = a3 \/ order_rel X a1 a3) /\ (a2 = a3 \/ order_rel X a2 a3).
{ exact (andER (order_rel X a3 x)
               ((a1 = a3 \/ order_rel X a1 a3) /\ (a2 = a3 \/ order_rel X a2 a3))
               Ha3x_and_max). }
claim Ha1le: a1 = a3 \/ order_rel X a1 a3.
{ exact (andEL (a1 = a3 \/ order_rel X a1 a3)
               (a2 = a3 \/ order_rel X a2 a3)
               Ha_max). }
claim Ha2le: a2 = a3 \/ order_rel X a2 a3.
{ exact (andER (a1 = a3 \/ order_rel X a1 a3)
               (a2 = a3 \/ order_rel X a2 a3)
               Ha_max). }

(** choose a right endpoint among b1x,b2x that is above x **)
claim Hexb: exists b3x :e X,
  (b3x = b1x \/ b3x = b2x) /\
  (order_rel X x b3x /\
   ((b3x = b1x \/ order_rel X b3x b1x) /\ (b3x = b2x \/ order_rel X b3x b2x))).
{ apply (order_rel_trichotomy_or_impred X b1x b2x Hso Hb1xX Hb2xX
        (exists b3x :e X,
           (b3x = b1x \/ b3x = b2x) /\
           (order_rel X x b3x /\
            ((b3x = b1x \/ order_rel X b3x b1x) /\ (b3x = b2x \/ order_rel X b3x b2x))))).
  - assume Hb12: order_rel X b1x b2x.
    witness b1x.
    apply andI.
    + exact Hb1xX.
    + apply andI.
      * prove b1x = b1x \/ b1x = b2x.
        apply orIL.
        reflexivity.
      * apply andI.
        - exact Hxb1x.
        - apply andI.
          + prove b1x = b1x \/ order_rel X b1x b1x.
            apply orIL.
            reflexivity.
          + prove b1x = b2x \/ order_rel X b1x b2x.
            apply orIR.
            exact Hb12.
  - assume Hbeq: b1x = b2x.
    witness b1x.
    apply andI.
    + exact Hb1xX.
    + apply andI.
      * prove b1x = b1x \/ b1x = b2x.
        apply orIL.
        reflexivity.
      * apply andI.
        - exact Hxb1x.
        - apply andI.
          + prove b1x = b1x \/ order_rel X b1x b1x.
            apply orIL.
            reflexivity.
          + prove b1x = b2x \/ order_rel X b1x b2x.
            apply orIL.
            exact Hbeq.
  - assume Hb21: order_rel X b2x b1x.
    witness b2x.
    apply andI.
    + exact Hb2xX.
    + apply andI.
      * prove b2x = b1x \/ b2x = b2x.
        apply orIR.
        reflexivity.
      * apply andI.
        - exact Hxb2x.
        - apply andI.
          + prove b2x = b1x \/ order_rel X b2x b1x.
            apply orIR.
            exact Hb21.
          + prove b2x = b2x \/ order_rel X b2x b2x.
            apply orIL.
            reflexivity. }
apply Hexb.
let b3x.
assume Hb3pack.
apply Hb3pack.
assume Hb3xX Hb3core.
claim Hxb3x_and_min: order_rel X x b3x /\
  ((b3x = b1x \/ order_rel X b3x b1x) /\ (b3x = b2x \/ order_rel X b3x b2x)).
{ exact (andER (b3x = b1x \/ b3x = b2x)
               (order_rel X x b3x /\
                ((b3x = b1x \/ order_rel X b3x b1x) /\ (b3x = b2x \/ order_rel X b3x b2x)))
               Hb3core). }
claim Hxb3x: order_rel X x b3x.
{ exact (andEL (order_rel X x b3x)
               ((b3x = b1x \/ order_rel X b3x b1x) /\ (b3x = b2x \/ order_rel X b3x b2x))
               Hxb3x_and_min). }
claim Hb_min: (b3x = b1x \/ order_rel X b3x b1x) /\ (b3x = b2x \/ order_rel X b3x b2x).
{ exact (andER (order_rel X x b3x)
               ((b3x = b1x \/ order_rel X b3x b1x) /\ (b3x = b2x \/ order_rel X b3x b2x))
               Hxb3x_and_min). }
claim Hb1ge: b3x = b1x \/ order_rel X b3x b1x.
{ exact (andEL (b3x = b1x \/ order_rel X b3x b1x)
               (b3x = b2x \/ order_rel X b3x b2x)
               Hb_min). }
claim Hb2ge: b3x = b2x \/ order_rel X b3x b2x.
{ exact (andER (b3x = b1x \/ order_rel X b3x b1x)
               (b3x = b2x \/ order_rel X b3x b2x)
               Hb_min). }

set b3 := {x0 :e X | order_rel X a3 x0 /\ order_rel X x0 b3x}.
claim Hb3basis: b3 :e order_topology_basis X.
{ (** expand `order_topology_basis` and enter the interval-family branch **)
  prove b3 :e
    (({I :e Power X | exists a :e X, exists b :e X, I = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}}
      :\/:
      {I :e Power X | exists b :e X, I = {x0 :e X | order_rel X x0 b}}
      :\/:
      {I :e Power X | exists a :e X, I = {x0 :e X | order_rel X a x0}})
     :\/:
     {X}).
  apply binunionI1.
  apply binunionI1.
  apply binunionI1.
  prove b3 :e {I :e Power X | exists a :e X, exists b :e X, I = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}}.
  apply (SepI (Power X)
              (fun I:set => exists a :e X, exists b :e X, I = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b})
              b3).
  - prove b3 :e Power X.
    apply (PowerI X b3).
    let y.
    assume Hy: y :e b3.
    exact (SepE1 X (fun x0:set => order_rel X a3 x0 /\ order_rel X x0 b3x) y Hy).
  - witness a3.
    apply andI.
    + exact Ha3X.
    + witness b3x.
      apply andI.
      * exact Hb3xX.
      * reflexivity. }
claim HxInb3: x :e b3.
{ apply (SepI X (fun x0:set => order_rel X a3 x0 /\ order_rel X x0 b3x) x HxX).
  apply andI.
  - exact Ha3x.
  - exact Hxb3x. }

witness b3.
apply andI.
- exact Hb3basis.
- apply andI.
  + exact HxInb3.
  + (** remaining: b3 subset b1 intersection b2; requires max and min endpoint reasoning and order_rel transitivity **)
    prove b3 c= b1 :/\: b2.
    let y.
    assume Hy: y :e b3.
    claim HyX: y :e X.
    { exact (SepE1 X (fun x0:set => order_rel X a3 x0 /\ order_rel X x0 b3x) y Hy). }
    claim Hyprop: order_rel X a3 y /\ order_rel X y b3x.
    { exact (SepE2 X (fun x0:set => order_rel X a3 x0 /\ order_rel X x0 b3x) y Hy). }
    claim Ha3y: order_rel X a3 y.
    { exact (andEL (order_rel X a3 y) (order_rel X y b3x) Hyprop). }
    claim Hyb3x: order_rel X y b3x.
    { exact (andER (order_rel X a3 y) (order_rel X y b3x) Hyprop). }
    claim Ha1y: order_rel X a1 y.
    { apply (Ha1le (order_rel X a1 y)).
      - assume Ha1eq: a1 = a3.
        rewrite Ha1eq.
        exact Ha3y.
      - assume Ha1a3: order_rel X a1 a3.
        exact (order_rel_trans X a1 a3 y Hso Ha1X Ha3X HyX Ha1a3 Ha3y). }
    claim Ha2y: order_rel X a2 y.
    { apply (Ha2le (order_rel X a2 y)).
      - assume Ha2eq: a2 = a3.
        rewrite Ha2eq.
        exact Ha3y.
      - assume Ha2a3: order_rel X a2 a3.
        exact (order_rel_trans X a2 a3 y Hso Ha2X Ha3X HyX Ha2a3 Ha3y). }
    claim Hyb1x: order_rel X y b1x.
    { apply (Hb1ge (order_rel X y b1x)).
      - assume Hb3eqb1: b3x = b1x.
        rewrite <- Hb3eqb1.
        exact Hyb3x.
      - assume Hb3ltb1: order_rel X b3x b1x.
        exact (order_rel_trans X y b3x b1x Hso HyX Hb3xX Hb1xX Hyb3x Hb3ltb1). }
    claim Hyb2x: order_rel X y b2x.
    { apply (Hb2ge (order_rel X y b2x)).
      - assume Hb3eqb2: b3x = b2x.
        rewrite <- Hb3eqb2.
        exact Hyb3x.
      - assume Hb3ltb2: order_rel X b3x b2x.
        exact (order_rel_trans X y b3x b2x Hso HyX Hb3xX Hb2xX Hyb3x Hb3ltb2). }
    claim Hyb1: y :e b1.
    { rewrite Hb1def.
      apply (SepI X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y HyX).
      apply andI.
      - exact Ha1y.
      - exact Hyb1x. }
    claim Hyb2: y :e b2.
    { rewrite Hb2def.
      apply (SepI X (fun x0:set => order_rel X a2 x0 /\ order_rel X x0 b2x) y HyX).
      apply andI.
      - exact Ha2y.
      - exact Hyb2x. }
    exact (binintersectI b1 b2 y Hyb1 Hyb2).
Qed.

(** from §14 The Order Topology: least and largest elements **)
(** LATEX VERSION: a0 is the smallest element of X if every x∈X satisfies not(x<a0); b0 is the largest if not(b0<x) for all x∈X. **)
Definition is_least_element : set -> set -> prop := fun X a0 =>
  a0 :e X /\ forall x:set, x :e X -> ~(order_rel X x a0).

Definition is_largest_element : set -> set -> prop := fun X b0 =>
  b0 :e X /\ forall x:set, x :e X -> ~(order_rel X b0 x).

(** from §14 Definition: order topology basis (TeX version) **)
(** LATEX VERSION: Assuming X has more than one element, a basis consists of (1) open intervals (a,b); (2) [a0,b) if a0 is the smallest element; (3) (a,b0] if b0 is the largest element. **)
Definition order_topology_basis_tex : set -> set := fun X =>
  ({I :e Power X | exists a :e X, exists b :e X, order_rel X a b /\ I = {x :e X | order_rel X a x /\ order_rel X x b}}
   :\/:
   {I :e Power X | exists a0 b:set, is_least_element X a0 /\ b :e X /\ order_rel X a0 b /\
     I = {x :e X | (x = a0 \/ order_rel X a0 x) /\ order_rel X x b}}
   :\/:
   {I :e Power X | exists b0 a:set, is_largest_element X b0 /\ a :e X /\ order_rel X a b0 /\
     I = {x :e X | order_rel X a x /\ (x = b0 \/ order_rel X x b0)}}).

(** from §14 Definition: order topology on a simply ordered set **)
(** LATEX VERSION: The order topology on X is the topology generated by the order-topology basis on X. **)
Definition order_topology : set -> set := fun X => generated_topology X (order_topology_basis X).

(** Helper: order topology basis satisfies basis axioms **)
Theorem order_topology_basis_is_basis : forall X:set,
  simply_ordered_set X ->
  basis_on X (order_topology_basis X).
let X.
assume Hso: simply_ordered_set X.
prove basis_on X (order_topology_basis X).
set A := order_topology_basis X c= Power X.
set Bcov := (forall x :e X, exists b :e (order_topology_basis X), x :e b).
set Bref := (forall b1 :e (order_topology_basis X),
               forall b2 :e (order_topology_basis X),
               forall x:set,
                 x :e b1 -> x :e b2 ->
                 exists b3 :e (order_topology_basis X), x :e b3 /\ b3 c= b1 :/\: b2).
claim Hab: A /\ Bcov.
{ apply andI.
  - (** basis elements are subsets of X **)
      prove order_topology_basis X c= Power X.
      let I.
      assume HI: I :e order_topology_basis X.
      prove I :e Power X.
      set Bold :=
        ({I0 :e Power X | exists a :e X, exists b :e X,
              I0 = {x :e X | order_rel X a x /\ order_rel X x b}}
         :\/:
         {I0 :e Power X | exists b :e X, I0 = {x :e X | order_rel X x b}}
         :\/:
         {I0 :e Power X | exists a :e X, I0 = {x :e X | order_rel X a x}}).
      apply (binunionE Bold {X} I HI).
      * assume HI0: I :e Bold.
        apply (binunionE ({I0 :e Power X | exists a :e X, exists b :e X,
                I0 = {x :e X | order_rel X a x /\ order_rel X x b}}
           :\/:
           {I0 :e Power X | exists b :e X, I0 = {x :e X | order_rel X x b}})
           ({I0 :e Power X | exists a :e X, I0 = {x :e X | order_rel X a x}})
           I HI0).
        * assume HI12: I :e
          ({I0 :e Power X | exists a :e X, exists b :e X,
                I0 = {x :e X | order_rel X a x /\ order_rel X x b}}
           :\/:
           {I0 :e Power X | exists b :e X, I0 = {x :e X | order_rel X x b}}).
      apply (binunionE
        ({I0 :e Power X | exists a :e X, exists b :e X,
              I0 = {x :e X | order_rel X a x /\ order_rel X x b}})
        ({I0 :e Power X | exists b :e X, I0 = {x :e X | order_rel X x b}})
        I
        HI12).
      - assume HI1: I :e {I0 :e Power X | exists a :e X, exists b :e X,
            I0 = {x :e X | order_rel X a x /\ order_rel X x b}}.
         exact (SepE1 (Power X)
           (fun I0:set => exists a :e X, exists b :e X,
             I0 = {x :e X | order_rel X a x /\ order_rel X x b})
           I HI1).
      - assume HI2: I :e {I0 :e Power X | exists b :e X, I0 = {x :e X | order_rel X x b}}.
         exact (SepE1 (Power X)
           (fun I0:set => exists b :e X, I0 = {x :e X | order_rel X x b})
           I HI2).
        * assume HI3: I :e {I0 :e Power X | exists a :e X, I0 = {x :e X | order_rel X a x}}.
          exact (SepE1 (Power X)
            (fun I0:set => exists a :e X, I0 = {x :e X | order_rel X a x})
            I HI3).
      * assume HIX: I :e {X}.
        claim HIEq: I = X.
        { exact (SingE X I HIX). }
        rewrite HIEq.
        exact (Self_In_Power X).
    - (** cover property: every x∈X lies in the basis element X **)
      prove forall x :e X, exists b :e (order_topology_basis X), x :e b.
      let x.
      assume HxX: x :e X.
      witness X.
      apply andI.
      + set Bold :=
          ({I0 :e Power X | exists a :e X, exists b :e X,
                I0 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}}
           :\/:
           {I0 :e Power X | exists b :e X, I0 = {x0 :e X | order_rel X x0 b}}
           :\/:
           {I0 :e Power X | exists a :e X, I0 = {x0 :e X | order_rel X a x0}}).
        exact (binunionI2 Bold {X} X (SingI X)).
      + exact HxX. }
claim Href: Bref.
{ (** refinement property: handle the `{X}` basis element, admit the nontrivial interval/ray cases **)
  let b1. assume Hb1: b1 :e order_topology_basis X.
  let b2. assume Hb2: b2 :e order_topology_basis X.
  let x.
  assume Hx1: x :e b1.
  assume Hx2: x :e b2.
  prove exists b3 :e (order_topology_basis X), x :e b3 /\ b3 c= b1 :/\: b2.
  set Bold :=
    ({I0 :e Power X | exists a :e X, exists b :e X,
          I0 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}}
     :\/:
     {I0 :e Power X | exists b :e X, I0 = {x0 :e X | order_rel X x0 b}}
     :\/:
     {I0 :e Power X | exists a :e X, I0 = {x0 :e X | order_rel X a x0}}).
  claim HsubPow: order_topology_basis X c= Power X.
  { exact (andEL A Bcov Hab). }
  apply (binunionE Bold {X} b1 Hb1).
  - assume Hb1old: b1 :e Bold.
    apply (binunionE Bold {X} b2 Hb2).
    + assume Hb2old: b2 :e Bold.
        (** partial refinement inside the original 3-family basis **)
        set Aint := {I0 :e Power X | exists a :e X, exists b :e X,
              I0 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}}.
        set Blow := {I0 :e Power X | exists b :e X, I0 = {x0 :e X | order_rel X x0 b}}.
        set Cup := {I0 :e Power X | exists a :e X, I0 = {x0 :e X | order_rel X a x0}}.
        claim HBdef: Bold = (Aint :\/: Blow :\/: Cup).
        { reflexivity. }
        claim Hb1tri: b1 :e (Aint :\/: Blow :\/: Cup).
        { rewrite <- HBdef.
          exact Hb1old. }
        claim Hb2tri: b2 :e (Aint :\/: Blow :\/: Cup).
        { rewrite <- HBdef.
          exact Hb2old. }
        apply (binunionE (Aint :\/: Blow) Cup b1 Hb1tri).
          - assume Hb1AB: b1 :e (Aint :\/: Blow).
              apply (binunionE Aint Blow b1 Hb1AB).
              * assume Hb1A: b1 :e Aint.
                claim Hexab1: exists a1 :e X, exists b1x :e X,
                  b1 = {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                { exact (SepE2 (Power X)
                          (fun I0:set => exists a1 :e X, exists b1x :e X,
                            I0 = {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x})
                          b1
                          Hb1A). }
                apply Hexab1.
                let a1.
                assume Ha1core: a1 :e X /\ exists b1x :e X,
                  b1 = {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                apply Ha1core.
                assume Ha1X: a1 :e X.
                assume Hexb1x: exists b1x :e X,
                  b1 = {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                apply Hexb1x.
                let b1x.
                assume Hb1xcore: b1x :e X /\ b1 = {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                apply Hb1xcore.
                assume Hb1xX: b1x :e X.
                assume Hb1eq: b1 = {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                apply (binunionE (Aint :\/: Blow) Cup b2 Hb2tri).
                  - assume Hb2AB: b2 :e (Aint :\/: Blow).
                    apply (binunionE Aint Blow b2 Hb2AB).
                    + assume Hb2A: b2 :e Aint.
                      claim Hexab2: exists a2 :e X, exists b2x :e X,
                        b2 = {x0 :e X | order_rel X a2 x0 /\ order_rel X x0 b2x}.
                      { exact (SepE2 (Power X)
                                (fun I0:set => exists a2 :e X, exists b2x :e X,
                                  I0 = {x0 :e X | order_rel X a2 x0 /\ order_rel X x0 b2x})
                                b2
                                Hb2A). }
                      apply Hexab2.
                      let a2.
                      assume Ha2core: a2 :e X /\ exists b2x :e X,
                        b2 = {x0 :e X | order_rel X a2 x0 /\ order_rel X x0 b2x}.
                      apply Ha2core.
                      assume Ha2X: a2 :e X.
                      assume Hexb2x: exists b2x :e X,
                        b2 = {x0 :e X | order_rel X a2 x0 /\ order_rel X x0 b2x}.
                      apply Hexb2x.
                      let b2x.
                      assume Hb2xcore: b2x :e X /\ b2 = {x0 :e X | order_rel X a2 x0 /\ order_rel X x0 b2x}.
                      apply Hb2xcore.
                      assume Hb2xX: b2x :e X.
                      assume Hb2eq: b2 = {x0 :e X | order_rel X a2 x0 /\ order_rel X x0 b2x}.
                      exact (order_topology_interval_refine X a1 b1x a2 b2x b1 b2 x
                               Hso Ha1X Hb1xX Ha2X Hb2xX Hb1eq Hb2eq Hx1 Hx2).
                    + assume Hb2B: b2 :e Blow.
                      claim Hexb0: exists b0 :e X, b2 = {x0 :e X | order_rel X x0 b0}.
                      { exact (SepE2 (Power X)
                                (fun I0:set => exists b0 :e X, I0 = {x0 :e X | order_rel X x0 b0})
                              b2
                              Hb2B). }
                    apply Hexb0.
                    let b0.
                    assume Hb0core: b0 :e X /\ b2 = {x0 :e X | order_rel X x0 b0}.
                    apply Hb0core.
                    assume Hb0X: b0 :e X.
                    assume Hb2eq: b2 = {x0 :e X | order_rel X x0 b0}.
                    apply (order_rel_trichotomy_or_impred X b1x b0 Hso Hb1xX Hb0X
                      (exists b3 :e (order_topology_basis X), x :e b3 /\ b3 c= b1 :/\: b2)).
                    - assume Hb1xlt: order_rel X b1x b0.
                      witness b1.
                      apply andI.
                      + exact (binunionI1 Bold {X} b1 Hb1old).
                      + apply andI.
                        * exact Hx1.
                        * prove b1 c= b1 :/\: b2.
                          let y. assume Hy: y :e b1.
                          prove y :e b1 :/\: b2.
                          claim Hyin: y :e {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                          { rewrite <- Hb1eq.
                            exact Hy. }
                          claim HyX: y :e X.
                          { exact (SepE1 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyin). }
                          claim Hyrel: order_rel X a1 y /\ order_rel X y b1x.
                          { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyin). }
                          claim Hyub1: order_rel X y b1x.
                          { exact (andER (order_rel X a1 y) (order_rel X y b1x) Hyrel). }
                          claim Hyub0: order_rel X y b0.
                          { exact (order_rel_trans X y b1x b0 Hso HyX Hb1xX Hb0X Hyub1 Hb1xlt). }
                          claim Hyb2: y :e b2.
                          { rewrite Hb2eq.
                            exact (SepI X (fun x0:set => order_rel X x0 b0) y HyX Hyub0). }
                          exact (binintersectI b1 b2 y Hy Hyb2).
                    - assume Hbeq: b1x = b0.
                      witness b1.
                      apply andI.
                      + exact (binunionI1 Bold {X} b1 Hb1old).
                      + apply andI.
                        * exact Hx1.
                        * prove b1 c= b1 :/\: b2.
                          let y. assume Hy: y :e b1.
                          prove y :e b1 :/\: b2.
                          claim Hyin: y :e {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                          { rewrite <- Hb1eq.
                            exact Hy. }
                          claim HyX: y :e X.
                          { exact (SepE1 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyin). }
                          claim Hyrel: order_rel X a1 y /\ order_rel X y b1x.
                          { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyin). }
                          claim Hyub1: order_rel X y b1x.
                          { exact (andER (order_rel X a1 y) (order_rel X y b1x) Hyrel). }
                          claim Hyub0: order_rel X y b0.
                          { rewrite <- Hbeq.
                            exact Hyub1. }
                          claim Hyb2: y :e b2.
                          { rewrite Hb2eq.
                            exact (SepI X (fun x0:set => order_rel X x0 b0) y HyX Hyub0). }
                          exact (binintersectI b1 b2 y Hy Hyb2).
                    - assume Hb0lt: order_rel X b0 b1x.
                      set b3 := {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b0}.
                      witness b3.
                      apply andI.
                      + (** b3 in basis **)
                        claim Hb3Pow: b3 :e Power X.
                        { apply PowerI.
                          let y. assume Hy: y :e b3.
                          exact (SepE1 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b0) y Hy). }
                        claim Hexa: exists a :e X, exists b :e X,
                          b3 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}.
                        { witness a1.
                          apply andI.
                          - exact Ha1X.
                          - witness b0.
                            apply andI.
                            + exact Hb0X.
                            + reflexivity. }
                        claim Hb3A: b3 :e Aint.
                        { exact (SepI (Power X)
                                  (fun I0:set => exists a :e X, exists b :e X,
                                    I0 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b})
                                  b3
                                  Hb3Pow
                                  Hexa). }
                        claim Hb3tri: b3 :e (Aint :\/: Blow :\/: Cup).
                        { exact (binunionI1 (Aint :\/: Blow) Cup b3
                                 (binunionI1 Aint Blow b3 Hb3A)). }
                        claim Hb3Bold: b3 :e Bold.
                        { rewrite HBdef.
                          exact Hb3tri. }
                        exact (binunionI1 Bold {X} b3 Hb3Bold).
                      + apply andI.
                        * (** x in b3 **)
                          claim HxIn1: x :e {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                          { rewrite <- Hb1eq.
                            exact Hx1. }
                          claim HxIn2: x :e {x0 :e X | order_rel X x0 b0}.
                          { rewrite <- Hb2eq.
                            exact Hx2. }
                          claim HxX: x :e X.
                          { exact (SepE1 X (fun x0:set => order_rel X x0 b0) x HxIn2). }
                          claim Hxrel2: order_rel X x b0.
                          { exact (SepE2 X (fun x0:set => order_rel X x0 b0) x HxIn2). }
                          claim Hxrel1: order_rel X a1 x /\ order_rel X x b1x.
                          { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) x HxIn1). }
                          claim Hxa1: order_rel X a1 x.
                          { exact (andEL (order_rel X a1 x) (order_rel X x b1x) Hxrel1). }
                          exact (SepI X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b0) x HxX
                                (andI (order_rel X a1 x) (order_rel X x b0) Hxa1 Hxrel2)).
                        * (** b3 subset b1 ∩ b2 **)
                          prove b3 c= b1 :/\: b2.
                          let y. assume Hy3: y :e b3.
                          claim HyX: y :e X.
                          { exact (SepE1 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b0) y Hy3). }
                          claim Hyrel: order_rel X a1 y /\ order_rel X y b0.
                          { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b0) y Hy3). }
                          claim Hyla1: order_rel X a1 y.
                          { exact (andEL (order_rel X a1 y) (order_rel X y b0) Hyrel). }
                          claim Hyub0: order_rel X y b0.
                          { exact (andER (order_rel X a1 y) (order_rel X y b0) Hyrel). }
                          claim Hyub1x: order_rel X y b1x.
                          { exact (order_rel_trans X y b0 b1x Hso HyX Hb0X Hb1xX Hyub0 Hb0lt). }
                          claim Hyb1: y :e b1.
                          { rewrite Hb1eq.
                            exact (SepI X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y HyX
                                  (andI (order_rel X a1 y) (order_rel X y b1x) Hyla1 Hyub1x)). }
                          claim Hyb2: y :e b2.
                          { rewrite Hb2eq.
                            exact (SepI X (fun x0:set => order_rel X x0 b0) y HyX Hyub0). }
                          exact (binintersectI b1 b2 y Hyb1 Hyb2).
                - assume Hb2C: b2 :e Cup.
                  claim Hexa0: exists a0 :e X, b2 = {x0 :e X | order_rel X a0 x0}.
                  { exact (SepE2 (Power X)
                            (fun I0:set => exists a0 :e X, I0 = {x0 :e X | order_rel X a0 x0})
                            b2
                            Hb2C). }
                  apply Hexa0.
                  let a0.
                  assume Ha0core: a0 :e X /\ b2 = {x0 :e X | order_rel X a0 x0}.
                  apply Ha0core.
                  assume Ha0X: a0 :e X.
                  assume Hb2eq: b2 = {x0 :e X | order_rel X a0 x0}.
                  apply (order_rel_trichotomy_or_impred X a0 a1 Hso Ha0X Ha1X
                    (exists b3 :e (order_topology_basis X), x :e b3 /\ b3 c= b1 :/\: b2)).
                  - assume Ha0lt: order_rel X a0 a1.
                    witness b1.
                    apply andI.
                    + exact (binunionI1 Bold {X} b1 Hb1old).
                    + apply andI.
                      * exact Hx1.
                      * prove b1 c= b1 :/\: b2.
                        let y. assume Hy: y :e b1.
                        prove y :e b1 :/\: b2.
                        claim Hyin: y :e {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                        { rewrite <- Hb1eq.
                          exact Hy. }
                        claim HyX: y :e X.
                        { exact (SepE1 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyin). }
                        claim Hyrel: order_rel X a1 y /\ order_rel X y b1x.
                        { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyin). }
                        claim Hyla1: order_rel X a1 y.
                        { exact (andEL (order_rel X a1 y) (order_rel X y b1x) Hyrel). }
                        claim Hyla0: order_rel X a0 y.
                        { exact (order_rel_trans X a0 a1 y Hso Ha0X Ha1X HyX Ha0lt Hyla1). }
                        claim Hyb2: y :e b2.
                        { rewrite Hb2eq.
                          exact (SepI X (fun x0:set => order_rel X a0 x0) y HyX Hyla0). }
                        exact (binintersectI b1 b2 y Hy Hyb2).
                  - assume Haeq: a0 = a1.
                    witness b1.
                    apply andI.
                    + exact (binunionI1 Bold {X} b1 Hb1old).
                    + apply andI.
                      * exact Hx1.
                      * prove b1 c= b1 :/\: b2.
                        let y. assume Hy: y :e b1.
                        prove y :e b1 :/\: b2.
                        claim Hyin: y :e {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                        { rewrite <- Hb1eq.
                          exact Hy. }
                        claim HyX: y :e X.
                        { exact (SepE1 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyin). }
                        claim Hyrel: order_rel X a1 y /\ order_rel X y b1x.
                        { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyin). }
                        claim Hyla1: order_rel X a1 y.
                        { exact (andEL (order_rel X a1 y) (order_rel X y b1x) Hyrel). }
                        claim Hyla0: order_rel X a0 y.
                        { rewrite Haeq.
                          exact Hyla1. }
                        claim Hyb2: y :e b2.
                        { rewrite Hb2eq.
                          exact (SepI X (fun x0:set => order_rel X a0 x0) y HyX Hyla0). }
                        exact (binintersectI b1 b2 y Hy Hyb2).
                  - assume Ha1lt: order_rel X a1 a0.
                    set b3 := {x0 :e X | order_rel X a0 x0 /\ order_rel X x0 b1x}.
                    witness b3.
                    apply andI.
                    + (** b3 in basis **)
                      claim Hb3Pow: b3 :e Power X.
                      { apply PowerI.
                        let y. assume Hy: y :e b3.
                        exact (SepE1 X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b1x) y Hy). }
                      claim Hexa: exists a :e X, exists b :e X,
                        b3 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}.
                      { witness a0.
                        apply andI.
                        - exact Ha0X.
                        - witness b1x.
                          apply andI.
                          + exact Hb1xX.
                          + reflexivity. }
                      claim Hb3A: b3 :e Aint.
                      { exact (SepI (Power X)
                                (fun I0:set => exists a :e X, exists b :e X,
                                  I0 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b})
                                b3
                                Hb3Pow
                                Hexa). }
                      claim Hb3tri: b3 :e (Aint :\/: Blow :\/: Cup).
                      { exact (binunionI1 (Aint :\/: Blow) Cup b3
                               (binunionI1 Aint Blow b3 Hb3A)). }
                      claim Hb3Bold: b3 :e Bold.
                      { rewrite HBdef.
                        exact Hb3tri. }
                      exact (binunionI1 Bold {X} b3 Hb3Bold).
                    + apply andI.
                      * (** x in b3 **)
                        claim HxIn1: x :e {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                        { rewrite <- Hb1eq.
                          exact Hx1. }
                        claim HxIn2: x :e {x0 :e X | order_rel X a0 x0}.
                        { rewrite <- Hb2eq.
                          exact Hx2. }
                        claim HxX: x :e X.
                        { exact (SepE1 X (fun x0:set => order_rel X a0 x0) x HxIn2). }
                        claim Hxa0: order_rel X a0 x.
                        { exact (SepE2 X (fun x0:set => order_rel X a0 x0) x HxIn2). }
                        claim Hxrel1: order_rel X a1 x /\ order_rel X x b1x.
                        { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) x HxIn1). }
                        claim Hxb1x: order_rel X x b1x.
                        { exact (andER (order_rel X a1 x) (order_rel X x b1x) Hxrel1). }
