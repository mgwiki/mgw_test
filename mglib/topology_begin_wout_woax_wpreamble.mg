                  claim HyRR: y :e RR.
                  { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) y HySq). }
                  claim Hyconj: order_rel RR a1 y /\ order_rel RR y b2x.
