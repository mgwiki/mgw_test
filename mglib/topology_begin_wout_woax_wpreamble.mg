        + reflexivity.
        + exact H0ltq.
      - exact Hqlt1. }
    claim Hwcap: w :e U :/\: ordsq_D.
    { exact (binintersectI U ordsq_D w HwU HwD). }
    exact (elem_implies_nonempty (U :/\: ordsq_D) w Hwcap).
- assume HIup: I :e Bup.
  claim Hexa: exists a0 :e ordered_square,
      I = {z :e ordered_square | order_rel (setprod R R) a0 z}.
  { exact (SepE2 (Power ordered_square)
                 (fun J0:set => exists a0 :e ordered_square,
                   J0 = {z :e ordered_square | order_rel (setprod R R) a0 z})
                 I
                 HIup). }
  apply Hexa.
  let a0. assume Ha0pack.
  apply Ha0pack.
  assume Ha0Sq HIeq.
  claim HpI': p :e {z :e ordered_square | order_rel (setprod R R) a0 z}.
  { rewrite <- HIeq.
    exact HpI. }
  claim Ha0p: order_rel (setprod R R) a0 p.
  { exact (SepE2 ordered_square (fun z:set => order_rel (setprod R R) a0 z) p HpI'). }
  set w := (x, eps_ 1).
  claim HwSq: w :e ordered_square.
  { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval x (eps_ 1)
          HxU eps_1_in_unit_interval). }
  claim Hpw: order_rel (setprod R R) p w.
  { rewrite Hpx at 1.
    apply (order_rel_setprod_R_R_intro x 0 x (eps_ 1)).
    apply orIR.
    apply andI.
    - reflexivity.
    - exact eps_1_pos_R. }
  claim Ha0w: order_rel (setprod R R) a0 w.
  { exact (order_rel_trans (setprod R R) a0 p w
          simply_ordered_set_setprod_R_R
          ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) a0 Ha0Sq)
          ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p HpSq)
          ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq)
          Ha0p Hpw). }
  claim HwI: w :e I.
  { rewrite HIeq.
    apply (SepI ordered_square (fun z:set => order_rel (setprod R R) a0 z) w HwSq).
    exact Ha0w. }
  claim HwU: w :e U.
  { exact (HIU w HwI). }
  claim HwD: w :e ordsq_D.
  { apply (SepI ordered_square
              (fun p0:set => exists x0:set, p0 = (x0,eps_ 1) /\ Rlt 0 x0 /\ Rlt x0 1)
              w
              HwSq).
    witness x.
    prove w = (x,eps_ 1) /\ Rlt 0 x /\ Rlt x 1.
    apply andI.
    - prove w = (x,eps_ 1) /\ Rlt 0 x.
      apply andI.
      + reflexivity.
      + exact Hxpos.
    - exact Hxlt1. }
  claim Hwcap: w :e U :/\: ordsq_D.
  { exact (binintersectI U ordsq_D w HwU HwD). }
  exact (elem_implies_nonempty (U :/\: ordsq_D) w Hwcap).
Qed.

(** helper: points on the top edge x×1 with x<1 lie in cl(D) **)
(** LATEX VERSION: In the ordered square, the closure of D contains all top-edge points (x,1) with x<1. **)
Theorem ex17_18_top_edge_lt1_Sub_closure_D :
  ordsq_top_edge_lt1 c= closure_of ordered_square ordered_square_topology ordsq_D.
let p. assume HpTop: p :e ordsq_top_edge_lt1.
prove p :e closure_of ordered_square ordered_square_topology ordsq_D.
claim HpSq: p :e ordered_square.
{ exact (SepE1 ordered_square
               (fun p0:set => exists x:set, p0 = (x,1) /\ x :e unit_interval /\ Rlt x 1)
               p
               HpTop). }
claim Hexx: exists x:set, p = (x,1) /\ x :e unit_interval /\ Rlt x 1.
{ exact (SepE2 ordered_square
               (fun p0:set => exists x:set, p0 = (x,1) /\ x :e unit_interval /\ Rlt x 1)
               p
               HpTop). }
apply Hexx.
let x. assume Hxpack.
claim Hxcore: p = (x,1) /\ x :e unit_interval.
{ exact (andEL (p = (x,1) /\ x :e unit_interval) (Rlt x 1) Hxpack). }
claim Hxlt1: Rlt x 1.
{ exact (andER (p = (x,1) /\ x :e unit_interval) (Rlt x 1) Hxpack). }
claim HpEq: p = (x,1).
{ exact (andEL (p = (x,1)) (x :e unit_interval) Hxcore). }
claim HxU: x :e unit_interval.
{ exact (andER (p = (x,1)) (x :e unit_interval) Hxcore). }
claim HxR: x :e R.
{ exact (unit_interval_sub_R x HxU). }
claim HxS: SNo x.
{ exact (real_SNo x HxR). }
claim Hxnotlt0: ~(Rlt x 0).
{ exact (andEL (~(Rlt x 0)) (~(Rlt 1 x))
              (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) x HxU)). }
claim Hxle0: Rle 0 x.
{ exact (RleI 0 x real_0 HxR Hxnotlt0). }
claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_D =
  {x0 :e ordered_square | forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_D <> Empty}.
{ reflexivity. }
rewrite Hdefcl.
apply (SepI ordered_square
            (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_D <> Empty)
            p
            HpSq).
let U. assume HUtop: U :e ordered_square_topology.
