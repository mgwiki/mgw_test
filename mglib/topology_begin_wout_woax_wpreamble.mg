                       claim Hya0: order_rel X a0 y.
                       { exact (order_rel_trans X a0 a1 y Hso Ha0X Ha1X HyX Ha0a1 Hyla1). }
                       claim Hyb1: y :e b1.
                       { rewrite Hb1eq.
                         exact (SepI X (fun x0:set => order_rel X a0 x0) y HyX Hya0). }
                       exact (binintersectI b1 b2 y Hyb1 Hyb2).
                 - assume Ha01eq: a0 = a1.
                   witness b2.
                   apply andI.
                   + exact (binunionI1 Bold {X} b2 Hb2old).
                   + apply andI.
                     * exact Hx2.
                     * prove b2 c= b1 :/\: b2.
                       let y. assume Hyb2: y :e b2.
                       claim Hyb2Sep: y :e {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                       { rewrite <- Hb2eq.
                         exact Hyb2. }
                       claim HyX: y :e X.
                       { exact (SepE1 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyb2Sep). }
                       claim Hyrel: order_rel X a1 y /\ order_rel X y b1x.
                       { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y Hyb2Sep). }
                       claim Hyla1: order_rel X a1 y.
                       { exact (andEL (order_rel X a1 y) (order_rel X y b1x) Hyrel). }
                       claim Hyb1: y :e b1.
                       { rewrite Hb1eq.
                         rewrite Ha01eq.
                         exact (SepI X (fun x0:set => order_rel X a1 x0) y HyX Hyla1). }
                       exact (binintersectI b1 b2 y Hyb1 Hyb2).
                 - assume Ha1a0: order_rel X a1 a0.
                   set b3 := {x0 :e X | order_rel X a0 x0 /\ order_rel X x0 b1x}.
                   witness b3.
                   apply andI.
                   + (** b3 is a basis element **)
                     claim Hb3Pow: b3 :e Power X.
                     { apply PowerI.
                       let y. assume Hy: y :e b3.
                       exact (SepE1 X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b1x) y Hy). }
                     claim Hexab3: exists a :e X, exists b :e X,
                       b3 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}.
                     { witness a0.
                       apply andI.
                       - exact Ha0X.
                       - witness b1x.
                         apply andI.
                         + exact Hb1xX.
                         + reflexivity. }
                     claim Hb3A: b3 :e Aint.
                     { exact (SepI (Power X)
                                   (fun I0:set => exists a :e X, exists b :e X,
                                     I0 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b})
                                   b3
                                   Hb3Pow
                                   Hexab3). }
                     claim Hb3tri: b3 :e (Aint :\/: Blow :\/: Cup).
                     { exact (binunionI1 (Aint :\/: Blow) Cup b3
                              (binunionI1 Aint Blow b3 Hb3A)). }
                     claim Hb3Bold: b3 :e Bold.
                     { rewrite HBdef.
                       exact Hb3tri. }
                     exact (binunionI1 Bold {X} b3 Hb3Bold).
                   + apply andI.
                     * (** x :e b3 **)
                       claim HxB1: x :e {x0 :e X | order_rel X a0 x0}.
                       { rewrite <- Hb1eq.
                         exact Hx1. }
                       claim HxB2: x :e {x0 :e X | order_rel X a1 x0 /\ order_rel X x0 b1x}.
                       { rewrite <- Hb2eq.
                         exact Hx2. }
                       claim HxX: x :e X.
                       { exact (SepE1 X (fun x0:set => order_rel X a0 x0) x HxB1). }
                       claim Hxa0: order_rel X a0 x.
                       { exact (SepE2 X (fun x0:set => order_rel X a0 x0) x HxB1). }
                       claim Hxrel2: order_rel X a1 x /\ order_rel X x b1x.
                       { exact (SepE2 X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) x HxB2). }
                       claim Hxb1x: order_rel X x b1x.
                       { exact (andER (order_rel X a1 x) (order_rel X x b1x) Hxrel2). }
                       exact (SepI X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b1x) x HxX
                         (andI (order_rel X a0 x) (order_rel X x b1x) Hxa0 Hxb1x)).
                     * (** b3 c= b1 :/\: b2 **)
                       prove b3 c= b1 :/\: b2.
                       let y. assume Hy3: y :e b3.
                       claim HyX: y :e X.
                       { exact (SepE1 X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b1x) y Hy3). }
                       claim Hyrel: order_rel X a0 y /\ order_rel X y b1x.
                       { exact (SepE2 X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b1x) y Hy3). }
                       claim Hyla0: order_rel X a0 y.
                       { exact (andEL (order_rel X a0 y) (order_rel X y b1x) Hyrel). }
                       claim Hyub1x: order_rel X y b1x.
                       { exact (andER (order_rel X a0 y) (order_rel X y b1x) Hyrel). }
                       claim Hyla1: order_rel X a1 y.
                       { exact (order_rel_trans X a1 a0 y Hso Ha1X Ha0X HyX Ha1a0 Hyla0). }
                       claim Hyb1: y :e b1.
                       { rewrite Hb1eq.
                         exact (SepI X (fun x0:set => order_rel X a0 x0) y HyX Hyla0). }
                       claim Hyb2: y :e b2.
                       { rewrite Hb2eq.
                         exact (SepI X (fun x0:set => order_rel X a1 x0 /\ order_rel X x0 b1x) y HyX
                           (andI (order_rel X a1 y) (order_rel X y b1x) Hyla1 Hyub1x)). }
                       exact (binintersectI b1 b2 y Hyb1 Hyb2).
            - assume Hb2B: b2 :e Blow.
               (** b1 is an upper ray and b2 is a lower ray; their intersection is an open interval **)
               claim Hexa0: exists a0 :e X, b1 = {x0 :e X | order_rel X a0 x0}.
               { exact (SepE2 (Power X)
                             (fun I0:set => exists a0 :e X, I0 = {x0 :e X | order_rel X a0 x0})
                             b1
                             Hb1C). }
               claim Hexb0: exists b0 :e X, b2 = {x0 :e X | order_rel X x0 b0}.
               { exact (SepE2 (Power X)
                             (fun I0:set => exists b0 :e X, I0 = {x0 :e X | order_rel X x0 b0})
                             b2
                             Hb2B). }
               apply Hexa0.
               let a0.
               assume Ha0core: a0 :e X /\ b1 = {x0 :e X | order_rel X a0 x0}.
               apply Ha0core.
               assume Ha0X: a0 :e X.
               assume Hb1eq: b1 = {x0 :e X | order_rel X a0 x0}.
               apply Hexb0.
               let b0.
               assume Hb0core: b0 :e X /\ b2 = {x0 :e X | order_rel X x0 b0}.
               apply Hb0core.
               assume Hb0X: b0 :e X.
               assume Hb2eq: b2 = {x0 :e X | order_rel X x0 b0}.
               set b3 := {x0 :e X | order_rel X a0 x0 /\ order_rel X x0 b0}.
               witness b3.
               apply andI.
               + (** b3 is a basis element **)
                  claim Hb3Pow: b3 :e Power X.
                  { apply PowerI.
                    let y. assume Hy: y :e b3.
                    exact (SepE1 X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b0) y Hy). }
                  claim Hexab: exists a :e X, exists b :e X,
                    b3 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}.
                  { witness a0.
                    apply andI.
                    - exact Ha0X.
                    - witness b0.
                      apply andI.
                      + exact Hb0X.
                      + reflexivity. }
                  claim Hb3A: b3 :e Aint.
                  { exact (SepI (Power X)
                                (fun I0:set => exists a :e X, exists b :e X,
                                  I0 = {x0 :e X | order_rel X a x0 /\ order_rel X x0 b})
                                b3
                                Hb3Pow
                                Hexab). }
                  claim Hb3tri: b3 :e (Aint :\/: Blow :\/: Cup).
                  { exact (binunionI1 (Aint :\/: Blow) Cup b3
                           (binunionI1 Aint Blow b3 Hb3A)). }
                  claim Hb3Bold: b3 :e Bold.
                  { rewrite HBdef.
                    exact Hb3tri. }
                  exact (binunionI1 Bold {X} b3 Hb3Bold).
               + apply andI.
                  - (** x :e b3 **)
                     claim HxB1: x :e {x0 :e X | order_rel X a0 x0}.
                     { rewrite <- Hb1eq.
                       exact Hx1. }
                     claim HxB2: x :e {x0 :e X | order_rel X x0 b0}.
                     { rewrite <- Hb2eq.
                       exact Hx2. }
                     claim Hrela0x: order_rel X a0 x.
                     { exact (SepE2 X (fun x0:set => order_rel X a0 x0) x HxB1). }
                     claim Hrelxb0: order_rel X x b0.
                     { exact (SepE2 X (fun x0:set => order_rel X x0 b0) x HxB2). }
                     claim HxX: x :e X.
                     { exact (SepE1 X (fun x0:set => order_rel X a0 x0) x HxB1). }
                     exact (SepI X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b0) x HxX
                           (andI (order_rel X a0 x) (order_rel X x b0) Hrela0x Hrelxb0)).
                  - (** b3 c= b1 :/\: b2 **)
                     prove b3 c= b1 :/\: b2.
                     let y. assume Hy3: y :e b3.
                     claim HyX: y :e X.
                     { exact (SepE1 X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b0) y Hy3). }
                     claim Hyrel: order_rel X a0 y /\ order_rel X y b0.
                     { exact (SepE2 X (fun x0:set => order_rel X a0 x0 /\ order_rel X x0 b0) y Hy3). }
                     claim Hyrela: order_rel X a0 y.
                     { exact (andEL (order_rel X a0 y) (order_rel X y b0) Hyrel). }
                     claim Hyrelb: order_rel X y b0.
                     { exact (andER (order_rel X a0 y) (order_rel X y b0) Hyrel). }
                     claim Hyb1: y :e b1.
                     { rewrite Hb1eq.
                       exact (SepI X (fun x0:set => order_rel X a0 x0) y HyX Hyrela). }
                     claim Hyb2: y :e b2.
                     { rewrite Hb2eq.
                       exact (SepI X (fun x0:set => order_rel X x0 b0) y HyX Hyrelb). }
                       exact (binintersectI b1 b2 y Hyb1 Hyb2).
            * assume Hb2C: b2 :e Cup.
              claim Hexa0: exists a0 :e X, b1 = {x0 :e X | order_rel X a0 x0}.
              { exact (SepE2 (Power X)
                            (fun I0:set => exists a0 :e X, I0 = {x0 :e X | order_rel X a0 x0})
                            b1
                            Hb1C). }
              claim Hexc0: exists c0 :e X, b2 = {x0 :e X | order_rel X c0 x0}.
              { exact (SepE2 (Power X)
                            (fun I0:set => exists c0 :e X, I0 = {x0 :e X | order_rel X c0 x0})
                            b2
                            Hb2C). }
              apply Hexa0.
              let a0.
              assume Ha0core: a0 :e X /\ b1 = {x0 :e X | order_rel X a0 x0}.
              apply Ha0core.
              assume Ha0X: a0 :e X.
              assume Hb1eq: b1 = {x0 :e X | order_rel X a0 x0}.
              apply Hexc0.
              let c0.
              assume Hc0core: c0 :e X /\ b2 = {x0 :e X | order_rel X c0 x0}.
              apply Hc0core.
              assume Hc0X: c0 :e X.
              assume Hb2eq: b2 = {x0 :e X | order_rel X c0 x0}.
              apply (order_rel_trichotomy_or_impred X a0 c0 Hso Ha0X Hc0X
                (exists b3 :e (order_topology_basis X), x :e b3 /\ b3 c= b1 :/\: b2)).
              - assume Hac: order_rel X a0 c0.
                witness b2.
                apply andI.
                + (** b2 is a basis element **)
                  claim Hb2tri: b2 :e (Aint :\/: Blow :\/: Cup).
                  { exact (binunionI2 (Aint :\/: Blow) Cup b2 Hb2C). }
                  claim Hb2Bold: b2 :e Bold.
                  { rewrite HBdef.
                    exact Hb2tri. }
                  exact (binunionI1 Bold {X} b2 Hb2Bold).
                + apply andI.
                  * exact Hx2.
                  * (** b2 c= b1 :/\: b2 **)
                    prove b2 c= b1 :/\: b2.
                    let y.
                    assume Hyb2: y :e b2.
                    claim Hyb2Sep: y :e {x0 :e X | order_rel X c0 x0}.
                    { rewrite <- Hb2eq.
                      exact Hyb2. }
                    claim Hyc0: order_rel X c0 y.
                    { exact (SepE2 X (fun x0:set => order_rel X c0 x0) y Hyb2Sep). }
                    claim HyX: y :e X.
                    { exact (SepE1 X (fun x0:set => order_rel X c0 x0) y Hyb2Sep). }
                    claim Hya0: order_rel X a0 y.
                    { exact (order_rel_trans X a0 c0 y Hso Ha0X Hc0X HyX Hac Hyc0). }
                    claim Hyb1: y :e b1.
                    { rewrite Hb1eq.
                      exact (SepI X (fun x0:set => order_rel X a0 x0) y HyX Hya0). }
                    exact (binintersectI b1 b2 y Hyb1 Hyb2).
              - assume H_eq: a0 = c0.
                witness b1.
                apply andI.
                + exact (binunionI1 Bold {X} b1 Hb1old).
                + apply andI.
                  * exact Hx1.
                  * prove b1 c= b1 :/\: b2.
                    let y.
                    assume Hyb1: y :e b1.
                    claim HyX: y :e X.
                    { claim Hyb1Sep: y :e {x0 :e X | order_rel X a0 x0}.
                      { rewrite <- Hb1eq.
                        exact Hyb1. }
                      exact (SepE1 X (fun x0:set => order_rel X a0 x0) y Hyb1Sep). }
                    claim Hya0: order_rel X a0 y.
                    { claim Hyb1Sep: y :e {x0 :e X | order_rel X a0 x0}.
                      { rewrite <- Hb1eq.
                        exact Hyb1. }
                      exact (SepE2 X (fun x0:set => order_rel X a0 x0) y Hyb1Sep). }
                    claim Hyc0: order_rel X c0 y.
                    { rewrite <- H_eq.
                      exact Hya0. }
                    claim Hyb2: y :e b2.
                    { rewrite Hb2eq.
                      exact (SepI X (fun x0:set => order_rel X c0 x0) y HyX Hyc0). }
                    exact (binintersectI b1 b2 y Hyb1 Hyb2).
              - assume Hca: order_rel X c0 a0.
                witness b1.
                apply andI.
                + exact (binunionI1 Bold {X} b1 Hb1old).
                + apply andI.
                  * exact Hx1.
                  * (** b1 c= b1 :/\: b2 **)
                    prove b1 c= b1 :/\: b2.
                    let y.
                    assume Hyb1: y :e b1.
                    claim Hya0: order_rel X a0 y.
                    { claim Hyb1Sep: y :e {x0 :e X | order_rel X a0 x0}.
                      { rewrite <- Hb1eq.
                        exact Hyb1. }
                      exact (SepE2 X (fun x0:set => order_rel X a0 x0) y Hyb1Sep). }
                    claim HyX: y :e X.
                    { claim Hyb1Sep: y :e {x0 :e X | order_rel X a0 x0}.
                      { rewrite <- Hb1eq.
                        exact Hyb1. }
                      exact (SepE1 X (fun x0:set => order_rel X a0 x0) y Hyb1Sep). }
                    claim Hyc0: order_rel X c0 y.
                    { exact (order_rel_trans X c0 a0 y Hso Hc0X Ha0X HyX Hca Hya0). }
                    claim Hyb2: y :e b2.
                    { rewrite Hb2eq.
                      exact (SepI X (fun x0:set => order_rel X c0 x0) y HyX Hyc0). }
                    exact (binintersectI b1 b2 y Hyb1 Hyb2).
    + assume Hb2X: b2 :e {X}.
      claim Hb2eq: b2 = X.
      { exact (SingE X b2 Hb2X). }
      rewrite Hb2eq.
      witness b1.
      apply andI.
      * exact (binunionI1 Bold {X} b1 Hb1old).
      * apply andI.
        - exact Hx1.
        - prove b1 c= b1 :/\: X.
           claim Hb1Pow: b1 :e Power X.
           { exact (HsubPow b1 (binunionI1 Bold {X} b1 Hb1old)). }
           claim Hb1sub: b1 c= X.
           { exact (PowerE X b1 Hb1Pow). }
           let y. assume Hy: y :e b1.
           exact (binintersectI b1 X y Hy (Hb1sub y Hy)).
  - assume Hb1X: b1 :e {X}.
    claim Hb1eq: b1 = X.
    { exact (SingE X b1 Hb1X). }
    rewrite Hb1eq.
    witness b2.
    apply andI.
    + exact Hb2.
    + apply andI.
      * exact Hx2.
      * prove b2 c= X :/\: b2.
        claim Hb2Pow: b2 :e Power X.
        { exact (HsubPow b2 Hb2). }
        claim Hb2sub: b2 c= X.
        { exact (PowerE X b2 Hb2Pow). }
        let y. assume Hy: y :e b2.
        exact (binintersectI X b2 y (Hb2sub y Hy) Hy). }
exact (andI (A /\ Bcov) Bref Hab Href).
Qed.

(** from §14: order topology is a topology **) 
(** LATEX VERSION: The order topology satisfies the topology axioms. **)
Theorem order_topology_is_topology : forall X:set,
  simply_ordered_set X ->
  topology_on X (order_topology X).
let X.
assume Hso: simply_ordered_set X.
prove topology_on X (order_topology X).
(** order_topology X = generated_topology X (order_topology_basis X) **)
(** Apply axiom that order_topology_basis X is a basis, then use lemma_topology_from_basis **)
exact (lemma_topology_from_basis X (order_topology_basis X) (order_topology_basis_is_basis X Hso)).
Qed.

(** from §16: open rays as building blocks in the order topology **) 
(** LATEX VERSION: The sets (a,∞) and (-∞,a) are open rays used to build the order topology; they form part of a subbasis. **)
(** REVIEWED: This is an “upper ray” relative to `order_rel X`; it is always a subset of X by construction. **)
Definition open_ray_upper : set -> set -> set := fun X a => {x :e X | order_rel X a x}.

(** from §16: open rays as building blocks in the order topology **) 
(** LATEX VERSION: The sets (a,∞) and (-∞,a) are open rays used to build the order topology; they form part of a subbasis. **)
(** REVIEWED: This is a “lower ray” relative to `order_rel X`; it is always a subset of X by construction. **)
Definition open_ray_lower : set -> set -> set := fun X a => {x :e X | order_rel X x a}.

(** from §16: open rays form a subbasis for the order topology **) 
(** LATEX VERSION: The order topology is generated by the subbasis of all open rays, together with X itself. **)
(** REVIEWED: This is a subbasis family packaged as a subset of `Power X`, plus {X}; later theorems use `open_rays_subbasis_is_subbasis`. **)
Definition open_rays_subbasis : set -> set := fun X =>
  (({I :e Power X | exists a :e X, I = open_ray_upper X a}
    :\/:
    {I :e Power X | exists b :e X, I = open_ray_lower X b})
   :\/:
   {X}).

(** Helper: open rays subbasis is a subset of Power X **)
(** LATEX VERSION: Every open ray subset of X is a subset of X, hence lies in Power X. **)
Theorem open_rays_subbasis_sub_Power : forall X:set,
  open_rays_subbasis X c= Power X.
let X.
prove open_rays_subbasis X c= Power X.
let I. assume HI: I :e open_rays_subbasis X.
prove I :e Power X.
apply (binunionE' ({I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}
                   :\/:
                   {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b})
                  {X}
                  I
                  (I :e Power X)).
- assume HI0: I :e ({I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}
                    :\/:
                    {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b}).
  apply (binunionE' {I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}
                    {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b}
                    I
                    (I :e Power X)).
  + assume HI1: I :e {I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}.
    exact (SepE1 (Power X) (fun I0 : set => exists a :e X, I0 = open_ray_upper X a) I HI1).
  + assume HI2: I :e {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b}.
    exact (SepE1 (Power X) (fun I0 : set => exists b :e X, I0 = open_ray_lower X b) I HI2).
  + exact HI0.
- assume HIX: I :e {X}.
  claim HIEq: I = X.
  { exact (SingE X I HIX). }
  rewrite HIEq.
  exact (Self_In_Power X).
- exact HI.
Qed.

(** Helper: open rays subbasis covers X and lies in Power X **)
(** LATEX VERSION: The open rays subbasis covers X and consists of subsets of X, so it is a subbasis on X. **)
Theorem open_rays_subbasis_is_subbasis : forall X:set,
  subbasis_on X (open_rays_subbasis X).
let X.
prove subbasis_on X (open_rays_subbasis X).
prove (open_rays_subbasis X c= Power X) /\ Union (open_rays_subbasis X) = X.
apply andI.
- exact (open_rays_subbasis_sub_Power X).
- apply set_ext.
  + let x. assume HxU: x :e Union (open_rays_subbasis X).
    prove x :e X.
    apply (UnionE_impred (open_rays_subbasis X) x HxU).
    let U.
    assume HxUin: x :e U.
    assume HU: U :e open_rays_subbasis X.
    claim HUpow: U :e Power X.
    { exact (open_rays_subbasis_sub_Power X U HU). }
    claim HUsub: U c= X.
    { exact (PowerE X U HUpow). }
    exact (HUsub x HxUin).
  + let x. assume HxX: x :e X.
    prove x :e Union (open_rays_subbasis X).
    claim HXInS: X :e open_rays_subbasis X.
    { exact (binunionI2 ({I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}
                         :\/:
                         {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b})
                        {X}
                        X
                        (SingI X)). }
    exact (UnionI (open_rays_subbasis X) x X HxX HXInS).
Qed.

(** Helper: an upper ray is a basis element for the order topology **)
(** LATEX VERSION: Each upper open ray (a, infty) is an element of the order-topology basis. **)
Theorem open_ray_upper_in_order_topology_basis : forall X a:set,
  a :e X -> open_ray_upper X a :e order_topology_basis X.
let X a. assume HaX.
prove open_ray_upper X a :e order_topology_basis X.
set U := open_ray_upper X a.
set Bold := ({I :e Power X | exists a0 :e X, exists b0 :e X,
                I = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
             :\/:
             {I :e Power X | exists b0 :e X, I = {x :e X | order_rel X x b0}}
             :\/:
             {I :e Power X | exists a0 :e X, I = {x :e X | order_rel X a0 x}}).
claim HUpow: U :e Power X.
{ apply PowerI.
  let x. assume HxU: x :e U.
  exact (SepE1 X (fun x0 : set => order_rel X a x0) x HxU). }
claim HUex: exists a0 :e X, U = {x :e X | order_rel X a0 x}.
{ witness a.
  prove a :e X /\ U = {x :e X | order_rel X a x}.
  apply andI.
  - exact HaX.
  - reflexivity.
}
claim HUfam: U :e {I :e Power X | exists a0 :e X, I = {x :e X | order_rel X a0 x}}.
{ exact (SepI (Power X)
              (fun I0 : set => exists a0 :e X, I0 = {x :e X | order_rel X a0 x})
              U
              HUpow
              HUex). }
claim HUold: U :e Bold.
{ exact (binunionI2 ({I :e Power X | exists a0 :e X, exists b0 :e X,
                        I = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
                     :\/:
                     {I :e Power X | exists b0 :e X, I = {x :e X | order_rel X x b0}})
                    {I :e Power X | exists a0 :e X, I = {x :e X | order_rel X a0 x}}
                    U
                    HUfam). }
exact (binunionI1 Bold {X} U HUold).
Qed.

(** Helper: a lower ray is a basis element for the order topology **)
(** LATEX VERSION: Each lower open ray (-infty, b) is an element of the order-topology basis. **)
Theorem open_ray_lower_in_order_topology_basis : forall X b:set,
  b :e X -> open_ray_lower X b :e order_topology_basis X.
let X b. assume HbX.
prove open_ray_lower X b :e order_topology_basis X.
set U := open_ray_lower X b.
set Bold := ({I :e Power X | exists a0 :e X, exists b0 :e X,
                I = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
             :\/:
             {I :e Power X | exists b0 :e X, I = {x :e X | order_rel X x b0}}
             :\/:
             {I :e Power X | exists a0 :e X, I = {x :e X | order_rel X a0 x}}).
claim HUpow: U :e Power X.
{ apply PowerI.
  let x. assume HxU: x :e U.
  exact (SepE1 X (fun x0 : set => order_rel X x0 b) x HxU). }
claim HUex: exists b0 :e X, U = {x :e X | order_rel X x b0}.
{ witness b.
  prove b :e X /\ U = {x :e X | order_rel X x b}.
  apply andI.
  - exact HbX.
  - reflexivity.
}
claim HUfam: U :e {I :e Power X | exists b0 :e X, I = {x :e X | order_rel X x b0}}.
{ exact (SepI (Power X)
              (fun I0 : set => exists b0 :e X, I0 = {x :e X | order_rel X x b0})
              U
              HUpow
              HUex). }
claim HUold: U :e Bold.
{ exact (binunionI1 ({I :e Power X | exists a0 :e X, exists b0 :e X,
                        I = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
                     :\/:
                     {I :e Power X | exists b0 :e X, I = {x :e X | order_rel X x b0}})
                    {I :e Power X | exists a0 :e X, I = {x :e X | order_rel X a0 x}}
                    U
                    (binunionI2 {I :e Power X | exists a0 :e X, exists b0 :e X,
                                  I = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
                                {I :e Power X | exists b0 :e X, I = {x :e X | order_rel X x b0}}
                                U
                                HUfam)). }
exact (binunionI1 Bold {X} U HUold).
Qed.

(** helper: order_topology_basis covers ω via successor lower rays **)
(** LATEX VERSION: For ω, every point lies in some basic open ray of the order topology. **)
Theorem order_topology_basis_covers_omega : forall x:set,
  x :e omega -> exists b :e (order_topology_basis omega), x :e b.
let x.
assume Hx: x :e omega.
set b := open_ray_lower omega (ordsucc x).
witness b.
apply andI.
- (** b is a basis element **)
  claim Hb: ordsucc x :e omega.
  { exact (omega_ordsucc x Hx). }
  exact (open_ray_lower_in_order_topology_basis omega (ordsucc x) Hb).
- (** x is in the lower ray below ordsucc x **)
  claim Hdef: open_ray_lower omega (ordsucc x) = {y :e omega | order_rel omega y (ordsucc x)}.
  { reflexivity. }
  rewrite Hdef.
  apply (SepI omega (fun y:set => order_rel omega y (ordsucc x)) x Hx).
  claim Hmem: x :e ordsucc x.
  { exact (ordsuccI2 x). }
  exact (mem_implies_order_rel_omega x (ordsucc x) Hmem).
Qed.

(** helper: the lower ray below 1 in ω is exactly {0} **)
(** LATEX VERSION: In ω, the initial segment below 1 is the singleton {0}. **)
Theorem open_ray_lower_omega_1_eq_Sing0 :
  open_ray_lower omega 1 = {0}.
prove open_ray_lower omega 1 = {0}.
apply set_ext.
- let y. assume Hy: y :e open_ray_lower omega 1.
  prove y :e {0}.
  claim Hyrel: order_rel omega y 1.
  { exact (SepE2 omega (fun y0:set => order_rel omega y0 1) y Hy). }
  claim Hymem: y :e 1.
  { exact (order_rel_omega_implies_mem y 1 Hyrel). }
  apply (ordsuccE 0 y Hymem).
  + assume Hy0: y :e 0.
    apply FalseE.
    exact (EmptyE y Hy0).
  + assume Heq: y = 0.
    rewrite Heq.
    exact (SingI 0).
- let y. assume Hy: y :e {0}.
  prove y :e open_ray_lower omega 1.
  claim Heq: y = 0.
  { exact (SingE 0 y Hy). }
  rewrite Heq.
  claim H0omega: 0 :e omega.
  { exact (nat_p_omega 0 nat_0). }
  claim Hdef: open_ray_lower omega 1 = {y0 :e omega | order_rel omega y0 1}.
  { reflexivity. }
  rewrite Hdef.
  apply (SepI omega (fun y0:set => order_rel omega y0 1) 0 H0omega).
  exact (mem_implies_order_rel_omega 0 1 In_0_1).
Qed.

(** helper: every singleton {x} with x∈ω is a basis element of the ω order topology basis **)
(** LATEX VERSION: In the order topology on ω, each point is isolated: {x} is a basic open set. **)
Theorem singleton_in_order_topology_basis_omega : forall x:set,
  x :e omega -> {x} :e order_topology_basis omega.
let x.
assume Hxomega: x :e omega.
claim Hxnat: nat_p x.
{ exact (omega_nat_p x Hxomega). }
claim Hinv: x = 0 \/ exists m:set, nat_p m /\ x = ordsucc m.
{ exact (nat_inv x Hxnat). }
apply Hinv.
- assume Hx0: x = 0.
  rewrite Hx0.
  rewrite <- open_ray_lower_omega_1_eq_Sing0.
  claim H1omega: 1 :e omega.
  { exact (nat_p_omega 1 nat_1). }
  exact (open_ray_lower_in_order_topology_basis omega 1 H1omega).
- assume Hex: exists m:set, nat_p m /\ x = ordsucc m.
  apply Hex.
  let m.
  assume Hmcore: nat_p m /\ x = ordsucc m.
  claim Hmnat: nat_p m.
  { exact (andEL (nat_p m) (x = ordsucc m) Hmcore). }
  claim Hxeq: x = ordsucc m.
  { exact (andER (nat_p m) (x = ordsucc m) Hmcore). }
  claim Hx1omega: ordsucc m :e omega.
  { rewrite <- Hxeq. exact Hxomega. }
  rewrite Hxeq.
  set x1 := ordsucc m.
  set b := ordsucc x1.
  claim Hmomega: m :e omega.
  { exact (nat_p_omega m Hmnat). }
  claim Hbomega: b :e omega.
  { exact (omega_ordsucc x1 Hx1omega). }
  set I := {y :e omega | order_rel omega m y /\ order_rel omega y b}.
  claim HIeq: I = {x1}.
  { apply set_ext.
    - let y. assume HyI: y :e I.
      prove y :e {x1}.
      claim Hycore: order_rel omega m y /\ order_rel omega y b.
      { exact (SepE2 omega (fun y0:set => order_rel omega m y0 /\ order_rel omega y0 b) y HyI). }
      claim Hmy: order_rel omega m y.
      { exact (andEL (order_rel omega m y) (order_rel omega y b) Hycore). }
      claim Hyb: order_rel omega y b.
      { exact (andER (order_rel omega m y) (order_rel omega y b) Hycore). }
      claim Hm_in_y: m :e y.
      { exact (order_rel_omega_implies_mem m y Hmy). }
      claim Hy_in_b: y :e b.
      { exact (order_rel_omega_implies_mem y b Hyb). }
      apply (ordsuccE x1 y Hy_in_b).
      + assume Hyin: y :e x1.
        apply (ordsuccE m y Hyin).
        * assume Hyinm: y :e m.
          apply FalseE.
          exact (In_no2cycle m y Hm_in_y Hyinm).
          * assume Heq0: y = m.
            apply FalseE.
            claim Hmm: m :e m.
              { rewrite <- Heq0 at 2.
                exact Hm_in_y. }
            exact ((In_irref m) Hmm).
      + assume Heq1: y = x1.
        rewrite Heq1.
        exact (SingI x1).
    - let y. assume HyS: y :e {x1}.
      prove y :e I.
      claim Heq: y = x1.
      { exact (SingE x1 y HyS). }
      rewrite Heq.
      apply (SepI omega (fun y0:set => order_rel omega m y0 /\ order_rel omega y0 b) x1 Hx1omega).
      apply andI.
      + claim Hmemb: m :e x1.
        { exact (ordsuccI2 m). }
        exact (mem_implies_order_rel_omega m x1 Hmemb).
      + claim Hx1b: x1 :e b.
        { exact (ordsuccI2 x1). }
        exact (mem_implies_order_rel_omega x1 b Hx1b). }
  claim HIpow: I :e Power omega.
  { apply PowerI.
    let y. assume HyI: y :e I.
    exact (SepE1 omega (fun y0:set => order_rel omega m y0 /\ order_rel omega y0 b) y HyI). }
  claim Hexab: exists a :e omega, exists b0 :e omega, I = {y :e omega | order_rel omega a y /\ order_rel omega y b0}.
  { witness m.
    apply andI.
    - exact Hmomega.
    - witness b.
      apply andI.
      + exact Hbomega.
      + reflexivity. }
  claim HIinFam: I :e {I0 :e Power omega | exists a :e omega, exists b0 :e omega,
        I0 = {y :e omega | order_rel omega a y /\ order_rel omega y b0}}.
  { exact (SepI (Power omega)
            (fun I0:set => exists a :e omega, exists b0 :e omega,
              I0 = {y :e omega | order_rel omega a y /\ order_rel omega y b0})
            I
            HIpow
            Hexab). }
  rewrite <- HIeq.
  set Bold := (({I0 :e Power omega | exists a0 :e omega, exists b0 :e omega,
                   I0 = {y :e omega | order_rel omega a0 y /\ order_rel omega y b0}}
                :\/:
                {I0 :e Power omega | exists b0 :e omega, I0 = {y :e omega | order_rel omega y b0}})
               :\/:
               {I0 :e Power omega | exists a0 :e omega, I0 = {y :e omega | order_rel omega a0 y}}).
  exact (binunionI1 Bold {omega} I
    (binunionI1
      ({I0 :e Power omega | exists a0 :e omega, exists b0 :e omega,
            I0 = {y :e omega | order_rel omega a0 y /\ order_rel omega y b0}}
       :\/:
       {I0 :e Power omega | exists b0 :e omega, I0 = {y :e omega | order_rel omega y b0}})
      {I0 :e Power omega | exists a0 :e omega, I0 = {y :e omega | order_rel omega a0 y}}
      I
      (binunionI1
        {I0 :e Power omega | exists a0 :e omega, exists b0 :e omega,
              I0 = {y :e omega | order_rel omega a0 y /\ order_rel omega y b0}}
        {I0 :e Power omega | exists b0 :e omega, I0 = {y :e omega | order_rel omega y b0}}
        I
        HIinFam))).
Qed.

(** helper: the order-topology basis on ω satisfies the basis axioms **)
(** LATEX VERSION: For ω with the usual order, the order-topology basis is a basis. **)
Theorem order_topology_basis_omega_is_basis :
  basis_on omega (order_topology_basis omega).
prove basis_on omega (order_topology_basis omega).
prove ((order_topology_basis omega c= Power omega)
  /\ (forall x :e omega, exists b :e (order_topology_basis omega), x :e b))
  /\ (forall b1 :e (order_topology_basis omega),
        forall b2 :e (order_topology_basis omega),
        forall x:set,
          x :e b1 -> x :e b2 ->
          exists b3 :e (order_topology_basis omega), x :e b3 /\ b3 c= b1 :/\: b2).
apply andI.
- prove (order_topology_basis omega c= Power omega) /\
    (forall x :e omega, exists b :e (order_topology_basis omega), x :e b).
  apply andI.
  + prove order_topology_basis omega c= Power omega.
    let I. assume HI: I :e order_topology_basis omega.
    prove I :e Power omega.
    set A := {I0 :e Power omega | exists a :e omega, exists b0 :e omega,
              I0 = {y :e omega | order_rel omega a y /\ order_rel omega y b0}}.
    set B := {I0 :e Power omega | exists b0 :e omega, I0 = {y :e omega | order_rel omega y b0}}.
    set C := {I0 :e Power omega | exists a :e omega, I0 = {y :e omega | order_rel omega a y}}.
    set Bold := (A :\/: B :\/: C).
    apply (binunionE Bold {omega} I HI).
    * assume HI': I :e Bold.
      apply (binunionE (A :\/: B) C I HI').
      - assume HIAB: I :e (A :\/: B).
        apply (binunionE A B I HIAB).
        + assume HIA: I :e A.
          exact (SepE1 (Power omega)
            (fun I0:set => exists a :e omega, exists b0 :e omega,
              I0 = {y :e omega | order_rel omega a y /\ order_rel omega y b0})
            I HIA).
        + assume HIB: I :e B.
          exact (SepE1 (Power omega)
            (fun I0:set => exists b0 :e omega, I0 = {y :e omega | order_rel omega y b0})
            I HIB).
      - assume HIC: I :e C.
        exact (SepE1 (Power omega)
          (fun I0:set => exists a :e omega, I0 = {y :e omega | order_rel omega a y})
          I HIC).
    * assume HIomega: I :e {omega}.
      claim HeqI: I = omega.
      { exact (SingE omega I HIomega). }
      rewrite HeqI.
      exact (Self_In_Power omega).
  + let x. assume Hx: x :e omega.
    witness {x}.
    apply andI.
    - exact (singleton_in_order_topology_basis_omega x Hx).
    - exact (SingI x).
- let b1. assume Hb1: b1 :e order_topology_basis omega.
  let b2. assume Hb2: b2 :e order_topology_basis omega.
  let x. assume Hx1: x :e b1.
  assume Hx2: x :e b2.
  prove exists b3 :e order_topology_basis omega, x :e b3 /\ b3 c= b1 :/\: b2.
  claim Hb1pow: b1 :e Power omega.
  { set A := {I0 :e Power omega | exists a :e omega, exists b0 :e omega,
                I0 = {y :e omega | order_rel omega a y /\ order_rel omega y b0}}.
    set B := {I0 :e Power omega | exists b0 :e omega, I0 = {y :e omega | order_rel omega y b0}}.
    set C := {I0 :e Power omega | exists a :e omega, I0 = {y :e omega | order_rel omega a y}}.
    set Bold := (A :\/: B :\/: C).
    apply (binunionE Bold {omega} b1 Hb1).
    - assume Hb1U: b1 :e Bold.
      apply (binunionE (A :\/: B) C b1 Hb1U).
      + assume Hb1AB: b1 :e (A :\/: B).
        apply (binunionE A B b1 Hb1AB).
        * assume Hb1A: b1 :e A.
          exact (SepE1 (Power omega)
            (fun I0:set => exists a :e omega, exists b0 :e omega,
              I0 = {y :e omega | order_rel omega a y /\ order_rel omega y b0})
            b1 Hb1A).
        * assume Hb1B: b1 :e B.
          exact (SepE1 (Power omega)
            (fun I0:set => exists b0 :e omega, I0 = {y :e omega | order_rel omega y b0})
            b1 Hb1B).
      + assume Hb1C: b1 :e C.
        exact (SepE1 (Power omega)
          (fun I0:set => exists a :e omega, I0 = {y :e omega | order_rel omega a y})
          b1 Hb1C).
    - assume Hb1omega: b1 :e {omega}.
      claim Hb1eq: b1 = omega.
      { exact (SingE omega b1 Hb1omega). }
      rewrite Hb1eq.
      exact (Self_In_Power omega). }
  claim Hb1sub: b1 c= omega.
  { exact (PowerE omega b1 Hb1pow). }
  claim Hxomega: x :e omega.
  { exact (Hb1sub x Hx1). }
  witness {x}.
  apply andI.
  + exact (singleton_in_order_topology_basis_omega x Hxomega).
  + apply andI.
    * exact (SingI x).
    * prove {x} c= b1 :/\: b2.
      let y. assume Hy: y :e {x}.
      claim Heq: y = x.
      { exact (SingE x y Hy). }
      rewrite Heq.
      exact (binintersectI b1 b2 x Hx1 Hx2).
Qed.

(** helper: the order topology on ω is a topology **)
(** LATEX VERSION: The order topology generated by the order basis is a topology. **)
Theorem order_topology_omega_is_topology :
  topology_on omega (order_topology omega).
prove topology_on omega (order_topology omega).
exact (lemma_topology_from_basis omega (order_topology_basis omega) order_topology_basis_omega_is_basis).
Qed.

(** Helper: open rays subbasis elements are open in the order topology **)
(** LATEX VERSION: Every open ray belongs to the order topology, so the open-rays subbasis is contained in it. **)
Theorem open_rays_subbasis_sub_order_topology : forall X:set,
  simply_ordered_set X ->
  open_rays_subbasis X c= order_topology X.
let X.
assume Hso: simply_ordered_set X.
prove open_rays_subbasis X c= order_topology X.
let U. assume HU: U :e open_rays_subbasis X.
prove U :e order_topology X.
apply (binunionE' ({I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}
                   :\/:
                   {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b})
                  {X}
                  U
                  (U :e order_topology X)).
- assume HU0: U :e ({I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}
                    :\/:
                    {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b}).
  apply (binunionE' {I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}
                    {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b}
                    U
                    (U :e order_topology X)).
  + assume HU1: U :e {I0 :e Power X | exists a :e X, I0 = open_ray_upper X a}.
    claim Hex: exists a :e X, U = open_ray_upper X a.
    { exact (SepE2 (Power X) (fun I0 : set => exists a :e X, I0 = open_ray_upper X a) U HU1). }
    apply Hex.
    let a.
    assume Hcore: a :e X /\ U = open_ray_upper X a.
    apply Hcore.
    assume HaX: a :e X.
    assume HUeq: U = open_ray_upper X a.
    rewrite HUeq.
    claim HUinB: open_ray_upper X a :e order_topology_basis X.
    { exact (open_ray_upper_in_order_topology_basis X a HaX). }
    claim HUpow: open_ray_upper X a :e Power X.
    { apply PowerI.
      let x. assume HxU: x :e open_ray_upper X a.
      exact (SepE1 X (fun x0 : set => order_rel X a x0) x HxU). }
    exact (generated_topology_contains_elem X (order_topology_basis X) (open_ray_upper X a) HUpow HUinB).
  + assume HU2: U :e {I0 :e Power X | exists b :e X, I0 = open_ray_lower X b}.
    claim Hex: exists b :e X, U = open_ray_lower X b.
    { exact (SepE2 (Power X) (fun I0 : set => exists b :e X, I0 = open_ray_lower X b) U HU2). }
    apply Hex.
    let b.
    assume Hcore: b :e X /\ U = open_ray_lower X b.
    apply Hcore.
    assume HbX: b :e X.
    assume HUeq: U = open_ray_lower X b.
    rewrite HUeq.
    claim HUinB: open_ray_lower X b :e order_topology_basis X.
    { exact (open_ray_lower_in_order_topology_basis X b HbX). }
    claim HUpow: open_ray_lower X b :e Power X.
    { apply PowerI.
      let x. assume HxU: x :e open_ray_lower X b.
      exact (SepE1 X (fun x0 : set => order_rel X x0 b) x HxU). }
    exact (generated_topology_contains_elem X (order_topology_basis X) (open_ray_lower X b) HUpow HUinB).
  + exact HU0.
- assume HUX: U :e {X}.
  claim HUeq: U = X.
  { exact (SingE X U HUX). }
  rewrite HUeq.
  exact (topology_has_X X (order_topology X) (order_topology_is_topology X Hso)).
- exact HU.
Qed.

(** Helper: any subbasis element is open in the generated topology from the subbasis **)
(** LATEX VERSION: Each element of a subbasis is open in the topology generated by that subbasis. **)
Theorem subbasis_elem_open_in_generated_from_subbasis : forall X S s:set,
  subbasis_on X S ->
  s :e S ->
  s :e generated_topology_from_subbasis X S.
let X S s.
assume HS HsS.
apply (xm (s = Empty)).
- assume HsEmpty.
  rewrite HsEmpty.
  claim HT: topology_on X (generated_topology_from_subbasis X S).
  { exact (topology_from_subbasis_is_topology X S HS). }
  exact (topology_has_empty X (generated_topology_from_subbasis X S) HT).
- assume HsNe.
  claim HBasis: basis_on X (basis_of_subbasis X S).
  { exact (finite_intersections_basis_of_subbasis X S HS). }
  claim HsBasis: s :e basis_of_subbasis X S.
  { exact (subbasis_elem_in_basis X S s HS HsS HsNe). }
  exact (generated_topology_contains_basis X (basis_of_subbasis X S) HBasis s HsBasis).
Qed.

(** Helper: upper ray belongs to open_rays_subbasis **)
(** LATEX VERSION: Each upper ray (a, infty) is a member of the open-rays subbasis. **)
Theorem open_ray_upper_in_open_rays_subbasis : forall X a:set,
  a :e X ->
  open_ray_upper X a :e open_rays_subbasis X.
let X a. assume HaX.
set U := open_ray_upper X a.
claim HUpow: U :e Power X.
{ apply PowerI.
  let x. assume HxU: x :e U.
  exact (SepE1 X (fun x0 : set => order_rel X a x0) x HxU). }
claim HUex: exists a0 :e X, U = open_ray_upper X a0.
{ witness a.
  prove a :e X /\ U = open_ray_upper X a.
  apply andI.
  - exact HaX.
  - reflexivity.
}
claim HUfam: U :e {I0 :e Power X | exists a0 :e X, I0 = open_ray_upper X a0}.
{ exact (SepI (Power X)
              (fun I0 : set => exists a0 :e X, I0 = open_ray_upper X a0)
              U
              HUpow
              HUex). }
exact (binunionI1 ({I0 :e Power X | exists a0 :e X, I0 = open_ray_upper X a0}
                   :\/:
                   {I0 :e Power X | exists b0 :e X, I0 = open_ray_lower X b0})
                  {X}
                  U
                  (binunionI1 {I0 :e Power X | exists a0 :e X, I0 = open_ray_upper X a0}
                              {I0 :e Power X | exists b0 :e X, I0 = open_ray_lower X b0}
                              U
                              HUfam)).
Qed.

(** Helper: lower ray belongs to open_rays_subbasis **)
(** LATEX VERSION: Each lower ray (-infty, b) is a member of the open-rays subbasis. **)
Theorem open_ray_lower_in_open_rays_subbasis : forall X b:set,
  b :e X ->
  open_ray_lower X b :e open_rays_subbasis X.
let X b. assume HbX.
set U := open_ray_lower X b.
claim HUpow: U :e Power X.
{ apply PowerI.
  let x. assume HxU: x :e U.
  exact (SepE1 X (fun x0 : set => order_rel X x0 b) x HxU). }
claim HUex: exists b0 :e X, U = open_ray_lower X b0.
{ witness b.
  prove b :e X /\ U = open_ray_lower X b.
  apply andI.
  - exact HbX.
  - reflexivity.
}
claim HUfam: U :e {I0 :e Power X | exists b0 :e X, I0 = open_ray_lower X b0}.
{ exact (SepI (Power X)
              (fun I0 : set => exists b0 :e X, I0 = open_ray_lower X b0)
              U
              HUpow
              HUex). }
exact (binunionI1 ({I0 :e Power X | exists a0 :e X, I0 = open_ray_upper X a0}
                   :\/:
                   {I0 :e Power X | exists b0 :e X, I0 = open_ray_lower X b0})
                  {X}
                  U
                  (binunionI2 {I0 :e Power X | exists a0 :e X, I0 = open_ray_upper X a0}
                              {I0 :e Power X | exists b0 :e X, I0 = open_ray_lower X b0}
                              U
                              HUfam)).
Qed.

(** Helper: open interval equals intersection of open rays **)
(** LATEX VERSION: The open interval (a,b) equals (a, infty) intersect (-infty, b). **)
Theorem open_interval_eq_rays_intersection : forall X a b:set,
  {x :e X | order_rel X a x /\ order_rel X x b}
  =
  (open_ray_upper X a) :/\: (open_ray_lower X b).
let X a b.
apply set_ext.
- let x. assume Hx: x :e {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}.
  prove x :e (open_ray_upper X a) :/\: (open_ray_lower X b).
  claim HxX: x :e X.
  { exact (SepE1 X (fun x0 : set => order_rel X a x0 /\ order_rel X x0 b) x Hx). }
  claim HxRel: order_rel X a x /\ order_rel X x b.
  { exact (SepE2 X (fun x0 : set => order_rel X a x0 /\ order_rel X x0 b) x Hx). }
  claim HxUp: x :e open_ray_upper X a.
  { exact (SepI X (fun x0 : set => order_rel X a x0) x HxX
                 (andEL (order_rel X a x) (order_rel X x b) HxRel)). }
  claim HxLo: x :e open_ray_lower X b.
  { exact (SepI X (fun x0 : set => order_rel X x0 b) x HxX
                 (andER (order_rel X a x) (order_rel X x b) HxRel)). }
  exact (binintersectI (open_ray_upper X a) (open_ray_lower X b) x HxUp HxLo).
- let x. assume Hx: x :e (open_ray_upper X a) :/\: (open_ray_lower X b).
  prove x :e {x0 :e X | order_rel X a x0 /\ order_rel X x0 b}.
  claim HxUp: x :e open_ray_upper X a.
  { exact (binintersectE1 (open_ray_upper X a) (open_ray_lower X b) x Hx). }
  claim HxLo: x :e open_ray_lower X b.
  { exact (binintersectE2 (open_ray_upper X a) (open_ray_lower X b) x Hx). }
  claim HxX: x :e X.
  { exact (SepE1 X (fun x0 : set => order_rel X a x0) x HxUp). }
  claim HxRelUp: order_rel X a x.
  { exact (SepE2 X (fun x0 : set => order_rel X a x0) x HxUp). }
  claim HxRelLo: order_rel X x b.
  { exact (SepE2 X (fun x0 : set => order_rel X x0 b) x HxLo). }
  exact (SepI X (fun x0 : set => order_rel X a x0 /\ order_rel X x0 b) x HxX
              (andI (order_rel X a x) (order_rel X x b) HxRelUp HxRelLo)).
Qed.

(** Helper: order topology basis elements are open in the topology generated by open rays **)
(** LATEX VERSION: Every basis element of the order topology is open in the topology generated by open rays. **)
Theorem order_topology_basis_sub_generated_from_open_rays : forall X:set,
  order_topology_basis X c= generated_topology_from_subbasis X (open_rays_subbasis X).
let X.
set Tsub := generated_topology_from_subbasis X (open_rays_subbasis X).
claim HSsub: subbasis_on X (open_rays_subbasis X).
{ exact (open_rays_subbasis_is_subbasis X). }
claim HTsub: topology_on X Tsub.
{ exact (topology_from_subbasis_is_topology X (open_rays_subbasis X) HSsub). }
prove order_topology_basis X c= Tsub.
let I. assume HI: I :e order_topology_basis X.
prove I :e Tsub.
set Bold := (({I0 :e Power X | exists a0 :e X, exists b0 :e X,
                 I0 = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
              :\/:
              {I0 :e Power X | exists b0 :e X, I0 = {x :e X | order_rel X x b0}})
             :\/:
             {I0 :e Power X | exists a0 :e X, I0 = {x :e X | order_rel X a0 x}}).
apply (binunionE' Bold {X} I (I :e Tsub)).
- assume HIold: I :e Bold.
  apply (binunionE' ({I0 :e Power X | exists a0 :e X, exists b0 :e X,
                        I0 = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
                     :\/:
                     {I0 :e Power X | exists b0 :e X, I0 = {x :e X | order_rel X x b0}})
                    {I0 :e Power X | exists a0 :e X, I0 = {x :e X | order_rel X a0 x}}
                    I
                    (I :e Tsub)).
  - assume HI0: I :e ({I0 :e Power X | exists a0 :e X, exists b0 :e X,
                        I0 = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
                       :\/:
                       {I0 :e Power X | exists b0 :e X, I0 = {x :e X | order_rel X x b0}}).
    apply (binunionE' {I0 :e Power X | exists a0 :e X, exists b0 :e X,
                         I0 = {x :e X | order_rel X a0 x /\ order_rel X x b0}}
                      {I0 :e Power X | exists b0 :e X, I0 = {x :e X | order_rel X x b0}}
                      I
                      (I :e Tsub)).
  + assume HIint: I :e {I0 :e Power X | exists a0 :e X, exists b0 :e X,
                          I0 = {x :e X | order_rel X a0 x /\ order_rel X x b0}}.
    claim Hex: exists a0 :e X, exists b0 :e X, I = {x :e X | order_rel X a0 x /\ order_rel X x b0}.
    { exact (SepE2 (Power X)
                   (fun I0 : set => exists a0 :e X, exists b0 :e X, I0 = {x :e X | order_rel X a0 x /\ order_rel X x b0})
                   I
                   HIint). }
    apply Hex.
    let a0.
    assume Hcore: a0 :e X /\ exists b0 :e X, I = {x :e X | order_rel X a0 x /\ order_rel X x b0}.
    apply Hcore.
    assume HaX: a0 :e X.
    assume Hexb: exists b0 :e X, I = {x :e X | order_rel X a0 x /\ order_rel X x b0}.
    apply Hexb.
    let b0.
    assume Hcore2: b0 :e X /\ I = {x :e X | order_rel X a0 x /\ order_rel X x b0}.
    apply Hcore2.
    assume HbX: b0 :e X.
    assume HIeq: I = {x :e X | order_rel X a0 x /\ order_rel X x b0}.
    rewrite HIeq.
    set U1 := open_ray_upper X a0.
    set U2 := open_ray_lower X b0.
    claim HU1S: U1 :e open_rays_subbasis X.
    { exact (open_ray_upper_in_open_rays_subbasis X a0 HaX). }
    claim HU2S: U2 :e open_rays_subbasis X.
    { exact (open_ray_lower_in_open_rays_subbasis X b0 HbX). }
    claim HU1open: U1 :e Tsub.
    { exact (subbasis_elem_open_in_generated_from_subbasis X (open_rays_subbasis X) U1 HSsub HU1S). }
    claim HU2open: U2 :e Tsub.
    { exact (subbasis_elem_open_in_generated_from_subbasis X (open_rays_subbasis X) U2 HSsub HU2S). }
    claim Heq: {x :e X | order_rel X a0 x /\ order_rel X x b0} = U1 :/\: U2.
    { exact (open_interval_eq_rays_intersection X a0 b0). }
    rewrite Heq.
    exact (topology_binintersect_closed X Tsub U1 U2 HTsub HU1open HU2open).
  + assume HIlow: I :e {I0 :e Power X | exists b0 :e X, I0 = {x :e X | order_rel X x b0}}.
    claim Hex: exists b0 :e X, I = {x :e X | order_rel X x b0}.
    { exact (SepE2 (Power X)
                   (fun I0 : set => exists b0 :e X, I0 = {x :e X | order_rel X x b0})
                   I
                   HIlow). }
    apply Hex.
    let b0.
    assume Hcore: b0 :e X /\ I = {x :e X | order_rel X x b0}.
    apply Hcore.
    assume HbX: b0 :e X.
    assume HIeq: I = {x :e X | order_rel X x b0}.
    rewrite HIeq.
    claim Hdef: open_ray_lower X b0 = {x :e X | order_rel X x b0}.
    { reflexivity. }
    rewrite <- Hdef.
    set U := open_ray_lower X b0.
    claim HUS: U :e open_rays_subbasis X.
    { exact (open_ray_lower_in_open_rays_subbasis X b0 HbX). }
    exact (subbasis_elem_open_in_generated_from_subbasis X (open_rays_subbasis X) U HSsub HUS).
  + exact HI0.
- assume HIup: I :e {I0 :e Power X | exists a0 :e X, I0 = {x :e X | order_rel X a0 x}}.
  claim Hex: exists a0 :e X, I = {x :e X | order_rel X a0 x}.
  { exact (SepE2 (Power X)
                 (fun I0 : set => exists a0 :e X, I0 = {x :e X | order_rel X a0 x})
                 I
                 HIup). }
  apply Hex.
  let a0.
  assume Hcore: a0 :e X /\ I = {x :e X | order_rel X a0 x}.
  apply Hcore.
  assume HaX: a0 :e X.
  assume HIeq: I = {x :e X | order_rel X a0 x}.
  rewrite HIeq.
  claim Hdef: open_ray_upper X a0 = {x :e X | order_rel X a0 x}.
  { reflexivity. }
  rewrite <- Hdef.
  set U := open_ray_upper X a0.
  claim HUS: U :e open_rays_subbasis X.
  { exact (open_ray_upper_in_open_rays_subbasis X a0 HaX). }
  exact (subbasis_elem_open_in_generated_from_subbasis X (open_rays_subbasis X) U HSsub HUS).
  - exact HIold.
- assume HIX: I :e {X}.
  claim HIeq: I = X.
  { exact (SingE X I HIX). }
  rewrite HIeq.
  exact (topology_has_X X Tsub HTsub).
- exact HI.
Qed.

(** Helper: open rays subbasis generates the order topology **)
(** LATEX VERSION: The order topology equals the topology generated by the subbasis of all open rays. **)
Theorem open_rays_subbasis_for_order_topology : forall X:set,
  simply_ordered_set X ->
  generated_topology_from_subbasis X (open_rays_subbasis X) = order_topology X.
let X.
assume Hso: simply_ordered_set X.
prove generated_topology_from_subbasis X (open_rays_subbasis X) = order_topology X.
apply set_ext.
- let U. assume HU : U :e generated_topology_from_subbasis X (open_rays_subbasis X).
  prove U :e order_topology X.
  claim HS: subbasis_on X (open_rays_subbasis X).
  { exact (open_rays_subbasis_is_subbasis X). }
  claim HT: topology_on X (order_topology X).
  { exact (order_topology_is_topology X Hso). }
  claim HSsub: open_rays_subbasis X c= order_topology X.
  { exact (open_rays_subbasis_sub_order_topology X Hso). }
  claim Hmin: finer_than (order_topology X) (generated_topology_from_subbasis X (open_rays_subbasis X)).
  { exact (topology_generated_by_basis_is_minimal X (open_rays_subbasis X) (order_topology X) HS HT HSsub). }
  exact (Hmin U HU).
- let U. assume HU : U :e order_topology X.
  prove U :e generated_topology_from_subbasis X (open_rays_subbasis X).
  set Tsub := generated_topology_from_subbasis X (open_rays_subbasis X).
  claim HS: subbasis_on X (open_rays_subbasis X).
  { exact (open_rays_subbasis_is_subbasis X). }
  claim HTsub: topology_on X Tsub.
  { exact (topology_from_subbasis_is_topology X (open_rays_subbasis X) HS). }
  claim HBsub: forall b :e order_topology_basis X, b :e Tsub.
  { let b. assume Hb.
    exact (order_topology_basis_sub_generated_from_open_rays X b Hb). }
  claim Hfiner: finer_than Tsub (generated_topology X (order_topology_basis X)).
  { exact (generated_topology_finer_weak X (order_topology_basis X) Tsub HTsub HBsub). }
  exact (Hfiner U HU).
Qed.

(** from §14 Example 1: standard basis is a basis on ℝ **)
(** LATEX VERSION: The standard open-interval basis on ℝ satisfies the basis axioms. **)
Theorem R_standard_basis_is_basis : basis_on R R_standard_basis.
prove basis_on R R_standard_basis.
(** Reuse the earlier proof to avoid duplicate work. **)
exact R_standard_basis_is_basis_local.
Qed.

(** from §14 Example 1: standard topology is a topology **)
(** LATEX VERSION: The standard topology on ℝ satisfies the topology axioms. **)
Theorem R_standard_topology_is_topology : topology_on R R_standard_topology.
prove topology_on R R_standard_topology.
exact (lemma_topology_from_basis R R_standard_basis (R_standard_basis_is_basis)).
Qed.

(** from §14 Example 1: standard topology on ℝ is the order topology **)
(** LATEX VERSION: Example 1: The standard topology on ℝ equals its order topology. **)
(** NOTE: The earlier axiom equating bases was too strong; we only need equality of the generated topologies. **)
(** Helper: any standard open interval is an order-topology basis element on ℝ. **)
Theorem open_interval_in_order_topology_basis_R : forall a b:set,
  a :e R -> b :e R -> open_interval a b :e order_topology_basis R.
let a b. assume HaR HbR.
set A := {I :e Power R | exists a1 :e R, exists b1 :e R,
            I = {x :e R | order_rel R a1 x /\ order_rel R x b1}}.
set B := {I :e Power R | exists b1 :e R, I = {x :e R | order_rel R x b1}}.
set C := {I :e Power R | exists a1 :e R, I = {x :e R | order_rel R a1 x}}.
claim HPow: open_interval a b :e Power R.
{ exact (PowerI R (open_interval a b) (open_interval_Subq_R a b)). }
claim HintEq: {x :e R | order_rel R a x /\ order_rel R x b} = open_interval a b.
{ apply set_ext.
  - let x. assume HxI: x :e {x0 :e R | order_rel R a x0 /\ order_rel R x0 b}.
    prove x :e open_interval a b.
    claim HxR: x :e R.
    { exact (SepE1 R (fun x0 : set => order_rel R a x0 /\ order_rel R x0 b) x HxI). }
    claim Hconj: order_rel R a x /\ order_rel R x b.
    { exact (SepE2 R (fun x0 : set => order_rel R a x0 /\ order_rel R x0 b) x HxI). }
    claim Hax: order_rel R a x.
    { exact (andEL (order_rel R a x) (order_rel R x b) Hconj). }
    claim Hxb: order_rel R x b.
    { exact (andER (order_rel R a x) (order_rel R x b) Hconj). }
    claim Haxlt: Rlt a x.
    { exact (order_rel_R_implies_Rlt a x Hax). }
    claim Hxblt: Rlt x b.
    { exact (order_rel_R_implies_Rlt x b Hxb). }
    exact (SepI R (fun x0 : set => Rlt a x0 /\ Rlt x0 b)
                x HxR (andI (Rlt a x) (Rlt x b) Haxlt Hxblt)).
  - let x. assume HxI: x :e open_interval a b.
    prove x :e {x0 :e R | order_rel R a x0 /\ order_rel R x0 b}.
    claim HxR: x :e R.
    { exact (SepE1 R (fun x0 : set => Rlt a x0 /\ Rlt x0 b) x HxI). }
    claim Hconj: Rlt a x /\ Rlt x b.
    { exact (SepE2 R (fun x0 : set => Rlt a x0 /\ Rlt x0 b) x HxI). }
    claim Hax: Rlt a x.
    { exact (andEL (Rlt a x) (Rlt x b) Hconj). }
    claim Hxb: Rlt x b.
    { exact (andER (Rlt a x) (Rlt x b) Hconj). }
    claim Haxrel: order_rel R a x.
    { exact (Rlt_implies_order_rel_R a x Hax). }
    claim Hxbrel: order_rel R x b.
    { exact (Rlt_implies_order_rel_R x b Hxb). }
    exact (SepI R (fun x0 : set => order_rel R a x0 /\ order_rel R x0 b)
                x HxR (andI (order_rel R a x) (order_rel R x b) Haxrel Hxbrel)). }
claim Hpred: exists a0 :e R, exists b0 :e R,
  open_interval a b = {x :e R | order_rel R a0 x /\ order_rel R x b0}.
{ witness a.
  apply andI.
  - exact HaR.
  - witness b.
    apply andI.
    + exact HbR.
    + rewrite HintEq.
      reflexivity. }
claim HInA: open_interval a b :e A.
{ exact (SepI (Power R)
              (fun I0 : set => exists a0 :e R, exists b0 :e R,
                              I0 = {x :e R | order_rel R a0 x /\ order_rel R x b0})
              (open_interval a b)
              HPow
              Hpred). }
claim HInAB: open_interval a b :e (A :\/: B).
{ exact (binunionI1 A B (open_interval a b) HInA). }
set Bold := (A :\/: B :\/: C).
exact (binunionI1 Bold {R} (open_interval a b)
  (binunionI1 (A :\/: B) C (open_interval a b) HInAB)).
Qed.

(** Helper: refine order-topology basis elements by standard open intervals on ℝ. **)
(** LATEX VERSION: Any order-topology basis neighborhood in ℝ contains a standard open interval around the point. **)
Theorem order_topology_basis_R_refines_standard_basis :
  forall b :e order_topology_basis R, forall x:set,
    x :e b ->
    exists I :e R_standard_basis, x :e I /\ I c= b.
let b. assume Hb.
let x. assume Hxb.
set A := {I :e Power R | exists a1 :e R, exists b1 :e R,
            I = {y :e R | order_rel R a1 y /\ order_rel R y b1}}.
set B := {I :e Power R | exists b1 :e R, I = {y :e R | order_rel R y b1}}.
set C := {I :e Power R | exists a1 :e R, I = {y :e R | order_rel R a1 y}}.
set Bold := (A :\/: B :\/: C).
apply (binunionE' Bold {R} b (exists I :e R_standard_basis, x :e I /\ I c= b)).
- assume HbU: b :e Bold.
  apply (binunionE' (A :\/: B) C b (exists I :e R_standard_basis, x :e I /\ I c= b)).
  - assume HbAB: b :e (A :\/: B).
    apply (binunionE' A B b (exists I :e R_standard_basis, x :e I /\ I c= b)).
    + assume HbA: b :e A.
    claim Hex: exists a0 :e R, exists b0 :e R, b = {y :e R | order_rel R a0 y /\ order_rel R y b0}.
    { exact (SepE2 (Power R)
                   (fun I0 : set => exists a0 :e R, exists b0 :e R,
                                  I0 = {y :e R | order_rel R a0 y /\ order_rel R y b0})
                   b
                   HbA). }
    apply Hex.
    let a0. assume Ha0core.
    apply Ha0core.
    assume Ha0R: a0 :e R.
    assume Hexb0: exists b0 :e R, b = {y :e R | order_rel R a0 y /\ order_rel R y b0}.
    apply Hexb0.
    let b0. assume Hb0core.
    apply Hb0core.
    assume Hb0R: b0 :e R.
    assume Hbeq: b = {y :e R | order_rel R a0 y /\ order_rel R y b0}.
    set I := open_interval a0 b0.
    claim HIinStdBasis: I :e R_standard_basis.
    { claim HIa: I :e {open_interval a0 bb|bb :e R}.
      { exact (ReplI R (fun bb : set => open_interval a0 bb) b0 Hb0R). }
      exact (famunionI R (fun aa : set => {open_interval aa bb|bb :e R}) a0 I Ha0R HIa). }
    claim HxInSet: x :e {y :e R | order_rel R a0 y /\ order_rel R y b0}.
    { rewrite <- Hbeq.
      exact Hxb. }
    claim HxR: x :e R.
    { exact (SepE1 R (fun y : set => order_rel R a0 y /\ order_rel R y b0) x HxInSet). }
    claim Hxconj: order_rel R a0 x /\ order_rel R x b0.
    { exact (SepE2 R (fun y : set => order_rel R a0 y /\ order_rel R y b0) x HxInSet). }
    claim Hax: order_rel R a0 x.
    { exact (andEL (order_rel R a0 x) (order_rel R x b0) Hxconj). }
    claim Hxb0: order_rel R x b0.
    { exact (andER (order_rel R a0 x) (order_rel R x b0) Hxconj). }
    claim Haxlt: Rlt a0 x.
    { exact (order_rel_R_implies_Rlt a0 x Hax). }
    claim Hxblt: Rlt x b0.
    { exact (order_rel_R_implies_Rlt x b0 Hxb0). }
    claim HxI: x :e I.
    { exact (SepI R (fun y : set => Rlt a0 y /\ Rlt y b0)
                x HxR (andI (Rlt a0 x) (Rlt x b0) Haxlt Hxblt)). }
    claim HIsubB: I c= b.
    { let y. assume HyI: y :e I.
      prove y :e b.
      claim HyR: y :e R.
      { exact (SepE1 R (fun y0 : set => Rlt a0 y0 /\ Rlt y0 b0) y HyI). }
      claim Hyconj: Rlt a0 y /\ Rlt y b0.
      { exact (SepE2 R (fun y0 : set => Rlt a0 y0 /\ Rlt y0 b0) y HyI). }
      claim Hay: Rlt a0 y.
      { exact (andEL (Rlt a0 y) (Rlt y b0) Hyconj). }
      claim Hyb: Rlt y b0.
      { exact (andER (Rlt a0 y) (Rlt y b0) Hyconj). }
      claim Hayrel: order_rel R a0 y.
      { exact (Rlt_implies_order_rel_R a0 y Hay). }
      claim Hybrel: order_rel R y b0.
      { exact (Rlt_implies_order_rel_R y b0 Hyb). }
      claim HySet: y :e {z :e R | order_rel R a0 z /\ order_rel R z b0}.
      { exact (SepI R (fun z : set => order_rel R a0 z /\ order_rel R z b0)
                  y HyR (andI (order_rel R a0 y) (order_rel R y b0) Hayrel Hybrel)). }
      rewrite Hbeq.
      exact HySet. }
    witness I.
    apply andI.
    - exact HIinStdBasis.
    - apply andI.
      + exact HxI.
      + exact HIsubB.
    + assume HbB: b :e B.
    claim Hex: exists b0 :e R, b = {y :e R | order_rel R y b0}.
    { exact (SepE2 (Power R)
                   (fun I0 : set => exists b0 :e R, I0 = {y :e R | order_rel R y b0})
                   b
                   HbB). }
    apply Hex.
    let b0. assume Hb0core.
    apply Hb0core.
    assume Hb0R: b0 :e R.
    assume Hbeq: b = {y :e R | order_rel R y b0}.
    claim HxInSet: x :e {y :e R | order_rel R y b0}.
    { rewrite <- Hbeq.
      exact Hxb. }
    claim HxR: x :e R.
    { exact (SepE1 R (fun y : set => order_rel R y b0) x HxInSet). }
    claim Hrel: order_rel R x b0.
    { exact (SepE2 R (fun y : set => order_rel R y b0) x HxInSet). }
    claim Hxltb0: Rlt x b0.
    { exact (order_rel_R_implies_Rlt x b0 Hrel). }
    claim Hxpm: x :e open_interval (add_SNo x (minus_SNo 1)) (add_SNo x 1).
    { exact (real_in_open_interval_minus1_plus1 x HxR). }
    set a1 := add_SNo x (minus_SNo 1).
    set c1 := add_SNo x 1.
    claim Ha1R: a1 :e R.
    { exact (open_interval_left_in_R a1 c1 x Hxpm). }
    claim Hleft: Rlt a1 x.
    { claim Hconj: Rlt a1 x /\ Rlt x c1.
      { exact (SepE2 R (fun y : set => Rlt a1 y /\ Rlt y c1) x Hxpm). }
      exact (andEL (Rlt a1 x) (Rlt x c1) Hconj). }
    set I := open_interval a1 b0.
    claim HIinStdBasis: I :e R_standard_basis.
    { claim HIa: I :e {open_interval a1 bb|bb :e R}.
      { exact (ReplI R (fun bb : set => open_interval a1 bb) b0 Hb0R). }
      exact (famunionI R (fun aa : set => {open_interval aa bb|bb :e R}) a1 I Ha1R HIa). }
    claim HxI: x :e I.
    { exact (SepI R (fun y : set => Rlt a1 y /\ Rlt y b0) x HxR
                (andI (Rlt a1 x) (Rlt x b0) Hleft Hxltb0)). }
    claim HIsubB: I c= b.
    { let y. assume HyI: y :e I.
      prove y :e b.
      claim HyR: y :e R.
      { exact (SepE1 R (fun y0 : set => Rlt a1 y0 /\ Rlt y0 b0) y HyI). }
      claim Hyconj: Rlt a1 y /\ Rlt y b0.
      { exact (SepE2 R (fun y0 : set => Rlt a1 y0 /\ Rlt y0 b0) y HyI). }
      claim Hyb: Rlt y b0.
      { exact (andER (Rlt a1 y) (Rlt y b0) Hyconj). }
      claim Hyrel: order_rel R y b0.
      { exact (Rlt_implies_order_rel_R y b0 Hyb). }
      claim HySet: y :e {z :e R | order_rel R z b0}.
      { exact (SepI R (fun z : set => order_rel R z b0) y HyR Hyrel). }
      rewrite Hbeq.
      exact HySet. }
    witness I.
    apply andI.
    - exact HIinStdBasis.
    - apply andI.
      + exact HxI.
      + exact HIsubB.
  + exact HbAB.
  - assume HbC: b :e C.
  claim Hex: exists a0 :e R, b = {y :e R | order_rel R a0 y}.
  { exact (SepE2 (Power R)
                 (fun I0 : set => exists a0 :e R, I0 = {y :e R | order_rel R a0 y})
                 b
                 HbC). }
  apply Hex.
  let a0. assume Ha0core.
  apply Ha0core.
  assume Ha0R: a0 :e R.
  assume Hbeq: b = {y :e R | order_rel R a0 y}.
  claim HxInSet: x :e {y :e R | order_rel R a0 y}.
  { rewrite <- Hbeq.
    exact Hxb. }
  claim HxR: x :e R.
  { exact (SepE1 R (fun y : set => order_rel R a0 y) x HxInSet). }
  claim Hrel: order_rel R a0 x.
  { exact (SepE2 R (fun y : set => order_rel R a0 y) x HxInSet). }
  claim Ha0ltx: Rlt a0 x.
  { exact (order_rel_R_implies_Rlt a0 x Hrel). }
  claim Hxpm: x :e open_interval (add_SNo x (minus_SNo 1)) (add_SNo x 1).
  { exact (real_in_open_interval_minus1_plus1 x HxR). }
  set a1 := add_SNo x (minus_SNo 1).
  set c1 := add_SNo x 1.
  claim Hright: Rlt x c1.
  { claim Hconj: Rlt a1 x /\ Rlt x c1.
    { exact (SepE2 R (fun y : set => Rlt a1 y /\ Rlt y c1) x Hxpm). }
    exact (andER (Rlt a1 x) (Rlt x c1) Hconj). }
  claim Hc1R: c1 :e R.
  { exact (open_interval_right_in_R a1 c1 x Hxpm). }
  set I := open_interval a0 c1.
  claim HIinStdBasis: I :e R_standard_basis.
  { claim HIa: I :e {open_interval a0 bb|bb :e R}.
    { exact (ReplI R (fun bb : set => open_interval a0 bb) c1 Hc1R). }
    exact (famunionI R (fun aa : set => {open_interval aa bb|bb :e R}) a0 I Ha0R HIa). }
  claim HxI: x :e I.
  { exact (SepI R (fun y : set => Rlt a0 y /\ Rlt y c1) x HxR
              (andI (Rlt a0 x) (Rlt x c1) Ha0ltx Hright)). }
  claim HIsubB: I c= b.
  { let y. assume HyI: y :e I.
    prove y :e b.
    claim HyR: y :e R.
    { exact (SepE1 R (fun y0 : set => Rlt a0 y0 /\ Rlt y0 c1) y HyI). }
    claim Hyconj: Rlt a0 y /\ Rlt y c1.
    { exact (SepE2 R (fun y0 : set => Rlt a0 y0 /\ Rlt y0 c1) y HyI). }
    claim Hay: Rlt a0 y.
    { exact (andEL (Rlt a0 y) (Rlt y c1) Hyconj). }
    claim Hayrel: order_rel R a0 y.
    { exact (Rlt_implies_order_rel_R a0 y Hay). }
    claim HySet: y :e {z :e R | order_rel R a0 z}.
    { exact (SepI R (fun z : set => order_rel R a0 z) y HyR Hayrel). }
    rewrite Hbeq.
    exact HySet. }
  witness I.
  apply andI.
  - exact HIinStdBasis.
  - apply andI.
    + exact HxI.
    + exact HIsubB.
- exact HbU.
- assume HbR: b :e {R}.
  claim HbEq: b = R.
  { exact (SingE R b HbR). }
  claim HxR: x :e R.
  { rewrite <- HbEq.
    exact Hxb. }
  claim HexI: exists I :e R_standard_basis, x :e I.
  { exact (basis_on_cover R R_standard_basis (R_standard_basis_is_basis) x HxR). }
  apply HexI.
  let I.
  assume Hcore: I :e R_standard_basis /\ x :e I.
  apply Hcore.
  assume HIbasis: I :e R_standard_basis.
  assume HxI: x :e I.
  witness I.
  apply andI.
  - exact HIbasis.
  - apply andI.
    + exact HxI.
    + prove I c= b.
      rewrite HbEq.
      claim HIPow: I :e Power R.
      { exact ((basis_on_sub_Power R R_standard_basis (R_standard_basis_is_basis)) I HIbasis). }
      exact (PowerE R I HIPow).
- exact Hb.
Qed.

(** Helper: order topology on ℝ equals the standard topology. **)
(** LATEX VERSION: The order topology on ℝ coincides with the standard topology generated by open intervals. **)
Theorem standard_topology_is_order_topology : order_topology R = R_standard_topology.
prove order_topology R = R_standard_topology.
apply set_ext.
- let U. assume HU: U :e order_topology R.
  prove U :e R_standard_topology.
  claim HdefOrd: order_topology R = generated_topology R (order_topology_basis R).
  { reflexivity. }
  claim HdefStd: R_standard_topology = generated_topology R R_standard_basis.
  { exact R_standard_topology_def_eq. }
  claim HUgen: U :e generated_topology R (order_topology_basis R).
  { rewrite <- HdefOrd.
    exact HU. }
  claim HUpow: U :e Power R.
  { exact (SepE1 (Power R)
                 (fun U0 : set => forall x :e U0, exists b :e order_topology_basis R, x :e b /\ b c= U0)
                 U
                 HUgen). }
  claim HUloc: forall x :e U, exists b :e order_topology_basis R, x :e b /\ b c= U.
  { exact (SepE2 (Power R)
                 (fun U0 : set => forall x :e U0, exists b :e order_topology_basis R, x :e b /\ b c= U0)
                 U
                 HUgen). }
  claim HUlocStd: forall x :e U, exists I :e R_standard_basis, x :e I /\ I c= U.
  { let x0. assume Hx0U: x0 :e U.
    apply (HUloc x0 Hx0U).
    let b0. assume Hb0core.
    claim Hb0B: b0 :e order_topology_basis R.
    { exact (andEL (b0 :e order_topology_basis R) (x0 :e b0 /\ b0 c= U) Hb0core). }
    claim Hrest: x0 :e b0 /\ b0 c= U.
    { exact (andER (b0 :e order_topology_basis R) (x0 :e b0 /\ b0 c= U) Hb0core). }
    claim Hx0b0: x0 :e b0.
    { exact (andEL (x0 :e b0) (b0 c= U) Hrest). }
    claim Hb0subU: b0 c= U.
    { exact (andER (x0 :e b0) (b0 c= U) Hrest). }
    claim HexI: exists I :e R_standard_basis, x0 :e I /\ I c= b0.
    { exact (order_topology_basis_R_refines_standard_basis b0 Hb0B x0 Hx0b0). }
    apply HexI.
    let I. assume HIcore.
    apply HIcore.
    assume HIbasis: I :e R_standard_basis.
    assume HIrest: x0 :e I /\ I c= b0.
    claim Hx0I: x0 :e I.
    { exact (andEL (x0 :e I) (I c= b0) HIrest). }
    claim HIsubb0: I c= b0.
    { exact (andER (x0 :e I) (I c= b0) HIrest). }
    witness I.
    apply andI.
    - exact HIbasis.
    - apply andI.
      + exact Hx0I.
      + exact (Subq_tra I b0 U HIsubb0 Hb0subU). }
  rewrite HdefStd.
  exact (SepI (Power R)
              (fun U0 : set => forall x :e U0, exists I :e R_standard_basis, x :e I /\ I c= U0)
              U
              HUpow
              HUlocStd).
- let U. assume HU: U :e R_standard_topology.
  prove U :e order_topology R.
  claim HdefStd: R_standard_topology = generated_topology R R_standard_basis.
  { exact R_standard_topology_def_eq. }
  claim HdefOrd: order_topology R = generated_topology R (order_topology_basis R).
  { reflexivity. }
  claim HUgen: U :e generated_topology R R_standard_basis.
  { rewrite <- HdefStd.
    exact HU. }
  claim HUpow: U :e Power R.
  { exact (SepE1 (Power R)
                 (fun U0 : set => forall x :e U0, exists I :e R_standard_basis, x :e I /\ I c= U0)
                 U
                 HUgen). }
  claim HUloc: forall x :e U, exists I :e R_standard_basis, x :e I /\ I c= U.
  { exact (SepE2 (Power R)
                 (fun U0 : set => forall x :e U0, exists I :e R_standard_basis, x :e I /\ I c= U0)
                 U
                 HUgen). }
  claim HUlocOrd: forall x :e U, exists b :e order_topology_basis R, x :e b /\ b c= U.
  { let x0. assume Hx0U: x0 :e U.
    apply (HUloc x0 Hx0U).
    let I. assume HIcore.
    apply HIcore.
    assume HIbasis: I :e R_standard_basis.
    assume HIrest: x0 :e I /\ I c= U.
    claim Hx0I: x0 :e I.
    { exact (andEL (x0 :e I) (I c= U) HIrest). }
    claim HIsubU: I c= U.
    { exact (andER (x0 :e I) (I c= U) HIrest). }
    claim Hexa : exists a0 :e R, I :e {open_interval a0 bb|bb :e R}.
    { exact (famunionE R (fun a0 : set => {open_interval a0 bb|bb :e R}) I HIbasis). }
    apply Hexa.
    let a0. assume Ha0core.
    apply Ha0core.
    assume Ha0R: a0 :e R.
    assume HIaFam: I :e {open_interval a0 bb|bb :e R}.
    claim Hexb : exists b0 :e R, I = open_interval a0 b0.
    { exact (ReplE R (fun bb0 : set => open_interval a0 bb0) I HIaFam). }
    apply Hexb.
    let b0. assume Hb0core.
    apply Hb0core.
    assume Hb0R: b0 :e R.
    assume HIeq: I = open_interval a0 b0.
    set b := open_interval a0 b0.
    claim HbBasis: b :e order_topology_basis R.
    { exact (open_interval_in_order_topology_basis_R a0 b0 Ha0R Hb0R). }
    claim Hx0b: x0 :e b.
    { rewrite <- HIeq.
      exact Hx0I. }
    claim HbsubU: b c= U.
    { rewrite <- HIeq.
      exact HIsubU. }
    witness b.
    apply andI.
    - exact HbBasis.
    - apply andI.
      + exact Hx0b.
      + exact HbsubU. }
  rewrite HdefOrd.
  exact (SepI (Power R)
              (fun U0 : set => forall x :e U0, exists b :e order_topology_basis R, x :e b /\ b c= U0)
              U
              HUpow
              HUlocOrd).
Qed.

(** Helper: order topology on ℝ is a topology, via equality with the standard topology. **)
(** LATEX VERSION: Since order_topology R equals the standard topology, it satisfies the topology axioms. **)
Theorem order_topology_R_is_topology : topology_on R (order_topology R).
prove topology_on R (order_topology R).
rewrite standard_topology_is_order_topology.
exact R_standard_topology_is_topology.
Qed.

(** Helper: the order-topology basis on ℝ satisfies the basis axioms. **)
(** LATEX VERSION: The order topology on ℝ is generated by open intervals and open rays, and these form a basis. **)
Theorem order_topology_basis_R_is_basis : basis_on R (order_topology_basis R).
prove basis_on R (order_topology_basis R).
set T := order_topology R.
claim HT: topology_on R T.
{ exact order_topology_R_is_topology. }
claim HCsub: forall c :e order_topology_basis R, c :e T.
  { let c. assume HcB: c :e order_topology_basis R.
    prove c :e T.
    set A := {I :e Power R | exists a1 :e R, exists b1 :e R,
                I = {x :e R | order_rel R a1 x /\ order_rel R x b1}}.
    set B := {I :e Power R | exists b1 :e R, I = {x :e R | order_rel R x b1}}.
    set C := {I :e Power R | exists a1 :e R, I = {x :e R | order_rel R a1 x}}.
    claim HcPow: c :e Power R.
    { set Bold := (A :\/: B :\/: C).
      apply (binunionE' Bold {R} c (c :e Power R)).
      - assume HcU: c :e Bold.
        apply (binunionE' (A :\/: B) C c (c :e Power R)).
        + assume HcAB: c :e (A :\/: B).
          apply (binunionE' A B c (c :e Power R)).
          * assume HcA: c :e A.
            exact (SepE1 (Power R)
                         (fun I0 : set => exists a0 :e R, exists b0 :e R,
                                          I0 = {x :e R | order_rel R a0 x /\ order_rel R x b0})
                         c
                         HcA).
          * assume HcB0: c :e B.
            exact (SepE1 (Power R)
                         (fun I0 : set => exists b0 :e R, I0 = {x :e R | order_rel R x b0})
                         c
                         HcB0).
          * exact HcAB.
        + assume HcC: c :e C.
          exact (SepE1 (Power R)
                       (fun I0 : set => exists a0 :e R, I0 = {x :e R | order_rel R a0 x})
                       c
                       HcC).
        + exact HcU.
      - assume HcR: c :e {R}.
        claim HcEq: c = R.
        { exact (SingE R c HcR). }
        rewrite HcEq.
        exact (Self_In_Power R).
      - exact HcB. }
    exact (generated_topology_contains_elem R (order_topology_basis R) c HcPow HcB). }
claim Href: forall U :e T, forall x :e U, exists c :e order_topology_basis R, x :e c /\ c c= U.
{ let U. assume HU: U :e T.
  let x. assume HxU: x :e U.
  prove exists c :e order_topology_basis R, x :e c /\ c c= U.
  claim HTdef: T = generated_topology R (order_topology_basis R).
  { reflexivity. }
  claim HUgen: U :e generated_topology R (order_topology_basis R).
  { rewrite <- HTdef.
    exact HU. }
  exact (SepE2 (Power R)
               (fun U0 : set => forall x0 :e U0, exists b :e order_topology_basis R, x0 :e b /\ b c= U0)
               U
               HUgen
               x
               HxU). }
exact (andEL (basis_on R (order_topology_basis R))
             (generated_topology R (order_topology_basis R) = T)
             (lemma13_2_basis_from_open_subcollection R T (order_topology_basis R) HT HCsub Href)).
Qed.

(** Helper: open rays subbasis elements are open in the order topology on ℝ. **)
(** LATEX VERSION: Every open ray in ℝ belongs to the order topology on ℝ. **)
Theorem open_rays_subbasis_sub_order_topology_R : open_rays_subbasis R c= order_topology R.
let U. assume HU: U :e open_rays_subbasis R.
prove U :e order_topology R.
apply (binunionE' ({I0 :e Power R | exists a :e R, I0 = open_ray_upper R a}
                   :\/:
                   {I0 :e Power R | exists b :e R, I0 = open_ray_lower R b})
                  {R}
                  U
                  (U :e order_topology R)).
- assume HU0: U :e ({I0 :e Power R | exists a :e R, I0 = open_ray_upper R a}
                    :\/:
                    {I0 :e Power R | exists b :e R, I0 = open_ray_lower R b}).
  apply (binunionE' {I0 :e Power R | exists a :e R, I0 = open_ray_upper R a}
                    {I0 :e Power R | exists b :e R, I0 = open_ray_lower R b}
                    U
                    (U :e order_topology R)).
  + assume HUup: U :e {I0 :e Power R | exists a :e R, I0 = open_ray_upper R a}.
    claim Hex: exists a :e R, U = open_ray_upper R a.
    { exact (SepE2 (Power R) (fun I0 : set => exists a :e R, I0 = open_ray_upper R a) U HUup). }
    apply Hex.
    let a. assume Hacore.
    apply Hacore.
    assume HaR: a :e R.
    assume HUeq: U = open_ray_upper R a.
    rewrite HUeq.
    claim HUbasis: open_ray_upper R a :e order_topology_basis R.
    { exact (open_ray_upper_in_order_topology_basis R a HaR). }
    claim HUpow: open_ray_upper R a :e Power R.
    { apply PowerI.
      let x. assume HxU: x :e open_ray_upper R a.
      exact (SepE1 R (fun x0 : set => order_rel R a x0) x HxU). }
    exact (generated_topology_contains_elem R (order_topology_basis R) (open_ray_upper R a) HUpow HUbasis).
  + assume HUlow: U :e {I0 :e Power R | exists b :e R, I0 = open_ray_lower R b}.
    claim Hex: exists b :e R, U = open_ray_lower R b.
    { exact (SepE2 (Power R) (fun I0 : set => exists b :e R, I0 = open_ray_lower R b) U HUlow). }
    apply Hex.
    let b. assume Hbcore.
    apply Hbcore.
    assume HbR: b :e R.
    assume HUeq: U = open_ray_lower R b.
    rewrite HUeq.
    claim HUbasis: open_ray_lower R b :e order_topology_basis R.
    { exact (open_ray_lower_in_order_topology_basis R b HbR). }
    claim HUpow: open_ray_lower R b :e Power R.
    { apply PowerI.
      let x. assume HxU: x :e open_ray_lower R b.
      exact (SepE1 R (fun x0 : set => order_rel R x0 b) x HxU). }
    exact (generated_topology_contains_elem R (order_topology_basis R) (open_ray_lower R b) HUpow HUbasis).
  + exact HU0.
- assume HUR: U :e {R}.
  claim HUeq: U = R.
  { exact (SingE R U HUR). }
  rewrite HUeq.
  exact (topology_has_X R (order_topology R) order_topology_R_is_topology).
- exact HU.
Qed.

(** Helper: on ℝ, the order topology is generated by the open rays subbasis. **)
(** LATEX VERSION: On ℝ, the topology generated by open rays equals the order topology. **)
Theorem open_rays_subbasis_for_order_topology_R :
  generated_topology_from_subbasis R (open_rays_subbasis R) = order_topology R.
prove generated_topology_from_subbasis R (open_rays_subbasis R) = order_topology R.
apply set_ext.
- let U. assume HU : U :e generated_topology_from_subbasis R (open_rays_subbasis R).
  prove U :e order_topology R.
  claim HS: subbasis_on R (open_rays_subbasis R).
  { exact (open_rays_subbasis_is_subbasis R). }
  claim HT: topology_on R (order_topology R).
  { exact order_topology_R_is_topology. }
  claim HSsub: open_rays_subbasis R c= order_topology R.
  { exact open_rays_subbasis_sub_order_topology_R. }
  claim Hmin: finer_than (order_topology R) (generated_topology_from_subbasis R (open_rays_subbasis R)).
  { exact (topology_generated_by_basis_is_minimal R (open_rays_subbasis R) (order_topology R) HS HT HSsub). }
  exact (Hmin U HU).
- let U. assume HU : U :e order_topology R.
  prove U :e generated_topology_from_subbasis R (open_rays_subbasis R).
  set Tsub := generated_topology_from_subbasis R (open_rays_subbasis R).
  claim HS: subbasis_on R (open_rays_subbasis R).
  { exact (open_rays_subbasis_is_subbasis R). }
  claim HTsub: topology_on R Tsub.
  { exact (topology_from_subbasis_is_topology R (open_rays_subbasis R) HS). }
  claim HBsub: forall b :e order_topology_basis R, b :e Tsub.
  { let b. assume Hb.
    exact (order_topology_basis_sub_generated_from_open_rays R b Hb). }
  claim Hfiner: finer_than Tsub (generated_topology R (order_topology_basis R)).
  { exact (generated_topology_finer_weak R (order_topology_basis R) Tsub HTsub HBsub). }
  exact (Hfiner U HU).
Qed.

(** from §14 Example 2: dictionary order topology on ℝ×ℝ **) 
(** LATEX VERSION: Example 2 defines the dictionary order topology on ℝ×ℝ via the order topology construction. **)
(** NOTE: We define the dictionary order topology via the open-rays subbasis. This is equivalent to the order-topology construction for the lexicographic order, but avoids dependence on the currently-admitted global order-topology basis axiom. **)
Definition R2_dictionary_order_topology : set :=
  generated_topology_from_subbasis (setprod R R) (open_rays_subbasis (setprod R R)).

Theorem dictionary_order_topology_is_topology :
  topology_on (setprod R R) R2_dictionary_order_topology.
prove topology_on (setprod R R) R2_dictionary_order_topology.
exact (topology_from_subbasis_is_topology (setprod R R)
        (open_rays_subbasis (setprod R R))
        (open_rays_subbasis_is_subbasis (setprod R R))).
Qed.

(** from §14 Example 2: rectangle subbasis yields product-style topology **) 
(** LATEX VERSION: Rectangle-type sets give a basis generating the dictionary order topology on ℝ×ℝ. **)
(** NOTE: Current witness uses the canonical basis from the open-rays subbasis via `basis_of_subbasis`; rectangle characterization is not yet formalized. **)
Theorem rectangles_basis_for_R2 :
  exists B:set, basis_on (setprod R R) B /\ generated_topology (setprod R R) B = R2_dictionary_order_topology.
prove exists B:set, basis_on (setprod R R) B /\ generated_topology (setprod R R) B = R2_dictionary_order_topology.
witness (basis_of_subbasis (setprod R R) (open_rays_subbasis (setprod R R))).
apply andI.
- exact (finite_intersections_basis_of_subbasis (setprod R R)
          (open_rays_subbasis (setprod R R))
          (open_rays_subbasis_is_subbasis (setprod R R))).
- reflexivity.
Qed.

(** from §14 Example 3: order topology on ℤ₊ is discrete **)
(** LATEX VERSION: Example 3: The order topology on the positive integers is the discrete topology. **)
Definition Zplus : set := omega :\: {0}.

(** Helper: 0 is not in Zplus **)
(** Uses the definition Zplus = omega :\: {0}. **)
Theorem zero_not_in_Zplus : 0 /:e Zplus.
prove ~(0 :e Zplus).
assume H0: 0 :e Zplus.
prove False.
claim H0m: 0 :e omega :\: {0}.
{ exact H0. }
claim Hcore: 0 :e omega /\ 0 /:e {0}.
{ exact (setminusE omega {0} 0 H0m). }
claim H0not: 0 /:e {0}.
{ exact (andER (0 :e omega) (0 /:e {0}) Hcore). }
exact (H0not (SingI 0)).
Qed.

(** Helper: 1 is in Zplus **)
(** Uses the definition Zplus = omega :\: {0}. **)
(** LATEX VERSION: Since 1 is in omega and 1 is not 0, we have 1 in omega\\{0} = Zplus. **)
Theorem one_in_Zplus : 1 :e Zplus.
prove 1 :e omega :\: {0}.
claim H1omega: 1 :e omega.
{ exact (nat_p_omega 1 nat_1). }
claim H1not0: 1 /:e {0}.
{ assume H1: 1 :e {0}.
  prove False.
  claim Heq: 1 = 0.
  { exact (SingE 0 1 H1). }
  exact (neq_1_0 Heq). }
exact (setminusI omega {0} 1 H1omega H1not0).
Qed.

(** Helper: 2 is in Zplus **)
(** Uses the definition Zplus = omega :\: {0}. **)
(** LATEX VERSION: Since 2 is in omega and 2 is not 0, we have 2 in omega\\{0} = Zplus. **)
Theorem two_in_Zplus : 2 :e Zplus.
prove 2 :e omega :\: {0}.
claim H2omega: 2 :e omega.
{ exact (nat_p_omega 2 nat_2). }
claim H2not0: 2 /:e {0}.
{ assume H2: 2 :e {0}.
  prove False.
  claim Heq: 2 = 0.
  { exact (SingE 0 2 H2). }
  exact (neq_2_0 Heq). }
exact (setminusI omega {0} 2 H2omega H2not0).
Qed.

(** Helper: 0 is in rational_numbers **)
(** Uses the definition rational = {x :e real | exists m :e int, exists n :e omega :\: {0}, x = m :/: n}. **)
(** LATEX VERSION: 0 is rational since 0 = 0/1 with 0 in int and 1 in omega\\{0}. **)
Theorem zero_in_rational_numbers : 0 :e rational_numbers.
prove 0 :e rational.
claim H0real: 0 :e real.
{ exact real_0. }
claim H0omega: 0 :e omega.
{ exact (nat_p_omega 0 nat_0). }
claim H0int: 0 :e int.
{ exact (Subq_omega_int 0 H0omega). }
claim H1omega: 1 :e omega.
{ exact (nat_p_omega 1 nat_1). }
claim H1not0: 1 /:e {0}.
{ assume H1: 1 :e {0}.
  prove False.
  claim Heq: 1 = 0.
  { exact (SingE 0 1 H1). }
  exact (neq_1_0 Heq). }
claim H1nonzero: 1 :e omega :\: {0}.
{ exact (setminusI omega {0} 1 H1omega H1not0). }
claim Heq0: 0 = div_SNo 0 1.
{ claim Hdiv: div_SNo 0 1 = 0.
  { exact (div_SNo_0_num 1 SNo_1). }
  rewrite <- Hdiv at 1.
  reflexivity. }
claim Hex: exists m :e int, exists n :e omega :\: {0}, 0 = div_SNo m n.
{ witness 0.
  apply andI.
  - exact H0int.
  - witness 1.
    apply andI.
    + exact H1nonzero.
    + exact Heq0. }
exact (SepI real
            (fun x:set => exists m :e int, exists n :e omega :\: {0}, x = div_SNo m n)
            0
            H0real
            Hex).
Qed.

(** Helper: 1 is in rational_numbers **)
(** Uses the definition rational = {x :e real | exists m :e int, exists n :e omega :\: {0}, x = m :/: n}. **)
(** LATEX VERSION: 1 is rational since 1 = 1/1 with 1 in int and 1 in omega\\{0}. **)
Theorem one_in_rational_numbers : 1 :e rational_numbers.
prove 1 :e rational.
claim H1real: 1 :e real.
{ exact real_1. }
claim H1omega: 1 :e omega.
{ exact (nat_p_omega 1 nat_1). }
claim H1int: 1 :e int.
{ exact (Subq_omega_int 1 H1omega). }
claim H1not0: 1 /:e {0}.
{ assume H1: 1 :e {0}.
  prove False.
  claim Heq: 1 = 0.
  { exact (SingE 0 1 H1). }
  exact (neq_1_0 Heq). }
claim H1nonzero: 1 :e omega :\: {0}.
{ exact (setminusI omega {0} 1 H1omega H1not0). }
claim Hrecip1: recip_SNo 1 = 1.
{ claim H1neq0: 1 <> 0.
  { exact neq_1_0. }
  claim Hinv: mul_SNo 1 (recip_SNo 1) = 1.
  { exact (recip_SNo_invR 1 SNo_1 H1neq0). }
  rewrite <- (mul_SNo_oneL (recip_SNo 1) (SNo_recip_SNo 1 SNo_1)) at 1.
  exact Hinv. }
claim Heq1: 1 = div_SNo 1 1.
{ claim Hdivdef: div_SNo 1 1 = mul_SNo 1 (recip_SNo 1).
  { reflexivity. }
  rewrite Hdivdef.
  rewrite Hrecip1.
  rewrite (mul_SNo_oneR 1 SNo_1).
  reflexivity. }
claim Hex: exists m :e int, exists n :e omega :\: {0}, 1 = div_SNo m n.
{ witness 1.
  apply andI.
  - exact H1int.
  - witness 1.
    apply andI.
    + exact H1nonzero.
    + exact Heq1. }
exact (SepI real
            (fun x:set => exists m :e int, exists n :e omega :\: {0}, x = div_SNo m n)
            1
            H1real
            Hex).
Qed.

(** Helper: minus one is in rational_numbers **)
(** LATEX VERSION: Rational numbers are closed under additive inverse, so -1 is rational. **)
Theorem minus_one_in_rational_numbers : minus_SNo 1 :e rational_numbers.
prove minus_SNo 1 :e rational.
claim HdefQ: rational_numbers = rational.
{ reflexivity. }
claim H1rat: 1 :e rational.
{ rewrite <- HdefQ at 1.
  exact one_in_rational_numbers. }
claim Hm1rat: minus_SNo 1 :e rational.
{ exact (rational_minus_SNo 1 H1rat). }
rewrite <- HdefQ at 1.
exact Hm1rat.
Qed.

(** Helper: minus one is not in omega **)
(** LATEX VERSION: omega contains only nonnegative numbers, so -1 is not in omega. **)
Theorem minus_one_not_in_omega : minus_SNo 1 /:e omega.
assume Hm1: minus_SNo 1 :e omega.
prove False.
claim Hle0: 0 <= minus_SNo 1.
{ exact (omega_nonneg (minus_SNo 1) Hm1). }
claim Hm1S: SNo (minus_SNo 1).
{ exact (SNo_minus_SNo 1 SNo_1). }
apply (SNoLeE 0 (minus_SNo 1) SNo_0 Hm1S Hle0 False).
- assume H0ltm1: 0 < minus_SNo 1.
  claim Hm1lt0: minus_SNo 1 < 0.
  { exact minus_1_lt_0. }
  claim H00: 0 < 0.
  { exact (SNoLt_tra 0 (minus_SNo 1) 0 SNo_0 Hm1S SNo_0 H0ltm1 Hm1lt0). }
  exact ((SNoLt_irref 0) H00).
- assume H0eqm1: 0 = minus_SNo 1.
  claim Hm1lt0: minus_SNo 1 < 0.
  { exact minus_1_lt_0. }
  claim H00: 0 < 0.
  { rewrite H0eqm1 at 1.
    exact Hm1lt0. }
  exact ((SNoLt_irref 0) H00).
Qed.

(** Helper: rational_numbers is not omega **)
(** LATEX VERSION: omega does not contain -1, but rational_numbers does, so they are not equal. **)
Theorem rational_numbers_neq_omega : rational_numbers <> omega.
assume Heq: rational_numbers = omega.
prove False.
claim Hm1Q: minus_SNo 1 :e rational_numbers.
{ exact minus_one_in_rational_numbers. }
claim Hm1omega: minus_SNo 1 :e omega.
{ rewrite <- Heq.
  exact Hm1Q. }
exact (minus_one_not_in_omega Hm1omega).
Qed.

(** Helper: rational_numbers is not omega minus {0} **)
(** LATEX VERSION: omega\\{0} still excludes -1, so it cannot equal rational_numbers. **)
Theorem rational_numbers_neq_omega_nonzero : rational_numbers <> (omega :\: {0}).
assume Heq: rational_numbers = omega :\: {0}.
prove False.
claim Hm1Q: minus_SNo 1 :e rational_numbers.
{ exact minus_one_in_rational_numbers. }
claim Hm1NZ: minus_SNo 1 :e omega :\: {0}.
{ rewrite <- Heq.
  exact Hm1Q. }
claim Hm1omega: minus_SNo 1 :e omega.
{ exact (setminusE1 omega {0} (minus_SNo 1) Hm1NZ). }
exact (minus_one_not_in_omega Hm1omega).
Qed.

(** Helper: Zplus is not omega **)
(** LATEX VERSION: 0 is in omega but 0 is not in Zplus, so Zplus is not omega. **)
Theorem Zplus_neq_omega : Zplus <> omega.
