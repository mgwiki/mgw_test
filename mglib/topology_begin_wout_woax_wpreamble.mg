    { exact (SepE2 ordered_square (fun x0:set => order_rel (setprod R R) a0 x0) p01 Hp01I2). }
    claim H1O: 1 :e omega.
    { exact (nat_p_omega 1 nat_1). }
    claim H1not0: 1 /:e {0}.
