                              claim Hxx: order_rel (setprod R R)
                                (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)
                                (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1).
                              { exact (order_rel_trans (setprod R R)
                                       (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)
                                       (add_SNo 1 (minus_SNo (inv_nat (ordsucc i))), eps_ 1)
                                       (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)
                                       simply_ordered_set_setprod_R_R
                                       (tuple_2_setprod_by_pair_Sigma R R
                                          (add_SNo 1 (minus_SNo (inv_nat (ordsucc j)))) (eps_ 1)
                                          (real_add_SNo 1 real_1 (minus_SNo (inv_nat (ordsucc j)))
                                             (real_minus_SNo (inv_nat (ordsucc j)) (inv_nat_real (ordsucc j) (omega_ordsucc j HjO))))
                                          eps_1_in_R)
                                       (tuple_2_setprod_by_pair_Sigma R R
                                          (add_SNo 1 (minus_SNo (inv_nat (ordsucc i)))) (eps_ 1)
                                          (real_add_SNo 1 real_1 (minus_SNo (inv_nat (ordsucc i)))
                                             (real_minus_SNo (inv_nat (ordsucc i)) (inv_nat_real (ordsucc i) (omega_ordsucc i HiO))))
                                          eps_1_in_R)
                                       (tuple_2_setprod_by_pair_Sigma R R
                                          (add_SNo 1 (minus_SNo (inv_nat (ordsucc j)))) (eps_ 1)
                                          (real_add_SNo 1 real_1 (minus_SNo (inv_nat (ordsucc j)))
                                             (real_minus_SNo (inv_nat (ordsucc j)) (inv_nat_real (ordsucc j) (omega_ordsucc j HjO))))
                                          eps_1_in_R)
                                         Hlt_ji Hlt_ij). }
                                exact ((order_rel_irref (setprod R R)
                                         (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)) Hxx). }

                          claim Hlt_j_succi: order_rel (setprod R R)
                            (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)
                            (add_SNo 1 (minus_SNo (inv_nat (ordsucc (ordsucc i)))), eps_ 1).
                          { prove order_rel (setprod R R)
                              (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)
                              (add_SNo 1 (minus_SNo (inv_nat (ordsucc (ordsucc i)))), eps_ 1).
                              rewrite <- HxEqJ at 1.
                              rewrite <- HbcurEq.
                              exact Hxbcur. }

                          (** Compare j with ordsucc i to rule out any possibility **)
                          apply (ordinal_trichotomy_or_impred j (ordsucc i) HjOrd HsuccIOrd False).
                          - assume HjIn: j :e ordsucc i.
                            apply (ordsuccE i j HjIn).
                            + assume Hji: j :e i.
                              exact (In_no2cycle i j HiInj Hji).
                              + assume Hjeq: j = i.
                                claim Hii: i :e i.
                                  { prove i :e i.
                                    rewrite <- Hjeq at 2.
                                    exact HiInj. }
                                exact (In_irref i Hii).
                            - assume Hjeq: j = ordsucc i.
                              apply FalseE.
                                claim HnEqSS: n = ordsucc (ordsucc i).
                                { prove n = ordsucc (ordsucc i).
                                  rewrite <- Hjeq.
                                  exact HnEq. }
                              claim HnminEqSS: nmin = ordsucc (ordsucc i).
                              { rewrite HmEq.
                                rewrite HmEqI.
                                reflexivity. }
                                claim HnEqNmin: n = nmin.
                                { rewrite HnminEqSS.
