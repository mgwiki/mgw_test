        claim HbPair2: (x,y2) = (b1, b2).
        { exact (andER ((inv_nat n,0) = (a1, a2)) ((x,y2) = (b1, b2)) Hpair2). }

        claim Ha1Eq: a1 = inv_nat n.
        { rewrite <- (tuple_2_0_eq a1 a2).
