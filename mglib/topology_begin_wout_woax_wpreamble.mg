Qed.

(** LATEX VERSION: Exercise 18: determine the closure of D={x×1/2 | 0<x<1} in the ordered square. **)
Theorem ex17_18_closure_D_eq :
  closure_of ordered_square ordered_square_topology ordsq_D = ordsq_D_closure.
prove closure_of ordered_square ordered_square_topology ordsq_D = ordsq_D_closure.
apply set_ext.
- let p. assume Hpcl: p :e closure_of ordered_square ordered_square_topology ordsq_D.
  prove p :e ordsq_D_closure.
  claim HpSq: p :e ordered_square.
  { exact (SepE1 ordered_square
           (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_D <> Empty)
           p Hpcl). }
  claim Hcond: forall U:set, U :e ordered_square_topology -> p :e U -> U :/\: ordsq_D <> Empty.
  { exact (SepE2 ordered_square
           (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_D <> Empty)
           p Hpcl). }
  set x := p 0.
  set y := p 1.
  claim HpEta: p = (x,y).
  { exact (setprod_eta unit_interval unit_interval p HpSq). }
  claim HyU: y :e unit_interval.
  { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) p HpSq). }
  claim HxU: x :e unit_interval.
  { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) p HpSq). }
  claim HyR: y :e R.
  { exact (unit_interval_sub_R y HyU). }
  claim HxR: x :e R.
  { exact (unit_interval_sub_R x HxU). }
  claim HyS: SNo y.
  { exact (real_SNo y HyR). }
  claim HxS: SNo x.
  { exact (real_SNo x HxR). }
  apply (xm (y = eps_ 1)).
    - assume Hyeps: y = eps_ 1.
      apply (xm (x = 0)).
      + assume Hx0: x = 0.
        apply FalseE.
        set a := (0,0).
