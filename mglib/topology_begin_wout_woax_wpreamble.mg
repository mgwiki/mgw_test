		              * (** b3 ⊆ b1 **)
		                let y. assume Hy: y :e b3.
		                prove y :e b1.
		                claim HySq: y :e ordered_square.
		                { exact (SepE1 ordered_square (fun y0:set => order_rel RR a1 y0 /\ order_rel RR y0 b2x) y Hy). }
		                claim Hyconj: order_rel RR a1 y /\ order_rel RR y b2x.
		                { exact (SepE2 ordered_square (fun y0:set => order_rel RR a1 y0 /\ order_rel RR y0 b2x) y Hy). }
		                claim Ha1y: order_rel RR a1 y.
		                { exact (andEL (order_rel RR a1 y) (order_rel RR y b2x) Hyconj). }
		                rewrite Hb1eq.
		                exact (SepI ordered_square (fun y0:set => order_rel RR a1 y0) y HySq Ha1y).
		              * (** b3 ⊆ b2 **)
		                let y. assume Hy: y :e b3.
		                prove y :e b2.
		                claim HySq: y :e ordered_square.
		                { exact (SepE1 ordered_square (fun y0:set => order_rel RR a1 y0 /\ order_rel RR y0 b2x) y Hy). }
		                claim HyRR: y :e RR.
		                { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) y HySq). }
		                claim Hyconj: order_rel RR a1 y /\ order_rel RR y b2x.
		                { exact (SepE2 ordered_square (fun y0:set => order_rel RR a1 y0 /\ order_rel RR y0 b2x) y Hy). }
		                claim Ha1y: order_rel RR a1 y.
		                { exact (andEL (order_rel RR a1 y) (order_rel RR y b2x) Hyconj). }
		                claim Ha2y: order_rel RR a2 y.
		                { exact (order_rel_trans RR a2 a1 y HsoRR Ha2RR Ha1RR HyRR Ha2lt Ha1y). }
		                claim Hyb2: order_rel RR y b2x.
		                { exact (andER (order_rel RR a1 y) (order_rel RR y b2x) Hyconj). }
		                rewrite Hb2eq.
		                exact (SepI ordered_square (fun y0:set => order_rel RR a2 y0 /\ order_rel RR y0 b2x) y HySq
		                           (andI (order_rel RR a2 y) (order_rel RR y b2x) Ha2y Hyb2)). }
		      - assume Hb2low: b2 :e Blow.
		        (** upper ray ∩ lower ray: take the interval (a1,b2x) **)
		        claim Hexb2: exists b0 :e ordered_square,
		          b2 = {y :e ordered_square | order_rel RR y b0}.
		        { exact (SepE2 (Power ordered_square)
		                       (fun I:set => exists b0 :e ordered_square,
		                         I = {y :e ordered_square | order_rel RR y b0})
		                       b2
		                       Hb2low). }
		        apply Hexb2.
		        let b2x. assume Hb2pack.
		        apply Hb2pack.
		        assume Hb2xSq Hb2eq.
		        claim Hb2xRR: b2x :e RR.
		        { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) b2x Hb2xSq). }
		        claim Hx2in: x :e {y :e ordered_square | order_rel RR y b2x}.
		        { rewrite <- Hb2eq.
		          exact Hx2. }
		        claim Hxb2: order_rel RR x b2x.
		        { exact (SepE2 ordered_square (fun y:set => order_rel RR y b2x) x Hx2in). }
		        set b3 := {y :e ordered_square | order_rel RR a1 y /\ order_rel RR y b2x}.
		        witness b3.
		        apply andI.
		        - (** b3 in basis **)
		          claim Hb3Pow: b3 :e Power ordered_square.
		          { apply PowerI.
		            let y. assume Hy: y :e b3.
		            exact (SepE1 ordered_square (fun y0:set => order_rel RR a1 y0 /\ order_rel RR y0 b2x) y Hy). }
		          claim Hexab: exists a0 :e ordered_square, exists b0 :e ordered_square,
		            b3 = {y :e ordered_square | order_rel RR a0 y /\ order_rel RR y b0}.
		          { witness a1.
		            apply andI.
		            - exact Ha1Sq.
		            - witness b2x.
		              apply andI.
		              + exact Hb2xSq.
		              + reflexivity. }
		          claim Hb3Bint: b3 :e Bint.
		          { exact (SepI (Power ordered_square)
		                        (fun I:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
		                          I = {y :e ordered_square | order_rel RR a0 y /\ order_rel RR y b0})
		                        b3 Hb3Pow Hexab). }
		          claim Hb3AB: b3 :e (Bint :\/: Blow).
