            apply FalseE.
            claim HzU: z :e U0.
            { exact (binintersectE1 U0 ordsq_C z Hz). }
            claim HzC: z :e ordsq_C.
            { exact (binintersectE2 U0 ordsq_C z Hz). }
            claim HzSq: z :e ordered_square.
            { exact (SepE1 ordered_square
                       (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1)
                       z
                       HzC). }
            claim HzOrd: order_rel (setprod R R) ordsq_p10 z.
            { exact (SepE2 ordered_square (fun x0:set => order_rel (setprod R R) ordsq_p10 x0) z HzU). }
            claim HzEx: exists x0:set, z = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1.
            { exact (SepE2 ordered_square
