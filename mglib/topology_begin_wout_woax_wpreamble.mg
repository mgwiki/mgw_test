      exact Hwb0. }
    claim HwU: w :e U.
    { exact (HIU w HwI). }
    claim Hqlt1: Rlt q 1.
    { exact (Rlt_tra q x 1 Hqltx Hxlt1). }
    claim HwD: w :e ordsq_D.
    { apply (SepI ordered_square
                (fun p0:set => exists x0:set, p0 = (x0,eps_ 1) /\ Rlt 0 x0 /\ Rlt x0 1)
                w
                HwSq).
      witness q.
      prove w = (q,eps_ 1) /\ Rlt 0 q /\ Rlt q 1.
      apply andI.
      - prove w = (q,eps_ 1) /\ Rlt 0 q.
