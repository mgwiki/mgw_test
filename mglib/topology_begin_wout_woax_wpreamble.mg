          { rewrite <- HbPair2 at 1.
            reflexivity. }
          exact H1eq. }

        claim H0lty2: Rlt 0 y2.
        { exact (Rlt_tra 0 y y2 H0ltyR Hylt_y2). }

        claim Hdisj2': Rlt (inv_nat n) x \/ (inv_nat n = x /\ Rlt 0 y2).
        { rewrite <- Ha1Eq at 1.
          rewrite <- Hb1Eq at 1.
          rewrite <- Ha1Eq at 1.
          rewrite <- Hb1Eq at 1.
          rewrite <- Ha2Eq at 1.
          rewrite <- Hb2Eq at 1.
