    set w := (inv_nat 1,0).
    claim HwA: w :e ordsq_A.
    { exact (ReplI (omega :\: {0}) (fun n1:set => (inv_nat n1,0)) 1 H1In). }
    claim HinvR: inv_nat 1 :e R.
    { exact (inv_nat_real 1 H1O). }
    claim Hinvpos: Rlt 0 (inv_nat 1).
    { exact (inv_nat_pos 1 H1In). }
    claim Hnlt0: ~(Rlt (inv_nat 1) 0).
    { exact (not_Rlt_sym 0 (inv_nat 1) Hinvpos). }
    claim Hinvle1: Rle (inv_nat 1) 1.
    { exact (inv_nat_Rle_1_local 1 H1In). }
    claim Hnlt1: ~(Rlt 1 (inv_nat 1)).
    { exact (RleE_nlt (inv_nat 1) 1 Hinvle1). }
    claim HinvU: (inv_nat 1) :e unit_interval.
    { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (inv_nat 1) HinvR).
      apply andI.
      - exact Hnlt0.
      - exact Hnlt1. }
    claim HwSq: w :e ordered_square.
    { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval (inv_nat 1) 0
              HinvU zero_in_unit_interval). }
    claim Hp01w: order_rel (setprod R R) p01 w.
    { rewrite Hp01def.
      apply (order_rel_setprod_R_R_intro 0 1 (inv_nat 1) 0).
      apply orIL.
      exact Hinvpos. }
    claim Ha0RR: a0 :e setprod R R.
    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) a0 Ha0Sq). }
    claim Hp01RR: p01 :e setprod R R.
    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p01 Hp01Sq). }
    claim HwRR: w :e setprod R R.
    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq). }
    claim Ha0w: order_rel (setprod R R) a0 w.
    { exact (order_rel_trans (setprod R R) a0 p01 w
