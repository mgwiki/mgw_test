    claim HwI: w :e I.
    { rewrite HeqI.
      apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) a0 x0) w HwSq).
      exact Ha0w. }
    claim HwU: w :e U.
    { exact (HIU w HwI). }
    claim HwUcap: w :e U :/\: ordsq_A.
    { exact (binintersectI U ordsq_A w HwU HwA). }
    exact (elem_implies_nonempty (U :/\: ordsq_A) w HwUcap).
Qed.

(** helper: reverse inclusion for closure of A in the ordered square **)
(** LATEX VERSION: cl(A) ⊆ A ∪ {(0,1)}. **)
Theorem ex17_18_closure_A_Subq :
  closure_of ordered_square ordered_square_topology ordsq_A c= ordsq_A :\/: {ordsq_p01}.
let p. assume Hpcl: p :e closure_of ordered_square ordered_square_topology ordsq_A.
prove p :e ordsq_A :\/: {ordsq_p01}.
set p01 := ordsq_p01.
claim Hp01def: p01 = (0,1).
{ reflexivity. }
claim Hp01Sq: p01 :e ordered_square.
{ rewrite Hp01def.
  exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 0 1 zero_in_unit_interval one_in_unit_interval). }
claim Hp01RR: p01 :e setprod R R.
{ exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p01 Hp01Sq). }

(** unfold closure to get p :e ordered_square and the neighborhood condition **)
claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_A =
  {x :e ordered_square | forall U:set, U :e ordered_square_topology -> x :e U -> U :/\: ordsq_A <> Empty}.
{ reflexivity. }
claim Hpcl': p :e {x :e ordered_square | forall U:set, U :e ordered_square_topology -> x :e U -> U :/\: ordsq_A <> Empty}.
{ rewrite <- Hdefcl.
  exact Hpcl. }
claim HpSq: p :e ordered_square.
{ exact (SepE1 ordered_square
         (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_A <> Empty)
         p Hpcl'). }
claim Hcond: forall U:set, U :e ordered_square_topology -> p :e U -> U :/\: ordsq_A <> Empty.
{ exact (SepE2 ordered_square
         (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_A <> Empty)
         p Hpcl'). }
claim HpRR: p :e setprod R R.
{ exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) p HpSq). }

(** split by trichotomy around p01 **)
apply (order_rel_trichotomy_or_impred (setprod R R) p01 p
        simply_ordered_set_setprod_R_R Hp01RR HpRR
        (p :e ordsq_A :\/: {ordsq_p01})).
- assume Hp01p: order_rel (setprod R R) p01 p.
  apply binunionI1.
  (** analyze p01<p via coordinates p=(x,y) **)
  set x := p 0.
  set y := p 1.
  claim HpEq: p = (x,y).
  { exact (setprod_eta unit_interval unit_interval p HpSq). }
  claim HxI: x :e unit_interval.
  { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) p HpSq). }
  claim HyI: y :e unit_interval.
  { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) p HpSq). }
  claim HxR: x :e R.
  { exact (unit_interval_sub_R x HxI). }
  claim HyR: y :e R.
  { exact (unit_interval_sub_R y HyI). }
  claim HyProp: ~(Rlt y 0) /\ ~(Rlt 1 y).
  { exact (SepE2 R (fun z:set => ~(Rlt z 0) /\ ~(Rlt 1 z)) y HyI). }
  claim Hnot1y: ~(Rlt 1 y).
  { exact (andER (~(Rlt y 0)) (~(Rlt 1 y)) HyProp). }
  claim Hp01p': order_rel (setprod R R) (0,1) (x,y).
  { rewrite <- Hp01def.
    rewrite <- HpEq.
    exact Hp01p. }
  claim Hex: exists c1 c2 d1 d2:set,
    (0,1) = (c1,c2) /\ (x,y) = (d1,d2) /\
    (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
  { exact (order_rel_setprod_R_R_unfold (0,1) (x,y) Hp01p'). }
  claim Hxpos: Rlt 0 x.
  { apply Hex.
    let c1. assume Hc1.
    apply Hc1.
    let c2. assume Hc2.
    apply Hc2.
    let d1. assume Hd1.
    apply Hd1.
    let d2. assume Hcore.
    apply Hcore.
    assume Hpair Hdisj.
    apply Hdisj.
    - assume Hlt: Rlt c1 d1.
      claim Heq01: (0,1) = (c1,c2).
      { exact (andEL ((0,1) = (c1,c2)) ((x,y) = (d1,d2)) Hpair). }
      claim Heqp: (x,y) = (d1,d2).
      { exact (andER ((0,1) = (c1,c2)) ((x,y) = (d1,d2)) Hpair). }
      claim Hc1eq0: 0 = c1.
      { claim Htmp0: (0,1) 0 = (c1,c2) 0.
        { rewrite Heq01. reflexivity. }
        claim Htmp1: 0 = c1.
        { rewrite <- (tuple_2_0_eq 0 1).
          rewrite <- (tuple_2_0_eq c1 c2).
          exact Htmp0. }
        exact Htmp1. }
      claim Hd1eqx: x = d1.
      { claim Htmp0: (x,y) 0 = (d1,d2) 0.
        { rewrite Heqp. reflexivity. }
        claim Htmp1: x = d1.
        { rewrite <- (tuple_2_0_eq x y).
          rewrite <- (tuple_2_0_eq d1 d2).
          exact Htmp0. }
        exact Htmp1. }
      rewrite Hd1eqx.
      rewrite Hc1eq0.
      exact Hlt.
    - assume Heq2: c1 = d1 /\ Rlt c2 d2.
      apply FalseE.
      claim Heq01: (0,1) = (c1,c2).
      { exact (andEL ((0,1) = (c1,c2)) ((x,y) = (d1,d2)) Hpair). }
      claim Heqp: (x,y) = (d1,d2).
      { exact (andER ((0,1) = (c1,c2)) ((x,y) = (d1,d2)) Hpair). }
      claim Hc2eq1: c2 = 1.
      { claim Htmp0: (0,1) 1 = (c1,c2) 1.
        { rewrite Heq01. reflexivity. }
        claim Htmp1: 1 = c2.
        { rewrite <- (tuple_2_1_eq 0 1).
          rewrite <- (tuple_2_1_eq c1 c2).
          exact Htmp0. }
        rewrite <- Htmp1. reflexivity. }
      claim Hd2eqy: y = d2.
      { claim Htmp0: (x,y) 1 = (d1,d2) 1.
        { rewrite Heqp. reflexivity. }
        claim Htmp1: y = d2.
        { rewrite <- (tuple_2_1_eq x y).
          rewrite <- (tuple_2_1_eq d1 d2).
          exact Htmp0. }
        exact Htmp1. }
      claim H1lty: Rlt 1 y.
      { claim Hlt12: Rlt c2 d2.
        { exact (andER (c1 = d1) (Rlt c2 d2) Heq2). }
        rewrite Hd2eqy.
        rewrite <- Hc2eq1.
        exact Hlt12. }
      exact (Hnot1y H1lty). }
  (** now force y = 0, then x ∈ K_set, hence p ∈ A **)
  claim HyS: SNo y.
  { exact (real_SNo y HyR). }
  apply (SNoLt_trichotomy_or_impred y 0 HyS SNo_0 (p :e ordsq_A)).
  - assume Hylt0: y < 0.
    apply FalseE.
    claim Hnoty0: ~(Rlt y 0).
    { exact (andEL (~(Rlt y 0)) (~(Rlt 1 y)) HyProp). }
    claim Hyl0R: Rlt y 0.
    { exact (RltI y 0 HyR real_0 Hylt0). }
    exact (Hnoty0 Hyl0R).
  - assume Hy0: y = 0.
    (** reduce to x ∈ K_set, then p = (inv_nat n,0) **)
    claim HxS: SNo x.
    { exact (real_SNo x HxR). }
    apply (xm (x :e K_set)).
    + assume HxK: x :e K_set.
      (** extract n with x = inv_nat n **)
      claim Hexn: exists n :e omega :\: {0}, x = inv_nat n.
      { exact (ReplE (omega :\: {0}) (fun n0:set => inv_nat n0) x HxK). }
      apply Hexn.
      let n. assume Hnpack.
      apply Hnpack.
      assume HnIn Hxeq.
      claim Hpeq: p = (inv_nat n,0).
      { rewrite HpEq.
        rewrite Hxeq.
        rewrite Hy0.
        reflexivity. }
      rewrite Hpeq.
      exact (ReplI (omega :\: {0}) (fun m0:set => (inv_nat m0,0)) n HnIn).
      + assume HxNotK: ~(x :e K_set).
        (** use an open neighborhood of x in R disjoint from K_set to contradict closure **)
        apply FalseE.
        claim H0ltx: 0 < x.
        { exact (RltE_lt 0 x Hxpos). }
        claim HexU: exists U:set, U :e R_standard_topology /\ x :e U /\ U :/\: K_set = Empty.
        { exact (standard_open_neighborhood_disjoint_from_K_set_pos x HxR H0ltx HxNotK). }
        (** TODO: refine U to an interval (a,b)⊆U with a,b in unit_interval and build an order-basis neighborhood of p disjoint from ordsq_A. **)
        apply HexU.
        let U0. assume HUpack.
        claim Hcore: U0 :e R_standard_topology /\ x :e U0.
        { exact (andEL (U0 :e R_standard_topology /\ x :e U0) (U0 :/\: K_set = Empty) HUpack). }
        claim HU0Kempty: U0 :/\: K_set = Empty.
        { exact (andER (U0 :e R_standard_topology /\ x :e U0) (U0 :/\: K_set = Empty) HUpack). }
        claim HU0open: U0 :e R_standard_topology.
        { exact (andEL (U0 :e R_standard_topology) (x :e U0) Hcore). }
        claim HxU0: x :e U0.
        { exact (andER (U0 :e R_standard_topology) (x :e U0) Hcore). }
        claim Hexab: exists a b:set,
          a :e R /\ b :e R /\
          x :e open_interval a b /\
          open_interval a b c= U0 /\
          Rlt a x /\ Rlt x b.
        { exact (R_standard_open_refine_interval U0 x HU0open HxU0). }
        apply Hexab.
        let a. assume Hapak.
        apply Hapak.
        let b. assume Habpack.
        (** unpack the interval data from `R_standard_open_refine_interval` (left-associative conjunctions) **)
        apply Habpack.
        assume Hab1 Hxltb.
        apply Hab1.
        assume Hab2 Haltx.
        apply Hab2.
        assume Hab3 HabSubU0.
        apply Hab3.
        assume HabR HxInt.
        apply HabR.
        assume HaR HbR.
        claim HabIntKempty: open_interval a b :/\: K_set = Empty.
        { apply (Empty_Subq_eq (open_interval a b :/\: K_set)).
          let z. assume Hz: z :e open_interval a b :/\: K_set.
          apply FalseE.
          claim HzInt: z :e open_interval a b.
          { exact (binintersectE1 (open_interval a b) K_set z Hz). }
          claim HzK: z :e K_set.
          { exact (binintersectE2 (open_interval a b) K_set z Hz). }
          claim HzU0: z :e U0.
          { exact (HabSubU0 z HzInt). }
          claim HzU0K: z :e U0 :/\: K_set.
          { exact (binintersectI U0 K_set z HzU0 HzK). }
          claim HzEmpty: z :e Empty.
          { rewrite <- HU0Kempty.
            exact HzU0K. }
          exact (EmptyE z HzEmpty).
        }
          (** TODO: use `HaR HbR HxInt HabSubU0 Haltx Hxltb HabIntKempty` to build an order-basis neighborhood W of p in `ordered_square_topology`
              with `W :/\\: ordsq_A = Empty`, contradicting closure. **)
            claim HinvNotInt: forall n:set, n :e omega :\: {0} -> ~(inv_nat n :e open_interval a b).
            { let n. assume HnIn: n :e omega :\: {0}.
              exact (inv_nat_not_in_open_interval_of_empty_cap_K_set a b HabIntKempty n HnIn). }
            (** pick q1 with a < q1 < x and q1 rational in the unit interval **)
            claim HxProp2: ~(Rlt x 0) /\ ~(Rlt 1 x).
            { exact (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) x HxI). }
            claim Hnot1x: ~(Rlt 1 x).
            { exact (andER (~(Rlt x 0)) (~(Rlt 1 x)) HxProp2). }
            claim HaS: SNo a.
            { exact (real_SNo a HaR). }
            claim Hexq1: exists q1:set,
              q1 :e rational_numbers /\ Rlt a q1 /\ Rlt q1 x /\ q1 :e unit_interval.
            { apply (SNoLt_trichotomy_or_impred a 0 HaS SNo_0
                (exists q1:set, q1 :e rational_numbers /\ Rlt a q1 /\ Rlt q1 x /\ q1 :e unit_interval)).
              - assume Halt0: a < 0.
                claim Halt0R: Rlt a 0.
                { exact (RltI a 0 HaR real_0 Halt0). }
                apply (rational_dense_between_reals 0 x real_0 HxR Hxpos).
                let q1. assume Hqpair. apply Hqpair.
                assume HqQ: q1 :e rational_numbers.
                assume Hqprop: Rlt 0 q1 /\ Rlt q1 x.
                claim H0ltq1: Rlt 0 q1.
                { exact (andEL (Rlt 0 q1) (Rlt q1 x) Hqprop). }
                claim Hq1ltx: Rlt q1 x.
                { exact (andER (Rlt 0 q1) (Rlt q1 x) Hqprop). }
                claim HaLtq1: Rlt a q1.
                { exact (Rlt_tra a 0 q1 Halt0R H0ltq1). }
                claim Hq1R: q1 :e R.
                { exact (rational_numbers_in_R q1 HqQ). }
                claim Hnltq10: ~(Rlt q1 0).
                { exact (not_Rlt_sym 0 q1 H0ltq1). }
                claim Hnlt1q1: ~(Rlt 1 q1).
                { assume H1ltq1: Rlt 1 q1.
                  claim H1ltx: Rlt 1 x.
                  { exact (Rlt_tra 1 q1 x H1ltq1 Hq1ltx). }
                  exact (Hnot1x H1ltx). }
                claim Hq1U: q1 :e unit_interval.
                { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q1 Hq1R).
                  apply andI.
                  - exact Hnltq10.
                  - exact Hnlt1q1. }
                witness q1.
                apply andI.
                - apply andI.
                  - apply andI.
                    - exact HqQ.
                    - exact HaLtq1.
                  - exact Hq1ltx.
                - exact Hq1U.
              - assume Haeq0: a = 0.
                apply (rational_dense_between_reals 0 x real_0 HxR Hxpos).
                let q1. assume Hqpair. apply Hqpair.
                assume HqQ: q1 :e rational_numbers.
                assume Hqprop: Rlt 0 q1 /\ Rlt q1 x.
                claim H0ltq1: Rlt 0 q1.
                { exact (andEL (Rlt 0 q1) (Rlt q1 x) Hqprop). }
                claim Hq1ltx: Rlt q1 x.
                { exact (andER (Rlt 0 q1) (Rlt q1 x) Hqprop). }
                claim HaLtq1: Rlt a q1.
                { rewrite Haeq0.
                  exact H0ltq1. }
                claim Hq1R: q1 :e R.
                { exact (rational_numbers_in_R q1 HqQ). }
                claim Hnltq10: ~(Rlt q1 0).
                { exact (not_Rlt_sym 0 q1 H0ltq1). }
                claim Hnlt1q1: ~(Rlt 1 q1).
                { assume H1ltq1: Rlt 1 q1.
                  claim H1ltx: Rlt 1 x.
                  { exact (Rlt_tra 1 q1 x H1ltq1 Hq1ltx). }
                  exact (Hnot1x H1ltx). }
                claim Hq1U: q1 :e unit_interval.
                { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q1 Hq1R).
                  apply andI.
                  - exact Hnltq10.
                  - exact Hnlt1q1. }
                witness q1.
                apply andI.
                - apply andI.
                  - apply andI.
                    - exact HqQ.
                    - exact HaLtq1.
                  - exact Hq1ltx.
                - exact Hq1U.
              - assume H0lta: 0 < a.
                claim H0ltaR: Rlt 0 a.
                { exact (RltI 0 a real_0 HaR H0lta). }
                apply (rational_dense_between_reals a x HaR HxR Haltx).
                let q1. assume Hqpair. apply Hqpair.
                assume HqQ: q1 :e rational_numbers.
                assume Hqprop: Rlt a q1 /\ Rlt q1 x.
                claim HaLtq1: Rlt a q1.
                { exact (andEL (Rlt a q1) (Rlt q1 x) Hqprop). }
                claim Hq1ltx: Rlt q1 x.
                { exact (andER (Rlt a q1) (Rlt q1 x) Hqprop). }
                claim H0ltq1: Rlt 0 q1.
                { exact (Rlt_tra 0 a q1 H0ltaR HaLtq1). }
                claim Hq1R: q1 :e R.
                { exact (rational_numbers_in_R q1 HqQ). }
                claim Hnltq10: ~(Rlt q1 0).
                { exact (not_Rlt_sym 0 q1 H0ltq1). }
                claim Hnlt1q1: ~(Rlt 1 q1).
                { assume H1ltq1: Rlt 1 q1.
                  claim H1ltx: Rlt 1 x.
                  { exact (Rlt_tra 1 q1 x H1ltq1 Hq1ltx). }
                  exact (Hnot1x H1ltx). }
                claim Hq1U: q1 :e unit_interval.
                { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q1 Hq1R).
                  apply andI.
                  - exact Hnltq10.
                  - exact Hnlt1q1. }
                witness q1.
                apply andI.
                - apply andI.
                  - apply andI.
                    - exact HqQ.
                    - exact HaLtq1.
                  - exact Hq1ltx.
                - exact Hq1U. }
            apply Hexq1.
            let q1. assume Hq1pack.
            apply Hq1pack.
            assume Hq1left Hq1U.
            apply Hq1left.
            assume Hq1left2 Hq1ltx.
            apply Hq1left2.
            assume Hq1Q HaLtq1.

            set W := {z :e ordered_square | order_rel (setprod R R) (q1,1) z /\ order_rel (setprod R R) z (x, eps_ 1)}.
            claim HWpow: W :e Power ordered_square.
            { exact (Sep_In_Power ordered_square (fun z0:set => order_rel (setprod R R) (q1,1) z0 /\ order_rel (setprod R R) z0 (x, eps_ 1))). }
            claim Ha0Sq: (q1,1) :e ordered_square.
            { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval q1 1 Hq1U one_in_unit_interval). }
            claim Hb0Sq: (x, eps_ 1) :e ordered_square.
            { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval x (eps_ 1) HxI eps_1_in_unit_interval). }
              claim HWbas: W :e ordered_square_order_basis.
              { set Bint := {I :e Power ordered_square | exists a0 :e ordered_square, exists b0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}}.
                set Blow := {I :e Power ordered_square | exists b0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}}.
                set Bup := {I :e Power ordered_square | exists a0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}}.
                claim HdefB: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
                { reflexivity. }
                rewrite HdefB.
                apply binunionI1.
                apply binunionI1.
                apply (SepI (Power ordered_square)
                  (fun I:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
                    I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0})
                  W HWpow).
                witness (q1,1).
                apply andI.
                - exact Ha0Sq.
                - witness (x, eps_ 1).
                  apply andI.
                  - exact Hb0Sq.
                  - reflexivity. }
            claim HWtop: W :e ordered_square_topology.
            { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
              { reflexivity. }
              rewrite HdefT.
              exact (generated_topology_contains_elem ordered_square ordered_square_order_basis W HWpow HWbas). }
            claim HpW: p :e W.
            { apply (SepI ordered_square
                     (fun z0:set => order_rel (setprod R R) (q1,1) z0 /\ order_rel (setprod R R) z0 (x, eps_ 1))
                     p
                     HpSq).
              claim Hleft: order_rel (setprod R R) (q1,1) p.
              { rewrite HpEq.
                rewrite Hy0.
                apply (order_rel_setprod_R_R_intro q1 1 x 0).
                apply orIL.
                exact Hq1ltx. }
                    claim Hright: order_rel (setprod R R) p (x, eps_ 1).
                    { rewrite HpEq at 1.
                      rewrite Hy0 at 1.
                      exact (order_rel_setprod_R_R_same_first x 0 (eps_ 1) eps_1_pos_R). }
              exact (andI (order_rel (setprod R R) (q1,1) p)
                          (order_rel (setprod R R) p (x, eps_ 1))
                          Hleft Hright). }

            claim HWcapEq: W :/\: ordsq_A = Empty.
            { claim HWcapSub: W :/\: ordsq_A c= Empty.
              { let w. assume Hw: w :e W :/\: ordsq_A.
                prove w :e Empty.
                apply FalseE.
                claim HwW: w :e W.
                { exact (binintersectE1 W ordsq_A w Hw). }
                claim HwA: w :e ordsq_A.
                { exact (binintersectE2 W ordsq_A w Hw). }
                claim Hexn: exists n :e omega :\: {0}, w = (inv_nat n,0).
                { exact (ReplE (omega :\: {0}) (fun m0:set => (inv_nat m0,0)) w HwA). }
                apply Hexn.
                let n. assume Hnpack.
                apply Hnpack.
                assume HnIn Hweq.
                claim HnOmega: n :e omega.
                { exact (andEL (n :e omega) (n /:e {0}) (setminusE omega {0} n HnIn)). }
                claim HinvR: inv_nat n :e R.
                { exact (inv_nat_real n HnOmega). }
                claim Hord1: order_rel (setprod R R) (q1,1) (inv_nat n,0).
                { claim Htmp: order_rel (setprod R R) (q1,1) w.
                  { exact (andEL (order_rel (setprod R R) (q1,1) w)
                                 (order_rel (setprod R R) w (x, eps_ 1))
                                 (SepE2 ordered_square
                                        (fun z0:set => order_rel (setprod R R) (q1,1) z0 /\ order_rel (setprod R R) z0 (x, eps_ 1))
                                        w HwW)). }
                  rewrite <- Hweq.
                  exact Htmp. }
                claim Hord2: order_rel (setprod R R) (inv_nat n,0) (x, eps_ 1).
                { claim Htmp: order_rel (setprod R R) w (x, eps_ 1).
                  { exact (andER (order_rel (setprod R R) (q1,1) w)
                                 (order_rel (setprod R R) w (x, eps_ 1))
                                 (SepE2 ordered_square
                                        (fun z0:set => order_rel (setprod R R) (q1,1) z0 /\ order_rel (setprod R R) z0 (x, eps_ 1))
                                        w HwW)). }
                  rewrite <- Hweq at 1.
                  exact Htmp. }
                (** extract q1 < inv_nat n from Hord1 **)
                claim Hex1: exists a1 a2 b1 b2:set,
                  (q1,1) = (a1, a2) /\ (inv_nat n,0) = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
                { exact (order_rel_setprod_R_R_unfold (q1,1) (inv_nat n,0) Hord1). }
                claim Hq1ltInv: Rlt q1 (inv_nat n).
                { apply Hex1.
                  let a1. assume Ha1.
                  apply Ha1.
                  let a2. assume Ha2.
                  apply Ha2.
                  let b1. assume Hb1.
                  apply Hb1.
                  let b2. assume Hcore.
                  apply Hcore.
                  assume Hpair Hdisj.
                  claim Hpa: (q1,1) = (a1,a2).
                  { exact (andEL ((q1,1) = (a1,a2)) ((inv_nat n,0) = (b1,b2)) Hpair). }
                  claim Hpb: (inv_nat n,0) = (b1,b2).
                  { exact (andER ((q1,1) = (a1,a2)) ((inv_nat n,0) = (b1,b2)) Hpair). }
                  claim Ha1eq: q1 = a1.
                  { rewrite <- (tuple_2_0_eq q1 1).
                    rewrite <- (tuple_2_0_eq a1 a2).
                    claim H0eq: (q1,1) 0 = (a1,a2) 0.
                    { rewrite Hpa. reflexivity. }
                    exact H0eq. }
                  claim Ha2eq: 1 = a2.
                  { rewrite <- (tuple_2_1_eq q1 1).
                    rewrite <- (tuple_2_1_eq a1 a2).
                    claim H1eq: (q1,1) 1 = (a1,a2) 1.
                    { rewrite Hpa. reflexivity. }
                    exact H1eq. }
                  claim Hb1eq: inv_nat n = b1.
                  { rewrite <- (tuple_2_0_eq (inv_nat n) 0).
                    rewrite <- (tuple_2_0_eq b1 b2).
                    claim H0eq: (inv_nat n,0) 0 = (b1,b2) 0.
                    { rewrite Hpb. reflexivity. }
                    exact H0eq. }
                  claim Hb2eq: 0 = b2.
                  { rewrite <- (tuple_2_1_eq (inv_nat n) 0).
                    rewrite <- (tuple_2_1_eq b1 b2).
                    claim H1eq: (inv_nat n,0) 1 = (b1,b2) 1.
                    { rewrite Hpb. reflexivity. }
                    exact H1eq. }
                  claim Hdisj': Rlt q1 (inv_nat n) \/ (q1 = inv_nat n /\ Rlt 1 0).
                  { rewrite Ha1eq.
                    rewrite Hb1eq.
                    rewrite Ha2eq.
                    rewrite Hb2eq.
                    exact Hdisj. }
                  apply Hdisj'.
                  - assume Hlt. exact Hlt.
                  - assume Hbad.
                    apply FalseE.
                    claim H10: Rlt 1 0.
                    { exact (andER (q1 = inv_nat n) (Rlt 1 0) Hbad). }
                    exact ((not_Rlt_sym 0 1 Rlt_0_1) H10). }
                (** extract inv_nat n < x from Hord2, using x notin K_set to rule out equality **)
                claim Hex2: exists a1 a2 b1 b2:set,
                  (inv_nat n,0) = (a1, a2) /\ (x, eps_ 1) = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
                { exact (order_rel_setprod_R_R_unfold (inv_nat n,0) (x, eps_ 1) Hord2). }
                claim Hinvltx: Rlt (inv_nat n) x.
                { apply Hex2.
                  let a1. assume Ha1.
                  apply Ha1.
                  let a2. assume Ha2.
                  apply Ha2.
                  let b1. assume Hb1.
                  apply Hb1.
                  let b2. assume Hcore.
                  apply Hcore.
                  assume Hpair Hdisj.
                  claim Hpa: (inv_nat n,0) = (a1,a2).
                  { exact (andEL ((inv_nat n,0) = (a1,a2)) ((x,eps_ 1) = (b1,b2)) Hpair). }
                  claim Hpb: (x,eps_ 1) = (b1,b2).
                  { exact (andER ((inv_nat n,0) = (a1,a2)) ((x,eps_  1) = (b1,b2)) Hpair). }
                  claim Ha1eq: inv_nat n = a1.
                  { rewrite <- (tuple_2_0_eq (inv_nat n) 0).
                    rewrite <- (tuple_2_0_eq a1 a2).
                    claim H0eq: (inv_nat n,0) 0 = (a1,a2) 0.
                    { rewrite Hpa. reflexivity. }
                    exact H0eq. }
                  claim Ha2eq: 0 = a2.
                  { rewrite <- (tuple_2_1_eq (inv_nat n) 0).
                    rewrite <- (tuple_2_1_eq a1 a2).
                    claim H1eq: (inv_nat n,0) 1 = (a1,a2) 1.
                    { rewrite Hpa. reflexivity. }
                    exact H1eq. }
                  claim Hb1eq: x = b1.
                  { rewrite <- (tuple_2_0_eq x (eps_ 1)).
                    rewrite <- (tuple_2_0_eq b1 b2).
                    claim H0eq: (x,eps_ 1) 0 = (b1,b2) 0.
                    { rewrite Hpb. reflexivity. }
                    exact H0eq. }
                  apply Hdisj.
                  - assume Hlt: Rlt a1 b1.
                    rewrite Ha1eq.
                    rewrite Hb1eq.
                    exact Hlt.
                  - assume Heq_and: a1 = b1 /\ Rlt a2 b2.
                    apply FalseE.
                    claim Heq1: a1 = b1.
                    { exact (andEL (a1 = b1) (Rlt a2 b2) Heq_and). }
                    claim Heq: inv_nat n = x.
                    { rewrite Ha1eq.
                      rewrite Hb1eq.
                      exact Heq1. }
                    claim HxK: x :e K_set.
                    { rewrite <- Heq.
                      exact (ReplI (omega :\: {0}) (fun t:set => inv_nat t) n HnIn). }
                    exact (HxNotK HxK). }
                (** derive inv_nat n :e open_interval a b and contradict HinvNotInt **)
                claim Hainv: Rlt a (inv_nat n).
                { exact (Rlt_tra a q1 (inv_nat n) HaLtq1 Hq1ltInv). }
                claim Hinvb: Rlt (inv_nat n) b.
                { exact (Rlt_tra (inv_nat n) x b Hinvltx Hxltb). }
                claim HinvInt: inv_nat n :e open_interval a b.
                { claim Hop_def: open_interval a b = {t :e R | Rlt a t /\ Rlt t b}.
                  { reflexivity. }
                  rewrite Hop_def.
                  apply (SepI R (fun t:set => Rlt a t /\ Rlt t b) (inv_nat n) HinvR).
                  exact (andI (Rlt a (inv_nat n)) (Rlt (inv_nat n) b) Hainv Hinvb). }
                exact ((HinvNotInt n HnIn) HinvInt). }
              exact (Empty_Subq_eq (W :/\: ordsq_A) HWcapSub). }

            exact ((Hcond W HWtop HpW) HWcapEq).
  - assume H0lty: 0 < y.
    (** y>0 gives a local order-interval neighborhood of p disjoint from ordsq_A, contradicting closure **)
    apply FalseE.
    claim H0ltyR: Rlt 0 y.
    { exact (RltI 0 y real_0 HyR H0lty). }
    apply (SNoLt_trichotomy_or_impred y 1 HyS SNo_1 False).
    + assume Hylt1: y < 1.
      (** choose rationals 0<q<y<y2<1 **)
      apply (rational_dense_between_reals 0 y real_0 HyR H0ltyR).
      let q. assume Hqpair. apply Hqpair.
      assume HqQ: q :e rational_numbers.
      assume Hqprop: Rlt 0 q /\ Rlt q y.
      claim H0ltq: Rlt 0 q.
      { exact (andEL (Rlt 0 q) (Rlt q y) Hqprop). }
      claim Hqlty: Rlt q y.
      { exact (andER (Rlt 0 q) (Rlt q y) Hqprop). }
      claim HqR: q :e R.
      { exact (rational_numbers_in_R q HqQ). }
      claim Hylt1R: Rlt y 1.
      { exact (RltI y 1 HyR real_1 Hylt1). }
      apply (rational_dense_between_reals y 1 HyR real_1 Hylt1R).
      let y2. assume Hy2pair. apply Hy2pair.
      assume Hy2Q: y2 :e rational_numbers.
      assume Hy2prop: Rlt y y2 /\ Rlt y2 1.
      claim Hylt_y2: Rlt y y2.
      { exact (andEL (Rlt y y2) (Rlt y2 1) Hy2prop). }
      claim Hy2lt1: Rlt y2 1.
      { exact (andER (Rlt y y2) (Rlt y2 1) Hy2prop). }
      claim Hy2R: y2 :e R.
      { exact (rational_numbers_in_R y2 Hy2Q). }
      (** build the basic interval neighborhood U = ((x,q),(x,y2)) in the order topology **)
      set a0 := (x,q).
      set b0 := (x,y2).
      claim Ha0Sq: a0 :e ordered_square.
      { claim Hsqdef: ordered_square = setprod unit_interval unit_interval.
        { reflexivity. }
        rewrite Hsqdef.
        claim Ha0def: a0 = (x,q).
        { reflexivity. }
        rewrite Ha0def.
        exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval x q HxI
          (SepI R (fun z:set => ~(Rlt z 0) /\ ~(Rlt 1 z)) q HqR
            (andI (~(Rlt q 0)) (~(Rlt 1 q))
              (not_Rlt_sym 0 q H0ltq)
              (not_Rlt_sym q 1 (Rlt_tra q y 1 Hqlty Hylt1R))))). }
      claim Hb0Sq: b0 :e ordered_square.
      { claim Hsqdef: ordered_square = setprod unit_interval unit_interval.
        { reflexivity. }
        rewrite Hsqdef.
        claim Hb0def: b0 = (x,y2).
        { reflexivity. }
        rewrite Hb0def.
        claim H0lty2: Rlt 0 y2.
        { exact (Rlt_tra 0 y y2 H0ltyR Hylt_y2). }
        exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval x y2 HxI
          (SepI R (fun z:set => ~(Rlt z 0) /\ ~(Rlt 1 z)) y2 Hy2R
            (andI (~(Rlt y2 0)) (~(Rlt 1 y2))
              (not_Rlt_sym 0 y2 H0lty2)
              (not_Rlt_sym y2 1 Hy2lt1)))). }
      set U := {z :e ordered_square | order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0}.
      claim HUpow: U :e Power ordered_square.
      { apply (PowerI ordered_square U).
        let z. assume Hz: z :e U.
        exact (SepE1 ordered_square
                    (fun z0:set => order_rel (setprod R R) a0 z0 /\ order_rel (setprod R R) z0 b0)
                    z Hz). }
      claim HUbas: U :e ordered_square_order_basis.
      { set Bint := {J :e Power ordered_square | exists a1 :e ordered_square, exists b1 :e ordered_square,
          J = {x0 :e ordered_square | order_rel (setprod R R) a1 x0 /\ order_rel (setprod R R) x0 b1}}.
        set Blow := {J :e Power ordered_square | exists b1 :e ordered_square,
          J = {x0 :e ordered_square | order_rel (setprod R R) x0 b1}}.
        set Bup := {J :e Power ordered_square | exists a1 :e ordered_square,
          J = {x0 :e ordered_square | order_rel (setprod R R) a1 x0}}.
        claim HUinBint: U :e Bint.
        { apply (SepI (Power ordered_square)
                 (fun J0:set => exists a1 :e ordered_square, exists b1 :e ordered_square,
                   J0 = {x0 :e ordered_square | order_rel (setprod R R) a1 x0 /\ order_rel (setprod R R) x0 b1})
                 U HUpow).
