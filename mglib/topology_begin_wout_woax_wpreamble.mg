	           (** lower ray ∩ lower ray: pick the smaller endpoint **)
           claim Hexb2: exists b0 :e ordered_square,
             b2 = {y :e ordered_square | order_rel RR y b0}.
           { exact (SepE2 (Power ordered_square)
                          (fun I:set => exists b0 :e ordered_square,
                            I = {y :e ordered_square | order_rel RR y b0})
                          b2
                          Hb2low). }
           apply Hexb2.
           let b2x. assume Hb2pack.
           apply Hb2pack.
           assume Hb2xSq Hb2eq.
           claim Hb2xRR: b2x :e RR.
           { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) b2x Hb2xSq). }
           claim Hx2in: x :e {y :e ordered_square | order_rel RR y b2x}.
           { rewrite <- Hb2eq.
             exact Hx2. }
           claim Hxltb2: order_rel RR x b2x.
           { exact (SepE2 ordered_square (fun y:set => order_rel RR y b2x) x Hx2in). }
           apply (order_rel_trichotomy_or_impred RR b1x b2x HsoRR Hb1xRR Hb2xRR
                  (exists b3 :e ordered_square_order_basis, x :e b3 /\ b3 c= b1 :/\: b2)).
           { (** b1x < b2x: take b3 = b1 **)
             assume Hb1lt: order_rel RR b1x b2x.
             witness b1.
             apply andI.
             - claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
               { reflexivity. }
               rewrite Hdef.
               exact Hb1case.
             - apply andI.
               + exact Hx1.
               + apply (binintersect_Subq_max b1 b2 b1).
                 * apply Subq_ref.
                 * (** b1 c= b2 **)
                   let y. assume Hy: y :e b1.
                   prove y :e b2.
                   claim Hyin: y :e {y0 :e ordered_square | order_rel RR y0 b1x}.
                   { rewrite <- Hb1eq.
                     exact Hy. }
                   claim HySq: y :e ordered_square.
                   { exact (SepE1 ordered_square (fun y0:set => order_rel RR y0 b1x) y Hyin). }
                   claim HyRR: y :e RR.
                   { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) y HySq). }
                   claim Hylt1: order_rel RR y b1x.
                   { exact (SepE2 ordered_square (fun y0:set => order_rel RR y0 b1x) y Hyin). }
                   claim Hylt2: order_rel RR y b2x.
                   { exact (order_rel_trans RR y b1x b2x HsoRR HyRR Hb1xRR Hb2xRR Hylt1 Hb1lt). }
                   rewrite Hb2eq.
                   exact (SepI ordered_square (fun y0:set => order_rel RR y0 b2x) y HySq Hylt2). }
           { (** b1x = b2x: take b3 = b1 **)
             assume Heq: b1x = b2x.
             witness b1.
             apply andI.
             - claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
               { reflexivity. }
               rewrite Hdef.
               exact Hb1case.
             - apply andI.
               + exact Hx1.
               + apply (binintersect_Subq_max b1 b2 b1).
                 * apply Subq_ref.
                 * (** b1 c= b2 by rewriting the endpoint **)
                   let y. assume Hy: y :e b1.
                   prove y :e b2.
                   claim Hyin: y :e {y0 :e ordered_square | order_rel RR y0 b1x}.
                   { rewrite <- Hb1eq.
                     exact Hy. }
                   claim HySq: y :e ordered_square.
                   { exact (SepE1 ordered_square (fun y0:set => order_rel RR y0 b1x) y Hyin). }
                   claim Hylt1: order_rel RR y b1x.
                   { exact (SepE2 ordered_square (fun y0:set => order_rel RR y0 b1x) y Hyin). }
                   rewrite Hb2eq.
                   rewrite <- Heq.
	                   exact (SepI ordered_square (fun y0:set => order_rel RR y0 b1x) y HySq Hylt1). }
           { (** b2x < b1x: take b3 = b2 **)
             assume Hb2lt: order_rel RR b2x b1x.
             witness b2.
             apply andI.
             - claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
               { reflexivity. }
               rewrite Hdef.
               exact Hb2case.
             - apply andI.
               + exact Hx2.
               + apply (binintersect_Subq_max b1 b2 b2).
                 * (** b2 c= b1 **)
                   let y. assume Hy: y :e b2.
                   prove y :e b1.
                   claim Hyin: y :e {y0 :e ordered_square | order_rel RR y0 b2x}.
                   { rewrite <- Hb2eq.
                     exact Hy. }
                   claim HySq: y :e ordered_square.
                   { exact (SepE1 ordered_square (fun y0:set => order_rel RR y0 b2x) y Hyin). }
                   claim HyRR: y :e RR.
                   { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) y HySq). }
                   claim Hylt2: order_rel RR y b2x.
                   { exact (SepE2 ordered_square (fun y0:set => order_rel RR y0 b2x) y Hyin). }
                   claim Hylt1: order_rel RR y b1x.
                   { exact (order_rel_trans RR y b2x b1x HsoRR HyRR Hb2xRR Hb1xRR Hylt2 Hb2lt). }
                   rewrite Hb1eq.
                   exact (SepI ordered_square (fun y0:set => order_rel RR y0 b1x) y HySq Hylt1). 
                 * apply Subq_ref. }
	      * assume Hb2up: b2 :e Bup.
	        (** lower ray ∩ upper ray: take the interval (a2,b1x) **)
	        claim Hexa2: exists a0 :e ordered_square,
	          b2 = {y :e ordered_square | order_rel RR a0 y}.
	        { exact (SepE2 (Power ordered_square)
	                       (fun I:set => exists a0 :e ordered_square,
	                         I = {y :e ordered_square | order_rel RR a0 y})
	                       b2
	                       Hb2up). }
	        apply Hexa2.
	        let a2. assume Ha2pack.
	        apply Ha2pack.
	        assume Ha2Sq Hb2eq.
	        claim Ha2RR: a2 :e RR.
	        { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) a2 Ha2Sq). }
	        claim Hx2in: x :e {y :e ordered_square | order_rel RR a2 y}.
	        { rewrite <- Hb2eq.
	          exact Hx2. }
	        claim Hxa2: order_rel RR a2 x.
	        { exact (SepE2 ordered_square (fun y:set => order_rel RR a2 y) x Hx2in). }
	        set b3 := {y :e ordered_square | order_rel RR a2 y /\ order_rel RR y b1x}.
	        witness b3.
	        apply andI.
	        - (** b3 is a basis interval element **)
	          claim Hb3Pow: b3 :e Power ordered_square.
	          { apply PowerI.
	            let y. assume Hy: y :e b3.
	            exact (SepE1 ordered_square (fun y0:set => order_rel RR a2 y0 /\ order_rel RR y0 b1x) y Hy). }
	          claim Hexab: exists a0 :e ordered_square, exists b0 :e ordered_square,
	            b3 = {y :e ordered_square | order_rel RR a0 y /\ order_rel RR y b0}.
	          { witness a2.
	            apply andI.
	            - exact Ha2Sq.
	            - witness b1x.
	              apply andI.
	              + exact Hb1xSq.
	              + reflexivity. }
	          claim Hb3Bint: b3 :e Bint.
	          { exact (SepI (Power ordered_square)
	                        (fun I:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
	                          I = {y :e ordered_square | order_rel RR a0 y /\ order_rel RR y b0})
	                        b3
	                        Hb3Pow
	                        Hexab). }
	          claim Hb3AB: b3 :e (Bint :\/: Blow).
	          { exact (binunionI1 Bint Blow b3 Hb3Bint). }
	          claim Hb3ABC: b3 :e ((Bint :\/: Blow) :\/: Bup).
	          { exact (binunionI1 (Bint :\/: Blow) Bup b3 Hb3AB). }
	          claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
	          { reflexivity. }
	          rewrite Hdef.
	          exact Hb3ABC.
	        - apply andI.
	          + (** x :e b3 **)
	            prove x :e b3.
	            exact (SepI ordered_square
	                       (fun y:set => order_rel RR a2 y /\ order_rel RR y b1x)
	                       x
	                       HxSq
	                       (andI (order_rel RR a2 x) (order_rel RR x b1x) Hxa2 Hxltb1)).
	          + (** b3 c= b1 ∩ b2 **)
	            apply (binintersect_Subq_max b1 b2 b3).
	            * (** b3 c= b1 **)
	              let y. assume Hy: y :e b3.
	              prove y :e b1.
	              claim HySq: y :e ordered_square.
	              { exact (SepE1 ordered_square (fun y0:set => order_rel RR a2 y0 /\ order_rel RR y0 b1x) y Hy). }
	              claim Hyconj: order_rel RR a2 y /\ order_rel RR y b1x.
	              { exact (SepE2 ordered_square (fun y0:set => order_rel RR a2 y0 /\ order_rel RR y0 b1x) y Hy). }
	              claim Hyltb1: order_rel RR y b1x.
	              { exact (andER (order_rel RR a2 y) (order_rel RR y b1x) Hyconj). }
	              rewrite Hb1eq.
	              exact (SepI ordered_square (fun y0:set => order_rel RR y0 b1x) y HySq Hyltb1).
	            * (** b3 c= b2 **)
	              let y. assume Hy: y :e b3.
	              prove y :e b2.
	              claim HySq: y :e ordered_square.
	              { exact (SepE1 ordered_square (fun y0:set => order_rel RR a2 y0 /\ order_rel RR y0 b1x) y Hy). }
	              claim Hyconj: order_rel RR a2 y /\ order_rel RR y b1x.
	              { exact (SepE2 ordered_square (fun y0:set => order_rel RR a2 y0 /\ order_rel RR y0 b1x) y Hy). }
	              claim Ha2y: order_rel RR a2 y.
	              { exact (andEL (order_rel RR a2 y) (order_rel RR y b1x) Hyconj). }
	              rewrite Hb2eq.
	              exact (SepI ordered_square (fun y0:set => order_rel RR a2 y0) y HySq Ha2y).
		  - assume Hb1up: b1 :e Bup.
		    (** b1 is an upper ray **)
		    claim Hexa1: exists a0 :e ordered_square,
		      b1 = {y :e ordered_square | order_rel RR a0 y}.
		    { exact (SepE2 (Power ordered_square)
		                   (fun I:set => exists a0 :e ordered_square,
		                     I = {y :e ordered_square | order_rel RR a0 y})
		                   b1
		                   Hb1up). }
		    apply Hexa1.
		    let a1. assume Ha1pack.
		    apply Ha1pack.
		    assume Ha1Sq Hb1eq.
		    claim Ha1RR: a1 :e RR.
		    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) a1 Ha1Sq). }
		    claim Hx1in: x :e {y :e ordered_square | order_rel RR a1 y}.
		    { rewrite <- Hb1eq.
		      exact Hx1. }
		    claim HxSq': x :e ordered_square.
		    { exact (SepE1 ordered_square (fun y:set => order_rel RR a1 y) x Hx1in). }
		    claim HxRR': x :e RR.
		    { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) x HxSq'). }
		    claim Ha1x: order_rel RR a1 x.
		    { exact (SepE2 ordered_square (fun y:set => order_rel RR a1 y) x Hx1in). }
		    (** split on b2 and handle ray/interval cases **)
		    apply (binunionE (Bint :\/: Blow) Bup b2 Hb2case).
		    * assume Hb2left: b2 :e (Bint :\/: Blow).
		      apply (binunionE Bint Blow b2 Hb2left).
		      - assume Hb2int: b2 :e Bint.
		        (** upper ray ∩ interval: compare left endpoints, possibly shrink the interval **)
		        claim Hexb2: exists a0 :e ordered_square, exists b0 :e ordered_square,
		          b2 = {y :e ordered_square | order_rel RR a0 y /\ order_rel RR y b0}.
		        { exact (SepE2 (Power ordered_square)
		                       (fun I:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
		                         I = {y :e ordered_square | order_rel RR a0 y /\ order_rel RR y b0})
		                       b2
		                       Hb2int). }
		        apply Hexb2.
		        let a2. assume Ha2pack.
		        apply Ha2pack.
		        assume Ha2Sq Hexb2b.
		        apply Hexb2b.
		        let b2x. assume Hb2pack.
		        apply Hb2pack.
		        assume Hb2xSq Hb2eq.
		        claim Ha2RR: a2 :e RR.
		        { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) a2 Ha2Sq). }
		        claim Hb2xRR: b2x :e RR.
		        { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) b2x Hb2xSq). }
		        claim Hx2in: x :e {y :e ordered_square | order_rel RR a2 y /\ order_rel RR y b2x}.
		        { rewrite <- Hb2eq.
		          exact Hx2. }
		        claim Hx2conj: order_rel RR a2 x /\ order_rel RR x b2x.
		        { exact (SepE2 ordered_square (fun y:set => order_rel RR a2 y /\ order_rel RR y b2x) x Hx2in). }
		        claim Ha2x: order_rel RR a2 x.
		        { exact (andEL (order_rel RR a2 x) (order_rel RR x b2x) Hx2conj). }
		        claim Hxb2: order_rel RR x b2x.
		        { exact (andER (order_rel RR a2 x) (order_rel RR x b2x) Hx2conj). }
		        apply (order_rel_trichotomy_or_impred RR a1 a2 HsoRR Ha1RR Ha2RR
		               (exists b3 :e ordered_square_order_basis, x :e b3 /\ b3 c= b1 :/\: b2)).
		        { (** a1 < a2: b2 ⊆ b1, so choose b3=b2 **)
		          assume Ha1lt: order_rel RR a1 a2.
		          witness b2.
		          apply andI.
		          - exact Hb2.
		          - apply andI.
		            + exact Hx2.
		            + apply (binintersect_Subq_max b1 b2 b2).
		              * (** b2 c= b1 **)
		                let y. assume Hy: y :e b2.
		                prove y :e b1.
		                claim Hyin: y :e {y0 :e ordered_square | order_rel RR a2 y0 /\ order_rel RR y0 b2x}.
		                { rewrite <- Hb2eq.
		                  exact Hy. }
		                claim HySq: y :e ordered_square.
		                { exact (SepE1 ordered_square (fun y0:set => order_rel RR a2 y0 /\ order_rel RR y0 b2x) y Hyin). }
		                claim HyRR: y :e RR.
		                { exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) y HySq). }
		                claim Hyconj: order_rel RR a2 y /\ order_rel RR y b2x.
		                { exact (SepE2 ordered_square (fun y0:set => order_rel RR a2 y0 /\ order_rel RR y0 b2x) y Hyin). }
		                claim Ha2y: order_rel RR a2 y.
