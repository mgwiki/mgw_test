      claim HUtop: U :e ordered_square_topology.
      { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
        { reflexivity. }
        rewrite HdefT.
        exact (generated_topology_contains_elem ordered_square ordered_square_order_basis U HUpow HUbas). }
        claim HpU: p :e U.
        { apply (SepI ordered_square
                 (fun z0:set => order_rel (setprod R R) a0 z0 /\ order_rel (setprod R R) z0 b0)
                 p).
          - exact HpSq.
          - prove order_rel (setprod R R) a0 p /\ order_rel (setprod R R) p b0.
            claim Ha0def: a0 = (x,q).
            { reflexivity. }
            claim Hb0def: b0 = (x,y2).
            { reflexivity. }
            claim Hleft: order_rel (setprod R R) a0 p.
            { rewrite Ha0def at 1.
              rewrite HpEq at 2.
              exact (order_rel_setprod_R_R_same_first x q y Hqlty). }
              claim Hright: order_rel (setprod R R) p b0.
              { rewrite HpEq at 1.
                rewrite Hb0def at 1.
                exact (order_rel_setprod_R_R_same_first x y y2 Hylt_y2). }
            exact (andI (order_rel (setprod R R) a0 p)
                        (order_rel (setprod R R) p b0)
                        Hleft Hright).
          }
      claim HcapEq: U :/\: ordsq_A = Empty.
      { apply (Empty_Subq_eq (U :/\: ordsq_A)).
        let z. assume Hz: z :e U :/\: ordsq_A.
        apply FalseE.
        claim HzU: z :e U.
        { exact (binintersectE1 U ordsq_A z Hz). }
        claim HzA: z :e ordsq_A.
        { exact (binintersectE2 U ordsq_A z Hz). }
        apply (ReplE_impred (omega :\: {0}) (fun n:set => (inv_nat n,0)) z HzA False).
        let n. assume HnIn: n :e omega :\: {0}. assume HzEq: z = (inv_nat n,0).
        claim HzRel: order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0.
        { exact (SepE2 ordered_square
                  (fun z0:set => order_rel (setprod R R) a0 z0 /\ order_rel (setprod R R) z0 b0)
                  z HzU). }
        claim HzOrd1: order_rel (setprod R R) a0 z.
        { exact (andEL (order_rel (setprod R R) a0 z) (order_rel (setprod R R) z b0) HzRel). }
        claim HzOrd2: order_rel (setprod R R) z b0.
        { exact (andER (order_rel (setprod R R) a0 z) (order_rel (setprod R R) z b0) HzRel). }
        claim Ha0def: a0 = (x,q).
        { reflexivity. }
        claim Hb0def: b0 = (x,y2).
        { reflexivity. }
        claim HzOrd1': order_rel (setprod R R) (x,q) (inv_nat n,0).
        { rewrite <- HzEq.
          rewrite <- Ha0def.
          exact HzOrd1. }
        claim HzOrd2': order_rel (setprod R R) (inv_nat n,0) (x,y2).
        { rewrite <- HzEq.
          rewrite <- Hb0def.
          exact HzOrd2. }
        claim HxR: x :e R.
        { exact (unit_interval_sub_R x HxI). }
        claim HnO: n :e omega.
        { exact (setminusE1 omega {0} n HnIn). }
        claim HinvR: inv_nat n :e R.
        { exact (inv_nat_real n HnO). }
        claim H0R: 0 :e R.
        { exact real_0. }
        claim HqR: q :e R.
        { exact (rational_numbers_in_R q HqQ). }
        claim Hy2R: y2 :e R.
        { exact (rational_numbers_in_R y2 Hy2Q). }

        (** from `HzOrd1'` we get x < inv_nat n, because q < 0 is impossible **)
        claim HxltInv: Rlt x (inv_nat n).
        { claim Hex1: exists a1 a2 b1 b2:set,
            (x,q) = (a1, a2) /\ (inv_nat n,0) = (b1, b2) /\ (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2)).
          { exact (order_rel_setprod_R_R_unfold (x,q) (inv_nat n,0) HzOrd1'). }
          apply Hex1.
          let a1. assume Ha1. apply Ha1.
          let a2. assume Ha2. apply Ha2.
          let b1. assume Hb1. apply Hb1.
          let b2. assume Hpack1.
          claim Hpair: (x,q) = (a1, a2) /\ (inv_nat n,0) = (b1, b2).
          { exact (andEL ((x,q) = (a1, a2) /\ (inv_nat n,0) = (b1, b2))
                         (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2))
                         Hpack1). }
          claim Hdisj: Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2).
          { exact (andER ((x,q) = (a1, a2) /\ (inv_nat n,0) = (b1, b2))
                         (Rlt a1 b1 \/ (a1 = b1 /\ Rlt a2 b2))
                         Hpack1). }
          claim HaPair: (x,q) = (a1, a2).
          { exact (andEL ((x,q) = (a1, a2)) ((inv_nat n,0) = (b1, b2)) Hpair). }
          claim HbPair: (inv_nat n,0) = (b1, b2).
          { exact (andER ((x,q) = (a1, a2)) ((inv_nat n,0) = (b1, b2)) Hpair). }

          claim HxEq: x = a1.
          { rewrite <- (tuple_2_0_eq x q).
            rewrite <- (tuple_2_0_eq a1 a2).
            claim H0eq: (x,q) 0 = (a1, a2) 0.
            { rewrite HaPair at 1.
              reflexivity. }
            exact H0eq. }
          claim HqEq: q = a2.
          { rewrite <- (tuple_2_1_eq x q).
            rewrite <- (tuple_2_1_eq a1 a2).
            claim H1eq: (x,q) 1 = (a1, a2) 1.
            { rewrite HaPair at 1.
              reflexivity. }
            exact H1eq. }
          claim Hb1Eq: inv_nat n = b1.
          { rewrite <- (tuple_2_0_eq (inv_nat n) 0).
            rewrite <- (tuple_2_0_eq b1 b2).
            claim H0eq: (inv_nat n,0) 0 = (b1, b2) 0.
            { rewrite HbPair at 1.
              reflexivity. }
            exact H0eq. }
          claim Hb2Eq: 0 = b2.
          { rewrite <- (tuple_2_1_eq (inv_nat n) 0).
            rewrite <- (tuple_2_1_eq b1 b2).
            claim H1eq: (inv_nat n,0) 1 = (b1, b2) 1.
            { rewrite HbPair at 1.
