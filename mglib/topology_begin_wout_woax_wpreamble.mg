                              claim HxEqCur: x = bcur.
                              { rewrite HxEq.
                                rewrite HnEqNmin.
                                reflexivity. }
                              claim Hbad: order_rel (setprod R R) bcur bcur.
                              { rewrite <- HxEqCur at 1.
                                exact Hxbcur. }
                              exact ((order_rel_irref (setprod R R) bcur) Hbad).
                          - assume HsuccInj: ordsucc i :e j.
                            apply FalseE.
                            claim HsuccIO': ordsucc i :e omega.
                            { exact HsuccIO. }
                            claim Hlt_succi_j: order_rel (setprod R R)
                              (add_SNo 1 (minus_SNo (inv_nat (ordsucc (ordsucc i)))), eps_ 1)
                              (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1).
                            { exact (ordsq_B_ordsucc_index_increasing (ordsucc i) j HsuccIO' HjO HsuccInj). }
                            claim Hxx: order_rel (setprod R R)
                              (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)
                              (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1).
                            { exact (order_rel_trans (setprod R R)
                                     (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)
                                     (add_SNo 1 (minus_SNo (inv_nat (ordsucc (ordsucc i)))), eps_ 1)
                                     (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)
                                     simply_ordered_set_setprod_R_R
                                     (tuple_2_setprod_by_pair_Sigma R R
                                        (add_SNo 1 (minus_SNo (inv_nat (ordsucc j)))) (eps_ 1)
                                        (real_add_SNo 1 real_1 (minus_SNo (inv_nat (ordsucc j)))
                                           (real_minus_SNo (inv_nat (ordsucc j)) (inv_nat_real (ordsucc j) (omega_ordsucc j HjO))))
                                        eps_1_in_R)
                                     (tuple_2_setprod_by_pair_Sigma R R
                                        (add_SNo 1 (minus_SNo (inv_nat (ordsucc (ordsucc i))))) (eps_ 1)
                                        (real_add_SNo 1 real_1 (minus_SNo (inv_nat (ordsucc (ordsucc i))))
                                           (real_minus_SNo (inv_nat (ordsucc (ordsucc i)))
                                              (inv_nat_real (ordsucc (ordsucc i)) (omega_ordsucc (ordsucc i) HsuccIO'))))
                                        eps_1_in_R)
                                     (tuple_2_setprod_by_pair_Sigma R R
                                        (add_SNo 1 (minus_SNo (inv_nat (ordsucc j)))) (eps_ 1)
                                        (real_add_SNo 1 real_1 (minus_SNo (inv_nat (ordsucc j)))
                                           (real_minus_SNo (inv_nat (ordsucc j)) (inv_nat_real (ordsucc j) (omega_ordsucc j HjO))))
                                        eps_1_in_R)
                                       Hlt_j_succi Hlt_succi_j). }
                              exact ((order_rel_irref (setprod R R)
                                       (add_SNo 1 (minus_SNo (inv_nat (ordsucc j))), eps_ 1)) Hxx).
                    - let x. assume Hx: x :e Empty.
                      prove x :e Ugap :/\: ordsq_B.
                      apply FalseE.
                      exact (EmptyE x Hx). }
                apply HcapNe2.
                exact HcapEmp2.
      * assume HpEq: p = p10.
        rewrite HpEq.
        exact (SingI ordsq_p10).
    * assume Hp10p: order_rel (setprod R R) p10 p.
      apply FalseE.
      claim HpU0: p :e U0.
      { apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) p10 x0) p HpSq).
        exact Hp10p. }
      claim HcapNe: U0 :/\: ordsq_B <> Empty.
      { exact (Hcond U0 HU0top HpU0). }
      claim Hexw: exists w:set, w :e U0 :/\: ordsq_B.
      { exact (nonempty_has_element (U0 :/\: ordsq_B) HcapNe). }
      apply Hexw.
      let w. assume Hwcap.
      claim HwU0: w :e U0.
      { exact (binintersectE1 U0 ordsq_B w Hwcap). }
      claim HwB: w :e ordsq_B.
      { exact (binintersectE2 U0 ordsq_B w Hwcap). }
      claim Hp10w: order_rel (setprod R R) p10 w.
      { exact (SepE2 ordered_square
                    (fun x0:set => order_rel (setprod R R) p10 x0)
                    w HwU0). }
      claim Hwp10: order_rel (setprod R R) w p10.
      { exact (ordsq_B_lt_p10 w HwB). }
      claim HwRR: w :e setprod R R.
      { claim HwSq: w :e ordered_square.
        { exact (SepE1 ordered_square (fun x0:set => order_rel (setprod R R) p10 x0) w HwU0). }
        exact ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq). }
      claim Hww: order_rel (setprod R R) w w.
      { exact (order_rel_trans (setprod R R) w p10 w
                simply_ordered_set_setprod_R_R
                HwRR Hp10RR HwRR
                Hwp10 Hp10w). }
      exact ((order_rel_irref (setprod R R) w) Hww).
- let p. assume Hp: p :e ordsq_B :\/: {ordsq_p10}.
  prove p :e closure_of ordered_square ordered_square_topology ordsq_B.
  apply (binunionE ordsq_B {ordsq_p10} p Hp).
  + assume HpB: p :e ordsq_B.
    (** unfold closure and use p itself to witness nonemptiness of U :/\: ordsq_B **)
    claim HpSq: p :e ordered_square.
    { exact (ordsq_B_sub_ordered_square p HpB). }
    claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_B =
      {x :e ordered_square | forall U:set, U :e ordered_square_topology -> x :e U -> U :/\: ordsq_B <> Empty}.
    { reflexivity. }
    rewrite Hdefcl.
    apply (SepI ordered_square
                (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_B <> Empty)
                p
                HpSq).
    let U. assume HUtop: U :e ordered_square_topology.
    assume HpU: p :e U.
    prove U :/\: ordsq_B <> Empty.
    claim HpUB: p :e U :/\: ordsq_B.
    { exact (binintersectI U ordsq_B p HpU HpB). }
    exact (elem_implies_nonempty (U :/\: ordsq_B) p HpUB).
    + assume Hp10: p :e {ordsq_p10}.
      (** show p10 lies in the closure of B **)
      claim HpEq: p = ordsq_p10.
      { exact (SingE ordsq_p10 p Hp10). }
      rewrite HpEq.
      set p10 := ordsq_p10.
      claim Hp10def: p10 = (1,0).
      { reflexivity. }
      claim Hp10Sq: p10 :e ordered_square.
      { rewrite Hp10def.
        exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 1 0
                one_in_unit_interval zero_in_unit_interval). }
      claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_B =
        {x :e ordered_square | forall U:set, U :e ordered_square_topology -> x :e U -> U :/\: ordsq_B <> Empty}.
      { reflexivity. }
      rewrite Hdefcl.
      apply (SepI ordered_square
                  (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_B <> Empty)
                  p10
                  Hp10Sq).
      let U. assume HUtop: U :e ordered_square_topology.
      assume Hp10U: p10 :e U.
      prove U :/\: ordsq_B <> Empty.
      claim HUgt: U :e generated_topology ordered_square ordered_square_order_basis.
      { claim HdefT: ordered_square_topology = generated_topology ordered_square ordered_square_order_basis.
        { reflexivity. }
        rewrite <- HdefT.
        exact HUtop. }
      claim HexI: exists I :e ordered_square_order_basis, p10 :e I /\ I c= U.
      { exact (generated_topology_local_refine ordered_square ordered_square_order_basis U p10 HUgt Hp10U). }
      apply HexI.
      let I. assume HIprop.
      apply HIprop.
      assume HIbas HIcore.
      apply HIcore.
      assume Hp10I HIU.
      set Bint := {J :e Power ordered_square | exists a0 :e ordered_square, exists b0 :e ordered_square,
            J = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}}.
      set Blow := {J :e Power ordered_square | exists b0 :e ordered_square,
            J = {x0 :e ordered_square | order_rel (setprod R R) x0 b0}}.
      set Bup := {J :e Power ordered_square | exists a0 :e ordered_square,
            J = {x0 :e ordered_square | order_rel (setprod R R) a0 x0}}.
      claim HIcase: I :e ((Bint :\/: Blow) :\/: Bup).
      { claim HdefB: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
        { reflexivity. }
        rewrite <- HdefB.
        exact HIbas. }
      apply (binunionE (Bint :\/: Blow) Bup I HIcase).
      - assume HIin: I :e Bint :\/: Blow.
        apply (binunionE Bint Blow I HIin).
        + assume HIint: I :e Bint.
          claim Hexab: exists a0 :e ordered_square, exists b0 :e ordered_square,
            I = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}.
          { exact (SepE2 (Power ordered_square)
                    (fun J0:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
                      J0 = {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0})
                    I HIint). }
          apply Hexab.
          let a0. assume Ha0pack.
          apply Ha0pack.
          assume Ha0Sq Hrest.
          apply Hrest.
          let b0. assume Hb0pack.
          apply Hb0pack.
          assume Hb0Sq HIeq.
          claim Hp10I': p10 :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}.
          { rewrite <- HIeq.
            exact Hp10I. }
          claim Hp10ord: order_rel (setprod R R) a0 p10 /\ order_rel (setprod R R) p10 b0.
          { exact (SepE2 ordered_square
                  (fun x0:set => order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0)
                  p10 Hp10I'). }
          claim Ha0p10: order_rel (setprod R R) a0 p10.
          { exact (andEL (order_rel (setprod R R) a0 p10) (order_rel (setprod R R) p10 b0) Hp10ord). }
          claim Hp10b0: order_rel (setprod R R) p10 b0.
          { exact (andER (order_rel (setprod R R) a0 p10) (order_rel (setprod R R) p10 b0) Hp10ord). }
          claim Hexw: exists w:set,
            w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0} /\
            w :e ordsq_B.
          { exact (ex17_18_p10_interval_basis_meets_B a0 b0 Ha0Sq Hb0Sq Ha0p10 Hp10b0). }
          apply Hexw.
          let w. assume Hwpack.
          claim HwIset: w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0}.
          { exact (andEL (w :e {x0 :e ordered_square | order_rel (setprod R R) a0 x0 /\ order_rel (setprod R R) x0 b0})
                         (w :e ordsq_B)
