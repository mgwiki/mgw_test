                 I
                 HIup). }
  apply Hexa.
  let a0. assume Ha0pack.
  apply Ha0pack.
  assume Ha0Sq HIeq.
  claim HpI': p :e {z :e ordered_square | order_rel (setprod R R) a0 z}.
  { rewrite <- HIeq.
    exact HpI. }
  claim Ha0p: order_rel (setprod R R) a0 p.
  { exact (SepE2 ordered_square (fun z:set => order_rel (setprod R R) a0 z) p HpI'). }
  apply (rational_dense_between_reals x 1 HxR real_1 Hxlt1).
  let q. assume Hqpack.
  apply Hqpack.
  assume HqQ Hqineq.
  claim HqR: q :e R.
  { exact (rational_numbers_in_R q HqQ). }
  claim Hxltq: Rlt x q.
  { exact (andEL (Rlt x q) (Rlt q 1) Hqineq). }
  claim Hqlt1: Rlt q 1.
  { exact (andER (Rlt x q) (Rlt q 1) Hqineq). }
  claim H0ltq: Rlt 0 q.
