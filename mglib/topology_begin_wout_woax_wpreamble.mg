		            { exact (binunionI1 Bint Blow b3 Hb3Bint). }
		            claim Hb3ABC: b3 :e ((Bint :\/: Blow) :\/: Bup).
		            { exact (binunionI1 (Bint :\/: Blow) Bup b3 Hb3AB). }
		            claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
		            { reflexivity. }
		            rewrite Hdef.
		            exact Hb3ABC.
		          - apply andI.
		            + (** x ∈ b3 **)
		              prove x :e b3.
		              exact (SepI ordered_square
		                         (fun y:set => order_rel RR a1 y /\ order_rel RR y b2x)
