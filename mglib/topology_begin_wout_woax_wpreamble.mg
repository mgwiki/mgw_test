        apply Hdisj2'.
        - assume Hinvltx.
          exact ((not_Rlt_sym (inv_nat n) x Hinvltx) HxltInv).
        - assume Heq_and.
          apply FalseE.
          claim Heq: inv_nat n = x.
          { exact (andEL (inv_nat n = x) (Rlt 0 y2) Heq_and). }
          claim Hxx: Rlt x x.
          { rewrite <- Heq at 2.
            exact HxltInv. }
          exact (not_Rlt_refl x HxR Hxx).
