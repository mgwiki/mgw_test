            { reflexivity. }
            rewrite HdefT.
            exact (generated_topology_contains_elem ordered_square ordered_square_order_basis U0 HU0Pow HU0basis). }
          claim HpOrd: order_rel (setprod R R) ordsq_p10 p.
          { claim Hp10def: ordsq_p10 = (1,0).
            { reflexivity. }
            rewrite Hp10def.
            rewrite HpEta.
            rewrite Haeq1.
            rewrite Hyeq1.
            apply (order_rel_setprod_R_R_intro 1 0 1 1).
            apply orIR.
            prove 1 = 1 /\ Rlt 0 1.
            apply andI.
            - reflexivity.
            - exact Rlt_0_1. }
          claim HpU0: p :e U0.
          { apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) ordsq_p10 x0) p HpSq).
            exact HpOrd. }
          claim HcapSub: U0 :/\: ordsq_C c= Empty.
          { let z. assume Hz: z :e U0 :/\: ordsq_C.
