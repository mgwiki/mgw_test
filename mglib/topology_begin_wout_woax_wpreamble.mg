      { exact (RltI 1 y real_1 HyR H1lty). }
      exact ((andER (~(Rlt y 0)) (~(Rlt 1 y))
            (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) y HyU)) H1ltyR).
- let p. assume Hp: p :e ordsq_C_closure.
  prove p :e closure_of ordered_square ordered_square_topology ordsq_C.
  (** union is left-associative: (ordsq_C :\/: ordsq_top_edge_lt1) :\/: {p10} **)
  apply (binunionE (ordsq_C :\/: ordsq_top_edge_lt1) {ordsq_p10} p Hp).
  + assume HpL: p :e ordsq_C :\/: ordsq_top_edge_lt1.
    apply (binunionE ordsq_C ordsq_top_edge_lt1 p HpL).
    * assume HpC: p :e ordsq_C.
      (** unfold closure and use p itself to witness nonemptiness of U :/\: ordsq_C **)
      claim HpSq: p :e ordered_square.
      { exact (SepE1 ordered_square (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1) p HpC). }
      claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_C =
        {x :e ordered_square | forall U:set, U :e ordered_square_topology -> x :e U -> U :/\: ordsq_C <> Empty}.
      { reflexivity. }
      rewrite Hdefcl.
      apply (SepI ordered_square
                  (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_C <> Empty)
                  p
                  HpSq).
      let U. assume HUtop: U :e ordered_square_topology.
      assume HpU: p :e U.
      prove U :/\: ordsq_C <> Empty.
      claim HpUC: p :e U :/\: ordsq_C.
      { exact (binintersectI U ordsq_C p HpU HpC). }
      exact (elem_implies_nonempty (U :/\: ordsq_C) p HpUC).
    * assume HpTop: p :e ordsq_top_edge_lt1.
      (** show top-edge points with x<1 lie in the closure of C **)
      exact (ex17_18_top_edge_lt1_Sub_closure_C p HpTop).
  + assume Hp10: p :e {ordsq_p10}.
    (** show p10 lies in the closure of C **)
    claim HpEq: p = ordsq_p10.
    { exact (SingE ordsq_p10 p Hp10). }
    rewrite HpEq.
    exact ex17_18_p10_in_closure_C.
Qed.

(** helper: closure(D) in the ordered square (packaged) **)
(** LATEX VERSION: Exercise 18 asks to determine cl(D) for D={x×1/2|0<x<1} in the ordered square. **)
(** helper: (1,0) lies in cl(D) **)
(** LATEX VERSION: In the ordered square, the closure of D contains the point (1,0). **)
Theorem ex17_18_p10_in_closure_D :
  ordsq_p10 :e closure_of ordered_square ordered_square_topology ordsq_D.
prove ordsq_p10 :e closure_of ordered_square ordered_square_topology ordsq_D.
claim Hp10Sq: ordsq_p10 :e ordered_square.
{ claim Hp10def: ordsq_p10 = (1,0).
  { reflexivity. }
  rewrite Hp10def.
  exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval 1 0 one_in_unit_interval zero_in_unit_interval). }
claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_D =
  {x0 :e ordered_square | forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_D <> Empty}.
{ reflexivity. }
rewrite Hdefcl.
apply (SepI ordered_square
            (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_D <> Empty)
            ordsq_p10
            Hp10Sq).
let U. assume HUtop: U :e ordered_square_topology.
assume Hp10U: ordsq_p10 :e U.
prove U :/\: ordsq_D <> Empty.
claim HexI: exists I :e ordered_square_order_basis, ordsq_p10 :e I /\ I c= U.
{ exact (generated_topology_local_refine ordered_square ordered_square_order_basis U ordsq_p10 HUtop Hp10U). }
apply HexI.
let I. assume HIpack.
apply HIpack.
assume HIbas HIcore.
apply HIcore.
assume Hp10I HIU.
set Bint := {J :e Power ordered_square | exists a :e ordered_square, exists b :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) a z /\ order_rel (setprod R R) z b}}.
set Blow := {J :e Power ordered_square | exists b :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) z b}}.
set Bup := {J :e Power ordered_square | exists a :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) a z}}.
claim HIcase: I :e ((Bint :\/: Blow) :\/: Bup).
{ claim Hdef: ordered_square_order_basis = ((Bint :\/: Blow) :\/: Bup).
  { reflexivity. }
  rewrite <- Hdef.
  exact HIbas. }
apply (binunionE (Bint :\/: Blow) Bup I HIcase).
- assume HIleft: I :e (Bint :\/: Blow).
  apply (binunionE Bint Blow I HIleft).
  + assume HIint: I :e Bint.
    claim Hexab: exists a0 :e ordered_square, exists b0 :e ordered_square,
      I = {z :e ordered_square | order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0}.
    { exact (SepE2 (Power ordered_square)
                   (fun J0:set => exists a0 :e ordered_square, exists b0 :e ordered_square,
                     J0 = {z :e ordered_square | order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0})
                   I
                   HIint). }
    apply Hexab.
    let a0. assume Ha0pack.
    apply Ha0pack.
    assume Ha0Sq Hb0ex.
    apply Hb0ex.
    let b0. assume Hb0pack.
    apply Hb0pack.
    assume Hb0Sq HIeq.

    claim HpI': ordsq_p10 :e {z :e ordered_square | order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0}.
    { rewrite <- HIeq.
      exact Hp10I. }
    claim Hp10core: order_rel (setprod R R) a0 ordsq_p10 /\ order_rel (setprod R R) ordsq_p10 b0.
    { exact (SepE2 ordered_square
               (fun z:set => order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0)
               ordsq_p10
               HpI'). }
    claim Ha0p10: order_rel (setprod R R) a0 ordsq_p10.
    { exact (andEL (order_rel (setprod R R) a0 ordsq_p10)
                  (order_rel (setprod R R) ordsq_p10 b0)
                  Hp10core). }
    claim Hp10b0: order_rel (setprod R R) ordsq_p10 b0.
    { exact (andER (order_rel (setprod R R) a0 ordsq_p10)
                  (order_rel (setprod R R) ordsq_p10 b0)
                  Hp10core). }

    set a00 := a0 0.
    claim Ha00U: a00 :e unit_interval.
    { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
    claim Ha00R: a00 :e R.
    { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a00 Ha00U). }
    claim Ha00notlt0: ~(Rlt a00 0).
    { exact (andEL (~(Rlt a00 0)) (~(Rlt 1 a00))
                  (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a00 Ha00U)). }

    claim Ha0lt1: Rlt a00 1.
    { (** a0 < (1,0) forces a00 < 1 since a0 1 is in unit_interval **)
      claim Hunf: exists c1 c2 d1 d2:set,
        a0 = (c1, c2) /\ ordsq_p10 = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
      { exact (order_rel_setprod_R_R_unfold a0 ordsq_p10 Ha0p10). }
      apply Hunf.
      let c1. assume Hc2.
      apply Hc2.
      let c2. assume Hd1.
      apply Hd1.
      let d1. assume Hd2.
      apply Hd2.
      let d2. assume Hcore.
      apply Hcore.
      assume Hab Hdisj.
      apply Hab.
      assume Ha0Eta Hp10Eta.
      claim Hp10def: ordsq_p10 = (1,0).
      { reflexivity. }
      claim HdPair: (d1,d2) = (1,0).
      { rewrite <- Hp10def at 1.
        rewrite Hp10Eta at 1.
        reflexivity. }
      claim Hd1eq: d1 = 1.
      { prove d1 = 1.
        rewrite <- (tuple_2_0_eq d1 d2) at 1.
        rewrite HdPair at 1.
        exact (tuple_2_0_eq 1 0). }
      claim HcPair: (c1,c2) = (a0 0, a0 1).
      { rewrite <- Ha0Eta at 1.
        exact (setprod_eta unit_interval unit_interval a0 Ha0Sq). }
      claim Hc1eq: c1 = (a0 0).
      { prove c1 = (a0 0).
        rewrite <- (tuple_2_0_eq c1 c2) at 1.
        rewrite HcPair at 1.
        exact (tuple_2_0_eq (a0 0) (a0 1)). }
      apply Hdisj.
      - assume Hlt: Rlt c1 d1.
        rewrite <- Hc1eq at 1.
        rewrite <- Hd1eq at 1.
        exact Hlt.
      - assume Heq: c1 = d1 /\ Rlt c2 d2.
        apply FalseE.
        claim Hc2lt: Rlt c2 d2.
        { exact (andER (c1 = d1) (Rlt c2 d2) Heq). }
        claim Ha01U: (a0 1) :e unit_interval.
        { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
        claim Ha01notlt0: ~(Rlt (a0 1) 0).
        { exact (andEL (~(Rlt (a0 1) 0)) (~(Rlt 1 (a0 1)))
                (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (a0 1) Ha01U)). }
        claim Hc2eq: c2 = (a0 1).
        { prove c2 = (a0 1).
          rewrite <- (tuple_2_1_eq c1 c2) at 1.
          rewrite HcPair at 1.
          exact (tuple_2_1_eq (a0 0) (a0 1)). }
        claim Hd2eq: d2 = 0.
        { prove d2 = 0.
          rewrite <- (tuple_2_1_eq d1 d2) at 1.
          rewrite HdPair at 1.
          exact (tuple_2_1_eq 1 0). }
        claim Hbad: Rlt (a0 1) 0.
        { rewrite <- Hc2eq at 1.
          rewrite <- Hd2eq at 1.
          exact Hc2lt. }
        exact (Ha01notlt0 Hbad). }

    apply (rational_dense_between_reals a00 1 Ha00R real_1 Ha0lt1).
    let q. assume Hqpack.
    apply Hqpack.
    assume HqQ Hqineq.
    claim HqR: q :e R.
    { exact (rational_numbers_in_R q HqQ). }
    claim Ha00ltq: Rlt a00 q.
    { exact (andEL (Rlt a00 q) (Rlt q 1) Hqineq). }
    claim Hqlt1: Rlt q 1.
    { exact (andER (Rlt a00 q) (Rlt q 1) Hqineq). }
    claim Ha00le0: Rle 0 a00.
    { exact (RleI 0 a00 real_0 Ha00R Ha00notlt0). }
    claim H0ltq: Rlt 0 q.
    { exact (Rle_Rlt_tra_Euclid 0 a00 q Ha00le0 Ha00ltq). }
    claim HqU: q :e unit_interval.
    { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q HqR).
      apply andI.
      - exact (not_Rlt_sym 0 q H0ltq).
      - exact (not_Rlt_sym q 1 Hqlt1). }
    set w := (q, eps_ 1).
      claim HwSq: w :e ordered_square.
      { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval q (eps_ 1)
              HqU eps_1_in_unit_interval). }
      claim Ha0w: order_rel (setprod R R) a0 w.
      { claim Ha0Eta: a0 = (a0 0, a0 1).
        { exact (setprod_eta unit_interval unit_interval a0 Ha0Sq). }
        rewrite Ha0Eta.
        apply (order_rel_setprod_R_R_intro (a0 0) (a0 1) q (eps_ 1)).
        apply orIL.
        exact Ha00ltq. }
    claim Hwp10: order_rel (setprod R R) w ordsq_p10.
    { claim Hp10def: ordsq_p10 = (1,0).
      { reflexivity. }
      rewrite Hp10def.
      apply (order_rel_setprod_R_R_intro q (eps_ 1) 1 0).
      apply orIL.
      exact Hqlt1. }
    claim Hwb0: order_rel (setprod R R) w b0.
    { exact (order_rel_trans (setprod R R) w ordsq_p10 b0
            simply_ordered_set_setprod_R_R
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq)
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) ordsq_p10 Hp10Sq)
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) b0 Hb0Sq)
            Hwp10 Hp10b0). }
    claim HwI: w :e I.
    { rewrite HIeq.
      apply (SepI ordered_square
          (fun z:set => order_rel (setprod R R) a0 z /\ order_rel (setprod R R) z b0)
          w HwSq).
      apply andI.
      - exact Ha0w.
      - exact Hwb0. }
    claim HwU: w :e U.
    { exact (HIU w HwI). }
    claim HwD: w :e ordsq_D.
    { apply (SepI ordered_square
                (fun p0:set => exists x0:set, p0 = (x0,eps_ 1) /\ Rlt 0 x0 /\ Rlt x0 1)
                w
                HwSq).
      witness q.
      prove w = (q,eps_ 1) /\ Rlt 0 q /\ Rlt q 1.
      apply andI.
      - prove w = (q,eps_ 1) /\ Rlt 0 q.
        apply andI.
        + reflexivity.
        + exact H0ltq.
      - exact Hqlt1. }
    claim Hwd: w :e U :/\: ordsq_D.
    { exact (binintersectI U ordsq_D w HwU HwD). }
    exact (elem_implies_nonempty (U :/\: ordsq_D) w Hwd).
  + assume HIlow: I :e Blow.
    claim Hexb: exists b0 :e ordered_square,
      I = {z :e ordered_square | order_rel (setprod R R) z b0}.
    { exact (SepE2 (Power ordered_square)
                   (fun J0:set => exists b0 :e ordered_square,
                     J0 = {z :e ordered_square | order_rel (setprod R R) z b0})
                   I
                   HIlow). }
    apply Hexb.
    let b0. assume Hb0pack.
    apply Hb0pack.
    assume Hb0Sq HIeq.
    claim HpI': ordsq_p10 :e {z :e ordered_square | order_rel (setprod R R) z b0}.
    { rewrite <- HIeq.
      exact Hp10I. }
    claim Hp10b0: order_rel (setprod R R) ordsq_p10 b0.
    { exact (SepE2 ordered_square (fun z:set => order_rel (setprod R R) z b0) ordsq_p10 HpI'). }
    set w := (eps_ 1, eps_ 1).
    claim HwSq: w :e ordered_square.
    { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval (eps_ 1) (eps_ 1)
            eps_1_in_unit_interval eps_1_in_unit_interval). }
    claim Hwp10: order_rel (setprod R R) w ordsq_p10.
    { claim Hp10def: ordsq_p10 = (1,0).
      { reflexivity. }
      rewrite Hp10def.
      apply (order_rel_setprod_R_R_intro (eps_ 1) (eps_ 1) 1 0).
      apply orIL.
      exact eps_1_lt1_R. }
    claim Hwb0: order_rel (setprod R R) w b0.
    { exact (order_rel_trans (setprod R R) w ordsq_p10 b0
            simply_ordered_set_setprod_R_R
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) w HwSq)
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) ordsq_p10 Hp10Sq)
            ((setprod_Subq unit_interval unit_interval R R unit_interval_sub_R unit_interval_sub_R) b0 Hb0Sq)
            Hwp10 Hp10b0). }
    claim HwI: w :e I.
    { rewrite HIeq.
      apply (SepI ordered_square (fun z:set => order_rel (setprod R R) z b0) w HwSq).
      exact Hwb0. }
    claim HwU: w :e U.
    { exact (HIU w HwI). }
    claim HwD: w :e ordsq_D.
    { apply (SepI ordered_square
                (fun p0:set => exists x0:set, p0 = (x0,eps_ 1) /\ Rlt 0 x0 /\ Rlt x0 1)
                w
                HwSq).
      witness (eps_ 1).
      prove w = (eps_ 1,eps_ 1) /\ Rlt 0 (eps_ 1) /\ Rlt (eps_ 1) 1.
      apply andI.
      - prove w = (eps_ 1,eps_ 1) /\ Rlt 0 (eps_ 1).
        apply andI.
        + reflexivity.
        + exact eps_1_pos_R.
      - exact eps_1_lt1_R. }
    claim Hwd: w :e U :/\: ordsq_D.
    { exact (binintersectI U ordsq_D w HwU HwD). }
    exact (elem_implies_nonempty (U :/\: ordsq_D) w Hwd).
- assume HIup: I :e Bup.
  claim HIup_ex: exists a0 :e ordered_square,
      I = {x :e ordered_square | order_rel (setprod R R) a0 x}.
  { exact (SepE2 (Power ordered_square)
                 (fun J0:set => exists a0 :e ordered_square,
                   J0 = {x :e ordered_square | order_rel (setprod R R) a0 x})
                 I
                 HIup). }
  apply HIup_ex.
  let a0. assume Ha0pack.
  apply Ha0pack.
  assume Ha0Sq HeqI.
  claim HpI': ordsq_p10 :e {x :e ordered_square | order_rel (setprod R R) a0 x}.
  { rewrite <- HeqI.
    exact Hp10I. }
  claim Ha0p10: order_rel (setprod R R) a0 ordsq_p10.
  { exact (SepE2 ordered_square (fun x0:set => order_rel (setprod R R) a0 x0) ordsq_p10 HpI'). }
  set a00 := a0 0.
  claim Ha00U: a00 :e unit_interval.
  { exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
  claim Ha00R: a00 :e R.
  { exact (SepE1 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a00 Ha00U). }
  claim Ha00notlt0: ~(Rlt a00 0).
  { exact (andEL (~(Rlt a00 0)) (~(Rlt 1 a00))
                (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) a00 Ha00U)). }
  claim Ha0lt1: Rlt a00 1.
  { (** a0 < (1,0) forces a00 < 1 since a0 1 is in unit_interval **)
    claim Hunf: exists c1 c2 d1 d2:set,
      a0 = (c1, c2) /\ ordsq_p10 = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
    { exact (order_rel_setprod_R_R_unfold a0 ordsq_p10 Ha0p10). }
    apply Hunf.
    let c1. assume Hc2.
    apply Hc2.
    let c2. assume Hd1.
    apply Hd1.
    let d1. assume Hd2.
    apply Hd2.
    let d2. assume Hcore.
    apply Hcore.
    assume Hab Hdisj.
    apply Hab.
    assume Ha0Eta Hp10Eta.
    claim Hp10def: ordsq_p10 = (1,0).
    { reflexivity. }
    claim HdPair: (d1,d2) = (1,0).
    { rewrite <- Hp10def at 1.
      rewrite Hp10Eta at 1.
      reflexivity. }
    claim Hd1eq: d1 = 1.
    { prove d1 = 1.
      rewrite <- (tuple_2_0_eq d1 d2) at 1.
      rewrite HdPair at 1.
      exact (tuple_2_0_eq 1 0). }
    claim HcPair: (c1,c2) = (a0 0, a0 1).
    { rewrite <- Ha0Eta at 1.
      exact (setprod_eta unit_interval unit_interval a0 Ha0Sq). }
    claim Hc1eq: c1 = (a0 0).
    { prove c1 = (a0 0).
      rewrite <- (tuple_2_0_eq c1 c2) at 1.
      rewrite HcPair at 1.
      exact (tuple_2_0_eq (a0 0) (a0 1)). }
    apply Hdisj.
    - assume Hlt: Rlt c1 d1.
      rewrite <- Hc1eq at 1.
      rewrite <- Hd1eq at 1.
      exact Hlt.
    - assume Heq: c1 = d1 /\ Rlt c2 d2.
      apply FalseE.
      claim Hc2lt: Rlt c2 d2.
      { exact (andER (c1 = d1) (Rlt c2 d2) Heq). }
      claim Ha01U: (a0 1) :e unit_interval.
      { exact (ap1_Sigma unit_interval (fun _ : set => unit_interval) a0 Ha0Sq). }
      claim Ha01notlt0: ~(Rlt (a0 1) 0).
      { exact (andEL (~(Rlt (a0 1) 0)) (~(Rlt 1 (a0 1)))
              (SepE2 R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) (a0 1) Ha01U)). }
      claim Hc2eq: c2 = (a0 1).
      { prove c2 = (a0 1).
        rewrite <- (tuple_2_1_eq c1 c2) at 1.
        rewrite HcPair at 1.
        exact (tuple_2_1_eq (a0 0) (a0 1)). }
      claim Hd2eq: d2 = 0.
      { prove d2 = 0.
        rewrite <- (tuple_2_1_eq d1 d2) at 1.
        rewrite HdPair at 1.
        exact (tuple_2_1_eq 1 0). }
      claim Hbad: Rlt (a0 1) 0.
      { rewrite <- Hc2eq at 1.
        rewrite <- Hd2eq at 1.
        exact Hc2lt. }
      exact (Ha01notlt0 Hbad). }
  apply (rational_dense_between_reals a00 1 Ha00R real_1 Ha0lt1).
  let q. assume Hqpack.
  apply Hqpack.
  assume HqQ Hqineq.
  claim HqR: q :e R.
  { exact (rational_numbers_in_R q HqQ). }
  claim Ha00ltq: Rlt a00 q.
  { exact (andEL (Rlt a00 q) (Rlt q 1) Hqineq). }
  claim Hqlt1: Rlt q 1.
  { exact (andER (Rlt a00 q) (Rlt q 1) Hqineq). }
  claim Ha00le0: Rle 0 a00.
  { exact (RleI 0 a00 real_0 Ha00R Ha00notlt0). }
  claim H0ltq: Rlt 0 q.
  { exact (Rle_Rlt_tra_Euclid 0 a00 q Ha00le0 Ha00ltq). }
  claim HqU: q :e unit_interval.
  { apply (SepI R (fun t:set => ~(Rlt t 0) /\ ~(Rlt 1 t)) q HqR).
    apply andI.
    - exact (not_Rlt_sym 0 q H0ltq).
    - exact (not_Rlt_sym q 1 Hqlt1). }
  set w := (q, eps_ 1).
  claim HwSq: w :e ordered_square.
  { exact (tuple_2_setprod_by_pair_Sigma unit_interval unit_interval q (eps_ 1)
          HqU eps_1_in_unit_interval). }
  claim Ha0w: order_rel (setprod R R) a0 w.
  { claim Ha0Eta: a0 = (a0 0, a0 1).
    { exact (setprod_eta unit_interval unit_interval a0 Ha0Sq). }
    rewrite Ha0Eta.
    apply (order_rel_setprod_R_R_intro (a0 0) (a0 1) q (eps_ 1)).
    apply orIL.
    exact Ha00ltq. }
  claim HwI: w :e I.
  { rewrite HeqI.
    apply (SepI ordered_square (fun x0:set => order_rel (setprod R R) a0 x0) w HwSq).
    exact Ha0w. }
  claim HwU: w :e U.
  { exact (HIU w HwI). }
  claim HwD: w :e ordsq_D.
  { apply (SepI ordered_square
              (fun p0:set => exists x0:set, p0 = (x0,eps_ 1) /\ Rlt 0 x0 /\ Rlt x0 1)
              w
              HwSq).
    witness q.
    prove w = (q,eps_ 1) /\ Rlt 0 q /\ Rlt q 1.
    apply andI.
    - prove w = (q,eps_ 1) /\ Rlt 0 q.
      apply andI.
      + reflexivity.
      + exact H0ltq.
    - exact Hqlt1. }
  claim Hwd: w :e U :/\: ordsq_D.
  { exact (binintersectI U ordsq_D w HwU HwD). }
  exact (elem_implies_nonempty (U :/\: ordsq_D) w Hwd).
Qed.

(** helper: C is contained in cl(D) **)
(** LATEX VERSION: In the ordered square, C c= cl(D). **)
Theorem ex17_18_C_Sub_closure_D :
  forall p:set, p :e ordsq_C -> p :e closure_of ordered_square ordered_square_topology ordsq_D.
let p. assume HpC: p :e ordsq_C.
claim HpSq: p :e ordered_square.
{ exact (SepE1 ordered_square (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1) p HpC). }
claim Hexx: exists x:set, p = (x,0) /\ Rlt 0 x /\ Rlt x 1.
{ exact (SepE2 ordered_square (fun p0:set => exists x0:set, p0 = (x0,0) /\ Rlt 0 x0 /\ Rlt x0 1) p HpC). }
apply Hexx.
let x. assume Hxpack.
apply Hxpack.
assume Hcore Hxlt1.
apply Hcore.
assume Hpx Hxpos.
claim Hp0U: p 0 :e unit_interval.
{ exact (ap0_Sigma unit_interval (fun _ : set => unit_interval) p HpSq). }
claim Hp0eq: p 0 = x.
{ rewrite Hpx at 1.
  exact (tuple_2_0_eq x 0). }
claim HxU: x :e unit_interval.
{ rewrite <- Hp0eq at 1.
  exact Hp0U. }
claim HxR: x :e R.
{ exact (unit_interval_sub_R x HxU). }
claim HxS: SNo x.
{ exact (real_SNo x HxR). }
claim Hdefcl: closure_of ordered_square ordered_square_topology ordsq_D =
  {x0 :e ordered_square | forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_D <> Empty}.
{ reflexivity. }
rewrite Hdefcl.
apply (SepI ordered_square
            (fun x0:set => forall U:set, U :e ordered_square_topology -> x0 :e U -> U :/\: ordsq_D <> Empty)
            p
            HpSq).
let U. assume HUtop: U :e ordered_square_topology.
assume HpU: p :e U.
prove U :/\: ordsq_D <> Empty.
claim HexI: exists I :e ordered_square_order_basis, p :e I /\ I c= U.
{ exact (generated_topology_local_refine ordered_square ordered_square_order_basis U p HUtop HpU). }
apply HexI.
let I. assume HIpack.
apply HIpack.
assume HIbas HIcore.
apply HIcore.
assume HpI HIU.
set Bint := {J :e Power ordered_square | exists a :e ordered_square, exists b :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) a z /\ order_rel (setprod R R) z b}}.
set Blow := {J :e Power ordered_square | exists b :e ordered_square,
      J = {z :e ordered_square | order_rel (setprod R R) z b}}.
set Bup := {J :e Power ordered_square | exists a :e ordered_square,
