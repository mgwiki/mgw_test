    apply (rational_dense_between_reals a00 x Ha00R HxR Ha00ltx).
    let q. assume Hqpack.
    apply Hqpack.
    assume HqQ Hqineq.
    claim HqR: q :e R.
    { exact (rational_numbers_in_R q HqQ). }
    claim Ha00ltq: Rlt a00 q.
    { exact (andEL (Rlt a00 q) (Rlt q x) Hqineq). }
    claim Hqltx: Rlt q x.
    { exact (andER (Rlt a00 q) (Rlt q x) Hqineq). }
    claim Hxlb00: Rlt x b00 \/ (x = b00 /\ Rlt 0 b01).
    { claim Hunf: exists c1 c2 d1 d2:set,
        p = (c1, c2) /\ b0 = (d1, d2) /\ (Rlt c1 d1 \/ (c1 = d1 /\ Rlt c2 d2)).
      { exact (order_rel_setprod_R_R_unfold p b0 Hpb0). }
      apply Hunf.
