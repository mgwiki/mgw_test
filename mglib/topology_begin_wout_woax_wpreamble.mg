Axiom nat_le2_cases: forall m, nat_p m -> m c= 2 -> m = 0 \/ m = 1 \/ m = 2.

Axiom prime_nat_2_lem: forall m, nat_p m -> forall n, nat_p n -> m * n = 2 -> m = 1 \/ m = 2.

Axiom prime_nat_2: prime_nat 2.

Prefix - 358 := minus_SNo.
Infix + 360 right := add_SNo.
Infix * 355 right := mul_SNo.

Axiom not_eq_2m_2n1: forall m n :e int, 2 * m <> 2 * n + 1.

